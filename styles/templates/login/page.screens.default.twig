{% extends "layout.light.twig" %}

{% block title %}{{ LNG.siteTitleScreens }}{% endblock %}
{% block content %}
<div class="lp-card">
	<div class="lp-card__header">
		<h2 class="lp-card__title">{{ LNG.siteTitleScreens }}</h2>
	</div>
	<div class="lp-card__body">
		<div class="lp-gallery">
			{% for screenshot in screenshots %}
			<div class="lp-gallery-item">
				<a class="lp-gallery-link" href="{{ screenshot.path }}" target="_blank" rel="gallery">
					<img src="{{ screenshot.thumbnail }}" alt="Screenshot {{ loop.index }}" class="lp-gallery-image">
				</a>
			</div>
			{% else %}
			<div class="lp-empty">
				<h3 class="lp-empty__title">No Screenshots Available</h3>
				<p class="lp-empty__text">Screenshots will be available soon.</p>
			</div>
			{% endfor %}
		</div>
	</div>
</div>
{% endblock %}
{% block script %}
<script>
$(function() {
	$(".lp-gallery-link").fancybox();
});
</script>
{% endblock %}
