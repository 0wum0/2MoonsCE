{% extends "layout.light.twig" %}

{% block title %}{{ LNG.siteTitleBanList }}{% endblock %}
{% block content %}
<div class="lp-card">
	<div class="lp-card__header">
		<h2 class="lp-card__title">{{ LNG.bn_players_banned_list }}</h2>
	</div>
	<div class="lp-card__body">
		{% if isMultiUniverse %}
		<div class="lp-field">
			<label for="universe" class="lp-label">{{ LNG.universe }}</label>
			<div class="lp-input-wrapper">
				<select class="lp-select changeUni" id="universe" name="universe">{% for key, value in universeSelect %}<option value="{{ key }}"{% if key == UNI %} selected{% endif %}>{{ value }}</option>{% endfor %}</select>
			</div>
		</div>
		{% endif %}
		
		<div class="lp-table-wrapper">
			<table class="lp-table">
				<thead>
					<tr>
						<th>{{ LNG.bn_from }}</th>
						<th>{{ LNG.bn_until }}</th>
						<th>{{ LNG.bn_player }}</th>
						<th>{{ LNG.bn_by }}</th>
						<th>{{ LNG.bn_reason }}</th>
					</tr>
				</thead>
				<tbody>
					{% if banCount %}
						{% for banRow in banList %}
						<tr>
							<td class="lp-table__date">{{ banRow.from }}</td>
							<td class="lp-table__date">{{ banRow.to }}</td>
							<td class="lp-table__player">{{ banRow.player }}</td>
							<td class="lp-table__admin">
								<a href="mailto:{{ banRow.mail }}" title="{{ banRow.info }}" class="lp-table__admin-link">{{ banRow.admin }}</a>
							</td>
							<td class="lp-table__reason">{{ banRow.theme }}</td>
						</tr>
						{% endfor %}
						<tr class="lp-table__summary">
							<td colspan="5">{{ LNG.bn_exists }}{{ banCount|number_format }}{{ LNG.bn_players_banned }}</td>
						</tr>
					{% else %}
						<tr class="lp-table__empty">
							<td colspan="5">{{ LNG.bn_no_players_banned }}</td>
						</tr>
					{% endif %}
				</tbody>
			</table>
		</div>
		
		{% if banCount %}
		<div class="lp-pagination">
			<ul class="lp-pagination__list">
				{% if page != 1 %}
				<li class="lp-pagination__item">
					<a href="index.php?page=banList&amp;side={{ page - 1 }}" class="lp-pagination__link lp-pagination__link--prev">Prev</a>
				</li>
				{% endif %}
				
				{% for site in range(1, maxPage) %}
					{% if site == page %}
					<li class="lp-pagination__item lp-pagination__item--active">
						<a href="#" class="lp-pagination__link lp-pagination__link--current">{{ site }}</a>
					</li>
					{% else %}
					<li class="lp-pagination__item">
						<a href="index.php?page=banList&amp;side={{ site }}" class="lp-pagination__link">{{ site }}</a>
					</li>
					{% endif %}
				{% endfor %}
				
				{% if page != maxPage %}
				<li class="lp-pagination__item">
					<a href="index.php?page=banList&amp;side={{ page + 1 }}" class="lp-pagination__link lp-pagination__link--next">Next</a>
				</li>
				{% endif %}
			</ul>
		</div>
		{% endif %}
	</div>
</div>
{% endblock %}
