{% extends "layout.light.twig" %}

{% block title %}{{ LNG.siteTitleBattleHall }}{% endblock %}
{% block content %}
<div class="lp-card">
	<div class="lp-card__header">
		<h2 class="lp-card__title">{{ LNG.siteTitleBattleHall }}</h2>
	</div>
	<div class="lp-card__body">
		{% if isMultiUniverse %}
		<div class="lp-field">
			<label for="universe" class="lp-label">{{ LNG.universe }}</label>
			<div class="lp-input-wrapper">
				<select class="lp-select changeUni" id="universe" name="universe">{% for key, value in universeSelect %}<option value="{{ key }}"{% if key == UNI %} selected{% endif %}>{{ value }}</option>{% endfor %}</select>
			</div>
		</div>
		{% endif %}
		
		<div class="lp-table-wrapper">
			<table class="lp-table">
				<thead>
					<tr>
						<th>{{ LNG.tkb_platz }}</th>
						<th>{{ LNG.tkb_owners }}</th>
						<th>{{ LNG.tkb_datum }}</th>
						<th>{{ LNG.tkb_units }}</th>
					</tr>
				</thead>
				<tbody>
					{% for hallRow in hallList %}
					<tr>
						<td class="lp-table__rank">{{ loop.index }}</td>
						<td class="lp-table__players">
							{% if hallRow.result == "a" %}
								<span class="lp-table__winner">{{ hallRow.attacker }}</span>
								<span class="lp-table__vs">VS</span>
								<span class="lp-table__loser">{{ hallRow.defender }}</span>
							{% elseif hallRow.result == "r" %}
								<span class="lp-table__loser">{{ hallRow.attacker }}</span>
								<span class="lp-table__vs">VS</span>
								<span class="lp-table__winner">{{ hallRow.defender }}</span>
							{% else %}
								<span>{{ hallRow.attacker }}</span>
								<span class="lp-table__vs">VS</span>
								<span>{{ hallRow.defender }}</span>
							{% endif %}
						</td>
						<td class="lp-table__date">{{ hallRow.time }}</td>
						<td class="lp-table__units">{{ hallRow.units|number_format }}</td>
					</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
		
		<div class="lp-table-legend">
			<p>{{ LNG.tkb_legende }}<span class="lp-table-legend__winner">{{ LNG.tkb_gewinner }}</span><span class="lp-table-legend__loser">{{ LNG.tkb_verlierer }}</span></p>
		</div>
	</div>
</div>
{% endblock %}
