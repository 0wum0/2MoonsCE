{% extends "layout.popup.twig" %}

{% block title %}{{ LNG.fcm_info }}{% endblock %}
{% block content %}
<div class="lp-card lp-card--popup">
	<div class="lp-card__header">
		<h2 class="lp-card__title">{{ LNG.fcm_info }}</h2>
	</div>
	<div class="lp-card__body">
		<div class="lp-message">
			<p class="lp-message__text">{{ message|raw }}</p>
			{% if redirectButtons %}
			<div class="lp-message__actions">
				{% for button in redirectButtons %}
				<a href="{{ button.url }}" class="lp-btn lp-btn--secondary">{{ button.label }}</a>
				{% endfor %}
			</div>
			{% endif %}
		</div>
	</div>
</div>
{% endblock %}
