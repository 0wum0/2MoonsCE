<div class="lp-topbar" role="banner">
	<div class="lp-topbar__left">
		<button class="lp-burger" id="lpBurger" aria-label="Toggle navigation" aria-expanded="false" aria-controls="lpSidebar">
			<span class="lp-burger__line"></span>
			<span class="lp-burger__line"></span>
			<span class="lp-burger__line"></span>
		</button>
		<a href="index.php" class="lp-topbar__brand">{{ gameName }}</a>
	</div>
	<div class="lp-topbar__center">
		<span class="lp-status-badge">
			<span class="lp-status-dot"></span>{{ onlineCount }} Online
		</span>
		{% if newestPlayer %}
		<span class="lp-topbar__newest">&#43; {{ newestPlayer }}</span>
		{% endif %}
	</div>
	<div class="lp-topbar__right">
		<a href="index.php?page=register" class="lp-btn lp-btn--primary lp-topbar__cta">{{ LNG.buttonRegister }}</a>
	</div>
</div>

<div class="lp-sidebar-backdrop" id="lpSidebarBackdrop" aria-hidden="true"></div>

<nav class="lp-sidebar" id="lpSidebar" role="navigation" aria-label="Main navigation">
	<div class="lp-sidebar__header">
		<a href="index.php" class="lp-sidebar__brand">{{ gameName }}</a>
		<button class="lp-sidebar__close" id="lpSidebarClose" aria-label="Close navigation">
			<span class="lp-sidebar__close-line"></span>
			<span class="lp-sidebar__close-line"></span>
		</button>
	</div>

	<ul class="lp-sidebar__nav">
		<li class="lp-sidebar__item">
			<a href="index.php" class="lp-sidebar__link">
				<span class="lp-sidebar__icon" aria-hidden="true">&#9679;</span>
				{{ LNG.menu_index }}
			</a>
		</li>
		<li class="lp-sidebar__item">
			<a href="index.php?page=board" target="board" class="lp-sidebar__link">
				<span class="lp-sidebar__icon" aria-hidden="true">&#9679;</span>
				{{ LNG.forum }}
			</a>
		</li>
		<li class="lp-sidebar__item">
			<a href="index.php?page=news" class="lp-sidebar__link">
				<span class="lp-sidebar__icon" aria-hidden="true">&#9679;</span>
				{{ LNG.menu_news }}
			</a>
		</li>
		<li class="lp-sidebar__item">
			<a href="index.php?page=rules" class="lp-sidebar__link">
				<span class="lp-sidebar__icon" aria-hidden="true">&#9679;</span>
				{{ LNG.menu_rules }}
			</a>
		</li>
		<li class="lp-sidebar__item">
			<a href="index.php?page=battleHall" class="lp-sidebar__link">
				<span class="lp-sidebar__icon" aria-hidden="true">&#9679;</span>
				{{ LNG.menu_battlehall }}
			</a>
		</li>
		<li class="lp-sidebar__item">
			<a href="index.php?page=banList" class="lp-sidebar__link">
				<span class="lp-sidebar__icon" aria-hidden="true">&#9679;</span>
				{{ LNG.menu_banlist }}
			</a>
		</li>
		<li class="lp-sidebar__item">
			<a href="index.php?page=disclamer" class="lp-sidebar__link">
				<span class="lp-sidebar__icon" aria-hidden="true">&#9679;</span>
				{{ LNG.menu_disclamer }}
			</a>
		</li>
	</ul>

	<div class="lp-sidebar__footer">
		{% if languages|length > 1 %}
		<div class="lp-sidebar-lang" id="lpSidebarLang">
			<button class="lp-sidebar-lang__toggle" id="lpSidebarLangToggle" aria-expanded="false" aria-haspopup="listbox">
				<span class="lp-sidebar-lang__icon" aria-hidden="true">&#127760;</span>
				{{ LNG.language_select|default('Language') }}
				<span class="lp-sidebar-lang__arrow" aria-hidden="true"></span>
			</button>
			<ul class="lp-sidebar-lang__menu" id="lpSidebarLangMenu" role="listbox">
				{% for langKey, langName in languages %}
				<li role="option"><a href="?lang={{ langKey }}" rel="alternate" hreflang="{{ langKey }}" title="{{ langName }}"><span class="flags {{ langKey }}">{{ langName }}</span></a></li>
				{% endfor %}
			</ul>
		</div>
		{% endif %}
	</div>
</nav>
