{% extends "layout.light.twig" %}

{% block title %}{{ LNG.siteTitleIndex }}{% endblock %}
{% block content %}
<div class="lp-surface">

	<div class="lp-hero lp-hero--index">
		<div class="lp-hero__eyebrow">
			<span class="lp-hero__badge">Space Browsergame</span>
		</div>
		<h1 class="lp-hero__title">{{ descHeader }}</h1>
		<p class="lp-hero__text">{{ descText }}</p>
		<div class="lp-hero__cta">
			<a href="#lp-login-anchor" class="lp-btn lp-btn--primary lp-btn--lg lp-hero__cta-login">{{ LNG.loginButton }}</a>
			<a href="index.php?page=register" class="lp-btn lp-btn--secondary lp-btn--lg">{{ LNG.buttonRegister }}</a>
			<a href="index.php?page=screens" class="lp-btn lp-btn--ghost lp-btn--lg">{{ LNG.buttonScreenshot }}</a>
		</div>
	</div>

	<div class="lp-index-grid">

		<div class="lp-card lp-card--news">
			<div class="lp-card__header">
				<h2 class="lp-card__title">{{ LNG.siteTitleNews }}</h2>
				<a href="index.php?page=news" class="lp-card__header-link">{{ LNG.siteTitleNews }} &rsaquo;</a>
			</div>
			<div class="lp-card__body lp-card__body--no-pad">
				{% set newsCount = newsList|length %}
				{% if newsCount > 0 %}
				<div class="lp-slideshow" id="lpNewsSlideshow" data-autoplay="7000">
					<div class="lp-slideshow__track">
						{% for newsRow in newsList %}
						<article class="lp-slideshow__slide" aria-hidden="{{ loop.first ? 'false' : 'true' }}">
							<div class="lp-slideshow__slide-inner">
								<h3 class="lp-slideshow__title">{{ newsRow.title }}</h3>
								<div class="lp-slideshow__meta">{{ newsRow.from }}</div>
								<div class="lp-slideshow__content">{{ newsRow.text|raw }}</div>
							</div>
						</article>
						{% endfor %}
					</div>
					{% if newsCount > 1 %}
					<div class="lp-slideshow__controls">
						<button class="lp-slideshow__arrow lp-slideshow__arrow--prev" aria-label="Previous news">&#8249;</button>
						<div class="lp-slideshow__dots">
							{% for newsRow in newsList %}
							<button class="lp-slideshow__dot{% if loop.first %} lp-slideshow__dot--active{% endif %}" aria-label="News {{ loop.index }}" data-index="{{ loop.index0 }}"></button>
							{% endfor %}
						</div>
						<button class="lp-slideshow__arrow lp-slideshow__arrow--next" aria-label="Next news">&#8250;</button>
					</div>
					{% endif %}
				</div>
				{% else %}
				<div class="lp-empty" style="padding: var(--sp-lg);">
					<h3 class="lp-empty__title">{{ LNG.news_does_not_exist }}</h3>
					<p class="lp-empty__text">No news articles are available at this time.</p>
				</div>
				{% endif %}
			</div>
		</div>

		<div class="lp-card lp-card--login" id="lp-login-anchor">
			<div class="lp-card__header">
				<h2 class="lp-card__title">{{ LNG.loginHeader }}</h2>
			</div>
			<div class="lp-card__body">
				{% if loginError %}
				<div class="lp-login-notice lp-login-notice--error" role="alert">
					<span class="lp-login-notice__icon">&#9888;</span>
					<span>{{ loginError }}</span>
				</div>
				{% endif %}
				<form id="login" name="login" action="index.php?page=login" data-action="index.php?page=login" method="post" class="lp-form">
					<div class="lp-field">
						<label for="universe" class="lp-label">{{ LNG.universe }}</label>
						<div class="lp-input-wrapper">
							<select name="uni" id="universe" class="lp-select changeAction">{% for key, value in universeSelect %}<option value="{{ key }}"{% if key == UNI %} selected{% endif %}>{{ value }}</option>{% endfor %}</select>
						</div>
					</div>
					<div class="lp-field">
						<label for="username" class="lp-label">{{ LNG.loginUsername }}</label>
						<div class="lp-input-wrapper">
							<input type="text" class="lp-input" name="username" id="username" placeholder="{{ LNG.loginUsername }}" autocomplete="username">
						</div>
					</div>
					<div class="lp-field">
						<label for="password" class="lp-label">{{ LNG.loginPassword }}</label>
						<div class="lp-input-wrapper">
							<input type="password" class="lp-input" name="password" id="password" placeholder="{{ LNG.loginPassword }}" autocomplete="current-password">
						</div>
					</div>
					<div class="lp-login-row">
						<label class="lp-remember">
							<input type="checkbox" name="rememberMe" value="1" class="lp-remember__input">
							<span class="lp-remember__checkmark"></span>
							<span class="lp-remember__label">{{ LNG.loginRemember }}</span>
						</label>
						{% if mailEnable %}<a href="index.php?page=lostPassword" class="lp-login-forgot">{{ LNG.buttonLostPassword }}</a>{% endif %}
					</div>
					<div class="lp-form__footer">
						<button type="submit" class="lp-btn lp-btn--primary lp-btn--lg lp-btn--full">
							<span class="btn-label">{{ LNG.loginButton }}</span>
							<span class="btn-spinner hidden"></span>
						</button>
					</div>
				</form>
				{% if facebookEnable %}<a href="#" data-href="index.php?page=externalAuth&method=facebook" class="fb_login"><img src="styles/resource/images/facebook/fb-connect-large.png" alt=""></a>{% endif %}
				<div class="lp-form__links">
					<div class="lp-links">
						<a href="index.php?page=register">{{ LNG.buttonRegister }}</a>
					</div>
					{% if loginInfo %}<span class="lp-desc">{{ loginInfo }}</span>{% endif %}
				</div>
			</div>
		</div>

	</div>
</div>
{% endblock %}
{% block script %}
{% if code %}<script>window.LoginUI.errorMessage = {{ code|json_encode|raw }};</script>{% endif %}
{% endblock %}
