<script>
var LoginConfig = {
    'isMultiUniverse': {{ isMultiUniverse|json_encode|raw }},
	'unisWildcast': {{ unisWildcast|json_encode|raw }},
	'referralEnable' : {{ referralEnable|json_encode|raw }},
	'basePath' : {{ basepath|json_encode|raw }}
};

// Enhanced language dropdown with robust event handling
document.addEventListener('DOMContentLoaded', function() {
    const langDropdowns = document.querySelectorAll('.auth-language-selector');
    
    langDropdowns.forEach(function(dropdown) {
        const toggle = dropdown.querySelector('.auth-lang-dropdown');
        const menu = dropdown.querySelector('.auth-dropdown-menu');
        
        if (!toggle || !menu) return;
        
        // Ensure dropdown is closed by default
        menu.style.display = 'none';
        
        // Toggle dropdown on click
        toggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const isVisible = menu.style.display === 'block';
            
            // Close all other dropdowns
            document.querySelectorAll('.auth-dropdown-menu').forEach(function(otherMenu) {
                if (otherMenu !== menu) {
                    otherMenu.style.display = 'none';
                }
            });
            
            // Toggle current dropdown
            menu.style.display = isVisible ? 'none' : 'block';
        });
        
        // Close on outside click with proper event delegation
        document.addEventListener('click', function(e) {
            if (!dropdown.contains(e.target)) {
                menu.style.display = 'none';
            }
        });
        
        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                menu.style.display = 'none';
            }
        });
        
        // Prevent menu clicks from closing the dropdown
        menu.addEventListener('click', function(e) {
            e.stopPropagation();
        });
    });
});
</script>
