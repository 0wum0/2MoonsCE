{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_research }}{% endblock %}
{% block content %}

<div class="content_page">
    <div class="aerospace-wrapper">
        
        <div class="content-box header-panel">
            <h2 class="page-title"><i class="fas fa-flask"></i> {{ LNG.lm_research }}</h2>
        </div>

        <div class="tech-grid">
            {% for ID, Element in ResearchList %}
            <div class="content-box tech-card {% if not Element.buyable %}disabled{% endif %}"
                 data-tt-name="{{ LNG.tech[ID] }}"
                 data-tt-level="{{ Element.level }}"
                 data-tt-max="{{ Element.maxLevel }}"
                 data-tt-time="{{ Element.elementTime|time }}"
                 {% for RessID, RessAmount in Element.costResources %}
                   {% if RessID == 901 %}data-tt-metal="{{ RessAmount }}"
                   {% elseif RessID == 902 %}data-tt-crystal="{{ RessAmount }}"
                   {% elseif RessID == 903 %}data-tt-deut="{{ RessAmount }}"
                   {% elseif RessID == 921 %}data-tt-energy="{{ RessAmount }}"
                   {% endif %}
                 {% endfor %}
                 >

                <div class="tech-visual">
                    <img src="{{ dpath }}gebaeude/{{ ID }}.gif" alt="{{ LNG.tech[ID] }}" class="tech-img">
                    {% if Element.level > 0 %}
                    <span class="level-tag">{{ Element.level }}</span>
                    {% endif %}
                </div>

                <div class="tech-content">
                    <div class="tech-header">
                        <h3 class="tech-name">
                            <a href="#" onclick="return Dialog.info({{ ID }});">{{ LNG.tech[ID] }}</a>
                        </h3>
                        {% if Element.maxLevel != 255 %}
                        <span class="max-lvl">{{ LNG.bd_max_level }}: {{ Element.maxLevel }}</span>
                        {% endif %}
                    </div>

                    <div class="tech-price">
                        {% for RessID, RessAmount in Element.costResources %}
                        <div class="price-item {% if Element.costOverflow[RessID] != 0 %}missing-res{% endif %}">
                            <img src="{{ dpath }}images/{{ RessID }}.gif" alt="" class="res-icon-sm">
                            <span class="res-val">{{ RessAmount|number_format }}</span>
                        </div>
                        {% endfor %}
                    </div>

                    <div class="tech-meta">
                        <span class="meta-item"><i class="far fa-clock"></i> {{ Element.elementTime|time }}</span>
                    </div>

                    <div class="tech-actions">
                        {% if Element.maxLevel == Element.levelToBuild %}
                            <div class="btn-disabled"><i class="fas fa-check"></i> {{ LNG.bd_maxlevel }}</div>
                        {% elseif IsLabinBuild or IsResearchInProgress %}
                            {% if IsLabinBuild %}
                                <div class="btn-disabled"><i class="fas fa-cog fa-spin"></i> {{ LNG.bd_building_lab }}</div>
                            {% else %}
                                <div class="btn-disabled"><i class="fas fa-cog fa-spin"></i> {{ LNG.bd_working }}</div>
                            {% endif %}
                        {% elseif Element.buyable %}
                            <form action="game.php?page=research" method="post" class="full-width-form" data-ajax="1">
                                <input type="hidden" name="cmd" value="insert">
                                <input type="hidden" name="tech" value="{{ ID }}">
                                <button type="submit" class="btn-action-glow">
                                    {% if Element.level == 0 %}
                                        {{ LNG.bd_research }}
                                    {% else %}
                                        {{ LNG.bd_research_next_level }} {{ Element.levelToBuild + 1 }}
                                    {% endif %}
                                </button>
                            </form>
                        {% else %}
                            <div class="btn-disabled text-danger"><i class="fas fa-lock"></i> {{ LNG.bd_tech_blocked }}</div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
