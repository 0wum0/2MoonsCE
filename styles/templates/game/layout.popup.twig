{% include "main.header.twig" with {'bodyclass': 'popup-window'} %}

<script type="text/javascript">
(function() {
    /* ------------------------------------------------------------------
       Bootstrap the glass modal system into the PARENT window.
       This runs inside the iframe; the parent is the real game page.
       We inject the CSS link and the modalManager script once, then
       call ModalManager.open() / close() on the parent.
    ------------------------------------------------------------------ */
    function _bootstrapParent() {
        try {
            var p = window.parent;
            if (!p || p === window) { return; }
            var pd = p.document;

            /* Inject modalManager.js into parent <head> (once).
               modalManager.js self-injects its own CSS on load. */
            if (!pd.getElementById('mm-js') && !p.ModalManager) {
                var script = pd.createElement('script');
                script.id   = 'mm-js';
                script.type = 'text/javascript';
                script.src  = 'scripts/game/modalManager.js';
                pd.getElementsByTagName('head')[0].appendChild(script);
            }

        } catch(e) {
            /* cross-origin or standalone — silently ignore */
        }
    }

    _bootstrapParent();

    /* ------------------------------------------------------------------
       Close helper: prefer ModalManager on parent, fall back to fancybox
    ------------------------------------------------------------------ */
    function closeParentModal() {
        try {
            var p = window.parent;
            if (p && p !== window) {
                if (p.ModalManager && typeof p.ModalManager.close === 'function') {
                    p.ModalManager.close();
                    return;
                }
                if (p.$ && p.$.fancybox && typeof p.$.fancybox.close === 'function') {
                    p.$.fancybox.close();
                }
            }
        } catch(e) {}
    }

    window._closeParentModal = closeParentModal;
})();
</script>

<div class="aerospace-modal-wrapper">

    <div class="modal-close-btn" onclick="window._closeParentModal();">
        <i class="fas fa-times"></i>
    </div>

    <div class="modal-content custom-scroll">
        {% block content %}{% endblock %}
    </div>

</div>

<script type="text/javascript">
var LoginConfig = {
    'isMultiUniverse': {{ isMultiUniverse|json_encode|raw }},
    'unisWildcast': {{ unisWildcast|json_encode|raw }},
    'referralEnable' : {{ referralEnable|json_encode|raw }},
    'basePath' : {{ basepath|json_encode|raw }}
};
</script>
{% block script %}{% endblock %}
</body>
</html>
