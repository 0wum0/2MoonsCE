{% extends "layout.popup.twig" %}

{% block title %}{{ LNG.lm_playercard }}{% endblock %}
{% block content %}

<div class="aerospace-popup">
    
    <div class="player-header">
        <div class="avatar-circle">
            <i class="fas fa-user-astronaut"></i>
        </div>
        <div class="player-info">
            <h2 class="player-name">{{ name }}</h2>
            <div class="player-meta">
                {% if allyname %}
                    <span class="meta-item">
                        <i class="fas fa-users"></i>
                        <a href="#" onclick="pcNavParent('game.php?page=alliance&mode=info&id={{ allyid }}'); return false;">
                            {{ allyname }}
                        </a>
                    </span>
                {% else %}
                    <span class="meta-item text-muted"><i class="fas fa-users-slash"></i> -</span>
                {% endif %}

                <span class="meta-item">
                    <i class="fas fa-globe"></i>
                    <a href="#" onclick="pcNavParent('game.php?page=galaxy&galaxy={{ galaxy }}&system={{ system }}'); return false;">
                        {{ homeplanet }} [{{ galaxy }}:{{ system }}:{{ planet }}]
                    </a>
                </span>
            </div>

            {% if not is_self %}
            <div class="pc-actions">
                <button type="button" class="pc-btn pc-btn-msg" onclick="pcOpenMessage({{ id }})">
                    <i class="fas fa-envelope"></i> Nachricht senden
                </button>
                {% if not buddy_exists %}
                <button type="button" class="pc-btn pc-btn-buddy" id="pc-buddy-btn" onclick="pcSendBuddy({{ id }}, this)">
                    <i class="fas fa-user-plus"></i> Freundschaftsanfrage
                </button>
                {% else %}
                <span class="pc-btn pc-btn-buddy-done">
                    <i class="fas fa-user-check"></i> Bereits befreundet
                </span>
                {% endif %}
            </div>
            <div id="pc-toast" class="pc-toast" style="display:none;"></div>
            {% endif %}
        </div>
    </div>

    <div class="player-grid">
        
        <div class="glass-card">
            <div class="card-title"><i class="fas fa-chart-line"></i> {{ LNG.pl_overview }}</div>
            <div class="stats-list">
                <div class="stat-row head">
                    <span>{{ LNG.pl_points }}</span>
                    <span class="text-right">{{ LNG.pl_range }}</span>
                </div>
                
                <div class="stat-row">
                    <span class="label">{{ LNG.pl_builds }}</span>
                    <span class="val">{{ build_points }}</span>
                    <span class="rank">#{{ build_rank }}</span>
                </div>
                <div class="stat-row">
                    <span class="label">{{ LNG.pl_tech }}</span>
                    <span class="val">{{ tech_points }}</span>
                    <span class="rank">#{{ tech_rank }}</span>
                </div>
                <div class="stat-row">
                    <span class="label">{{ LNG.pl_fleet }}</span>
                    <span class="val">{{ fleet_points }}</span>
                    <span class="rank">#{{ fleet_rank }}</span>
                </div>
                <div class="stat-row">
                    <span class="label">{{ LNG.pl_def }}</span>
                    <span class="val">{{ defs_points }}</span>
                    <span class="rank">#{{ defs_rank }}</span>
                </div>
                <div class="stat-row highlight">
                    <span class="label">{{ LNG.pl_total }}</span>
                    <span class="val">{{ total_points }}</span>
                    <span class="rank">#{{ total_rank }}</span>
                </div>
            </div>
        </div>

        <div class="glass-card">
            <div class="card-title"><i class="fas fa-crosshairs"></i> {{ LNG.pl_fightstats }}</div>
            <div class="combat-stats">
                
                <div class="combat-row">
                    <div class="c-label">{{ LNG.pl_fightwon }} ({{ siegprozent }}%)</div>
                    <div class="progress-bar">
                        <div class="fill win" style="width: {{ siegprozent }}%"></div>
                    </div>
                    <div class="c-val">{{ wons }}</div>
                </div>

                <div class="combat-row">
                    <div class="c-label">{{ LNG.pl_fightdraw }} ({{ drawsprozent }}%)</div>
                    <div class="progress-bar">
                        <div class="fill draw" style="width: {{ drawsprozent }}%"></div>
                    </div>
                    <div class="c-val">{{ draws }}</div>
                </div>

                <div class="combat-row">
                    <div class="c-label">{{ LNG.pl_fightlose }} ({{ loosprozent }}%)</div>
                    <div class="progress-bar">
                        <div class="fill lose" style="width: {{ loosprozent }}%"></div>
                    </div>
                    <div class="c-val">{{ loos }}</div>
                </div>

                <div class="total-fights">
                    {{ LNG.pl_totalfight }}: <span class="text-white">{{ totalfights }}</span>
                </div>
            </div>
        </div>

        <div class="glass-card full-width">
            <div class="card-title"><i class="fas fa-skull-crossbones"></i> {{ playerdestory }}</div>
            <div class="destruct-grid">
                <div class="destruct-item">
                    <span class="d-label">{{ LNG.pl_unitsshot }}</span>
                    <span class="d-val text-success">{{ desunits }}</span>
                </div>
                <div class="destruct-item">
                    <span class="d-label">{{ LNG.pl_unitslose }}</span>
                    <span class="d-val text-danger">{{ lostunits }}</span>
                </div>
                <div class="destruct-item">
                    <span class="d-label">{{ LNG.pl_dermetal }}</span>
                    <span class="d-val">{{ kbmetal }}</span>
                </div>
                <div class="destruct-item">
                    <span class="d-label">{{ LNG.pl_dercrystal }}</span>
                    <span class="d-val">{{ kbcrystal }}</span>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block script %}
{% autoescape false %}
<script>
/* Navigate the parent game window and close the modal */
function pcNavParent(url) {
    try {
        var p = window.parent;
        if (p && p !== window) {
            if (p.ModalManager && typeof p.ModalManager.close === 'function') {
                p.ModalManager.close();
            }
            p.location.href = url;
        } else {
            window.location.href = url;
        }
    } catch(e) { window.location.href = url; }
}

/* Swap the modal to the message compose view */
function pcOpenMessage(playerId) {
    try {
        var p = window.parent;
        if (p && p !== window && p.ModalManager && typeof p.ModalManager.open === 'function') {
            p.ModalManager.open(
                'game.php?page=messages&mode=write&id=' + playerId,
                { title: 'Nachricht senden' }
            );
        } else {
            window.location.href = 'game.php?page=messages&mode=write&id=' + playerId;
        }
    } catch(e) {
        window.location.href = 'game.php?page=messages&mode=write&id=' + playerId;
    }
}

/* POST buddy request, show inline toast */
function pcSendBuddy(playerId, btn) {
    btn.disabled = true;
    btn.style.opacity = '0.6';
    var toast = document.getElementById('pc-toast');

    fetch('game.php?page=buddyList&mode=send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'id=' + encodeURIComponent(playerId) + '&text='
    })
    .then(function(r) { return r.text(); })
    .then(function(html) {
        var isError = html.indexOf('bu_request_exists') !== -1
                   || html.indexOf('cannot_request') !== -1
                   || html.toLowerCase().indexOf('error') !== -1;
        if (toast) {
            toast.style.display = 'block';
            if (isError) {
                toast.style.background = 'rgba(239,68,68,.15)';
                toast.style.border     = '1px solid #ef4444';
                toast.style.color      = '#f87171';
                toast.textContent      = 'Anfrage konnte nicht gesendet werden.';
                btn.disabled    = false;
                btn.style.opacity = '1';
            } else {
                toast.style.background = 'rgba(16,185,129,.15)';
                toast.style.border     = '1px solid #10b981';
                toast.style.color      = '#10b981';
                toast.textContent      = '✓ Freundschaftsanfrage gesendet!';
                btn.style.display      = 'none';
            }
        }
    })
    .catch(function() {
        if (toast) {
            toast.style.display = 'block';
            toast.style.background = 'rgba(239,68,68,.15)';
            toast.style.border     = '1px solid #ef4444';
            toast.style.color      = '#f87171';
            toast.textContent      = 'Netzwerkfehler. Bitte erneut versuchen.';
        }
        btn.disabled    = false;
        btn.style.opacity = '1';
    });
}
</script>
{% endautoescape %}
{% endblock %}
