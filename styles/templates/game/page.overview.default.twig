{% extends "layout.full.twig" %}
{% block title %}{{ LNG.lm_overview }}{% endblock %}

{% block script %}
<script>
// ── Planet rename ──────────────────────────────────────────
function ovStartRename() {
  const display = document.getElementById('ov-planet-name-display');
  const input   = document.getElementById('ov-planet-name-input');
  const nameEl  = document.getElementById('ov-pname-text');
  if (!display || !input || !nameEl) return;
  input.value = nameEl.textContent;
  display.style.display = 'none';
  input.style.display   = 'inline-block';
  input.focus();
  input.select();
}
function ovCancelRename() {
  const display = document.getElementById('ov-planet-name-display');
  const input   = document.getElementById('ov-planet-name-input');
  if (!display || !input) return;
  input.style.display   = 'none';
  display.style.display = '';
}
var _ovSaving = false;
function ovSaveRename() {
  if (_ovSaving) return;
  const display = document.getElementById('ov-planet-name-display');
  const input   = document.getElementById('ov-planet-name-input');
  const nameEl  = document.getElementById('ov-pname-text');
  if (!display || !input || !nameEl) return;
  const newName = input.value.trim();
  if (!newName || newName === nameEl.textContent) { ovCancelRename(); return; }
  _ovSaving = true;
  input.disabled = true;
  fetch('game.php?page=overview&mode=rename', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'name=' + encodeURIComponent(newName)
  })
  .then(r => r.json())
  .then(data => {
    if (data && !data.error) {
      nameEl.textContent = newName;
      // Also update page title and planet selector in header if present
      document.title = document.title.replace(/^[^|]+/, newName + ' ');
      const selOpt = document.querySelector('#planetSelector option[selected], #planet-select option[selected]');
      if (selOpt) selOpt.textContent = newName + selOpt.textContent.replace(/^[^\[]+/, '');
    } else if (data && data.message) {
      alert(data.message);
    }
  })
  .catch(() => {})
  .finally(() => {
    _ovSaving = false;
    input.disabled = false;
    ovCancelRename();
  });
}

window.OVERVIEW_DATA = {
  planet_name:   {{ planetname|default('Planet')|json_encode|raw }},
  planet_image:  {{ planetimage|default('')|json_encode|raw }},
  has_moon:      {{ Moon is defined and Moon ? 'true' : 'false' }},
  planet_type:   {{ planet_type|default(1)|json_encode|raw }},
  temp_max:      {{ planet_temp_max|default(40)|json_encode|raw }},
  temp_min:      {{ planet_temp_min|default(-10)|json_encode|raw }},
  diameter:      {{ planet_diameter|default(12800)|json_encode|raw }},
  fields_used:   {{ planet_field_current|default(0)|json_encode|raw }},
  fields_max:    {{ planet_field_max|default(163)|json_encode|raw }},
  galaxy:        {{ galaxy|default(1)|json_encode|raw }},
  system:        {{ system|default(1)|json_encode|raw }},
  planet_pos:    {{ planet|default(1)|json_encode|raw }},
  ref_active:    {{ ref_active|default(false)|json_encode|raw }},
  userid:        {{ userid|default(0)|json_encode|raw }},
  path:          {{ path|default('')|json_encode|raw }}
};
</script>
<script src="scripts/game/overview.js"></script>
{% endblock %}

{% block content %}
<div class="content_page ov-page">

  {% if messages %}
  <div class="ov-alert"><i class="fas fa-envelope"></i> <a href="game.php?page=messages">{{ messages|raw }}</a></div>
  {% endif %}

  {% if is_news and newsItems is defined and newsItems|length > 0 %}
  <div class="ov-news-bar" id="ov-news-ticker-box">
    <span class="ov-news-label"><i class="fas fa-bullhorn"></i> NEWS</span>
    <div class="ov-news-slides" id="newsTickerTrack">
      {% for item in newsItems %}
      <div class="ov-news-slide{% if loop.first %} active{% endif %}">
        {% if item.title %}<strong>{{ item.title }}</strong> &mdash; {% endif %}{{ item.text|raw }}
      </div>
      {% endfor %}
    </div>
    {% if newsItems|length > 1 %}
    <div class="ov-news-nav">
      <button class="ov-news-btn" id="newsPrev">&#8592;</button>
      <span class="ov-news-count"><span id="newsIdx">1</span>/{{ newsItems|length }}</span>
      <button class="ov-news-btn" id="newsNext">&#8594;</button>
    </div>
    {% endif %}
  </div>
  {% endif %}

  {{ hook('content_top') }}

  <div class="ov-main-grid">

    <!-- ══════════ LEFT: Colonies + Debris ══════════ -->
    <div class="ov-col-left">

      <!-- COLONIES -->
      {% if AllPlanets is defined and AllPlanets|length > 0 %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-globe"></i> {{ LNG.ov_colonies|default('Kolonien') }} <span class="ov-badge">{{ AllPlanets|length }}</span></div>
        <div class="ov-planet-list">
          {% for p in AllPlanets %}
          <a href="game.php?page=overview&cp={{ p.id }}" class="ov-planet-row">
            <img src="styles/theme/gow/planeten/{{ p.image }}.jpg" onerror="this.src='styles/theme/gow/planeten/normaltempplanet01.jpg'" class="ov-planet-thumb" alt="">
            <div class="ov-planet-row-info">
              <span class="ov-planet-row-name">{{ p.name }}</span>
              <span class="ov-planet-row-build {% if p.build == LNG.ov_free %}ov-free{% else %}ov-building{% endif %}">
                {% if p.build == LNG.ov_free %}<i class="fas fa-check-circle"></i>{% else %}<i class="fas fa-hammer"></i>{% endif %}
                {{ p.build|raw }}
              </span>
            </div>
          </a>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {{ hook('overview.after_planets') }}

      <!-- DEBRIS -->
      {% if GalaxyRows is defined and GalaxyRows and (GalaxyRows.debris.metal > 0 or GalaxyRows.debris.crystal > 0) %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-recycle"></i> {{ LNG.ov_debris_field }}</div>
        <div class="ov-card-body">
          <div class="ov-debris-row"><span style="color:var(--dim)">{{ LNG.tech[901]|default('Metall') }}</span><span style="color:var(--cyan)">{{ GalaxyRows.debris.metal|number_format }}</span></div>
          <div class="ov-debris-row"><span style="color:var(--dim)">{{ LNG.tech[902]|default('Kristall') }}</span><span style="color:var(--purple)">{{ GalaxyRows.debris.crystal|number_format }}</span></div>
          <a href="game.php?page=fleetTable&galaxy={{ galaxy }}&system={{ system }}&planet={{ planet }}&planettype=1&target_mission=8" class="ov-btn ov-btn-sm" style="margin-top:10px;width:100%;justify-content:center;"><i class="fas fa-satellite"></i> {{ LNG.ov_harvest }}</a>
        </div>
      </div>
      {% endif %}

    </div>

    <!-- ══════════ CENTER: Planet + Build Queue + Fleets ══════════ -->
    <div class="ov-col-center">

      <!-- CINEMATIC PLANET CARD -->
      <div class="ov-card ov-planet-card">
        <div class="ov-card-header">
          <i class="fas fa-globe-americas"></i>
          <span id="ov-planet-name-display" class="ov-planet-name-editable" onclick="ovStartRename()" title="{{ LNG.ov_rename|default('Planet umbenennen') }}">&ldquo;<span id="ov-pname-text">{{ planetname }}</span>&rdquo; <i class="fas fa-pen" style="font-size:9px;opacity:.55;margin-left:3px;"></i></span>
          <input id="ov-planet-name-input" class="ov-planet-name-input" type="text" maxlength="20" style="display:none" onblur="ovSaveRename()" onkeydown="if(event.key==='Enter')ovSaveRename();if(event.key==='Escape')ovCancelRename();">
          <a href="#" onclick="return Dialog.PlanetAction();" class="ov-icon-btn" title="{{ LNG.ov_planetmenu }}"><i class="fas fa-ellipsis-v"></i></a>
        </div>
        <div class="ov-planet-scene" id="ovPlanetScene">
          <canvas class="ov-stars-canvas" id="ovStarsCanvas"></canvas>

          <!-- LEFT: PLANET STATS OVERLAY -->
          <div class="ov-scene-overlay ov-scene-left">
            <div class="ov-scene-type-badge">{{ LNG["type_planet_" ~ planet_type] }}</div>
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">{{ LNG.ov_diameter }}</span>
              <span class="ov-scene-val">{{ planet_diameter }}</span>
            </div>
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">{{ LNG.ov_temperature }}</span>
              <span class="ov-scene-val">{{ planet_temp_min }}° / {{ planet_temp_max }}°</span>
            </div>
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">{{ LNG.ov_fields }}</span>
              <span class="ov-scene-val {% if planet_field_current >= planet_field_max %}ov-danger{% endif %}">{{ planet_field_current }}/{{ planet_field_max }}</span>
              <div class="ov-scene-bar"><div class="ov-scene-fill" style="width:{{ planet_field_max > 0 ? ((planet_field_current / planet_field_max)*100)|round(1) : 0 }}%"></div></div>
            </div>
            {% if Moon is defined and Moon %}
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">{{ LNG.fcm_moon }}</span>
              <a href="game.php?page=overview&cp={{ Moon.id }}&re=0" class="ov-scene-val" style="color:var(--gold)">{{ Moon.name }}</a>
            </div>
            {% endif %}
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">Koordinaten</span>
              <a href="game.php?page=galaxy&galaxy={{ galaxy }}&system={{ system }}" class="ov-scene-val" style="color:var(--cyan);font-size:11px;font-family:var(--font-mono)">[{{ galaxy }}:{{ system }}:{{ planet }}]</a>
            </div>
          </div>

          <!-- RIGHT: SERVER INFO OVERLAY -->
          <div class="ov-scene-overlay ov-scene-right">
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">{{ LNG.ov_online_user }}</span>
              <span class="ov-scene-val" style="color:var(--green)">{{ onlineUser }}</span>
            </div>
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">Chat</span>
              <span class="ov-scene-val" style="color:{% if chatOnline is defined and chatOnline|length > 0 %}var(--green){% else %}var(--dim){% endif %}">
                {% if chatOnline is defined %}{{ chatOnline|length }}{% else %}0{% endif %}
              </span>
            </div>
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">{{ LNG.ov_admins_online }}</span>
              <span class="ov-scene-val">
                {% if AdminsOnline %}
                  {% for ID, Name in AdminsOnline %}<a href="#" onclick="return Dialog.PM({{ ID }});" style="color:var(--red)">{{ Name }}</a>{% if not loop.last %}, {% endif %}{% endfor %}
                {% else %}<span style="color:var(--dim)">–</span>{% endif %}
              </span>
            </div>
            <div class="ov-scene-stat">
              <span class="ov-scene-lbl">{{ LNG.ov_points }}</span>
              <span class="ov-scene-val" style="font-size:10px;font-weight:400;color:var(--text)">{{ rankInfo|raw }}</span>
            </div>
          </div>

          <!-- PLANET IMAGE (clickable, hover glow) -->
          <div class="ov-planet-img-wrap" id="ovPlanetImgWrap" onclick="window.location.href='game.php?page=buildings'" title="{{ LNG.ov_buildings|default('Gebäude') }}">
            <img src="styles/theme/gow/planeten/{{ planetimage }}.jpg"
                 onerror="this.src='styles/theme/gow/planeten/normaltempplanet01.jpg'"
                 class="ov-planet-img" id="ovPlanetImg" alt="{{ planetname }}">
            <div class="ov-planet-atmosphere" id="ovPlanetAtm"></div>
            <div class="ov-planet-shimmer"></div>
          </div>
          <div class="ov-orbit-ring ov-orbit-1"></div>
          <div class="ov-orbit-ring ov-orbit-2"></div>
          {% if Moon is defined and Moon %}
          <div class="ov-moon-orbit-wrap" id="ovMoonOrbit"><div class="ov-moon-img"></div></div>
          {% endif %}
        </div>
        <!-- ACTION BUTTONS INSIDE PLANET CARD -->
        <div class="ov-planet-actions">
          <a href="game.php?page=ticket" class="ov-btn ov-btn-sm"><i class="fas fa-headset"></i> Support</a>
          <a href="game.php?page=messages" class="ov-btn ov-btn-sm"><i class="fas fa-envelope"></i> {{ LNG.lm_messages }}</a>
          <a href="game.php?page=statistics" class="ov-btn ov-btn-sm"><i class="fas fa-chart-bar"></i> {{ LNG.lm_statistics|default('Statistik') }}</a>
        </div>
      </div>

      <!-- BUILD QUEUE -->
      {% if buildInfo.buildings or buildInfo.tech or buildInfo.fleet %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-hammer"></i> {{ LNG.ov_queue|default('Bauqueue') }}</div>
        <div class="ov-queue-list">
          {% if buildInfo.buildings %}
          <div class="ov-queue-item ov-queue-building">
            <i class="fas fa-city"></i>
            <div class="ov-queue-info">
              <span class="ov-queue-name">{{ LNG.tech[buildInfo.buildings.id]|default('Gebäude') }} <span class="ov-queue-lvl">Lv {{ buildInfo.buildings.level }}</span></span>
              <span class="ov-queue-time" data-time="{{ buildInfo.buildings.timeleft }}"><i class="fas fa-clock"></i> {{ buildInfo.buildings.starttime }}</span>
            </div>
            <div class="ov-queue-bar-wrap"><div class="ov-queue-bar" id="qbar-building"></div></div>
          </div>
          {% endif %}
          {% if buildInfo.tech %}
          <div class="ov-queue-item ov-queue-tech">
            <i class="fas fa-flask"></i>
            <div class="ov-queue-info">
              <span class="ov-queue-name">{{ LNG.tech[buildInfo.tech.id]|default('Forschung') }} <span class="ov-queue-lvl">Lv {{ buildInfo.tech.level }}</span></span>
              <span class="ov-queue-time" data-time="{{ buildInfo.tech.timeleft }}"><i class="fas fa-clock"></i> {{ buildInfo.tech.starttime }}</span>
            </div>
            <div class="ov-queue-bar-wrap"><div class="ov-queue-bar" id="qbar-tech"></div></div>
          </div>
          {% endif %}
          {% if buildInfo.fleet %}
          <div class="ov-queue-item ov-queue-fleet">
            <i class="fas fa-rocket"></i>
            <div class="ov-queue-info">
              <span class="ov-queue-name">{{ LNG.tech[buildInfo.fleet.id]|default('Schiff') }} <span class="ov-queue-lvl">x{{ buildInfo.fleet.level }}</span></span>
              <span class="ov-queue-time" data-time="{{ buildInfo.fleet.timeleft }}"><i class="fas fa-clock"></i> {{ buildInfo.fleet.starttime }}</span>
            </div>
            <div class="ov-queue-bar-wrap"><div class="ov-queue-bar" id="qbar-fleet"></div></div>
          </div>
          {% endif %}
        </div>
      </div>
      {% endif %}

      <!-- FLEETS -->
      {% if fleets is defined and fleets|length > 0 %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-rocket"></i> {{ LNG.ov_fleet|default('Flotten') }} <span class="ov-badge">{{ fleets|length }}</span></div>
        <div class="ov-fleet-body">
          {% for fleetEntry in fleets %}
          <div class="ov-fleet-entry {% if fleetEntry.isHostile %}ov-fleet-hostile{% elseif fleetEntry.isOwn %}ov-fleet-own{% else %}ov-fleet-foreign{% endif %}">
            <div class="ov-fleet-text">{{ fleetEntry.text|raw }}</div>
            <div class="ov-fleet-timer" data-fleet-time="{{ fleetEntry.resttime }}">
              <i class="fas fa-clock"></i>
              <span class="ov-fleet-countdown">–</span>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}

    </div>

    <!-- ══════════ RIGHT: Reflink compact + Colonies ══════════ -->
    <div class="ov-col-right">

      <!-- REFLINK COMPACT -->
      {% if ref_active %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-share-alt"></i> {{ LNG.ov_reflink }}</div>
        <div class="ov-card-body">
          {% if isModuleAvailable(constant('MODULE_BANNER')) %}
          <img src="userpic.php?id={{ userid }}" alt="Banner" style="max-width:100%;border-radius:6px;margin-bottom:10px;">
          <div class="ov-ref-code-block">
            <div class="ov-ref-label">HTML</div>
            <input type="text" value='<a href="{{ path }}index.php?ref={{ userid }}"><img src="{{ path }}userpic.php?id={{ userid }}"></a>' readonly class="ov-ref-input" onclick="this.select()">
          </div>
          <div class="ov-ref-code-block" style="margin-top:6px;">
            <div class="ov-ref-label">BBCode</div>
            <input type="text" value="[url={{ path }}index.php?ref={{ userid }}][img]{{ path }}userpic.php?id={{ userid }}[/img][/url]" readonly class="ov-ref-input" onclick="this.select()">
          </div>
          {% endif %}
          {% if RefLinks is defined and RefLinks|length > 0 %}
          <div class="ov-ref-list">
            {% for RefID, RefLink in RefLinks %}
            <div class="ov-ref-row">
              <a href="#" onclick="return Dialog.Playercard({{ RefID }}, '{{ RefLink.username }}');">{{ RefLink.username }}</a>
              <span class="ov-ref-pts {% if RefLink.points >= ref_minpoints %}ov-ref-done{% endif %}">{{ RefLink.points|number_format }}/{{ ref_minpoints|number_format }}</span>
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </div>
      {% endif %}

      <!-- TEAMSPEAK -->
      {% if teamspeakData is defined and teamspeakData and not teamspeakData.error %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-headphones"></i> TeamSpeak</div>
        <div class="ov-card-body" style="text-align:center;">
          <div style="font-size:26px;font-weight:900;color:var(--cyan)">{{ teamspeakData.current }}/{{ teamspeakData.max }}</div>
          <div style="color:var(--dim);font-size:10px;margin-bottom:10px">Online</div>
          <a href="{{ teamspeakData.url }}" class="ov-btn ov-btn-sm" style="width:100%;justify-content:center;"><i class="fas fa-sign-in-alt"></i> Verbinden</a>
        </div>
      </div>
      {% endif %}

    </div>

  </div>
</div>

<style>
/* ── PLANET RENAME ── */
.ov-planet-name-editable { cursor:pointer; transition:color .15s; }
.ov-planet-name-editable:hover { color:var(--cyan); }
.ov-planet-name-input {
  background:rgba(0,212,255,0.08); border:1px solid rgba(0,212,255,0.45);
  border-radius:5px; color:#fff; font-size:13px; font-family:inherit;
  padding:2px 8px; outline:none; width:160px; margin:0 4px;
}
.ov-planet-name-input:focus { border-color:rgba(0,212,255,0.9); box-shadow:0 0 8px rgba(0,212,255,0.25); }
/* ── PAGE BASE ── */
.ov-page { padding-bottom:24px; }
.ov-alert { background:rgba(0,212,255,0.08); border:1px solid rgba(0,212,255,0.3); border-radius:8px; padding:10px 16px; margin-bottom:14px; font-size:13px; color:var(--cyan); }
.ov-alert a { color:var(--cyan); }

/* ── NEWS BAR ── */
.ov-news-bar { display:flex; align-items:center; gap:10px; background:rgba(0,212,255,0.05); border:1px solid rgba(0,212,255,0.18); border-radius:10px; padding:9px 14px; margin-bottom:14px; min-height:42px; }
.ov-news-label { font-family:var(--font-hud); font-size:8px; letter-spacing:2px; color:var(--cyan); white-space:nowrap; flex-shrink:0; display:flex; align-items:center; gap:5px; }
.ov-news-slides { flex:1; min-width:0; position:relative; }
.ov-news-slide { display:none; font-size:13px; color:var(--text); animation:newsIn .4s ease; }
.ov-news-slide.active { display:block; }
@keyframes newsIn { from{opacity:0;transform:translateX(6px)} to{opacity:1;transform:translateX(0)} }
.ov-news-nav { display:flex; align-items:center; gap:5px; flex-shrink:0; }
.ov-news-btn { background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.25); color:var(--cyan); border-radius:4px; width:22px; height:22px; cursor:pointer; font-size:12px; padding:0; transition:.15s; }
.ov-news-btn:hover { background:var(--cyan); color:#000; }
.ov-news-count { font-size:10px; color:var(--dim); font-family:var(--font-hud); white-space:nowrap; }

/* ── MAIN GRID ── */
.ov-main-grid { display:grid; grid-template-columns:220px 1fr 220px; gap:14px; align-items:start; }
@media(max-width:1100px){ .ov-main-grid { grid-template-columns:200px 1fr; } .ov-col-right { display:none; } }
@media(max-width:760px){ .ov-main-grid { grid-template-columns:1fr; } }
/* INFO ROWS */
.ov-info-rows { padding:4px 0; }
.ov-info-row { display:flex; justify-content:space-between; align-items:center; padding:7px 14px; border-bottom:1px solid rgba(255,255,255,0.04); gap:8px; }
.ov-info-row:last-child { border-bottom:none; }
.ov-info-lbl { font-size:11px; color:var(--dim); display:flex; align-items:center; gap:5px; }
.ov-info-lbl i { font-size:10px; width:12px; }
.ov-info-val { font-size:12px; color:var(--white); font-weight:600; text-align:right; }
.ov-info-row-rank { flex-direction:column; align-items:flex-start; gap:3px; }
.ov-rank-val { font-size:11px; color:var(--text); font-weight:400; line-height:1.4; }
/* ── PLANET SCENE OVERLAYS ── */
.ov-scene-overlay { position:absolute; top:0; bottom:0; width:34%; display:flex; flex-direction:column; justify-content:center; gap:9px; padding:14px 13px; z-index:4; pointer-events:none; }
.ov-scene-overlay a { pointer-events:auto; }
.ov-scene-left { left:0; background:linear-gradient(to right, rgba(2,4,8,0.88) 0%, rgba(2,4,8,0.55) 60%, transparent 100%); align-items:flex-start; }
.ov-scene-right { right:0; background:linear-gradient(to left, rgba(2,4,8,0.88) 0%, rgba(2,4,8,0.55) 60%, transparent 100%); align-items:flex-end; text-align:right; }
.ov-scene-stat { display:flex; flex-direction:column; gap:2px; }
.ov-scene-lbl { font-family:var(--font-hud); font-size:8px; letter-spacing:1.5px; color:rgba(0,212,255,0.7); text-transform:uppercase; }
.ov-scene-val { font-size:12px; color:#fff; font-weight:700; line-height:1.2; }
.ov-scene-val.ov-danger { color:var(--red); }
.ov-scene-bar { height:3px; background:rgba(255,255,255,0.1); border-radius:2px; margin-top:3px; width:72px; overflow:hidden; }
.ov-scene-fill { height:100%; background:linear-gradient(90deg,var(--cyan),var(--purple)); border-radius:2px; }
.ov-scene-type-badge { background:rgba(0,212,255,0.12); border:1px solid rgba(0,212,255,0.25); border-radius:20px; padding:3px 10px; font-family:var(--font-hud); font-size:8px; letter-spacing:1.5px; color:var(--cyan); text-transform:uppercase; white-space:nowrap; }
.ov-scene-coord { margin-top:4px; }
.ov-coord-badge { display:none; }
/* planet clickable wrap */
.ov-planet-img-wrap { cursor:pointer; }
.ov-planet-img-wrap:hover .ov-planet-img { filter:saturate(1.3) contrast(1.1) brightness(1.1); }
.ov-planet-img-wrap:hover { box-shadow:0 0 55px 16px rgba(30,100,255,0.55), 0 0 90px 30px rgba(0,80,200,0.25) !important; transform:translate(-50%,-50%) scale(1.07) !important; }
.ov-planet-img-wrap:hover ~ .ov-orbit-ring { opacity:3; }
/* action buttons below planet scene */
.ov-planet-actions { display:flex; gap:8px; padding:10px 14px; border-top:1px solid var(--border); flex-wrap:wrap; }
.ov-planet-actions .ov-btn { flex:1; justify-content:center; min-width:80px; }

/* ── CARDS ── */
.ov-card { background:var(--panel); border:1px solid var(--border); border-radius:12px; overflow:hidden; margin-bottom:12px; }
.ov-card-header { display:flex; align-items:center; gap:8px; padding:11px 15px; font-family:var(--font-hud); font-size:10px; letter-spacing:1.5px; text-transform:uppercase; color:var(--cyan); border-bottom:1px solid var(--border); background:rgba(0,212,255,0.03); }
.ov-card-header i { font-size:13px; color:var(--cyan); opacity:.8; }
.ov-card-body { padding:14px 15px; }
.ov-icon-btn { margin-left:auto; color:var(--dim); padding:2px 6px; border-radius:4px; transition:.15s; font-size:13px; }
.ov-icon-btn:hover { color:var(--cyan); background:rgba(0,212,255,0.1); }
.ov-badge { margin-left:auto; background:rgba(0,212,255,0.15); color:var(--cyan); border-radius:10px; padding:1px 8px; font-size:10px; }

/* ── PLANET HERO ── */
.ov-planet-hero { display:block; text-decoration:none; cursor:pointer; position:relative; }
.ov-planet-scene { position:relative; width:100%; height:280px; overflow:hidden; background:radial-gradient(ellipse at 50% 60%,#0a0f1e 0%,#020408 100%); }
.ov-stars-canvas { position:absolute; inset:0; width:100%; height:100%; opacity:.9; pointer-events:none; }
.ov-planet-img-wrap { position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); width:190px; height:190px; border-radius:50%; transition:transform .4s cubic-bezier(.22,1,.36,1), box-shadow .4s ease; will-change:transform; }
.ov-planet-img { width:100%; height:100%; border-radius:50%; object-fit:cover; display:block; filter:saturate(1.15) contrast(1.05); }
.ov-planet-atmosphere { position:absolute; inset:-8px; border-radius:50%; pointer-events:none;
  background:radial-gradient(ellipse at 30% 30%, rgba(120,180,255,0.18) 0%, transparent 60%),
             radial-gradient(ellipse at 70% 80%, rgba(0,80,200,0.22) 0%, transparent 55%);
  box-shadow: 0 0 40px 12px rgba(30,80,200,0.35), inset 0 0 30px rgba(0,100,255,0.12);
  animation:atmPulse 4s ease-in-out infinite; }
@keyframes atmPulse { 0%,100%{opacity:.7} 50%{opacity:1} }
.ov-planet-shimmer { position:absolute; inset:0; border-radius:50%; background:linear-gradient(135deg,rgba(255,255,255,0.12) 0%,transparent 50%,rgba(0,150,255,0.06) 100%); pointer-events:none; }
.ov-orbit-ring { position:absolute; left:50%; top:50%; border-radius:50%; border:1px solid rgba(0,212,255,0.1); transform:translate(-50%,-50%) rotateX(72deg); pointer-events:none; transition:opacity .3s; }
.ov-orbit-1 { width:230px; height:230px; animation:orbitSpin 20s linear infinite; }
.ov-orbit-2 { width:280px; height:280px; animation:orbitSpin 35s linear infinite reverse; border-color:rgba(120,80,255,0.08); }
@keyframes orbitSpin { to{transform:translate(-50%,-50%) rotateX(72deg) rotateZ(360deg)} }
.ov-moon-orbit-wrap { position:absolute; left:50%; top:50%; width:220px; height:220px; margin-left:-110px; margin-top:-110px; border-radius:50%; animation:moonOrbit 14s linear infinite; pointer-events:none; }
.ov-moon-img { position:absolute; top:-8px; left:50%; margin-left:-8px; width:16px; height:16px; border-radius:50%; background:radial-gradient(circle at 38% 35%,#d0d0d0,#707070); box-shadow:0 0 8px rgba(255,255,255,0.25); }
@keyframes moonOrbit { to{transform:rotate(360deg)} }
.ov-planet-cta { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; opacity:0; background:rgba(0,0,0,0.55); backdrop-filter:blur(2px); transition:opacity .3s ease; border-radius:0; }
.ov-planet-cta i { font-size:28px; color:var(--cyan); filter:drop-shadow(0 0 10px var(--cyan)); }
.ov-planet-cta span { font-family:var(--font-hud); font-size:11px; letter-spacing:3px; color:#fff; text-transform:uppercase; }
.ov-planet-hero:hover .ov-planet-cta { opacity:1; }
.ov-planet-hero:hover .ov-planet-img-wrap { transform:translate(-50%,-50%) scale(1.06); box-shadow:0 0 60px 18px rgba(30,100,255,0.45); }
.ov-planet-hero:hover .ov-orbit-ring { opacity:2.5; }
.ov-coord-badge { display:block; text-align:center; background:rgba(0,212,255,0.08); border-top:1px solid rgba(0,212,255,0.15); padding:7px 12px; font-family:var(--font-mono); font-size:12px; color:var(--cyan); transition:.2s; }
.ov-coord-badge a { color:var(--cyan); }
.ov-planet-hero:hover .ov-coord-badge { background:rgba(0,212,255,0.14); }
/* STATS */
.ov-planet-stats { padding:4px 14px 10px; display:flex; flex-direction:column; gap:0; }
.ov-stat-item { display:grid; grid-template-columns:18px 1fr; gap:8px; align-items:start; padding:7px 0; border-bottom:1px solid rgba(255,255,255,0.04); }
.ov-stat-item:last-child { border-bottom:none; }
.ov-stat-item > i { color:var(--dim); font-size:12px; margin-top:3px; }
.ov-stat-body { display:flex; flex-direction:column; }
.ov-stat-val { font-size:12px; color:var(--white); font-weight:600; }
.ov-stat-val a { color:var(--gold); }
.ov-stat-lbl { font-size:10px; color:var(--dim); }
.ov-danger { color:var(--red) !important; }
.ov-field-bar { height:3px; background:rgba(255,255,255,0.07); border-radius:2px; margin-top:4px; overflow:hidden; grid-column:1/-1; }
.ov-field-fill { height:100%; background:linear-gradient(90deg,var(--cyan),var(--purple)); border-radius:2px; }

/* ── BUILD QUEUE ── */
.ov-queue-list { padding:4px 0; }
.ov-queue-item { display:grid; grid-template-columns:32px 1fr; gap:10px; padding:10px 14px; border-bottom:1px solid rgba(255,255,255,0.04); align-items:center; }
.ov-queue-item:last-child { border-bottom:none; }
.ov-queue-item > i { font-size:16px; text-align:center; }
.ov-queue-building > i { color:var(--cyan); }
.ov-queue-tech > i { color:var(--purple); }
.ov-queue-fleet > i { color:var(--green); }
.ov-queue-info { display:flex; flex-direction:column; gap:2px; }
.ov-queue-name { font-size:12px; color:var(--white); font-weight:600; }
.ov-queue-lvl { color:var(--dim); font-weight:400; font-size:11px; }
.ov-queue-time { font-size:11px; color:var(--dim); }
.ov-queue-bar-wrap { grid-column:1/-1; height:2px; background:rgba(255,255,255,0.06); border-radius:1px; overflow:hidden; margin-top:2px; }
.ov-queue-bar { height:100%; border-radius:1px; transition:width 1s linear; width:0%; }
#qbar-building { background:var(--cyan); }
#qbar-tech { background:var(--purple); }
#qbar-fleet { background:var(--green); }

/* ── SERVER CARD ── */
.ov-server-grid { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--border); }
.ov-server-stat { background:var(--panel); padding:12px 15px; display:flex; flex-direction:column; gap:3px; }
.ov-server-val { font-size:14px; color:var(--white); font-weight:700; }
.ov-server-lbl { font-size:10px; color:var(--dim); font-family:var(--font-hud); letter-spacing:.5px; }
.ov-server-actions { display:flex; gap:8px; padding:12px 14px; flex-wrap:wrap; border-top:1px solid var(--border); }

/* ── FLEET BODY ── */
.ov-fleet-body { padding:4px 0; font-size:12px; }
.ov-fleet-body table { width:100%; }
.ov-fleet-entry { padding:9px 14px; border-bottom:1px solid rgba(255,255,255,0.04); display:flex; flex-direction:column; gap:4px; }
.ov-fleet-entry:last-child { border-bottom:none; }
.ov-fleet-entry.ov-fleet-own  { border-left:2px solid var(--cyan); }
.ov-fleet-entry.ov-fleet-hostile { border-left:2px solid var(--red); background:rgba(255,61,87,0.03); }
.ov-fleet-entry.ov-fleet-foreign { opacity:.8; }
.ov-fleet-text { font-size:12px; color:var(--text); line-height:1.5; }
.ov-fleet-text a { color:var(--cyan) !important; }
.ov-fleet-timer { font-family:var(--font-mono); font-size:11px; color:var(--dim); display:flex; align-items:center; gap:5px; }
.ov-fleet-entry.ov-fleet-hostile .ov-fleet-timer { color:var(--red); }

/* ── REFERRAL ── */
.ov-ref-code-block { display:flex; flex-direction:column; gap:3px; }
.ov-ref-label { font-size:9px; color:var(--dim); font-family:var(--font-hud); letter-spacing:1px; text-transform:uppercase; }
.ov-ref-input { width:100%; background:rgba(0,0,0,0.4); border:1px solid var(--border); border-radius:5px; color:var(--dim); padding:5px 8px; font-family:var(--font-mono); font-size:10px; box-sizing:border-box; }
.ov-ref-list { margin-top:12px; border-top:1px solid var(--border); padding-top:10px; display:flex; flex-direction:column; gap:6px; }
.ov-ref-row { display:flex; justify-content:space-between; align-items:center; font-size:12px; }
.ov-ref-pts { color:var(--dim); font-family:var(--font-mono); font-size:11px; }
.ov-ref-done { color:var(--green) !important; }

/* ── PLANET LIST ── */
.ov-planet-list { padding:4px 0; }
.ov-planet-row { display:flex; align-items:center; gap:10px; padding:8px 14px; border-bottom:1px solid rgba(255,255,255,0.04); transition:.15s; text-decoration:none; }
.ov-planet-row:last-child { border-bottom:none; }
.ov-planet-row:hover { background:rgba(0,212,255,0.05); }
.ov-planet-thumb { width:32px; height:32px; border-radius:50%; object-fit:cover; flex-shrink:0; }
.ov-planet-row-info { display:flex; flex-direction:column; gap:2px; min-width:0; }
.ov-planet-row-name { font-size:12px; color:var(--white); font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.ov-planet-row-build { font-size:10px; color:var(--dim); }
.ov-planet-row-build.ov-free i { color:var(--green); }
.ov-planet-row-build.ov-building i { color:var(--gold); }

/* ── DEBRIS ── */
.ov-debris-row { display:flex; justify-content:space-between; padding:5px 0; font-size:12px; border-bottom:1px solid rgba(255,255,255,0.04); }
.ov-card .ov-debris-row:last-of-type { border-bottom:none; }

/* ── BUTTONS ── */
.ov-btn { display:inline-flex; align-items:center; gap:6px; padding:7px 14px; background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.25); border-radius:6px; color:var(--cyan); font-size:12px; font-weight:600; cursor:pointer; transition:.15s; text-decoration:none; white-space:nowrap; }
.ov-btn:hover { background:rgba(0,212,255,0.2); color:var(--cyan); }
.ov-btn-sm { padding:5px 10px; font-size:11px; }
</style>

<script>
(function(){
  var D = window.OVERVIEW_DATA || {};

  /* ── STAR FIELD ── */
  (function(){
    var c = document.getElementById('ovStarsCanvas');
    if (!c) return;
    var ctx = c.getContext('2d');
    var W = c.offsetWidth || 280, H = c.offsetHeight || 240;
    c.width = W; c.height = H;
    var stars = [];
    for (var i = 0; i < 120; i++) {
      stars.push({ x: Math.random()*W, y: Math.random()*H, r: Math.random()*1.2+0.2, a: Math.random(), speed: Math.random()*0.003+0.001 });
    }
    function drawStars() {
      ctx.clearRect(0,0,W,H);
      stars.forEach(function(s){
        s.a += s.speed;
        var alpha = 0.4 + 0.5 * Math.abs(Math.sin(s.a));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
        ctx.fillStyle = 'rgba(255,255,255,' + alpha + ')';
        ctx.fill();
      });
      requestAnimationFrame(drawStars);
    }
    drawStars();
  })();

  /* ── PLANET PARALLAX ── */
  (function(){
    var scene = document.getElementById('ovPlanetScene');
    var wrap  = document.getElementById('ovPlanetImgWrap');
    var atm   = document.getElementById('ovPlanetAtm');
    if (!scene || !wrap) return;
    scene.addEventListener('mousemove', function(e){
      var r = scene.getBoundingClientRect();
      var cx = r.left + r.width/2, cy = r.top + r.height/2;
      var dx = (e.clientX - cx) / (r.width/2);
      var dy = (e.clientY - cy) / (r.height/2);
      wrap.style.transform = 'translate(calc(-50% + '+(dx*10)+'px), calc(-50% + '+(dy*8)+'px)) scale(1.07)';
      if (atm) atm.style.background = 'radial-gradient(ellipse at '+(50+dx*20)+'% '+(50+dy*20)+'%, rgba(120,180,255,0.28) 0%, transparent 60%)';
    });
    scene.addEventListener('mouseleave', function(){
      wrap.style.transform = 'translate(-50%,-50%) scale(1)';
      if (atm) atm.style.background = '';
    });
  })();

  /* ── NEWS TICKER ── */
  (function(){
    var track = document.getElementById('newsTickerTrack');
    if (!track) return;
    var slides = track.querySelectorAll('.ov-news-slide');
    if (slides.length <= 1) return;
    var idx = 0, timer, paused = false;
    var counter = document.getElementById('newsIdx');
    function show(n) {
      slides[idx].classList.remove('active');
      idx = (n + slides.length) % slides.length;
      slides[idx].classList.add('active');
      if (counter) counter.textContent = idx + 1;
    }
    function startTimer() { timer = setInterval(function(){ show(idx+1); }, 6000); }
    function stopTimer() { clearInterval(timer); }
    startTimer();
    var box = document.getElementById('ov-news-ticker-box');
    if (box) {
      box.addEventListener('mouseenter', function(){ paused=true; stopTimer(); });
      box.addEventListener('mouseleave', function(){ paused=false; startTimer(); });
    }
    var btnN = document.getElementById('newsNext'), btnP = document.getElementById('newsPrev');
    if (btnN) btnN.addEventListener('click', function(){ stopTimer(); show(idx+1); if(!paused) startTimer(); });
    if (btnP) btnP.addEventListener('click', function(){ stopTimer(); show(idx-1); if(!paused) startTimer(); });
  })();

  /* ── BUILD QUEUE PROGRESS BARS ── */
  (function(){
    var queues = [
      { el: document.getElementById('qbar-building'), timeEl: document.querySelector('.ov-queue-building .ov-queue-time') },
      { el: document.getElementById('qbar-tech'),     timeEl: document.querySelector('.ov-queue-tech .ov-queue-time') },
      { el: document.getElementById('qbar-fleet'),    timeEl: document.querySelector('.ov-queue-fleet .ov-queue-time') }
    ];
    queues.forEach(function(q){
      if (!q.el || !q.timeEl) return;
      var total = parseInt(q.timeEl.getAttribute('data-time')) || 0;
      if (total <= 0) { q.el.style.width = '100%'; return; }
      var start = Date.now();
      var elapsed = 0;
      function tick(){
        elapsed = (Date.now() - start) / 1000;
        var pct = Math.min(100, (elapsed / total) * 100);
        q.el.style.width = pct + '%';
        var left = Math.max(0, total - elapsed);
        var h = Math.floor(left/3600), m = Math.floor((left%3600)/60), s = Math.floor(left%60);
        q.timeEl.innerHTML = '<i class="fas fa-clock"></i> ' + (h>0?h+'h ':'')+m+'m '+s+'s';
        if (pct < 100) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  })();

  /* ── FLEET COUNTDOWN TIMERS ── */
  (function(){
    function fmt(s) {
      s = Math.max(0, Math.floor(s));
      var h = Math.floor(s/3600), m = Math.floor((s%3600)/60), sec = s%60;
      return (h>0 ? h+'h ' : '') + (m>0||h>0 ? m+'m ' : '') + sec+'s';
    }
    document.querySelectorAll('.ov-fleet-timer').forEach(function(el){
      var total = parseInt(el.getAttribute('data-fleet-time')) || 0;
      var cd = el.querySelector('.ov-fleet-countdown');
      if (!cd) return;
      if (total <= 0) { cd.textContent = '–'; return; }
      var start = Date.now();
      function tick(){
        var left = total - (Date.now() - start) / 1000;
        if (left <= 0) { cd.textContent = '–'; return; }
        cd.textContent = fmt(left);
        setTimeout(tick, 1000);
      }
      tick();
    });
  })();

  /* ── ENTRANCE ANIMATION ── */
  if(typeof gsap !== 'undefined'){
    gsap.from('.ov-card', {opacity:0, y:14, duration:0.45, stagger:0.07, ease:'power2.out', delay:0.05});
    gsap.from('.ov-news-bar', {opacity:0, y:-6, duration:0.3, ease:'power2.out'});
  }
})();
</script>
{% endblock %}
