{% extends "layout.full.twig" %}
{% block title %}{{ LNG.lm_overview }}{% endblock %}

{% block script %}
<script>
window.OVERVIEW_DATA = {
  planet_name:   {{ planetname|default('Planet')|json_encode|raw }},
  planet_image:  {{ planetimage|default('')|json_encode|raw }},
  has_moon:      {{ Moon is defined and Moon ? 'true' : 'false' }},
  planet_type:   {{ planet_type|default(1)|json_encode|raw }},
  temp_max:      {{ planet_temp_max|default(40)|json_encode|raw }},
  temp_min:      {{ planet_temp_min|default(-10)|json_encode|raw }},
  diameter:      {{ planet_diameter|default(12800)|json_encode|raw }},
  fields_used:   {{ planet_field_current|default(0)|json_encode|raw }},
  fields_max:    {{ planet_field_max|default(163)|json_encode|raw }},
  galaxy:        {{ galaxy|default(1)|json_encode|raw }},
  system:        {{ system|default(1)|json_encode|raw }},
  planet_pos:    {{ planet|default(1)|json_encode|raw }},
  ref_active:    {{ ref_active|default(false)|json_encode|raw }},
  userid:        {{ userid|default(0)|json_encode|raw }},
  path:          {{ path|default('')|json_encode|raw }}
};
</script>
<script src="scripts/game/overview.js"></script>
{% endblock %}

{% block content %}
<div class="content_page ov-page">

  {% if messages %}
  <div class="ov-alert"><i class="fas fa-envelope"></i> <a href="game.php?page=messages">{{ messages|raw }}</a></div>
  {% endif %}

  {% if is_news and newsItems is defined and newsItems|length > 0 %}
  <div class="ov-news-bar" id="ov-news-ticker-box">
    <span class="ov-news-label"><i class="fas fa-bullhorn"></i> NEWS</span>
    <div class="ov-news-slides" id="newsTickerTrack">
      {% for item in newsItems %}
      <div class="ov-news-slide{% if loop.first %} active{% endif %}">
        {% if item.title %}<strong>{{ item.title }}</strong> &mdash; {% endif %}{{ item.text|raw }}
      </div>
      {% endfor %}
    </div>
    {% if newsItems|length > 1 %}
    <div class="ov-news-nav">
      <button class="ov-news-btn" id="newsPrev">&#8592;</button>
      <span class="ov-news-count"><span id="newsIdx">1</span>/{{ newsItems|length }}</span>
      <button class="ov-news-btn" id="newsNext">&#8594;</button>
    </div>
    {% endif %}
  </div>
  {% endif %}

  {{ hook('content_top') }}

  <div class="ov-main-grid">

    <!-- ═══════════════════════════ LEFT COLUMN ═══════════════════════════ -->
    <div class="ov-col-left">

      <!-- PLANET CARD -->
      <div class="ov-card ov-planet-card">
        <div class="ov-card-header">
          <i class="fas fa-globe-americas"></i>
          <span>{{ LNG["type_planet_" ~ planet_type] }} &ldquo;{{ planetname }}&rdquo;</span>
          <a href="#" onclick="return Dialog.PlanetAction();" class="ov-icon-btn" title="{{ LNG.ov_planetmenu }}"><i class="fas fa-ellipsis-v"></i></a>
        </div>
        <div class="ov-planet-body">
          <div class="ov-planet-visual">
            <div class="ov-planet-3d-wrap">
              <canvas id="ov-planet-canvas"></canvas>
              <div class="ov-planet-glow-ring"></div>
              {% if Moon is defined and Moon %}
              <div class="ov-moon-orbit"><div class="ov-moon-dot"></div></div>
              {% endif %}
            </div>
            <div class="ov-coord-badge">
              <a href="game.php?page=galaxy&galaxy={{ galaxy }}&system={{ system }}">[{{ galaxy }}:{{ system }}:{{ planet }}]</a>
            </div>
          </div>
          <div class="ov-planet-stats">
            <div class="ov-stat-item">
              <i class="fas fa-arrows-alt-h"></i>
              <div class="ov-stat-body">
                <span class="ov-stat-val">{{ planet_diameter }} {{ LNG.ov_distance_unit }}</span>
                <span class="ov-stat-lbl">{{ LNG.ov_diameter }}</span>
              </div>
            </div>
            <div class="ov-stat-item">
              <i class="fas fa-thermometer-half"></i>
              <div class="ov-stat-body">
                <span class="ov-stat-val">{{ planet_temp_min }}° – {{ planet_temp_max }}°</span>
                <span class="ov-stat-lbl">{{ LNG.ov_temperature }}</span>
              </div>
            </div>
            <div class="ov-stat-item">
              <i class="fas fa-th-large"></i>
              <div class="ov-stat-body">
                <span class="ov-stat-val {% if planet_field_current >= planet_field_max %}ov-danger{% endif %}">{{ planet_field_current }} / {{ planet_field_max }}</span>
                <span class="ov-stat-lbl">{{ LNG.ov_fields }}</span>
              </div>
              <div class="ov-field-bar"><div class="ov-field-fill" style="width:{{ planet_field_max > 0 ? ((planet_field_current / planet_field_max) * 100)|round(1) : 0 }}%"></div></div>
            </div>
            {% if Moon is defined and Moon %}
            <div class="ov-stat-item">
              <i class="fas fa-moon" style="color:var(--gold)"></i>
              <div class="ov-stat-body">
                <a href="game.php?page=overview&cp={{ Moon.id }}&re=0" class="ov-stat-val" style="color:var(--gold)">{{ Moon.name }}</a>
                <span class="ov-stat-lbl">{{ LNG.fcm_moon }}</span>
              </div>
            </div>
            {% endif %}
          </div>
        </div>
      </div>

      <!-- BUILD QUEUE CARD -->
      {% if buildInfo.buildings or buildInfo.tech or buildInfo.fleet %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-hammer"></i> {{ LNG.ov_queue|default('Bauqueue') }}</div>
        <div class="ov-queue-list">
          {% if buildInfo.buildings %}
          <div class="ov-queue-item ov-queue-building">
            <i class="fas fa-city"></i>
            <div class="ov-queue-info">
              <span class="ov-queue-name">{{ LNG.tech[buildInfo.buildings.id]|default('Gebäude') }} <span class="ov-queue-lvl">Lv {{ buildInfo.buildings.level }}</span></span>
              <span class="ov-queue-time" data-time="{{ buildInfo.buildings.timeleft }}"><i class="fas fa-clock"></i> {{ buildInfo.buildings.starttime }}</span>
            </div>
            <div class="ov-queue-bar-wrap"><div class="ov-queue-bar" id="qbar-building"></div></div>
          </div>
          {% endif %}
          {% if buildInfo.tech %}
          <div class="ov-queue-item ov-queue-tech">
            <i class="fas fa-flask"></i>
            <div class="ov-queue-info">
              <span class="ov-queue-name">{{ LNG.tech[buildInfo.tech.id]|default('Forschung') }} <span class="ov-queue-lvl">Lv {{ buildInfo.tech.level }}</span></span>
              <span class="ov-queue-time" data-time="{{ buildInfo.tech.timeleft }}"><i class="fas fa-clock"></i> {{ buildInfo.tech.starttime }}</span>
            </div>
            <div class="ov-queue-bar-wrap"><div class="ov-queue-bar" id="qbar-tech"></div></div>
          </div>
          {% endif %}
          {% if buildInfo.fleet %}
          <div class="ov-queue-item ov-queue-fleet">
            <i class="fas fa-rocket"></i>
            <div class="ov-queue-info">
              <span class="ov-queue-name">{{ LNG.tech[buildInfo.fleet.id]|default('Schiff') }} <span class="ov-queue-lvl">x{{ buildInfo.fleet.level }}</span></span>
              <span class="ov-queue-time" data-time="{{ buildInfo.fleet.timeleft }}"><i class="fas fa-clock"></i> {{ buildInfo.fleet.starttime }}</span>
            </div>
            <div class="ov-queue-bar-wrap"><div class="ov-queue-bar" id="qbar-fleet"></div></div>
          </div>
          {% endif %}
        </div>
      </div>
      {% endif %}

      <!-- DEBRIS CARD -->
      {% if GalaxyRows is defined and GalaxyRows and (GalaxyRows.debris.metal > 0 or GalaxyRows.debris.crystal > 0) %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-recycle"></i> {{ LNG.ov_debris_field }}</div>
        <div class="ov-card-body">
          <div class="ov-debris-row">
            <span style="color:var(--dim)">{{ LNG.tech[901]|default('Metall') }}</span>
            <span style="color:var(--cyan)">{{ GalaxyRows.debris.metal|number_format }}</span>
          </div>
          <div class="ov-debris-row">
            <span style="color:var(--dim)">{{ LNG.tech[902]|default('Kristall') }}</span>
            <span style="color:var(--purple)">{{ GalaxyRows.debris.crystal|number_format }}</span>
          </div>
          <a href="game.php?page=fleetTable&galaxy={{ galaxy }}&system={{ system }}&planet={{ planet }}&planettype=1&target_mission=8" class="ov-btn ov-btn-sm" style="margin-top:10px;">
            <i class="fas fa-satellite"></i> {{ LNG.ov_harvest }}
          </a>
        </div>
      </div>
      {% endif %}

    </div>

    <!-- ═══════════════════════════ CENTER COLUMN ═══════════════════════════ -->
    <div class="ov-col-center">

      <!-- SERVER STATUS -->
      <div class="ov-card ov-server-card">
        <div class="ov-card-header"><i class="fas fa-server"></i> {{ LNG.ov_server_info|default('Server') }}</div>
        <div class="ov-server-grid">
          <div class="ov-server-stat">
            <span class="ov-server-val" style="color:var(--green)">{{ onlineUser }}</span>
            <span class="ov-server-lbl">{{ LNG.ov_online_user }}</span>
          </div>
          <div class="ov-server-stat">
            <span class="ov-server-val">
              {% if AdminsOnline %}
                {% for ID, Name in AdminsOnline %}
                  <a href="#" onclick="return Dialog.PM({{ ID }});" style="color:var(--red)">{{ Name }}</a>{% if not loop.last %}, {% endif %}
                {% endfor %}
              {% else %}<span style="color:var(--dim)">–</span>{% endif %}
            </span>
            <span class="ov-server-lbl">{{ LNG.ov_admins_online }}</span>
          </div>
          <div class="ov-server-stat">
            <span class="ov-server-val">{{ rankInfo|raw }}</span>
            <span class="ov-server-lbl">{{ LNG.ov_points }}</span>
          </div>
          <div class="ov-server-stat">
            <span class="ov-server-val">
              {% if chatOnline is defined and chatOnline|length > 0 %}
                <span style="color:var(--green)">{{ chatOnline|length }}</span>
              {% else %}<span style="color:var(--dim)">0</span>{% endif %}
            </span>
            <span class="ov-server-lbl">Chat Online</span>
          </div>
        </div>
        <div class="ov-server-actions">
          <a href="game.php?page=ticket" class="ov-btn ov-btn-sm"><i class="fas fa-headset"></i> Support</a>
          <a href="game.php?page=messages" class="ov-btn ov-btn-sm"><i class="fas fa-envelope"></i> {{ LNG.lm_messages }}</a>
          <a href="game.php?page=statistics" class="ov-btn ov-btn-sm"><i class="fas fa-chart-bar"></i> {{ LNG.lm_statistics|default('Statistik') }}</a>
        </div>
      </div>

      <!-- FLEET STATUS -->
      {% if fleets is defined and fleets %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-rocket"></i> {{ LNG.ov_fleet|default('Flotten') }}</div>
        <div class="ov-fleet-body">{{ fleets|raw }}</div>
      </div>
      {% endif %}

      <!-- REFERRAL -->
      {% if ref_active %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-share-alt"></i> {{ LNG.ov_reflink }}</div>
        <div class="ov-card-body">
          {% if isModuleAvailable(constant('MODULE_BANNER')) %}
          <img src="userpic.php?id={{ userid }}" alt="Banner" style="max-width:100%;border-radius:8px;margin-bottom:12px;box-shadow:0 4px 20px rgba(0,0,0,0.5);">
          <div class="ov-ref-code-block">
            <div class="ov-ref-label">HTML</div>
            <input type="text" value='<a href="{{ path }}index.php?ref={{ userid }}"><img src="{{ path }}userpic.php?id={{ userid }}"></a>' readonly class="ov-ref-input" onclick="this.select()">
          </div>
          <div class="ov-ref-code-block" style="margin-top:8px;">
            <div class="ov-ref-label">BBCode</div>
            <input type="text" value="[url={{ path }}index.php?ref={{ userid }}][img]{{ path }}userpic.php?id={{ userid }}[/img][/url]" readonly class="ov-ref-input" onclick="this.select()">
          </div>
          {% endif %}
          {% if RefLinks is defined and RefLinks|length > 0 %}
          <div class="ov-ref-list">
            {% for RefID, RefLink in RefLinks %}
            <div class="ov-ref-row">
              <a href="#" onclick="return Dialog.Playercard({{ RefID }}, '{{ RefLink.username }}');">{{ RefLink.username }}</a>
              <span class="ov-ref-pts {% if RefLink.points >= ref_minpoints %}ov-ref-done{% endif %}">{{ RefLink.points|number_format }} / {{ ref_minpoints|number_format }}</span>
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </div>
      {% endif %}

    </div>

    <!-- ═══════════════════════════ RIGHT COLUMN ═══════════════════════════ -->
    <div class="ov-col-right">

      <!-- OTHER PLANETS -->
      {% if AllPlanets is defined and AllPlanets|length > 0 %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-globe"></i> {{ LNG.ov_colonies|default('Kolonien') }} <span class="ov-badge">{{ AllPlanets|length }}</span></div>
        <div class="ov-planet-list">
          {% for p in AllPlanets %}
          <a href="game.php?page=overview&cp={{ p.id }}" class="ov-planet-row">
            <img src="styles/theme/{{ p.image }}.png" onerror="this.style.display='none'" class="ov-planet-thumb" alt="">
            <div class="ov-planet-row-info">
              <span class="ov-planet-row-name">{{ p.name }}</span>
              <span class="ov-planet-row-build {% if p.build == LNG.ov_free %}ov-free{% else %}ov-building{% endif %}">
                {% if p.build == LNG.ov_free %}<i class="fas fa-check-circle"></i>{% else %}<i class="fas fa-hammer"></i>{% endif %}
                {{ p.build|raw }}
              </span>
            </div>
          </a>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      <!-- TEAMSPEAK -->
      {% if teamspeakData is defined and teamspeakData and not teamspeakData.error %}
      <div class="ov-card">
        <div class="ov-card-header"><i class="fas fa-headphones"></i> TeamSpeak</div>
        <div class="ov-card-body" style="text-align:center;">
          <div style="font-size:28px;font-weight:900;color:var(--cyan)">{{ teamspeakData.current }} / {{ teamspeakData.max }}</div>
          <div style="color:var(--dim);font-size:11px;margin-bottom:12px">Online</div>
          <a href="{{ teamspeakData.url }}" class="ov-btn ov-btn-sm"><i class="fas fa-sign-in-alt"></i> Verbinden</a>
        </div>
      </div>
      {% endif %}

    </div>

  </div>
</div>

<style>
/* ── PAGE BASE ── */
.ov-page { padding-bottom:24px; }
.ov-alert { background:rgba(0,212,255,0.08); border:1px solid rgba(0,212,255,0.3); border-radius:8px; padding:10px 16px; margin-bottom:14px; font-size:13px; color:var(--cyan); }
.ov-alert a { color:var(--cyan); }

/* ── NEWS BAR ── */
.ov-news-bar { display:flex; align-items:center; gap:10px; background:rgba(0,212,255,0.05); border:1px solid rgba(0,212,255,0.18); border-radius:10px; padding:9px 14px; margin-bottom:14px; min-height:42px; }
.ov-news-label { font-family:var(--font-hud); font-size:8px; letter-spacing:2px; color:var(--cyan); white-space:nowrap; flex-shrink:0; display:flex; align-items:center; gap:5px; }
.ov-news-slides { flex:1; min-width:0; position:relative; }
.ov-news-slide { display:none; font-size:13px; color:var(--text); animation:newsIn .4s ease; }
.ov-news-slide.active { display:block; }
@keyframes newsIn { from{opacity:0;transform:translateX(6px)} to{opacity:1;transform:translateX(0)} }
.ov-news-nav { display:flex; align-items:center; gap:5px; flex-shrink:0; }
.ov-news-btn { background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.25); color:var(--cyan); border-radius:4px; width:22px; height:22px; cursor:pointer; font-size:12px; padding:0; transition:.15s; }
.ov-news-btn:hover { background:var(--cyan); color:#000; }
.ov-news-count { font-size:10px; color:var(--dim); font-family:var(--font-hud); white-space:nowrap; }

/* ── MAIN GRID ── */
.ov-main-grid { display:grid; grid-template-columns:280px 1fr 260px; gap:14px; align-items:start; }
@media(max-width:1200px){ .ov-main-grid { grid-template-columns:260px 1fr; } .ov-col-right { display:none; } }
@media(max-width:800px){ .ov-main-grid { grid-template-columns:1fr; } }

/* ── CARDS ── */
.ov-card { background:var(--panel); border:1px solid var(--border); border-radius:12px; overflow:hidden; margin-bottom:12px; }
.ov-card-header { display:flex; align-items:center; gap:8px; padding:11px 15px; font-family:var(--font-hud); font-size:10px; letter-spacing:1.5px; text-transform:uppercase; color:var(--cyan); border-bottom:1px solid var(--border); background:rgba(0,212,255,0.03); }
.ov-card-header i { font-size:13px; color:var(--cyan); opacity:.8; }
.ov-card-body { padding:14px 15px; }
.ov-icon-btn { margin-left:auto; color:var(--dim); padding:2px 6px; border-radius:4px; transition:.15s; font-size:13px; }
.ov-icon-btn:hover { color:var(--cyan); background:rgba(0,212,255,0.1); }
.ov-badge { margin-left:auto; background:rgba(0,212,255,0.15); color:var(--cyan); border-radius:10px; padding:1px 8px; font-size:10px; }

/* ── PLANET CARD ── */
.ov-planet-body { display:flex; flex-direction:column; align-items:center; gap:14px; padding:18px 15px; }
.ov-planet-visual { position:relative; display:flex; flex-direction:column; align-items:center; gap:8px; }
.ov-planet-3d-wrap { position:relative; width:180px; height:180px; }
#ov-planet-canvas { width:180px !important; height:180px !important; border-radius:50%; display:block; }
.ov-planet-glow-ring { position:absolute; inset:-6px; border-radius:50%; border:1px solid rgba(0,212,255,0.2); box-shadow:0 0 20px rgba(0,80,200,0.3),inset 0 0 20px rgba(0,80,200,0.1); animation:glowPulse 3s ease-in-out infinite; pointer-events:none; }
@keyframes glowPulse { 0%,100%{opacity:.5;transform:scale(1)} 50%{opacity:1;transform:scale(1.03)} }
.ov-moon-orbit { position:absolute; inset:-18px; border-radius:50%; border:1px dashed rgba(170,170,170,0.2); animation:moonOrbit 12s linear infinite; }
.ov-moon-dot { position:absolute; top:-4px; left:calc(50% - 4px); width:7px; height:7px; border-radius:50%; background:radial-gradient(circle at 38% 35%,#ccc,#888); box-shadow:0 0 5px rgba(255,255,255,0.2); }
@keyframes moonOrbit { to{transform:rotate(360deg)} }
.ov-coord-badge { background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.2); border-radius:20px; padding:4px 12px; font-family:var(--font-mono); font-size:12px; color:var(--cyan); }
.ov-coord-badge a { color:var(--cyan); }
.ov-planet-stats { width:100%; display:flex; flex-direction:column; gap:2px; }
.ov-stat-item { display:grid; grid-template-columns:18px 1fr; gap:8px; align-items:start; padding:7px 0; border-bottom:1px solid rgba(255,255,255,0.04); }
.ov-stat-item:last-child { border-bottom:none; }
.ov-stat-item > i { color:var(--dim); font-size:12px; margin-top:3px; }
.ov-stat-body { display:flex; flex-direction:column; }
.ov-stat-val { font-size:12px; color:var(--white); font-weight:600; }
.ov-stat-val a { color:var(--gold); }
.ov-stat-lbl { font-size:10px; color:var(--dim); }
.ov-danger { color:var(--red) !important; }
.ov-field-bar { height:3px; background:rgba(255,255,255,0.07); border-radius:2px; margin-top:4px; overflow:hidden; grid-column:1/-1; }
.ov-field-fill { height:100%; background:linear-gradient(90deg,var(--cyan),var(--purple)); border-radius:2px; }

/* ── BUILD QUEUE ── */
.ov-queue-list { padding:4px 0; }
.ov-queue-item { display:grid; grid-template-columns:32px 1fr; gap:10px; padding:10px 14px; border-bottom:1px solid rgba(255,255,255,0.04); align-items:center; }
.ov-queue-item:last-child { border-bottom:none; }
.ov-queue-item > i { font-size:16px; text-align:center; }
.ov-queue-building > i { color:var(--cyan); }
.ov-queue-tech > i { color:var(--purple); }
.ov-queue-fleet > i { color:var(--green); }
.ov-queue-info { display:flex; flex-direction:column; gap:2px; }
.ov-queue-name { font-size:12px; color:var(--white); font-weight:600; }
.ov-queue-lvl { color:var(--dim); font-weight:400; font-size:11px; }
.ov-queue-time { font-size:11px; color:var(--dim); }
.ov-queue-bar-wrap { grid-column:1/-1; height:2px; background:rgba(255,255,255,0.06); border-radius:1px; overflow:hidden; margin-top:2px; }
.ov-queue-bar { height:100%; border-radius:1px; transition:width 1s linear; width:0%; }
#qbar-building { background:var(--cyan); }
#qbar-tech { background:var(--purple); }
#qbar-fleet { background:var(--green); }

/* ── SERVER CARD ── */
.ov-server-grid { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--border); }
.ov-server-stat { background:var(--panel); padding:12px 15px; display:flex; flex-direction:column; gap:3px; }
.ov-server-val { font-size:14px; color:var(--white); font-weight:700; }
.ov-server-lbl { font-size:10px; color:var(--dim); font-family:var(--font-hud); letter-spacing:.5px; }
.ov-server-actions { display:flex; gap:8px; padding:12px 14px; flex-wrap:wrap; border-top:1px solid var(--border); }

/* ── FLEET BODY ── */
.ov-fleet-body { padding:0 4px; font-size:12px; }
.ov-fleet-body table { width:100%; }

/* ── REFERRAL ── */
.ov-ref-code-block { display:flex; flex-direction:column; gap:3px; }
.ov-ref-label { font-size:9px; color:var(--dim); font-family:var(--font-hud); letter-spacing:1px; text-transform:uppercase; }
.ov-ref-input { width:100%; background:rgba(0,0,0,0.4); border:1px solid var(--border); border-radius:5px; color:var(--dim); padding:5px 8px; font-family:var(--font-mono); font-size:10px; box-sizing:border-box; }
.ov-ref-list { margin-top:12px; border-top:1px solid var(--border); padding-top:10px; display:flex; flex-direction:column; gap:6px; }
.ov-ref-row { display:flex; justify-content:space-between; align-items:center; font-size:12px; }
.ov-ref-pts { color:var(--dim); font-family:var(--font-mono); font-size:11px; }
.ov-ref-done { color:var(--green) !important; }

/* ── PLANET LIST ── */
.ov-planet-list { padding:4px 0; }
.ov-planet-row { display:flex; align-items:center; gap:10px; padding:8px 14px; border-bottom:1px solid rgba(255,255,255,0.04); transition:.15s; text-decoration:none; }
.ov-planet-row:last-child { border-bottom:none; }
.ov-planet-row:hover { background:rgba(0,212,255,0.05); }
.ov-planet-thumb { width:32px; height:32px; border-radius:50%; object-fit:cover; flex-shrink:0; }
.ov-planet-row-info { display:flex; flex-direction:column; gap:2px; min-width:0; }
.ov-planet-row-name { font-size:12px; color:var(--white); font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.ov-planet-row-build { font-size:10px; color:var(--dim); }
.ov-planet-row-build.ov-free i { color:var(--green); }
.ov-planet-row-build.ov-building i { color:var(--gold); }

/* ── DEBRIS ── */
.ov-debris-row { display:flex; justify-content:space-between; padding:5px 0; font-size:12px; border-bottom:1px solid rgba(255,255,255,0.04); }
.ov-card .ov-debris-row:last-of-type { border-bottom:none; }

/* ── BUTTONS ── */
.ov-btn { display:inline-flex; align-items:center; gap:6px; padding:7px 14px; background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.25); border-radius:6px; color:var(--cyan); font-size:12px; font-weight:600; cursor:pointer; transition:.15s; text-decoration:none; white-space:nowrap; }
.ov-btn:hover { background:rgba(0,212,255,0.2); color:var(--cyan); }
.ov-btn-sm { padding:5px 10px; font-size:11px; }
</style>

<script>
(function(){
  var D = window.OVERVIEW_DATA || {};

  /* ── THREE.JS 3D PLANET ── */
  (function(){
    var canvas = document.getElementById('ov-planet-canvas');
    if(!canvas || typeof THREE === 'undefined') return;
    var W=180, H=180;
    var renderer = new THREE.WebGLRenderer({canvas:canvas, antialias:true, alpha:true});
    renderer.setSize(W,H); renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
    var scene = new THREE.Scene();
    var camera = new THREE.PerspectiveCamera(45,1,0.1,100);
    camera.position.z = 2.6;
    var pType = parseInt(D.planet_type)||1;
    var tMax  = parseFloat(D.temp_max)||40;
    var COLOR_MAP = {
      1:{top:'#4a7bcc',mid:'#2255aa',bot:'#0f2d6e'},
      2:{top:'#8b6914',mid:'#5c3d08',bot:'#2a1a00'},
      3:{top:'#88ffcc',mid:'#228855',bot:'#0a2a18'},
      4:{top:'#eeffff',mid:'#aaccdd',bot:'#223344'},
      5:{top:'#cc4400',mid:'#992200',bot:'#3a0a00'}
    };
    var cols = tMax>80?COLOR_MAP[5]:tMax>50?COLOR_MAP[2]:tMax<-20?COLOR_MAP[4]:(COLOR_MAP[pType]||COLOR_MAP[1]);
    function makeTex(){
      var tc=document.createElement('canvas'); tc.width=512; tc.height=256;
      var x=tc.getContext('2d');
      var g=x.createLinearGradient(0,0,0,256);
      g.addColorStop(0,cols.top); g.addColorStop(0.5,cols.mid); g.addColorStop(1,cols.bot);
      x.fillStyle=g; x.fillRect(0,0,512,256);
      x.globalAlpha=0.18;
      for(var i=0;i<28;i++){
        x.fillStyle='rgba('+(Math.random()*80+100)+','+(Math.random()*80+100)+','+(Math.random()*80+160)+',0.4)';
        x.beginPath();
        x.ellipse(Math.random()*512,Math.random()*256,Math.random()*60+10,Math.random()*40+8,Math.random()*Math.PI,0,Math.PI*2);
        x.fill();
      }
      return new THREE.CanvasTexture(tc);
    }
    var geo=new THREE.SphereGeometry(1,48,48);
    var mat=new THREE.MeshPhongMaterial({map:makeTex(),shininess:28,specular:new THREE.Color(0x224466)});
    var planet=new THREE.Mesh(geo,mat); scene.add(planet);
    var atmGeo=new THREE.SphereGeometry(1.045,32,32);
    var atmMat=new THREE.MeshPhongMaterial({color:new THREE.Color(cols.top),transparent:true,opacity:0.13,side:THREE.FrontSide});
    scene.add(new THREE.Mesh(atmGeo,atmMat));
    var cldTc=document.createElement('canvas'); cldTc.width=512; cldTc.height=256;
    var cctx=cldTc.getContext('2d');
    for(var i=0;i<80;i++){
      cctx.fillStyle='rgba(255,255,255,'+(Math.random()*0.3+0.08)+')';
      cctx.beginPath();
      cctx.ellipse(Math.random()*512,Math.random()*256,Math.random()*50+8,Math.random()*25+4,Math.random()*Math.PI,0,Math.PI*2);
      cctx.fill();
    }
    var cloudGeo=new THREE.SphereGeometry(1.02,32,32);
    var cloudMat=new THREE.MeshPhongMaterial({map:new THREE.CanvasTexture(cldTc),transparent:true,opacity:0.28,depthWrite:false});
    var clouds=new THREE.Mesh(cloudGeo,cloudMat); scene.add(clouds);
    var sun=new THREE.DirectionalLight(0xffffff,1.1); sun.position.set(5,3,5); scene.add(sun);
    scene.add(new THREE.AmbientLight(0x112244,0.6));
    var moonMesh=null;
    if(D.has_moon){
      var mGeo=new THREE.SphereGeometry(0.18,16,16);
      var mMat=new THREE.MeshPhongMaterial({color:0xaaaaaa,shininess:5});
      moonMesh=new THREE.Mesh(mGeo,mMat); scene.add(moonMesh);
    }
    var t=0;
    (function animate(){
      requestAnimationFrame(animate);
      t+=0.004; planet.rotation.y+=0.003; clouds.rotation.y+=0.004;
      if(moonMesh){ moonMesh.position.set(Math.cos(t)*1.6,Math.sin(t)*0.3,Math.sin(t)*1.6); }
      renderer.render(scene,camera);
    })();
  })();

  /* ── NEWS TICKER ── */
  (function(){
    var track = document.getElementById('newsTickerTrack');
    if (!track) return;
    var slides = track.querySelectorAll('.ov-news-slide');
    if (slides.length <= 1) return;
    var idx = 0, timer, paused = false;
    var counter = document.getElementById('newsIdx');
    function show(n) {
      slides[idx].classList.remove('active');
      idx = (n + slides.length) % slides.length;
      slides[idx].classList.add('active');
      if (counter) counter.textContent = idx + 1;
    }
    function startTimer() { timer = setInterval(function(){ show(idx+1); }, 6000); }
    function stopTimer() { clearInterval(timer); }
    startTimer();
    var box = document.getElementById('ov-news-ticker-box');
    if (box) {
      box.addEventListener('mouseenter', function(){ paused=true; stopTimer(); });
      box.addEventListener('mouseleave', function(){ paused=false; startTimer(); });
    }
    var btnN = document.getElementById('newsNext'), btnP = document.getElementById('newsPrev');
    if (btnN) btnN.addEventListener('click', function(){ stopTimer(); show(idx+1); if(!paused) startTimer(); });
    if (btnP) btnP.addEventListener('click', function(){ stopTimer(); show(idx-1); if(!paused) startTimer(); });
  })();

  /* ── BUILD QUEUE PROGRESS BARS ── */
  (function(){
    var queues = [
      { el: document.getElementById('qbar-building'), timeEl: document.querySelector('.ov-queue-building .ov-queue-time') },
      { el: document.getElementById('qbar-tech'),     timeEl: document.querySelector('.ov-queue-tech .ov-queue-time') },
      { el: document.getElementById('qbar-fleet'),    timeEl: document.querySelector('.ov-queue-fleet .ov-queue-time') }
    ];
    queues.forEach(function(q){
      if (!q.el || !q.timeEl) return;
      var total = parseInt(q.timeEl.getAttribute('data-time')) || 0;
      if (total <= 0) { q.el.style.width = '100%'; return; }
      var start = Date.now();
      var elapsed = 0;
      function tick(){
        elapsed = (Date.now() - start) / 1000;
        var pct = Math.min(100, (elapsed / total) * 100);
        q.el.style.width = pct + '%';
        var left = Math.max(0, total - elapsed);
        var h = Math.floor(left/3600), m = Math.floor((left%3600)/60), s = Math.floor(left%60);
        q.timeEl.innerHTML = '<i class="fas fa-clock"></i> ' + (h>0?h+'h ':'')+m+'m '+s+'s';
        if (pct < 100) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  })();

  /* ── ENTRANCE ANIMATION ── */
  if(typeof gsap !== 'undefined'){
    gsap.from('.ov-card', {opacity:0, y:14, duration:0.45, stagger:0.07, ease:'power2.out', delay:0.05});
    gsap.from('.ov-news-bar', {opacity:0, y:-6, duration:0.3, ease:'power2.out'});
  }
})();
</script>
{% endblock %}
