{% extends "layout.full.twig" %}
{% block title %}{{ LNG.lm_overview }}{% endblock %}

{% block script %}
<script>
window.OVERVIEW_DATA = {
  planet_name:   {{ planetname|default('Planet')|json_encode|raw }},
  planet_image:  {{ planetimage|default('')|json_encode|raw }},
  has_moon:      {{ Moon is defined and Moon ? 'true' : 'false' }},
  planet_type:   {{ planet_type|default(1)|json_encode|raw }},
  temp_max:      {{ planet_temp_max|default(40)|json_encode|raw }},
  temp_min:      {{ planet_temp_min|default(-10)|json_encode|raw }},
  diameter:      {{ planet_diameter|default(12800)|json_encode|raw }},
  fields_used:   {{ planet_field_current|default(0)|json_encode|raw }},
  fields_max:    {{ planet_field_max|default(163)|json_encode|raw }},
  galaxy:        {{ galaxy|default(1)|json_encode|raw }},
  system:        {{ system|default(1)|json_encode|raw }},
  planet_pos:    {{ planet|default(1)|json_encode|raw }},
  ref_active:    {{ ref_active|default(false)|json_encode|raw }},
  userid:        {{ userid|default(0)|json_encode|raw }},
  path:          {{ path|default('')|json_encode|raw }}
};
</script>
<script src="scripts/game/overview.js"></script>
{% endblock %}

{% block content %}
<div class="content_page">
<div class="ov-grid">

  <!-- LEFT: 3D PLANET CARD -->
  <div class="ov-col-left">

    <div class="glass-panel ov-planet-card">
      <div class="panel-header">
        <i class="fas fa-globe-americas"></i>
        <span>{{ LNG["type_planet_" ~ planet_type] }} &ldquo;{{ planetname }}&rdquo;</span>
        <a href="#" onclick="return Dialog.PlanetAction();" class="ov-rename-btn" title="{{ LNG.ov_planetmenu }}"><i class="fas fa-pen"></i></a>
      </div>
      <div class="ov-planet-body">
        <div class="ov-planet-3d-wrap">
          <canvas id="ov-planet-canvas"></canvas>
          <div class="ov-planet-glow-ring"></div>
          {% if Moon is defined and Moon %}
          <div class="ov-moon-orbit"><div class="ov-moon-dot"></div></div>
          {% endif %}
        </div>
        <div class="ov-planet-stats">
          <div class="ov-coord">
            <i class="fas fa-map-marker-alt"></i>
            <a href="game.php?page=galaxy&galaxy={{ galaxy }}&system={{ system }}">[{{ galaxy }}:{{ system }}:{{ planet }}]</a>
          </div>
          <div class="ov-stat-row">
            <i class="fas fa-arrows-alt-h"></i>
            <span class="ov-stat-val">{{ planet_diameter }} {{ LNG.ov_distance_unit }}</span>
            <span class="ov-stat-lbl">{{ LNG.ov_diameter }}</span>
          </div>
          <div class="ov-stat-row">
            <i class="fas fa-th-large"></i>
            <span class="ov-stat-val {% if planet_field_current >= planet_field_max %}text-danger{% endif %}">{{ planet_field_current }}/{{ planet_field_max }}</span>
            <span class="ov-stat-lbl">{{ LNG.ov_fields }}</span>
          </div>
          <div class="ov-stat-row">
            <i class="fas fa-thermometer-half"></i>
            <span class="ov-stat-val">{{ planet_temp_min }}{{ LNG.ov_temp_unit }} – {{ planet_temp_max }}{{ LNG.ov_temp_unit }}</span>
            <span class="ov-stat-lbl">{{ LNG.ov_temperature }}</span>
          </div>
          {% if Moon is defined and Moon %}
          <div class="ov-stat-row">
            <i class="fas fa-moon"></i>
            <a href="game.php?page=overview&cp={{ Moon.id }}&re=0" class="ov-stat-val" style="color:var(--gold);">{{ Moon.name }}</a>
            <span class="ov-stat-lbl">{{ LNG.fcm_moon }}</span>
          </div>
          {% endif %}
          <div class="ov-fields-bar-wrap">
            <div class="ov-fields-bar">
              <div class="ov-fields-fill" id="ov-fields-fill-bar" style="width:{{ planet_field_max > 0 ? ((planet_field_current / planet_field_max) * 100)|round : 0 }}%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Server Info Card -->
    <div class="glass-panel ov-info-card">
      <div class="panel-header"><i class="fas fa-server"></i> {{ LNG.ov_server_info|default('Server') }}</div>
      <div class="ov-info-body">
        <div class="data-row">
          <span class="data-label"><i class="fas fa-user"></i> {{ LNG.ov_online_user }}</span>
          <span class="data-value" style="color:var(--green);font-weight:bold;">{{ onlineUser|number_format }}</span>
        </div>
        <div class="data-row">
          <span class="data-label"><i class="fas fa-users-cog"></i> {{ LNG.ov_admins_online }}</span>
          <span class="data-value">
            {% if AdminsOnline %}
              {% for ID, Name in AdminsOnline %}
                <a href="#" onclick="return Dialog.PM({{ ID }});" style="color:var(--red);font-weight:bold;">{{ Name }}</a>{% if not loop.last %}, {% endif %}
              {% endfor %}
            {% else %}
              <span style="color:var(--dim);">{{ LNG.ov_no_admins_online }}</span>
            {% endif %}
          </span>
        </div>
        <div class="data-row">
          <span class="data-label"><i class="fas fa-headset"></i> Support</span>
          <span class="data-value"><a href="game.php?page=ticket">{{ LNG.ov_ticket }}</a></span>
        </div>
        <div class="data-row">
          <span class="data-label"><i class="fas fa-chart-line"></i> {{ LNG.ov_points }}</span>
          <span class="data-value">{{ rankInfo|raw }}</span>
        </div>
      </div>
    </div>

    {% if GalaxyRows and (GalaxyRows.debris.metal > 0 or GalaxyRows.debris.crystal > 0) %}
    <div class="glass-panel ov-debris-card">
      <div class="panel-header"><i class="fas fa-recycle"></i> {{ LNG.ov_debris_field }}</div>
      <div class="ov-info-body">
        <div class="data-row">
          <span class="data-label">{{ LNG.tech[901]|default('Metal') }}</span>
          <span class="data-value">{{ GalaxyRows.debris.metal|number_format }}</span>
        </div>
        <div class="data-row">
          <span class="data-label">{{ LNG.tech[902]|default('Crystal') }}</span>
          <span class="data-value">{{ GalaxyRows.debris.crystal|number_format }}</span>
        </div>
        <div style="padding:8px 16px;">
          <a href="game.php?page=fleetTable&galaxy={{ galaxy }}&system={{ system }}&planet={{ planet }}&planettype=1&target_mission=8" class="btn" style="width:100%;justify-content:center;">
            <i class="fas fa-satellite"></i> {{ LNG.ov_harvest }}
          </a>
        </div>
      </div>
    </div>
    {% endif %}

  </div>

  <!-- RIGHT: NEWS + CONTENT -->
  <div class="ov-col-right">

    {% if is_news and newsItems is defined and newsItems|length > 0 %}
    <div class="glass-panel ov-news-ticker" id="ov-news-ticker-box">
      <div class="news-label"><i class="fas fa-bullhorn"></i> {{ LNG.ov_news }}</div>
      <div class="news-ticker-wrap">
        <div class="news-ticker-track" id="newsTickerTrack">
          {% for item in newsItems %}
          <div class="news-ticker-slide">
            {% if item.title %}<span class="news-ticker-title">{{ item.title }}</span> — {% endif %}
            <span class="news-ticker-text">{{ item.text|raw }}</span>
          </div>
          {% endfor %}
        </div>
        {% if newsItems|length > 1 %}
        <div class="news-ticker-nav">
          <button class="news-nav-btn" id="newsPrev" title="Zurück">&#8592;</button>
          <span class="news-ticker-counter"><span id="newsIdx">1</span> / {{ newsItems|length }}</span>
          <button class="news-nav-btn" id="newsNext" title="Weiter">&#8594;</button>
        </div>
        {% endif %}
      </div>
    </div>
    <script>
    (function(){
      var track = document.getElementById('newsTickerTrack');
      if (!track) return;
      var slides = track.querySelectorAll('.news-ticker-slide');
      if (slides.length <= 1) return;
      var idx = 0, timer, paused = false;
      var counter = document.getElementById('newsIdx');
      function show(n) {
        slides[idx].classList.remove('active');
        idx = (n + slides.length) % slides.length;
        slides[idx].classList.add('active');
        if (counter) counter.textContent = idx + 1;
      }
      slides[0].classList.add('active');
      function next() { show(idx + 1); }
      function prev() { show(idx - 1); }
      function startTimer() { timer = setInterval(next, 6000); }
      function stopTimer() { clearInterval(timer); }
      startTimer();
      var box = document.getElementById('ov-news-ticker-box');
      if (box) {
        box.addEventListener('mouseenter', function(){ paused=true; stopTimer(); });
        box.addEventListener('mouseleave', function(){ paused=false; startTimer(); });
      }
      var btnNext = document.getElementById('newsNext');
      var btnPrev = document.getElementById('newsPrev');
      if (btnNext) btnNext.addEventListener('click', function(){ stopTimer(); next(); if(!paused) startTimer(); });
      if (btnPrev) btnPrev.addEventListener('click', function(){ stopTimer(); prev(); if(!paused) startTimer(); });
    })();
    </script>
    {% endif %}

    <!-- Plugin Banners -->
    {{ hook('content_top') }}

    <!-- Referral Banner -->
    {% if ref_active %}
    <div class="glass-panel ov-referral-card">
      <div class="panel-header"><i class="fas fa-share-alt"></i> {{ LNG.ov_reflink }}</div>
      <div class="ov-referral-body">
        {% if isModuleAvailable(constant('MODULE_BANNER')) %}
        <div class="ov-banner-preview">
          <img src="userpic.php?id={{ userid }}" alt="User Banner" style="max-width:100%;border-radius:8px;box-shadow:var(--shadow-md);">
        </div>
        <div class="ov-banner-codes">
          <div class="banner-label">HTML:</div>
          <input type="text" value='<a href="{{ path }}index.php?ref={{ userid }}"><img src="{{ path }}userpic.php?id={{ userid }}"></a>' readonly class="glass-input banner-input" onclick="this.select()">
          <div class="banner-label" style="margin-top:8px;">BBCode:</div>
          <input type="text" value="[url={{ path }}index.php?ref={{ userid }}][img]{{ path }}userpic.php?id={{ userid }}[/img][/url]" readonly class="glass-input banner-input" onclick="this.select()">
        </div>
        {% endif %}
        {% if RefLinks is defined %}
        <table style="width:100%;margin-top:12px;border-top:1px solid var(--border);padding-top:8px;">
          {% for RefID, RefLink in RefLinks %}
          <tr>
            <td style="padding:5px 0;"><a href="#" onclick="return Dialog.Playercard({{ RefID }}, '{{ RefLink.username }}');">{{ RefLink.username }}</a></td>
            <td style="text-align:right;padding:5px 0;color:var(--green);">{{ RefLink.points|number }} / {{ ref_minpoints|number }}</td>
          </tr>
          {% else %}
          <tr><td colspan="2" style="color:var(--dim);padding:10px 0;">{{ LNG.ov_noreflink }}</td></tr>
          {% endfor %}
        </table>
        {% endif %}
      </div>
    </div>
    {% endif %}

  </div>
</div>
</div>

<style>
.ov-grid { display:grid; grid-template-columns:320px 1fr; gap:16px; align-items:start; }
@media(max-width:900px){ .ov-grid { grid-template-columns:1fr; } }

.ov-planet-body { padding:20px; display:flex; flex-direction:column; gap:16px; align-items:center; }
.ov-planet-3d-wrap { position:relative; width:200px; height:200px; flex-shrink:0; }
#ov-planet-canvas { width:200px !important; height:200px !important; border-radius:50%; display:block; }
.ov-planet-glow-ring { position:absolute; inset:-8px; border-radius:50%; border:1px solid rgba(0,212,255,0.2); box-shadow:0 0 24px rgba(0,80,200,0.3),inset 0 0 24px rgba(0,80,200,0.1); animation:glowPulse 3s ease-in-out infinite; pointer-events:none; }
@keyframes glowPulse { 0%,100%{opacity:.5;transform:scale(1)} 50%{opacity:1;transform:scale(1.02)} }
.ov-moon-orbit { position:absolute; inset:-20px; border-radius:50%; border:1px dashed rgba(170,170,170,0.2); animation:moonOrbit 12s linear infinite; }
.ov-moon-dot { position:absolute; top:-4px; left:calc(50% - 4px); width:8px; height:8px; border-radius:50%; background:radial-gradient(circle at 38% 35%,#ccc 0%,#888 60%); box-shadow:0 0 6px rgba(255,255,255,0.2); }
@keyframes moonOrbit { to { transform:rotate(360deg); } }

.ov-planet-stats { width:100%; }
.ov-coord { display:flex; align-items:center; gap:6px; font-family:var(--font-mono); font-size:13px; color:var(--cyan); margin-bottom:12px; }
.ov-coord i { color:var(--dim); }
.ov-stat-row { display:flex; align-items:center; gap:8px; padding:5px 0; border-bottom:1px solid rgba(255,255,255,0.035); font-size:12px; }
.ov-stat-row:last-of-type { border-bottom:none; }
.ov-stat-row i { width:15px; text-align:center; color:var(--dim); font-size:12px; }
.ov-stat-val { color:var(--white); flex:1; }
.ov-stat-lbl { color:var(--dim); font-size:10px; }
.ov-rename-btn { margin-left:auto; color:var(--dim) !important; font-size:11px; padding:2px 6px; border-radius:5px; transition:var(--transition); }
.ov-rename-btn:hover { color:var(--cyan) !important; background:rgba(0,212,255,0.1); }
.ov-fields-bar-wrap { margin-top:8px; }
.ov-fields-bar { height:4px; background:rgba(255,255,255,0.06); border-radius:2px; overflow:hidden; }
.ov-fields-fill { height:100%; background:linear-gradient(90deg,var(--cyan),var(--purple)); border-radius:2px; transition:width 0.6s ease; }

.ov-info-body { padding:0; }
.ov-info-body .data-row { padding:8px 16px; }

.ov-news-ticker { display:flex; align-items:center; gap:12px; padding:12px 16px; border-radius:12px !important; margin-bottom:12px; flex-wrap:wrap; }
.ov-news-ticker .news-label { font-family:var(--font-hud); font-size:9px; letter-spacing:2px; color:var(--cyan); white-space:nowrap; display:flex; align-items:center; gap:6px; flex-shrink:0; }
.news-ticker-wrap { flex:1; min-width:0; display:flex; align-items:center; gap:10px; }
.news-ticker-track { flex:1; min-width:0; position:relative; min-height:2.4em; }
.news-ticker-slide { display:none; font-size:13px; color:var(--text); line-height:1.5; animation:tickerFadeIn 0.5s ease; }
.news-ticker-slide.active { display:block; }
@keyframes tickerFadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }
.news-ticker-title { color:var(--cyan); font-weight:700; }
.news-ticker-nav { display:flex; align-items:center; gap:6px; flex-shrink:0; }
.news-nav-btn { background:rgba(0,212,255,0.08); border:1px solid rgba(0,212,255,0.25); color:var(--cyan); border-radius:5px; width:24px; height:24px; cursor:pointer; font-size:14px; line-height:1; transition:0.2s; padding:0; }
.news-nav-btn:hover { background:rgba(0,212,255,0.2); }
.news-ticker-counter { font-size:10px; color:var(--dim); font-family:var(--font-hud); white-space:nowrap; }

.ov-referral-body { padding:16px; }
.ov-banner-preview { margin-bottom:12px; }
.ov-banner-codes { display:flex; flex-direction:column; gap:4px; }
.banner-label { font-size:10px; color:var(--dim); font-family:var(--font-hud); letter-spacing:1px; }
.banner-input { width:100%; font-family:var(--font-mono) !important; font-size:11px !important; }
</style>

<script>
(function(){
  var D = window.OVERVIEW_DATA || {};

  /* ── THREE.JS 3D PLANET ── */
  (function(){
    var canvas = document.getElementById('ov-planet-canvas');
    if(!canvas || typeof THREE === 'undefined') return;
    var W=200, H=200;
    var renderer = new THREE.WebGLRenderer({canvas:canvas, antialias:true, alpha:true});
    renderer.setSize(W,H); renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
    var scene = new THREE.Scene();
    var camera = new THREE.PerspectiveCamera(45,1,0.1,100);
    camera.position.z = 2.6;
    var pType = parseInt(D.planet_type)||1;
    var tMax  = parseFloat(D.temp_max)||40;
    var COLOR_MAP = {
      1:{top:'#4a7bcc',mid:'#2255aa',bot:'#0f2d6e'},
      2:{top:'#8b6914',mid:'#5c3d08',bot:'#2a1a00'},
      3:{top:'#88ffcc',mid:'#228855',bot:'#0a2a18'},
      4:{top:'#eeffff',mid:'#aaccdd',bot:'#223344'},
      5:{top:'#cc4400',mid:'#992200',bot:'#3a0a00'}
    };
    var cols = tMax>80?COLOR_MAP[5]:tMax>50?COLOR_MAP[2]:tMax<-20?COLOR_MAP[4]:(COLOR_MAP[pType]||COLOR_MAP[1]);
    function makeTex(){
      var tc=document.createElement('canvas'); tc.width=512; tc.height=256;
      var x=tc.getContext('2d');
      var g=x.createLinearGradient(0,0,0,256);
      g.addColorStop(0,cols.top); g.addColorStop(0.5,cols.mid); g.addColorStop(1,cols.bot);
      x.fillStyle=g; x.fillRect(0,0,512,256);
      x.globalAlpha=0.18;
      for(var i=0;i<28;i++){
        x.fillStyle='rgba('+(Math.random()*80+100)+','+(Math.random()*80+100)+','+(Math.random()*80+160)+',0.4)';
        x.beginPath();
        x.ellipse(Math.random()*512,Math.random()*256,Math.random()*60+10,Math.random()*40+8,Math.random()*Math.PI,0,Math.PI*2);
        x.fill();
      }
      return new THREE.CanvasTexture(tc);
    }
    var geo=new THREE.SphereGeometry(1,48,48);
    var mat=new THREE.MeshPhongMaterial({map:makeTex(),shininess:28,specular:new THREE.Color(0x224466)});
    var planet=new THREE.Mesh(geo,mat); scene.add(planet);
    var atmGeo=new THREE.SphereGeometry(1.045,32,32);
    var atmMat=new THREE.MeshPhongMaterial({color:new THREE.Color(cols.top),transparent:true,opacity:0.13,side:THREE.FrontSide});
    scene.add(new THREE.Mesh(atmGeo,atmMat));
    var cldTc=document.createElement('canvas'); cldTc.width=512; cldTc.height=256;
    var cctx=cldTc.getContext('2d');
    for(var i=0;i<80;i++){
      cctx.fillStyle='rgba(255,255,255,'+(Math.random()*0.3+0.08)+')';
      cctx.beginPath();
      cctx.ellipse(Math.random()*512,Math.random()*256,Math.random()*50+8,Math.random()*25+4,Math.random()*Math.PI,0,Math.PI*2);
      cctx.fill();
    }
    var cloudGeo=new THREE.SphereGeometry(1.02,32,32);
    var cloudMat=new THREE.MeshPhongMaterial({map:new THREE.CanvasTexture(cldTc),transparent:true,opacity:0.28,depthWrite:false});
    var clouds=new THREE.Mesh(cloudGeo,cloudMat); scene.add(clouds);
    var sun=new THREE.DirectionalLight(0xffffff,1.1); sun.position.set(5,3,5); scene.add(sun);
    scene.add(new THREE.AmbientLight(0x112244,0.6));
    var moonMesh=null;
    if(D.has_moon){
      var mGeo=new THREE.SphereGeometry(0.18,16,16);
      var mMat=new THREE.MeshPhongMaterial({color:0xaaaaaa,shininess:5});
      moonMesh=new THREE.Mesh(mGeo,mMat); scene.add(moonMesh);
    }
    var t=0;
    (function animate(){
      requestAnimationFrame(animate);
      t+=0.004; planet.rotation.y+=0.003; clouds.rotation.y+=0.004;
      if(moonMesh){ moonMesh.position.set(Math.cos(t)*1.6,Math.sin(t)*0.3,Math.sin(t)*1.6); }
      renderer.render(scene,camera);
    })();
  })();

  /* ── GSAP Entrance Animation ── */
  if(typeof gsap !== 'undefined'){
    gsap.from('.ov-grid > *', {opacity:0, y:18, duration:0.5, stagger:0.1, ease:'power2.out', delay:0.1});
  }
})();
</script>
{% endblock %}
