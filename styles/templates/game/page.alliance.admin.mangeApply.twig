{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_alliance }}{% endblock %}
{% block content %}

<div class="aerospace-container">
    <div class="content-box header-panel">
        <h2 class="page-title"><i class="fas fa-file-signature"></i> {{ LNG.al_request_list }}</h2>
        <a href="game.php?page=alliance&amp;mode=admin" class="btn-ghost small">{{ LNG.al_back }}</a>
    </div>

    <div class="content-box table-panel">
        <table class="glass-table full-width">
            <thead>
                <tr>
                    <th>{{ LNG.al_candidate }}</th>
                    <th>{{ LNG.al_request_date }}</th>
                    <th>{{ LNG.al_actions }}</th>
                </tr>
            </thead>
            <tbody>
                {% for applyRow in applyList %}
                <tr>
                    <td>
                        <a href="game.php?page=alliance&amp;mode=admin&amp;action=detailApply&amp;id={{ applyRow.id }}" class="text-highlight">
                            {{ applyRow.username }}
                        </a>
                    </td>
                    <td>{{ applyRow.time }}</td>
                    <td>
                        <a href="game.php?page=alliance&amp;mode=admin&amp;action=detailApply&amp;id={{ applyRow.id }}" class="btn-action-glow small">
                            {{ LNG.al_request_from_user }}
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="3" class="text-center text-muted p-3">{{ LNG.al_no_requests }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}