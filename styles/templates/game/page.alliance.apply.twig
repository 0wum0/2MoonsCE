{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_alliance }}{% endblock %}
{% block content %}

<div class="aerospace-container">
    <div class="glass-panel center-panel">
        
        <div class="panel-header">
            <i class="fas fa-file-signature"></i> {{ al_write_request }}
        </div>

        <form action="game.php?page=alliance&amp;mode=apply&amp;id={{ allyid }}" method="post">
            <div class="form-group">
                <label for="apply-message" class="form-label">{{ LNG.al_message }}</label>
                <div class="bbcode-editor-wrap">
                    <div data-bbcode-toolbar="apply-message"></div>
                    <textarea name="text" id="apply-message" class="glass-textarea" rows="15">{{ applytext }}</textarea>
                </div>
            </div>

            <div class="action-bar-bottom">
                <a href="game.php?page=alliance&amp;mode=search" class="btn-ghost">{{ LNG.al_back }}</a>
                <button type="submit" class="btn-action-glow">
                    <i class="fas fa-paper-plane"></i> {{ LNG.al_applyform_send }}
                </button>
            </div>
        </form>

    </div>
</div>
{% endblock %}
{% block script %}
<script src="scripts/game/bbcodeToolbar.js"></script>
{% endblock %}
