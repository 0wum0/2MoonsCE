{% extends "layout.ajax.twig" %}
{% block content %}

<div class="mcc-feed">

{% if MessageList is not empty %}

    {# ── BULK BAR ── #}
    {% if MessID != 999 %}
    <div class="mcc-bulk-bar">
        <input type="checkbox" class="mcc-bulk-check" id="mcc-all"
               onchange="document.querySelectorAll('.mcc-row-check').forEach(function(c){c.checked=this.checked;},this)">
        <label for="mcc-all" class="mcc-bulk-label">Alle</label>
        <button class="mcc-bulk-del" onclick="mccDeleteChecked({{ MessID }}, {{ page }})">
            <svg viewBox="0 0 16 16" fill="currentColor" width="10" height="10"><path d="M6 2a1 1 0 00-1 1H2v1h12V3h-3a1 1 0 00-1-1H6zM3 5l1 9h8l1-9H3z"/></svg>
            Markierte löschen
        </button>
        <span class="mcc-bulk-count">{{ MessageList|length }} Nachrichten</span>
    </div>
    {% endif %}

    {# ── CARDS ── #}
    {% for Msg in MessageList %}
    {% set initial = Msg.from|striptags|slice(0,1)|upper %}
    {% set isSystem = Msg.sender is not defined or Msg.sender <= 0 %}
    {% set isAttack = MessID == 2 %}
    <div class="mcc-card {% if Msg.unread %}is-unread{% endif %} msg-item" id="mcc-card-{{ Msg.id }}">

        <div class="mcc-card-head" onclick="mccToggle({{ Msg.id }})">
            {% if MessID != 999 %}
            <input type="checkbox" class="mcc-row-check" value="{{ Msg.id }}" onclick="event.stopPropagation()">
            {% endif %}

            <div class="mcc-avatar {% if isSystem %}system{% elseif isAttack %}attack{% else %}player{% endif %}">
                {% if isSystem %}
                    <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm.75 10.5h-1.5v-5h1.5v5zm0-6.5h-1.5V3.5h1.5V5z"/></svg>
                {% elseif isAttack %}
                    <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13"><path d="M9.5 2.672a.5.5 0 001 0V.843a.5.5 0 00-.859-.349L7.14 3a.5.5 0 00.859.349l1.5-1.5v.823zM6 3a.5.5 0 000 1h1.5v1.5A3.5 3.5 0 014 9H2.5a.5.5 0 000 1H4a4.5 4.5 0 004.5-4.5V4h1.5a.5.5 0 000-1H6zm4 3.5a.5.5 0 01.5.5v5.5a.5.5 0 01-1 0V7a.5.5 0 01.5-.5z"/></svg>
                {% else %}
                    {{ initial }}
                {% endif %}
            </div>

            <div class="mcc-card-meta">
                <div class="mcc-card-subject">{{ Msg.subject|striptags|e }}</div>
                <div class="mcc-card-from-row">
                    {% if Msg.unread %}<span class="mcc-unread-pip"></span>{% endif %}
                    <span class="mcc-card-from">{{ Msg.from|striptags|e }}</span>
                    <span class="mcc-card-time">{{ Msg.time }}</span>
                </div>
            </div>

            <div class="mcc-card-right">
                <svg class="mcc-chevron" viewBox="0 0 16 16" fill="currentColor" width="11" height="11"><path d="M1.646 4.646a.5.5 0 01.708 0L8 10.293l5.646-5.647a.5.5 0 01.708.708l-6 6a.5.5 0 01-.708 0l-6-6a.5.5 0 010-.708z"/></svg>
            </div>
        </div>

        <div class="mcc-card-body">
            <div class="mcc-card-text">{{ Msg.text|raw }}</div>
            <div class="mcc-card-actions">
                {% if MessID != 999 and Msg.sender is defined and Msg.sender > 0 %}
                <button class="mcc-act reply"
                        onclick="Dialog.PM({{ Msg.sender }}, 'RE: {{ Msg.subject|striptags|e('js') }}')">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11"><path d="M7.5 2L2 7l5.5 5V9.5C10.5 9.5 13.5 11.5 13.5 14.5c0-5.5-3-7-6-7V2z"/></svg>
                    Antworten
                </button>
                {% endif %}
                <button class="mcc-act delete"
                        onclick="Message.deleteMessage({{ Msg.id }}, {{ MessID }}, {{ page }})">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11"><path d="M6 2a1 1 0 00-1 1H2v1h12V3h-3a1 1 0 00-1-1H6zM3 5l1 9h8l1-9H3z"/></svg>
                    Löschen
                </button>
            </div>
        </div>

    </div>
    {% endfor %}

{% else %}
    <div class="mcc-empty">
        <div class="mcc-empty-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
        </div>
        <div class="mcc-empty-title">Keine Nachrichten</div>
        <div class="mcc-empty-sub">// MAILBOX_EMPTY</div>
    </div>
{% endif %}

</div>

{% if maxPage > 1 %}
<div class="mcc-pager">
    {% if page > 1 %}
    <a href="#" class="mcc-pager-btn" onclick="Message.getMessages({{ MessID }}, {{ page - 1 }}); return false;">
        <svg viewBox="0 0 16 16" fill="currentColor" width="10" height="10"><path d="M11.354 1.646a.5.5 0 010 .708L5.707 8l5.647 5.646a.5.5 0 01-.708.708l-6-6a.5.5 0 010-.708l6-6a.5.5 0 01.708 0z"/></svg>
    </a>
    {% endif %}
    {% for site in range([1, page - 2]|max, [maxPage, page + 2]|min) %}
    <a href="#" class="mcc-pager-btn {% if site == page %}active{% endif %}"
       onclick="Message.getMessages({{ MessID }}, {{ site }}); return false;">{{ site }}</a>
    {% endfor %}
    {% if page < maxPage %}
    <a href="#" class="mcc-pager-btn" onclick="Message.getMessages({{ MessID }}, {{ page + 1 }}); return false;">
        <svg viewBox="0 0 16 16" fill="currentColor" width="10" height="10"><path d="M4.646 1.646a.5.5 0 000 .708L10.293 8 4.646 13.646a.5.5 0 00.708.708l6-6a.5.5 0 000-.708l-6-6a.5.5 0 00-.708 0z"/></svg>
    </a>
    {% endif %}
</div>
{% endif %}

<script>
function mccToggle(id) {
    var card = document.getElementById('mcc-card-' + id);
    if (!card) return;
    card.classList.toggle('is-open');
}
function mccDeleteChecked(messCat, pg) {
    var ids = [];
    document.querySelectorAll('.mcc-row-check:checked').forEach(function(c){ ids.push(c.value); });
    if (!ids.length) return;
    if (!confirm('Markierte Nachrichten löschen?')) return;
    if (typeof SmAjax !== 'undefined') {
        var payload = {};
        ids.forEach(function(id, i){ payload['messageID[' + i + ']'] = id; });
        SmAjax.post('game.php?page=messages&mode=delete', payload, { noRefresh: true })
            .done(function(){ Message.getMessages(messCat, pg); });
    }
}
</script>
{% endblock %}