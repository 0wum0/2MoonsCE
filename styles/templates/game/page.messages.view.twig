{% extends "layout.ajax.twig" %}
{% block content %}
<style>
    .galactic-msg-card { background: rgba(22, 27, 34, 0.8); border: 1px solid rgba(56, 189, 248, 0.15); border-radius: 12px; margin-bottom: 12px; overflow: hidden; transition: 0.3s; }
    .galactic-msg-card.is-unread { border-left: 4px solid #38bdf8; background: rgba(56, 189, 248, 0.04); }
    .msg-head { padding: 15px 20px; cursor: pointer; display: flex; align-items: center; gap: 15px; }
    .msg-meta-wrap { flex-grow: 1; min-width: 0; }
    .msg-info-top { display: flex; justify-content: space-between; margin-bottom: 4px; font-size: 11px; color: #8b949e; }
    .msg-subject-line { font-weight: 700; color: #fff; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .msg-content-panel { padding: 20px; background: rgba(0,0,0,0.35); border-top: 1px solid rgba(255,255,255,0.05); color: #d1d5db; line-height: 1.7; font-size: 14px; }
</style>

<form action="game.php?page=messages" method="post" id="msg-form">
    <input type="hidden" name="mode" value="action">
    <input type="hidden" name="messcat" value="{{ MessID }}">

    <div class="msg-feed-galactic">
        {% for Message in MessageList %}
        <div class="galactic-msg-card {% if Message.unread %}is-unread{% endif %}">
            <details>
                <summary class="msg-head" onclick="event.stopPropagation();">
                    {% if MessID != 999 %}
                    <input type="checkbox" name="messageID[{{ Message.id }}]" value="{{ Message.id }}">
                    {% endif %}
                    <div class="msg-meta-wrap">
                        <div class="msg-info-top">
                            <span>👤 {{ Message.from }}</span>
                            <span>📅 {{ Message.time }}</span>
                        </div>
                        {# Betreff mit raw ausgeben falls HTML enthalten #}
                        <div class="msg-subject-line">{{ Message.subject|raw }}</div>
                    </div>
                </summary>
                
                <div class="msg-content-panel">
                    {# WICHTIG: text|raw sorgt dafür, dass HTML gerendert wird! #}
                    {{ Message.text|raw }}
                </div>
                
                <div style="display: flex; justify-content: flex-end; gap: 10px; padding: 10px 20px; background: rgba(0,0,0,0.2);">
                    {% if MessID != 999 and Message.sender != -1 %}
                    <button type="button" class="btn-galactic-sm" onclick="Dialog.PM({{ Message.sender }}, 'RE: {{ Message.subject|striptags|e('js') }}');">Antworten</button>
                    {% endif %}
                    <button type="button" class="btn-galactic-sm" onclick="Message.deleteMessage({{ Message.id }}, {{ MessID }}, {{ page }});" style="color: #f87171;">Löschen</button>
                </div>
            </details>
        </div>
        {% else %}
        <div style="padding: 60px; text-align: center; color: #8b949e;">Keine Nachrichten vorhanden.</div>
        {% endfor %}
    </div>

    {% if maxPage > 1 %}
    <div style="display: flex; justify-content: center; gap: 6px; margin-top: 25px;">
        {% for site in range(1, maxPage) %}
        <a href="#" onclick="Message.getMessages({{ MessID }}, {{ site }}); return false;" class="g-page-link {% if site == page %}active{% endif %}">
            {{ site }}
        </a>
        {% endfor %}
    </div>
    {% endif %}
</form>
{% endblock %}