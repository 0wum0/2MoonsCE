<script>
(function(){
    /* Dynamischer Progressbar-Farbverlauf (0-30% rot, 30-70% gelb, 70-100% grün) */
    function resBarGradient(pct) {
        function lc(a, b, t) {
            function p(h){ return [parseInt(h.slice(1,3),16),parseInt(h.slice(3,5),16),parseInt(h.slice(5,7),16)]; }
            function h(n){ return ('0'+Math.round(n).toString(16)).slice(-2); }
            var A=p(a),B=p(b);
            return '#'+h(A[0]+(B[0]-A[0])*t)+h(A[1]+(B[1]-A[1])*t)+h(A[2]+(B[2]-A[2])*t);
        }
        if (pct <= 30) {
            var m = pct / 30;
            return 'linear-gradient(90deg,#ef4444,'+lc('#ef4444','#f97316',m)+')';
        } else if (pct <= 70) {
            var m = (pct - 30) / 40;
            return 'linear-gradient(90deg,'+lc('#f97316','#eab308',m)+','+lc('#eab308','#84cc16',m)+')';
        } else {
            var m = (pct - 70) / 30;
            return 'linear-gradient(90deg,'+lc('#84cc16','#22d3ee',m)+','+lc('#22d3ee','#3b82f6',m)+')';
        }
    }

    /* Smooth Einfahren via rAF */
    function animateBar(fill, target) {
        var cur = parseFloat(fill.style.width) || 0;
        var diff = target - cur;
        if (Math.abs(diff) < 0.15) { fill.style.width = target.toFixed(2)+'%'; return; }
        fill.style.width = (cur + diff * 0.15).toFixed(2) + '%';
        requestAnimationFrame(function(){ animateBar(fill, target); });
    }

    function applyResourceBars(animate){
        var nodes = document.querySelectorAll('.res-item[data-res-current]');
        nodes.forEach(function(node){
            var current    = Number(node.getAttribute('data-res-current') || 0);
            var max        = Number(node.getAttribute('data-res-max') || 0);
            var production = Number(node.getAttribute('data-res-production') || 0);
            var name       = node.getAttribute('data-res-name') || '';
            var fill       = name ? document.getElementById('resbar_' + name) : null;
            var trend      = name ? document.getElementById('restrend_' + name) : null;
            if (!fill) return;

            var pct = max > 0 ? Math.max(0, Math.min(100, (current / max) * 100)) : 0;
            var visiblePct = pct > 0 ? Math.max(3, pct) : 0;

            /* Farbe */
            fill.style.background = resBarGradient(pct);

            /* Breite: beim ersten Aufruf smooth einfahren, danach direkt */
            if (animate) {
                fill.style.width = '0%';
                requestAnimationFrame(function(){ requestAnimationFrame(function(){ animateBar(fill, visiblePct); }); });
            } else {
                fill.style.width = visiblePct.toFixed(2) + '%';
            }

            fill.classList.toggle('is-full', pct >= 98);
            fill.classList.toggle('is-low',  pct <= 15);
            fill.classList.toggle('is-positive', production > 0);
            fill.classList.toggle('is-negative', production < 0);

            node.classList.toggle('res-anim-full',     pct >= 98);
            node.classList.toggle('res-anim-low',      pct <= 15);
            node.classList.toggle('res-anim-negative', production < 0);
            node.classList.toggle('res-anim-positive', production > 0);

            if (trend) {
                var absProd = Math.abs(production);
                var prefix = production > 0 ? '+' : (production < 0 ? '-' : '\u00b1');
                trend.textContent = prefix + Math.round(absProd).toLocaleString('de-DE');
                trend.classList.toggle('up',   production > 0);
                trend.classList.toggle('down', production < 0);
                trend.classList.toggle('flat', production === 0);
            }
        });
    }

    /* Erster Aufruf mit Animation, danach alle 2s ohne */
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function(){ applyResourceBars(true); });
    } else {
        applyResourceBars(true);
    }
    window.setInterval(function(){ applyResourceBars(false); }, 2000);
})();
</script>

<!-- SMARTNOTIF v5 FIXED -->
<script>
var SmartNotif=(function(){
    var openPanel=null;
    var panels=['fleets','messages','building','research','hangar','forum','usermenu'];
    var fleetTickHandle=null;
    var queueTickHandle=null;

    function toggle(p){
        var dd=document.getElementById('notif-'+p+'-dropdown');
        if(!dd) return;
        if(openPanel && openPanel!==p){
            var prev=document.getElementById('notif-'+openPanel+'-dropdown');
            if(prev) prev.classList.remove('open');
        }
        openPanel = dd.classList.toggle('open') ? p : null;
    }

    function closeAll(){
        panels.forEach(function(p){
            var d=document.getElementById('notif-'+p+'-dropdown');
            if(d) d.classList.remove('open');
        });
        openPanel=null;
    }

    document.addEventListener('click', function(e){
        if(!e.target.closest('.notif-icon-wrap') && !e.target.closest('.user-avatar-wrap')) closeAll();
    });
    document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeAll(); });

    function setBadge(id,n){
        var b=document.getElementById(id);
        if(!b) return;
        if(n>0){ b.textContent = n>99 ? '99+' : n; b.style.display='flex'; }
        else { b.style.display='none'; }
        // Also toggle active class on the parent button for fleet badge
        if(id==='fleet-badge'){
            var btn=document.getElementById('fleet-notif-btn');
            if(btn){ if(n>0) btn.classList.add('notif-btn-active'); else btn.classList.remove('notif-btn-active'); }
        }
    }

    function setAttackMode(on){
        var i=document.getElementById('attack-indicator');
        var h=document.getElementById('game-header');
        if(i) i.style.display = on ? 'flex' : 'none';
        if(h){ if(on) h.classList.add('under-attack'); else h.classList.remove('under-attack'); }
    }

    function fmt(s){
        s=Math.max(0, Math.floor(s));
        var h=Math.floor(s/3600), m=Math.floor((s%3600)/60), sc=s%60;
        return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(sc).padStart(2,'0');
    }

    /* TOAST NOTIFICATIONS */
    function toast(msg, icon, color){
        var c=document.getElementById('toast-container');
        if(!c) return;
        var t=document.createElement('div');
        t.className='sm-toast';
        t.style.borderLeftColor = color || '#00f3ff';
        t.innerHTML='<i class="fas fa-'+(icon||'bell')+'" style="color:'+(color||'#00f3ff')+'"></i><span>'+msg+'</span>';
        c.appendChild(t);
        requestAnimationFrame(function(){ t.classList.add('show'); });
        setTimeout(function(){ t.classList.remove('show'); setTimeout(function(){ if(t.parentNode) t.parentNode.removeChild(t); }, 400); }, 4000);
    }

    /* ===== FLOTTEN via sicheres JSON (script tag, kein Escape-Problem) ===== */
    function initFleets(){
        var fl = [];
        try {
            var jsonEl = document.getElementById('fleet-json-data');
            if(jsonEl && jsonEl.textContent) {
                var content = jsonEl.textContent.trim();
                if(content && content !== '[]') {
                    fl = JSON.parse(content);
                }
            }
        } catch(e) { 
            console.error('Fleet JSON parse error:', e); 
            fl = []; 
        }

        if((!Array.isArray(fl) || !fl.length) && Array.isArray(window.globalFleetMovementsFallback)) {
            fl = window.globalFleetMovementsFallback;
        }
        
        if(!Array.isArray(fl) || !fl.length) {
            setBadge('fleet-badge', 0);
            var emptyTarget = document.getElementById('notif-fleets-list');
            if(emptyTarget) {
                emptyTarget.innerHTML = '<div class="notif-empty"><i class="fas fa-check-circle"></i> Keine Flottenbewegungen</div>';
            }
            return;
        }

        var el = document.getElementById('notif-fleets-list');
        if(!el) return;
        setBadge('fleet-badge', fl.length);

        var html='', atk=false;
        for(var i=0; i<fl.length; i++){
            var f = fl[i];
            if(f.isHostile) atk = true;
            
            var restTime = parseInt(f.resttime) || 0;
            var fleetText = (typeof f.text === 'string' && f.text.length) ? f.text : 'Unbekannte Flotte';
            
            html += '<div class="notif-fleet-item' + (f.isHostile ? ' hostile' : '') + '">';
            html += '<span class="notif-fleet-timer" id="hft-'+i+'">' + fmt(restTime) + '</span>';
            html += '<span class="notif-fleet-text">' + fleetText + '</span>';
            html += '</div>';
        }
        el.innerHTML = html;
        setAttackMode(atk);
        if(atk) toast('Feindliche Flotte im Anflug!', 'exclamation-triangle', '#ef4444');

        // Timer update only if we have fleets
        if(fleetTickHandle) {
            clearInterval(fleetTickHandle);
        }
        fleetTickHandle = setInterval(function(){
            for(var i=0; i<fl.length; i++){
                fl[i].resttime = Math.max(0, (fl[i].resttime||0) - 1);
                var t = document.getElementById('hft-'+i);
                if(t) t.textContent = fmt(fl[i].resttime);
            }
        }, 1000);
    }

    function findQueueActiveItem(queueId) {
        var root = document.getElementById('notif-' + queueId + '-dropdown');
        if(!root) return null;
        return root.querySelector('.notif-queue-item.nq-active');
    }

    function mountCancelButton(queueId, cancelUrl) {
        if(!cancelUrl) return;
        var item = findQueueActiveItem(queueId);
        if(!item) return;
        var header = item.querySelector('.nq-header');
        if(!header || header.querySelector('.nq-cancel')) return;

        var cancelBtn = document.createElement('button');
        cancelBtn.className = 'nq-cancel';
        cancelBtn.innerHTML = '<i class="fas fa-times"></i>';
        cancelBtn.title = 'Abbrechen';
        cancelBtn.onclick = function() {
            if(confirm('Bau wirklich abbrechen?')) {
                window.location.href = cancelUrl;
            }
        };
        header.appendChild(cancelBtn);
    }

    function updateQueueDom(queueId, leftSeconds, pct) {
        var timer = document.getElementById('nq-' + queueId + '-timer');
        var bar   = document.getElementById('nq-' + queueId + '-bar');
        if(timer) timer.textContent = fmt(leftSeconds);
        if(bar) bar.style.width = Math.min(100, Math.max(0, pct)).toFixed(1) + '%';
    }

    function queueProgress(q) {
        if(q.mode === 'elapsed') {
            q.elapsed = (q.elapsed||0) + 1;
            q.left = Math.max(0, (q.total||0) - q.elapsed);
            return q.total > 0 ? (q.elapsed / q.total * 100) : 100;
        }

        q.left = Math.max(0, q.left - 1);
        return q._init > 0 ? ((q._init - q.left) / q._init * 100) : 100;
    }

    /* ===== BUILD QUEUES + PROGRESSBARS ===== */
    function initQueues(){
        var Q = [];
        {% if buildQueue.building %}
        Q.push({id:'building', left:{{ buildQueue.building.timeLeft|default(0)|raw }}, total:{{ buildQueue.building.totalTime|default(1)|raw }}, elapsed:{{ buildQueue.building.elapsed|default(0)|raw }}, mode:'elapsed', cancelUrl:'game.php?page=buildings&mode=cancel'});
        {% endif %}
        {% if buildQueue.research %}
        Q.push({id:'research', left:{{ buildQueue.research.timeLeft|default(0)|raw }}, total:{{ buildQueue.research.totalTime|default(1)|raw }}, elapsed:{{ buildQueue.research.elapsed|default(0)|raw }}, mode:'elapsed', cancelUrl:'game.php?page=research&mode=cancel'});
        {% endif %}
        {% if buildQueue.hangar %}
        Q.push({id:'hangar', left:{{ buildQueue.hangar.timeLeft|default(0)|raw }}, total:{{ buildQueue.hangar.totalTime|default(1)|raw }}, elapsed:{{ buildQueue.hangar.elapsed|default(0)|raw }}, mode:'elapsed', cancelUrl:'game.php?page=shipyard&mode=cancel'});
        {% endif %}

        if(!Q.length) return;

        Q.forEach(function(q) {
            mountCancelButton(q.id, q.cancelUrl);
        });

        var refreshScheduled = false;
        var firstTick = true;
        function tick(){
            var shouldReload = false;
            for(var i=0; i<Q.length; i++){
                var q = Q[i];
                var pct = queueProgress(q);
                updateQueueDom(q.id, q.left, pct);
                
                if(q.left <= 0) {
                    shouldReload = true;
                }
            }

            if(shouldReload) {
                setTimeout(function() {
                    window.location.reload();
                }, 2000);
            }
        }
        tick();
        if(queueTickHandle) {
            clearInterval(queueTickHandle);
        }
        queueTickHandle = setInterval(tick, 1000);
    }

    /* ===== TOAST bei Page Load ===== */
    function initToasts(){
        {% if new_message is defined and new_message > 0 %}
        toast({{ (new_message ~ ' neue Nachricht(en)')|json_encode }}, 'envelope', '#00f3ff');
        {% endif %}
        {% if buildQueue.building is defined and buildQueue.building %}
        toast({{ ('Bau: ' ~ buildQueue.building.items[0].name|default('?') ~ ' Lv.' ~ buildQueue.building.items[0].level|default('?'))|json_encode }}, 'building', '#3b82f6');
        {% endif %}
        {% if buildQueue.research is defined and buildQueue.research %}
        toast({{ ('Forschung: ' ~ buildQueue.research.items[0].name|default('?') ~ ' Lv.' ~ buildQueue.research.items[0].level|default('?'))|json_encode }}, 'flask', '#a855f7');
        {% endif %}
    }

    /* ===== INIT â jQuery oder Vanilla ===== */
    function doInit(){
        try { initFleets(); } catch(e){ console.error('SmartNotif fleets error:', e); }
        try { initQueues(); } catch(e){ console.error('SmartNotif queues error:', e); }
        setTimeout(function(){
            try { initToasts(); } catch(e){ console.error('SmartNotif toasts error:', e); }
        }, 800);
    }

    if(typeof jQuery !== 'undefined'){
        jQuery(doInit);
    } else {
        document.addEventListener('DOMContentLoaded', doInit);
    }
    window.addEventListener('load', function() {
        setTimeout(doInit, 50);
    });
    return {toggle:toggle, closeAll:closeAll, setBadge:setBadge, setAttackMode:setAttackMode, toast:toast};
})();
</script>

<!-- FORUM NOTIFICATIONS CSS -->
<!-- Forum notification styles moved to smartmoons.css -->

<!-- FORUM NOTIFICATIONS JS -->
<script>
(function(){
    var _items = [];
    {% if forum_notif_count is defined and forum_notif_count > 0 %}
    var count = {{ forum_notif_count }};
    {% else %}
    var count = 0;
    {% endif %}
    var _activeTab = 'mention';
    var _loaded = false;

    function relTime(ts) {
        var diff = Math.floor(Date.now()/1000) - ts;
        if (diff < 60)   return 'gerade eben';
        if (diff < 3600) return Math.floor(diff/60) + ' Min.';
        if (diff < 86400) return Math.floor(diff/3600) + ' Std.';
        return Math.floor(diff/86400) + ' Tg.';
    }

    function updateBadge(count) {
        var badge = document.getElementById('forum-notif-badge');
        var btn   = document.getElementById('forum-notif-btn');
        if (!badge) return;
        if (count > 0) {
            badge.textContent = count > 99 ? '99+' : count;
            badge.style.display = 'flex';
            if (btn) btn.classList.add('notif-btn-active');
        } else {
            badge.style.display = 'none';
            if (btn) btn.classList.remove('notif-btn-active');
        }
    }

    function renderList() {
        var list = document.getElementById('forum-notif-list');
        if (!list) return;
        var filtered = _items.filter(function(i){ return i.type === _activeTab; });
        if (!filtered.length) {
            list.innerHTML = '<div class="notif-empty"><i class="fas fa-check-circle"></i> Keine neuen ' + (_activeTab === 'mention' ? 'Erw\u00e4hnungen' : 'Beitr\u00e4ge') + '</div>';
            return;
        }
        var html = '';
        filtered.forEach(function(item) {
            var icon = item.type === 'mention'
                ? '<i class="fas fa-at forum-notif-icon fn-mention"></i>'
                : '<i class="fas fa-reply forum-notif-icon fn-newpost"></i>';
            var link = 'game.php?page=forum&mode=topic&id=' + item.topic_id + '#post-' + item.post_id;
            html += '<div class="forum-notif-item" data-id="' + item.id + '" data-type="' + item.type + '" data-link="' + link + '">';
            html += '<div>' + icon + '<span class="forum-notif-title">' + item.topic_title + '</span></div>';
            html += '<div class="forum-notif-by">von ' + item.by_username + '</div>';
            if (item.snippet) html += '<div class="forum-notif-snippet">' + item.snippet + '</div>';
            html += '<div style="display:flex;justify-content:space-between;align-items:center;">';
            html += '<span class="forum-notif-time">' + relTime(item.created_at) + '</span>';
            html += '<button class="forum-notif-read-btn" data-id="' + item.id + '" data-type="' + item.type + '" title="Als gelesen markieren"><i class="fas fa-check"></i></button>';
            html += '</div></div>';
        });
        list.innerHTML = html;

        list.querySelectorAll('.forum-notif-item').forEach(function(el) {
            el.addEventListener('click', function(e) {
                if (e.target.closest('.forum-notif-read-btn')) return;
                var id   = parseInt(el.getAttribute('data-id'));
                var type = el.getAttribute('data-type');
                var link = el.getAttribute('data-link');
                markRead(type, id, function(){ window.location.href = link; });
            });
        });

        list.querySelectorAll('.forum-notif-read-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var id   = parseInt(btn.getAttribute('data-id'));
                var type = btn.getAttribute('data-type');
                markRead(type, id, null);
            });
        });
    }

    function markRead(type, id, callback) {
        var fd = new FormData();
        fd.append('type', type);
        fd.append('id', id);
        fetch('game.php?page=forumNotif&mode=mark_read&ajax=1', {method:'POST', body:fd})
            .then(function(r){ return r.json(); })
            .then(function(data) {
                _items = _items.filter(function(i){ return !(i.id === id && i.type === type); });
                updateBadge(data.count !== undefined ? data.count : _items.length);
                renderList();
                if (callback) callback();
            })
            .catch(function(){});
    }

    function markAllRead() {
        var fd = new FormData();
        fetch('game.php?page=forumNotif&mode=mark_all_read&ajax=1', {method:'POST', body:fd})
            .then(function(r){ return r.json(); })
            .then(function() {
                _items = [];
                updateBadge(0);
                renderList();
            })
            .catch(function(){});
    }

    function fetchCount() {
        fetch('game.php?page=forumNotif&mode=notif_count&ajax=1')
            .then(function(r){ return r.json(); })
            .then(function(data) { updateBadge(data.count || 0); })
            .catch(function(){});
    }

    function fetchList() {
        var list = document.getElementById('forum-notif-list');
        if (list) list.innerHTML = '<div class="notif-empty"><i class="fas fa-spinner fa-spin"></i> Lade\u2026</div>';
        fetch('game.php?page=forumNotif&mode=notifications&ajax=1')
            .then(function(r){ return r.json(); })
            .then(function(data) {
                _items = data.items || [];
                _loaded = true;
                updateBadge(data.count || 0);
                renderList();
            })
            .catch(function() {
                var list2 = document.getElementById('forum-notif-list');
                if (list2) list2.innerHTML = '<div class="notif-empty"><i class="fas fa-exclamation-circle"></i> Fehler beim Laden</div>';
            });
    }

    function initForumNotif() {
        var btn = document.getElementById('forum-notif-btn');
        if (!btn || btn._fnBound) return;
        btn._fnBound = true;

        btn.addEventListener('click', function() {
            if (!_loaded) fetchList();
        });

        document.querySelectorAll('.forum-notif-tab').forEach(function(tab) {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.forum-notif-tab').forEach(function(t){ t.classList.remove('active'); });
                tab.classList.add('active');
                _activeTab = tab.getAttribute('data-tab');
                renderList();
            });
        });

        var markAllBtn = document.getElementById('forum-mark-all-btn');
        if (markAllBtn) {
            markAllBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                markAllRead();
            });
        }

        fetchCount();
        setInterval(fetchCount, 20000);
    }

    if (typeof jQuery !== 'undefined') {
        jQuery(initForumNotif);
    } else {
        document.addEventListener('DOMContentLoaded', initForumNotif);
    }
    window.addEventListener('load', function(){ setTimeout(initForumNotif, 100); });
})();
</script>
