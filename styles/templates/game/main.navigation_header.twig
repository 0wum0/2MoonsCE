<!-- SMARTMOONS HEADER v8 -->
<header class="game-header" id="game-header">
    <div class="header-row-main">
        <!-- BURGER -->
        <button id="sidebar-toggle" class="sidebar-menu-toggle burger-menu mobile-menu-toggle" type="button" aria-label="Menu" aria-controls="leftmenu" aria-expanded="false">
            <span class="burger-line"></span><span class="burger-line"></span><span class="burger-line"></span>
        </button>

        <!-- LOGO -->
        <a href="game.php?page=overview" class="header-logo">
            <i class="fas fa-moon"></i> <span class="logo-text">{{ game_name|default('2Moons') }}</span>
        </a>

        <!-- PLANET SELECT -->
        <div class="planet-select-wrapper">
            <div class="sci-select-container">
                <i class="fas fa-globe-americas select-icon"></i>
                <select id="planetSelector" class="sci-select" onchange="window.location.href='?cp='+this.value;">
                    {% for key, value in PlanetSelect %}
                        <option value="{{ key }}"{% if key == current_pid %} selected{% endif %}>{{ value }}</option>
                    {% endfor %}
                </select>
                <i class="fas fa-caret-down select-arrow"></i>
            </div>
        </div>

        <div class="header-spacer"></div>

        <!-- NOTIFICATION ICONS -->
        <div class="header-notifications">
            <!-- ATTACK -->
            <div class="notif-icon-wrap" id="attack-indicator" style="display:none;">
                <div class="attack-pulse-ring"></div>
                <button class="notif-btn attack-btn"><i class="fas fa-exclamation-triangle"></i></button>
            </div>

            <!-- GEBÄUDE -->
            <div class="notif-icon-wrap">
                <button class="notif-btn{% if buildQueue.building %} notif-btn-active{% endif %}" onclick="SmartNotif.toggle('building')">
                    <i class="fas fa-building"></i>{% if buildQueue.building %}<span class="notif-badge">{{ buildQueue.building.count }}</span>{% endif %}
                </button>
                <div class="notif-dropdown" id="notif-building-dropdown">
                    <div class="notif-dropdown-header">
                        <span><i class="fas fa-building"></i> Gebäude</span>
                        <a href="game.php?page=buildings" class="notif-header-link"><i class="fas fa-external-link-alt"></i></a>
                    </div>
                    <div class="notif-dropdown-body">
                        {% if buildQueue.building %}
                            {% for item in buildQueue.building.items %}
                                <div class="notif-queue-item{% if loop.first %} nq-active{% endif %}">
                                    <div class="nq-header">
                                        <span class="nq-name">{{ item.name }}</span>
                                        <span class="nq-level">Lv. {{ item.level }}</span>
                                    </div>
                                    {% if loop.first %}
                                        <div class="nq-progress-wrap">
                                            <div class="nq-progress-bar"><div class="nq-progress-fill" id="nq-building-bar"></div></div>
                                            <span class="nq-timer" id="nq-building-timer">--:--:--</span>
                                        </div>
                                    {% else %}
                                        <div class="nq-queued"><i class="fas fa-clock"></i> In Warteschlange</div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="notif-empty"><i class="fas fa-check-circle"></i> Frei</div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- FORSCHUNG -->
            <div class="notif-icon-wrap">
                <button class="notif-btn{% if buildQueue.research %} notif-btn-active{% endif %}" onclick="SmartNotif.toggle('research')">
                    <i class="fas fa-flask"></i>{% if buildQueue.research %}<span class="notif-badge">{{ buildQueue.research.count }}</span>{% endif %}
                </button>
                <div class="notif-dropdown" id="notif-research-dropdown">
                    <div class="notif-dropdown-header">
                        <span><i class="fas fa-flask"></i> Forschung</span>
                        <a href="game.php?page=research" class="notif-header-link"><i class="fas fa-external-link-alt"></i></a>
                    </div>
                    <div class="notif-dropdown-body">
                        {% if buildQueue.research %}
                            {% for item in buildQueue.research.items %}
                                <div class="notif-queue-item{% if loop.first %} nq-active{% endif %}">
                                    <div class="nq-header">
                                        <span class="nq-name">{{ item.name }}</span>
                                        <span class="nq-level">Lv. {{ item.level }}</span>
                                    </div>
                                    {% if loop.first %}
                                        <div class="nq-progress-wrap">
                                            <div class="nq-progress-bar"><div class="nq-progress-fill nq-fill-purple" id="nq-research-bar"></div></div>
                                            <span class="nq-timer" id="nq-research-timer">--:--:--</span>
                                        </div>
                                    {% else %}
                                        <div class="nq-queued"><i class="fas fa-clock"></i> In Warteschlange</div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="notif-empty"><i class="fas fa-check-circle"></i> Frei</div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- WERFT -->
            <div class="notif-icon-wrap">
                <button class="notif-btn{% if buildQueue.hangar %} notif-btn-active{% endif %}" onclick="SmartNotif.toggle('hangar')">
                    <i class="fas fa-hammer"></i>{% if buildQueue.hangar %}<span class="notif-badge">{{ buildQueue.hangar.totalItems }}</span>{% endif %}
                </button>
                <div class="notif-dropdown" id="notif-hangar-dropdown">
                    <div class="notif-dropdown-header">
                        <span><i class="fas fa-hammer"></i> Werft</span>
                        <a href="game.php?page=shipyard" class="notif-header-link"><i class="fas fa-external-link-alt"></i></a>
                    </div>
                    <div class="notif-dropdown-body">
                        {% if buildQueue.hangar %}
                            {% for item in buildQueue.hangar.items %}
                                <div class="notif-queue-item{% if loop.first %} nq-active{% endif %}">
                                    <div class="nq-header">
                                        <span class="nq-name">{{ item.name }}</span>
                                        <span class="nq-level">&times; {{ item.count }}</span>
                                    </div>
                                    {% if loop.first %}
                                        <div class="nq-progress-wrap">
                                            <div class="nq-progress-bar"><div class="nq-progress-fill nq-fill-green" id="nq-hangar-bar"></div></div>
                                            <span class="nq-timer" id="nq-hangar-timer">--:--:--</span>
                                        </div>
                                    {% else %}
                                        <div class="nq-queued"><i class="fas fa-clock"></i> Warteschlange</div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="notif-empty"><i class="fas fa-check-circle"></i> Frei</div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- FLOTTEN -->
            <div class="notif-icon-wrap">
                <button class="notif-btn" onclick="SmartNotif.toggle('fleets')">
                    <i class="fas fa-rocket"></i><span class="notif-badge" id="fleet-badge" style="display:none;">0</span>
                </button>
                <div class="notif-dropdown" id="notif-fleets-dropdown">
                    <div class="notif-dropdown-header">
                        <span><i class="fas fa-rocket"></i> Flotten</span>
                        <a href="game.php?page=fleetTable" class="notif-header-link"><i class="fas fa-external-link-alt"></i></a>
                    </div>
                    <div class="notif-dropdown-body" id="notif-fleets-list">
                        <div class="notif-empty"><i class="fas fa-check-circle"></i> Keine Flottenbewegungen</div>
                    </div>
                </div>
            </div>

            <!-- NACHRICHTEN -->
            <div class="notif-icon-wrap">
                <button class="notif-btn{% if new_message > 0 %} notif-btn-active{% endif %}" onclick="SmartNotif.toggle('messages')">
                    <i class="fas fa-envelope"></i>{% if new_message > 0 %}<span class="notif-badge">{{ new_message }}</span>{% endif %}
                </button>
                <div class="notif-dropdown" id="notif-messages-dropdown">
                    <div class="notif-dropdown-header">
                        <span><i class="fas fa-envelope"></i> Nachrichten</span>
                        <a href="game.php?page=messages" class="notif-header-link">Alle <i class="fas fa-external-link-alt"></i></a>
                    </div>
                    <div class="notif-dropdown-body">
                        {% if recentMessages is defined and recentMessages|length > 0 %}
                            {% for msg in recentMessages %}
                                <a href="game.php?page=messages&id={{ msg.id }}" class="notif-msg-item unread">
                                    <div class="notif-msg-from"><i class="fas fa-envelope-open-text"></i> {{ msg.subject|default('(Kein Betreff)') }}</div>
                                    <div class="notif-msg-preview">{{ msg.preview }}</div>
                                    <div class="notif-msg-time">{{ msg.time|date('d.m.Y H:i') }}</div>
                                </a>
                            {% endfor %}
                            {% if new_message > recentMessages|length %}
                                <a href="game.php?page=messages" class="notif-msg-more">+{{ new_message - recentMessages|length }} weitere</a>
                            {% endif %}
                        {% elseif new_message > 0 %}
                            <a href="game.php?page=messages" class="notif-msg-item unread">
                                <div class="notif-msg-from"><i class="fas fa-envelope-open-text"></i> {{ new_message }} neue Nachricht(en)</div>
                            </a>
                        {% else %}
                            <div class="notif-empty"><i class="fas fa-check-circle"></i> Keine neuen Nachrichten</div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- ======== USER AVATAR MENU ======== -->
            <div class="notif-icon-wrap user-avatar-wrap">
                <button class="user-avatar-btn" type="button" onclick="SmartNotif.toggle('usermenu')" aria-label="Profil" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-user"></i>
                    {% if new_message > 0 %}<span class="avatar-dot"></span>{% endif %}
                </button>

                <div class="notif-dropdown user-menu-dropdown" id="notif-usermenu-dropdown" role="menu" aria-label="Benutzermenü">
                    <div class="user-menu-header">
                        <div class="user-menu-avatar"><i class="fas fa-user-astronaut"></i></div>
                        <div class="user-menu-info">
                            <div class="user-menu-name">{{ username }}</div>
                            <div class="user-menu-planet">{{ PlanetSelect[current_pid]|default('') }}</div>
                        </div>
                    </div>

                    <div class="user-menu-body">

                        <a href="game.php?page=messages&category=100&side=1" class="user-menu-item">
                            <i class="fas fa-envelope"></i><span>{{ LNG.lm_messages|default('Nachrichten') }}</span>
                            {% if new_message > 0 %}<span class="user-menu-badge">{{ new_message }}</span>{% endif %}
                        </a>

                        <a href="game.php?page=buddyList" class="user-menu-item"><i class="fas fa-user-friends"></i><span>{{ LNG.lm_buddylist|default('Buddyliste') }}</span></a>
                        <a href="game.php?page=statistics" class="user-menu-item"><i class="fas fa-chart-line"></i><span>{{ LNG.lm_statistics|default('Statistiken') }}</span></a>
                        <a href="game.php?page=alliance" class="user-menu-item"><i class="fas fa-users"></i><span>{{ LNG.lm_alliance|default('Allianz') }}</span></a>

                        {% if authlevel > 0 %}
                            <a href="./admin.php" class="user-menu-item user-menu-admin"><i class="fas fa-user-shield"></i><span>{{ LNG.lm_administration|default('Administration') }}</span></a>
                        {% endif %}

                        <a href="game.php?page=settings" class="user-menu-item"><i class="fas fa-cog"></i><span>{{ LNG.lm_settings|default('Einstellungen') }}</span></a>
                                            <div class="user-menu-divider"></div>
                        {% if isModuleAvailable(constant('MODULE_SEARCH')) %}
                            <a href="game.php?page=search" class="user-menu-item"><i class="fas fa-search"></i><span>{{ LNG.lm_search }}</span></a>
                        {% endif %}
                        {% if isModuleAvailable(constant('MODULE_BANLIST')) %}
                            <a href="game.php?page=banList" class="user-menu-item"><i class="fas fa-user-slash"></i><span>{{ LNG.lm_banned }}</span></a>
                        {% endif %}
                        {% if isModuleAvailable(constant('MODULE_BATTLEHALL')) %}
                            <a href="game.php?page=battleHall" class="user-menu-item"><i class="fas fa-trophy"></i><span>{{ LNG.lm_topkb }}</span></a>
                        {% endif %}
                        {% if isModuleAvailable(constant('MODULE_RECORDS')) %}
                            <a href="game.php?page=records" class="user-menu-item"><i class="fas fa-medal"></i><span>{{ LNG.lm_records }}</span></a>
                        {% endif %}
                        {% if isModuleAvailable(constant('MODULE_SIMULATOR')) %}
                            <a href="game.php?page=battleSimulator" class="user-menu-item"><i class="fas fa-chess-knight"></i><span>{{ LNG.lm_battlesim }}</span></a>
                        {% endif %}
                        {% if isModuleAvailable(constant('MODULE_NOTICE')) %}
                            <a href="#" onclick="Dialog.open('game.php?page=notes', 720, 300); return false;" class="user-menu-item"><i class="fas fa-sticky-note"></i><span>{{ LNG.lm_notes|default('Notizen') }}</span></a>
                        {% endif %}
                        <a href="index.php?page=rules" target="rules" class="user-menu-item"><i class="fas fa-gavel"></i><span>{{ LNG.lm_rules }}</span></a>

                        <div class="user-menu-divider"></div>

                        <a href="game.php?page=logout" class="user-menu-item user-menu-logout"><i class="fas fa-power-off"></i><span>{{ LNG.lm_logout|default('Logout') }}</span></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RESOURCE BAR (eigene Zeile, NICHT im header-row-main!) -->
    <div class="res-bar-row">
        <div class="res-bar-container">
            <div class="res-bar">
                {% for resourceID, resourceData in resourceTable %}
                <div class="res-item tooltip" data-tooltip-content="{{ LNG.tech[resourceID] }}" data-res-current="{{ resourceData.current|default(0)|raw }}" data-res-max="{{ resourceData.max|default(0)|raw }}" data-res-production="{{ resourceData.production|default(0)|raw }}" data-res-name="{{ resourceData.name }}">
                    <div class="res-icon"><img src="{{ dpath }}images/{{ resourceData.name }}.gif" alt="{{ LNG.tech[resourceID] }}"></div>
                    <div class="res-info">
                        <span class="res-val {% if resourceData.current >= resourceData.max %}text-danger{% endif %}" id="current_{{ resourceData.name }}">
                            {% if shortlyNumber %}{{ resourceData.current|default(resourceData.max + resourceData.used)|shortly_number }}{% else %}{{ resourceData.current|default(resourceData.max + resourceData.used)|number_format }}{% endif %}
                        </span>
                        <div class="res-progress"><div class="res-progress-fill" id="resbar_{{ resourceData.name }}"></div></div>
                        <span class="res-trend" id="restrend_{{ resourceData.name }}">±0</span>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</header>

