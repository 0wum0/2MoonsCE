<!-- FEATURES 1,3,4,5: Tooltip / Section-Highlight / Warn-Toast / Dock-Active -->
<script>
(function(){
    /* === FEATURE 3: Section-Has-Active Fallback (ohne :has()) === */
    function markActiveSections() {
        var sections = document.querySelectorAll('#leftmenu .nav-section');
        sections.forEach(function(sec) {
            var hasActive = sec.querySelector('.nav-link.active');
            sec.classList.toggle('section-has-active', !!hasActive);
        });
    }
    markActiveSections(); // Einmalig beim Load

    /* === FEATURE 1: Ressource-Tooltip via data-res-tooltip Attribut ==
       Füllt das CSS-attr(data-res-tooltip) mit formatiertem Text.
       Läuft einmalig + beim 2s-Interval Tick der applyResourceBars. */
    function updateResTooltips() {
        var items = document.querySelectorAll('.res-item-tooltip[data-res-current]');
        items.forEach(function(item) {
            var name       = item.getAttribute('data-res-name') || '';
            var current    = Number(item.getAttribute('data-res-current')) || 0;
            var max        = Number(item.getAttribute('data-res-max'))     || 0;
            var production = Number(item.getAttribute('data-res-production')) || 0;

            // Dynamischen aktuellen Wert aus dem DOM holen (falls resourceTicker läuft)
            var valEl = name ? document.getElementById('current_' + name) : null;
            if (valEl) {
                // Nutze innerHTML da resourceTicker dort einträgt
                var raw = valEl.textContent || valEl.innerText || '';
                // current bleibt als Näherung
            }

            var pct   = max > 0 ? Math.min(100, (current / max) * 100).toFixed(1) : '0.0';
            var prod  = production;
            var prodStr;
            if (prod > 0)      prodStr = '+' + Math.round(prod).toLocaleString('de-DE') + '/h';
            else if (prod < 0) prodStr = Math.round(prod).toLocaleString('de-DE') + '/h';
            else               prodStr = '\u00b10/h';

            var tooltipText = name + '\n' + pct + '% voll\n' + prodStr;
            item.setAttribute('data-res-tooltip', tooltipText);
        });
    }

    // Initial + alle 5s aktualisieren (weniger aggressiv als der 1s-Ticker)
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', updateResTooltips);
    } else {
        updateResTooltips();
    }
    window.setInterval(updateResTooltips, 5000);

    /* === FEATURE 4: Ressource-Warnung Toast bei >= 90% Füllstand ==
       Einmalig pro Ressource pro Session (sessionStorage Guard). */
    var warnedRes = {};
    try {
        var saved = sessionStorage.getItem('sm_res_warned');
        if (saved) warnedRes = JSON.parse(saved);
    } catch(e) {}

    function checkResWarnings() {
        var items = document.querySelectorAll('.res-item-tooltip[data-res-current]');
        items.forEach(function(item) {
            var name    = item.getAttribute('data-res-name') || '';
            var current = Number(item.getAttribute('data-res-current')) || 0;
            var max     = Number(item.getAttribute('data-res-max')) || 0;
            if (!name || !max) return;
            var pct = (current / max) * 100;
            if (pct >= 90 && !warnedRes[name]) {
                warnedRes[name] = true;
                try { sessionStorage.setItem('sm_res_warned', JSON.stringify(warnedRes)); } catch(e) {}
                // Toast via SmartNotif (falls geladen)
                if (typeof SmartNotif !== 'undefined' && SmartNotif.toast) {
                    SmartNotif.toast(
                        name + ' fast voll (' + pct.toFixed(0) + '%)',
                        'exclamation-circle',
                        '#f97316'
                    );
                }
            }
        });
    }
    // Warn-Check nach 3s (resourceTicker hat dann schon aktualisiert)
    setTimeout(checkResWarnings, 3000);
    window.setInterval(checkResWarnings, 60000); // Danach alle 60s erneut prüfen

    /* _resWarnCheck Hook: wird von topnav.js resourceTicker aufgerufen */
    window._resWarnCheck = function(elemId, current, max) {
        if (!max) return;
        var pct = (current / max) * 100;
        var name = elemId.replace('current_', '');
        if (pct >= 90 && !warnedRes[name]) {
            warnedRes[name] = true;
            try { sessionStorage.setItem('sm_res_warned', JSON.stringify(warnedRes)); } catch(e) {}
            if (typeof SmartNotif !== 'undefined' && SmartNotif.toast) {
                SmartNotif.toast(
                    name.charAt(0).toUpperCase() + name.slice(1) + ' fast voll (' + pct.toFixed(0) + '%)',
                    'exclamation-circle',
                    '#f97316'
                );
            }
        }
    };

    /* === FEATURE 5: Dock FAB Active-State für fleetTable ==
       Twig setzt kein active auf .dock-fab, nur auf .dock-item.
       Wir prüfen die aktuelle page aus body-id. */
    function setDockFabActive() {
        var bodyId  = document.body.id || '';
        var fab     = document.querySelector('.dock-fab');
        if (!fab) return;
        // FAB verlinkt auf fleetTable
        fab.classList.toggle('dock-fab-active', bodyId === 'fleetTable');
    }
    setDockFabActive();

})();
</script>

