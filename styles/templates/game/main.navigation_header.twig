<script type="application/json" id="fleet-json-data">{{ globalFleetJSON|default("[]")|raw }}</script>

<!-- SMARTNOTIF v5 FIXED -->
<script>
var SmartNotif=(function(){
    var openPanel=null;
    var panels=['fleets','messages','building','research','hangar','usermenu'];

    function toggle(p){
        var dd=document.getElementById('notif-'+p+'-dropdown');
        if(!dd) return;
        if(openPanel && openPanel!==p){
            var prev=document.getElementById('notif-'+openPanel+'-dropdown');
            if(prev) prev.classList.remove('open');
        }
        openPanel = dd.classList.toggle('open') ? p : null;
    }

    function closeAll(){
        panels.forEach(function(p){
            var d=document.getElementById('notif-'+p+'-dropdown');
            if(d) d.classList.remove('open');
        });
        openPanel=null;
    }

    document.addEventListener('click', function(e){
        if(!e.target.closest('.notif-icon-wrap') && !e.target.closest('.user-avatar-wrap')) closeAll();
    });
    document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeAll(); });

    function setBadge(id,n){
        var b=document.getElementById(id);
        if(!b) return;
        if(n>0){ b.textContent = n>99 ? '99+' : n; b.style.display='flex'; }
        else { b.style.display='none'; }
    }

    function setAttackMode(on){
        var i=document.getElementById('attack-indicator');
        var h=document.getElementById('game-header');
        if(i) i.style.display = on ? 'flex' : 'none';
        if(h){ if(on) h.classList.add('under-attack'); else h.classList.remove('under-attack'); }
    }

    function fmt(s){
        s=Math.max(0, Math.floor(s));
        var h=Math.floor(s/3600), m=Math.floor((s%3600)/60), sc=s%60;
        return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(sc).padStart(2,'0');
    }

    /* TOAST NOTIFICATIONS */
    function toast(msg, icon, color){
        var c=document.getElementById('toast-container');
        if(!c) return;
        var t=document.createElement('div');
        t.className='sm-toast';
        t.style.borderLeftColor = color || '#00f3ff';
        t.innerHTML='<i class="fas fa-'+(icon||'bell')+'" style="color:'+(color||'#00f3ff')+'"></i><span>'+msg+'</span>';
        c.appendChild(t);
        requestAnimationFrame(function(){ t.classList.add('show'); });
        setTimeout(function(){ t.classList.remove('show'); setTimeout(function(){ if(t.parentNode) t.parentNode.removeChild(t); }, 400); }, 4000);
    }

    /* ===== FLOTTEN via sicheres JSON (script tag, kein Escape-Problem) ===== */
    function initFleets(){
        var fl = [];
        try {
            var jsonEl = document.getElementById('fleet-json-data');
            if(jsonEl) fl = JSON.parse(jsonEl.textContent || '[]');
        } catch(e) { console.error('Fleet JSON parse error:', e); fl = []; }
        if(!fl || !fl.length) return;

        var el = document.getElementById('notif-fleets-list');
        if(!el) return;
        setBadge('fleet-badge', fl.length);

        var html='', atk=false;
        for(var i=0; i<fl.length; i++){
            var f = fl[i];
            if(f.isHostile) atk = true;
            html += '<div class="notif-fleet-item' + (f.isHostile ? ' hostile' : '') + '">';
            html += '<span class="notif-fleet-timer" id="hft-'+i+'">' + fmt(f.resttime||0) + '</span>';
            html += '<span class="notif-fleet-text">' + (f.text||'') + '</span>';
            html += '</div>';
        }
        el.innerHTML = html;
        setAttackMode(atk);
        if(atk) toast('Feindliche Flotte im Anflug!', 'exclamation-triangle', '#ef4444');

        setInterval(function(){
            for(var i=0; i<fl.length; i++){
                fl[i].resttime = Math.max(0, (fl[i].resttime||0) - 1);
                var t = document.getElementById('hft-'+i);
                if(t) t.textContent = fmt(fl[i].resttime);
            }
        }, 1000);
    }

    /* ===== BUILD QUEUES + PROGRESSBARS ===== */
    function initQueues(){
        var Q = [];
        {% if buildQueue.building %}
        Q.push({id:'building', left:{{ buildQueue.building.timeLeft|default(0)|raw }}, _init:{{ buildQueue.building.timeLeft|default(0)|raw }}, mode:'end'});
        {% endif %}
        {% if buildQueue.research %}
        Q.push({id:'research', left:{{ buildQueue.research.timeLeft|default(0)|raw }}, _init:{{ buildQueue.research.timeLeft|default(0)|raw }}, mode:'end'});
        {% endif %}
        {% if buildQueue.hangar %}
        Q.push({id:'hangar', left:{{ buildQueue.hangar.timeLeft|default(0)|raw }}, _init:{{ buildQueue.hangar.timeLeft|default(1)|raw }}, total:{{ buildQueue.hangar.totalTime|default(0)|raw }}, elapsed:{{ buildQueue.hangar.elapsed|default(0)|raw }}, mode:'elapsed'});
        {% endif %}

        if(!Q.length) return;

        function tick(){
            for(var i=0; i<Q.length; i++){
                var q = Q[i];
                var timer = document.getElementById('nq-' + q.id + '-timer');
                var bar   = document.getElementById('nq-' + q.id + '-bar');
                if(!timer) continue;

                var pct;
                if(q.mode === 'elapsed'){
                    q.elapsed = (q.elapsed||0) + 1;
                    q.left = Math.max(0, (q.total||0) - q.elapsed);
                    pct = q.total > 0 ? (q.elapsed / q.total * 100) : 100;
                } else {
                    q.left = Math.max(0, q.left - 1);
                    pct = q._init > 0 ? ((q._init - q.left) / q._init * 100) : 100;
                }

                timer.textContent = fmt(q.left);
                if(bar) bar.style.width = Math.min(100, pct).toFixed(1) + '%';
            }
        }
        tick();
        setInterval(tick, 1000);
    }

    /* ===== TOAST bei Page Load ===== */
    function initToasts(){
        {% if new_message is defined and new_message > 0 %}
        toast('{{ new_message }} neue Nachricht(en)', 'envelope', '#00f3ff');
        {% endif %}
        {% if buildQueue.building is defined and buildQueue.building %}
        toast('Bau: {{ buildQueue.building.items[0].name|default("?")|e("js") }} Lv.{{ buildQueue.building.items[0].level|default("?") }}', 'building', '#3b82f6');
        {% endif %}
        {% if buildQueue.research is defined and buildQueue.research %}
        toast('Forschung: {{ buildQueue.research.items[0].name|default("?")|e("js") }} Lv.{{ buildQueue.research.items[0].level|default("?") }}', 'flask', '#a855f7');
        {% endif %}
    }

    /* ===== INIT — jQuery oder Vanilla ===== */
    function doInit(){
        try { initFleets(); } catch(e){ console.error('SmartNotif fleets error:', e); }
        try { initQueues(); } catch(e){ console.error('SmartNotif queues error:', e); }
        setTimeout(function(){
            try { initToasts(); } catch(e){ console.error('SmartNotif toasts error:', e); }
        }, 800);
    }

    if(typeof jQuery !== 'undefined'){
        jQuery(doInit);
    } else {
        document.addEventListener('DOMContentLoaded', doInit);
    }

    return {toggle:toggle, closeAll:closeAll, setBadge:setBadge, setAttackMode:setAttackMode, toast:toast};
})();
</script>
