<!-- SIDEBAR TOGGLE -->
<script>
(function(){var t=document.getElementById('sidebar-toggle'),s=document.getElementById('leftmenu')||document.querySelector('.sidebar-nav'),o=document.getElementById('sidebar-overlay');if(!t||!s||t.dataset.sidebarBound==='1')return;t.dataset.sidebarBound='1';function set(open){s.classList.toggle('active',open);s.classList.toggle('collapsed',!open);t.classList.toggle('active',open);t.setAttribute('aria-expanded',open);document.body.classList.toggle('sidebar-open',open);if(o)o.classList.toggle('active',open);}t.addEventListener('click',function(e){e.preventDefault();e.stopImmediatePropagation();set(!s.classList.contains('active'));},true);if(o)o.addEventListener('click',function(){set(false);});document.addEventListener('keydown',function(e){if(e.key==='Escape')set(false);});if(window.matchMedia('(max-width:992px)').matches)set(false);s.querySelectorAll('a.sidebar-link').forEach(function(l){l.addEventListener('click',function(){if(window.matchMedia('(max-width:992px)').matches)set(false);});});})();
</script>

<!-- FIX 4: Header-Höhe messen → CSS Custom Property --sm-header-total -->
<script>
(function() {
    function measureAndSetHeaderHeight() {
        var header = document.getElementById('game-header');
        if (!header) return;
        var h = header.getBoundingClientRect().height;
        if (h > 0) {
            document.documentElement.style.setProperty('--sm-header-total', Math.ceil(h) + 'px');
        }
    }
    // Sofort + nach Fonts/Bildern geladen
    measureAndSetHeaderHeight();
    window.addEventListener('load', measureAndSetHeaderHeight);
    window.addEventListener('resize', measureAndSetHeaderHeight);
})();
</script>

<!-- SIDEBAR DESKTOP COLLAPSE (Feature 2) -->
<script>
(function(){
    var STORAGE_KEY = 'sm_sidebar_collapsed';
    var sidebar = document.getElementById('leftmenu');
    var btn     = document.getElementById('sidebar-collapse-btn');
    var icon    = document.getElementById('sidebar-collapse-icon');
    var body    = document.body;
    if (!sidebar || !btn) return;

    function setCollapsed(collapsed) {
        sidebar.classList.toggle('sidebar-icon-only', collapsed);
        body.classList.toggle('sidebar-collapsed', collapsed);
        if (icon) {
            icon.className = collapsed ? 'fas fa-chevron-right' : 'fas fa-chevron-left';
        }
        btn.setAttribute('aria-label', collapsed ? 'Sidebar ausklappen' : 'Sidebar einklappen');
        try { localStorage.setItem(STORAGE_KEY, collapsed ? '1' : '0'); } catch(e){}
    }

    btn.addEventListener('click', function() {
        setCollapsed(!sidebar.classList.contains('sidebar-icon-only'));
    });

    // Zustand aus localStorage wiederherstellen (nur Desktop)
    if (window.matchMedia('(min-width: 769px)').matches) {
        try {
            var saved = localStorage.getItem(STORAGE_KEY);
            if (saved === '1') setCollapsed(true);
        } catch(e) {}
    }

    // Bei Resize: auf Mobile niemals Icon-Only
    window.addEventListener('resize', function() {
        if (window.innerWidth <= 768) {
            sidebar.classList.remove('sidebar-icon-only');
            body.classList.remove('sidebar-collapsed');
        }
    });
})();
</script>

