{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_messages }}{% endblock %}

{% block content %}
<div class="mcc-root">

    {# ── TOP BAR ── #}
    <div class="mcc-topbar">
        <div class="mcc-topbar-left">
            <div class="mcc-topbar-icon">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
            </div>
            <div>
                <div class="mcc-topbar-title">{{ LNG.lm_messages }}</div>
                <div class="mcc-topbar-sub">// COMMUNICATION_CENTER</div>
            </div>
        </div>
        <div class="mcc-topbar-right">
            <div id="mcc-loading">
                <span class="mcc-loader-dot"></span>
                <span class="mcc-loader-dot"></span>
                <span class="mcc-loader-dot"></span>
                <span>SYNC</span>
            </div>
            <div class="mcc-btn-icon" onclick="Message.getMessages(Message.MessID, Message.Page);" title="Aktualisieren">
                <svg viewBox="0 0 20 20" fill="currentColor" width="13" height="13"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg>
            </div>
            <a href="#" class="mcc-btn-compose" onclick="return Message.openCompose();">
                <svg viewBox="0 0 20 20" fill="currentColor" width="12" height="12"><path d="M17.414 2.586a2 2 0 00-2.828 0L7 10.172V13h2.828l7.586-7.586a2 2 0 000-2.828z"/><path fill-rule="evenodd" d="M2 6a2 2 0 012-2h4a1 1 0 010 2H4v10h10v-4a1 1 0 112 0v4a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" clip-rule="evenodd"/></svg>
                {{ LNG.mg_send_new }}
            </a>
        </div>
    </div>

    {# ── BODY ── #}
    <div class="mcc-body">

        {# ── SIDEBAR ── #}
        <div class="mcc-sidebar">
            <div class="mcc-sidebar-label">// KATEGORIEN</div>
            <div class="mcc-sidebar-cats-inner">

            {% set catData = {
                0:   {icon: 'fa-globe',       color: '#f0b429', bg: 'rgba(240,180,41,0.12)',  badge: 'gold'},
                1:   {icon: 'fa-user',         color: '#00d4ff', bg: 'rgba(0,212,255,0.1)',    badge: 'cyan'},
                2:   {icon: 'fa-crosshairs',   color: '#ff3d57', bg: 'rgba(255,61,87,0.1)',    badge: 'red'},
                3:   {icon: 'fa-satellite',    color: '#f97316', bg: 'rgba(249,115,22,0.1)',   badge: 'orange'},
                4:   {icon: 'fa-chess-rook',   color: '#b47cff', bg: 'rgba(180,124,255,0.1)', badge: 'purple'},
                5:   {icon: 'fa-shield-alt',   color: '#00e676', bg: 'rgba(0,230,118,0.1)',   badge: 'green'},
                15:  {icon: 'fa-handshake',    color: '#6495ed', bg: 'rgba(100,149,237,0.1)', badge: 'cyan'},
                50:  {icon: 'fa-server',       color: '#a0a020', bg: 'rgba(160,160,32,0.12)', badge: 'gold'},
                99:  {icon: 'fa-cog',          color: '#20a0a0', bg: 'rgba(32,160,160,0.12)', badge: 'cyan'},
                100: {icon: 'fa-inbox',        color: '#8090a0', bg: 'rgba(128,144,160,0.1)', badge: 'muted'},
                999: {icon: 'fa-paper-plane',  color: '#b47cff', bg: 'rgba(180,124,255,0.1)', badge: 'purple'}
            } %}

            {% for CategoryID, CategoryRow in CategoryList %}
            {% if CategoryRow.total > 0 or CategoryID == 100 or CategoryID == 999 %}
            {% set cd = catData[CategoryID] ?? {icon:'fa-envelope', color:'#00d4ff', bg:'rgba(0,212,255,0.1)', badge:'cyan'} %}
            <div class="mcc-cat-item {% if category == CategoryID %}active{% endif %}"
                 onclick="(function(el,id){Message.getMessages(id,1);document.querySelectorAll('.mcc-cat-item').forEach(function(x){x.classList.remove('active');});el.classList.add('active');})(this,{{ CategoryID }})">
                <div class="mcc-cat-icon-wrap" style="background:{{ cd.bg }};color:{{ cd.color }}">
                    <i class="fas {{ cd.icon }}"></i>
                </div>
                <span class="mcc-cat-label">{{ LNG.mg_type[CategoryID] }}</span>
                {% if CategoryRow.unread > 0 %}
                    <span class="mcc-cat-badge is-unread">{{ CategoryRow.unread }}</span>
                {% elseif CategoryRow.total > 0 %}
                    <span class="mcc-cat-badge is-count">{{ CategoryRow.total }}</span>
                {% endif %}
            </div>
            {% endif %}
            {% endfor %}

            </div>
        </div>

        {# ── CONTENT ── #}
        <div class="mcc-content">
            <div class="mcc-toolbar-row">
                <div class="mcc-search-wrap">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="8" cy="8" r="5"/><path d="M14 14l3.5 3.5" stroke-linecap="round"/></svg>
                    <input type="text" id="message-search" class="mcc-search-input" placeholder="Nachrichten durchsuchen…">
                </div>
                <input type="hidden" id="message-category-select" value="{{ category|default(100) }}">
                <input type="hidden" id="message-current-page" value="{{ side|default(1) }}">
            </div>
            <div class="mcc-messages-scroll">
                <div id="messages-view"></div>
            </div>
        </div>

    </div>
</div>
{% endblock %}