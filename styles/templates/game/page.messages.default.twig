{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_messages }}{% endblock %}
{% block content %}
<div class="msg-shell-container">
    <div class="galactic-header-card">
        <div>
            <h2 class="galactic-title"><i class="fas fa-envelope-open-text"></i> {{ LNG.lm_messages }}</h2>
            <div class="galactic-subtitle">{{ LNG.mg_inbox|default('Inbox') }}</div>
        </div>
        <div class="msg-actions">
            <span id="loading" style="display:none;" class="msg-time"><i class="fas fa-spinner fa-spin"></i></span>
            <a href="#" class="btn-galactic-main" onclick="return Message.openCompose();">
                <i class="fas fa-pen"></i> {{ LNG.mg_send_new }}
            </a>
        </div>
    </div>

    <div class="msg-filter-card">
        <select id="message-category-select" class="galactic-select" onchange="Message.getMessages(this.value, 1);">
            {% for CategoryID, CategoryRow in CategoryList %}
            <option value="{{ CategoryID }}"{% if category == CategoryID %} selected{% endif %}>
                {{ LNG.mg_type[CategoryID] }} ({{ CategoryRow.total }}){% if CategoryRow.unread > 0 %} - [{{ CategoryRow.unread }} NEU]{% endif %}
            </option>
            {% endfor %}
        </select>
        <button onclick="Message.getMessages($('#message-category-select').val(), 1);" class="btn-ghost">
            <i class="fas fa-sync-alt"></i>
        </button>
    </div>

    <div id="messages-view" class="msg-list-area">
        {# Inhalt wird per AJAX geladen #}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Automatisches Laden beim Start
    setTimeout(function() {
        Message.getMessages({{ category|default(100) }}, {{ side|default(1) }});
    }, 150);
});
</script>
{% endblock %}