<!-- chat-fab: NUR Desktop sichtbar (Mobile nutzt Dock-Chat-Button) -->
<button id="chat-fab" class="chat-fab chat-fab-desktop-only" onclick="SmartChat.toggle();return false;" aria-label="Chat öffnen">
    <i class="fas fa-comments"></i>
    <span id="chat-fab-indicator" class="chat-fab-indicator"></span>
</button>

<!-- GLOBAL CHAT OVERLAY -->
<div id="smart-chat-panel" class="smart-chat-panel">
    <div class="smart-chat-header">
        <div class="smart-chat-tabs">
            <button class="chat-tab active" data-tab="global" onclick="SmartChat.switchTab('global',this)">Global</button>
            <button class="chat-tab" data-tab="alliance" onclick="SmartChat.switchTab('alliance',this)">Allianz</button>
        </div>
        <button class="smart-chat-close" onclick="SmartChat.toggle()"><i class="fas fa-times"></i></button>
    </div>
    <div class="smart-chat-body">
        <iframe id="smart-chat-iframe" src="" class="smart-chat-iframe" allowtransparency="true"></iframe>
    </div>
</div>

{% autoescape false %}
<script>
var SmartChat=(function(){
    var isOpen=false;
    function updateIndicator(show){
        var indicator=document.getElementById('chat-fab-indicator');
        if(indicator) indicator.style.display = show ? 'block' : 'none';
    }
    function toggle(){
        var p=document.getElementById('smart-chat-panel');if(!p)return;
        isOpen=!isOpen;p.classList.toggle('open',isOpen);
        if(isOpen){var f=document.getElementById('smart-chat-iframe');if(f&&!f.src)f.src='./chat/index.php';}
        updateIndicator(!isOpen);
    }
    function switchTab(tab,btn){
        var f=document.getElementById('smart-chat-iframe');if(!f)return;
        f.src='./chat/index.php'+(tab==='alliance'?'?action=alliance':'');
        document.querySelectorAll('.chat-tab').forEach(function(t){t.classList.remove('active');});
        if(btn)btn.classList.add('active');
    }
    window.setInterval(function(){ if(!isOpen) updateIndicator(true); }, 30000);
    updateIndicator(true);
    return{toggle:toggle,switchTab:switchTab};
})();
</script>
{% endautoescape %}

