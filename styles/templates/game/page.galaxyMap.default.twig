{% extends "layout.full.twig" %}

{% block title %}Galaxy Map{% endblock %}

{% block content %}
{% autoescape false %}
<script>
  window.SM = {
    userId:  {{ USER.id|default(0) }},
    allyId:  {{ USER.ally_id|default(0) }},
    galaxy:  {{ PLANET.galaxy|default(1) }},
    system:  {{ PLANET.system|default(1) }},
    planet:  {{ PLANET.planet|default(1) }},
    planetName: {{ USER.current_planet|default('Home Planet')|json_encode }},
    apiBase: 'game.php?page=galaxyMap&mode='
  };
</script>
{% endautoescape %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600&display=swap');

/* ── Root: covers full viewport over game UI ──────────────────────── */
#gm-root {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 8000;
  background: #020510;
  font-family: 'Rajdhani', sans-serif;
  color: #c8e6ff;
  overflow: hidden;
  /* Footer height injected by JS as --ingameFooterH */
  --ingameFooterH: 0px;
}

/* Canvas wrapper: pointer-events:none so panel edges don't block canvas pan */
.galaxy-wrapper {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

#gm-canvas {
  position: absolute;
  inset: 0;
  /* 100dvh respects mobile browser chrome (address bar) */
  width: 100% !important;
  height: 100% !important;
  display: block;
  cursor: grab;
  pointer-events: all;
  z-index: 1;
  touch-action: none;
}
#gm-canvas:active { cursor: grabbing; }

/* HUD and panels sit above canvas */
#gm-hud, #gm-side, #gm-action, #gm-card, #gm-tip, #gm-load, #gm-hint {
  z-index: 100;
  pointer-events: all;
}

/* ── CSS Variables ───────────────────────────────────────────────── */
#gm-root {
  --cyan:   #00d4ff;
  --gold:   #ffd700;
  --red:    #e8304a;
  --green:  #00e87a;
  --purple: #a855f7;
  --dim:    #4a6a8a;
  --text:   #c8e6ff;
  --panel:  rgba(4,14,38,0.90);
  --border: rgba(0,200,255,0.18);
}

/* ── HUD top bar ─────────────────────────────────────────────────── */
#gm-hud {
  position: absolute; top: 0; left: 0; right: 0;
  min-height: 50px;
  background: linear-gradient(180deg,rgba(2,5,16,.97) 55%,transparent);
  display: flex; align-items: center; gap: 8px;
  padding: 6px 12px; z-index: 100; pointer-events: none;
  flex-wrap: wrap;
}
.hud-title {
  font-family: 'Orbitron', monospace;
  font-size: 12px; font-weight: 900;
  color: var(--cyan); letter-spacing: 4px;
  text-shadow: 0 0 20px var(--cyan);
}
.hud-sep { width: 1px; height: 18px; background: var(--border); }
.hud-pill {
  padding: 2px 8px; border-radius: 20px;
  font-family: 'Orbitron', monospace; font-size: 10px; letter-spacing: 1px;
  white-space: nowrap;
}
.hud-pill.c { border:1px solid rgba(0,212,255,.3);  color:var(--cyan);   background:rgba(0,212,255,.07); }
.hud-pill.g { border:1px solid rgba(0,255,136,.3);  color:var(--green);  background:rgba(0,255,136,.07); }
.hud-pill.r { border:1px solid rgba(255,48,96,.35); color:var(--red);    background:rgba(255,48,96,.09); }

/* Close button to go back to game */
#gm-close {
  margin-left: auto;
  flex-shrink: 0;
  pointer-events: all;
  background: rgba(255,48,96,.1);
  border: 1px solid rgba(255,48,96,.3);
  color: var(--red);
  padding: 4px 10px; border-radius: 6px;
  font-family: 'Orbitron', monospace; font-size: 9px; letter-spacing: 1px;
  cursor: pointer; transition: all .2s; white-space: nowrap;
}
#gm-close:hover { background: rgba(255,48,96,.25); }

/* ── Side panel ──────────────────────────────────────────────────── */
#gm-side {
  position: absolute; top: 58px; left: 12px;
  width: 236px;
  /* Bottom guard: never overlap footer – use ingameFooterH + action panel height + padding */
  max-height: calc(100vh - 58px - var(--ingameFooterH) - 80px);
  overflow-y: auto;
  background: var(--panel); backdrop-filter: blur(18px);
  border: 1px solid var(--border); border-radius: 12px;
  padding: 13px 14px; z-index: 100;
  box-shadow: 0 8px 30px rgba(0,0,0,.75), inset 0 1px 0 rgba(255,255,255,.04);
  pointer-events: all;
}

/* ── Mobile: FAB + collapsible side panel ────────────────────────── */
#gm-panel-toggle {
  display: none; /* hidden on desktop */
}

/* FAB rendered OUTSIDE #gm-root so it is never clipped by overflow */
#gm-fab-outer {
  display: none;
  position: fixed;
  bottom: 72px;
  right: 14px;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: rgba(0,212,255,.18);
  border: 2px solid rgba(0,212,255,.55);
  color: #00d4ff;
  font-size: 20px;
  cursor: pointer;
  z-index: 9100;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  box-shadow: 0 4px 20px rgba(0,0,0,.65), 0 0 18px rgba(0,212,255,.18);
  align-items: center;
  justify-content: center;
  transition: background .2s, transform .15s;
  pointer-events: all;
}
#gm-fab-outer:hover, #gm-fab-outer.active {
  background: rgba(0,212,255,.32);
  transform: scale(1.08);
}

/* ── Mobile: hide 3D view button, only 2D available ─────────────── */
@media (max-width: 768px) {
  #vb-3d { display: none !important; }
  #gm-view-row .vw-btn:only-child,
  #vb-2d { flex: 1 1 100%; }
}

@media (max-width: 768px) {
  /* Canvas fills the full 100dvh (mobile browser bars excluded) */
  .galaxy-wrapper, #gm-canvas {
    height: 100dvh !important;
  }

  /* HUD: compact on mobile so pills don't overflow */
  #gm-hud {
    gap: 5px;
    padding: 5px 8px;
  }
  .hud-title {
    font-size: 10px;
    letter-spacing: 2px;
  }
  .hud-pill {
    font-size: 9px;
    padding: 2px 6px;
  }
  .hud-sep { display: none; }

  /* Side panel: slides up from bottom */
  #gm-side {
    position: fixed;
    top: auto;
    bottom: calc(var(--ingameFooterH) + 68px);
    left: auto;
    right: 12px;
    width: calc(100vw - 24px);
    max-width: 340px;
    max-height: 52dvh;
    overflow-y: auto;
    transform: translateY(110%);
    transition: transform .28s cubic-bezier(.4,0,.2,1);
    border-radius: 14px 14px 6px 6px;
    z-index: 8100;
  }
  #gm-side.panel-open {
    transform: translateY(0);
  }

  /* Old inner FAB: hide (replaced by outer FAB) */
  #gm-panel-toggle {
    display: none !important;
  }

  /* Outer FAB visible on mobile */
  #gm-fab-outer {
    display: flex;
  }

  /* Action panel: full width, sits above FAB, never overflows viewport */
  #gm-action {
    min-width: unset !important;
    width: calc(100vw - 20px) !important;
    max-width: calc(100vw - 20px) !important;
    bottom: calc(var(--ingameFooterH) + 68px);
    left: 10px;
    transform: none;
    z-index: 8200;
    animation: none;
  }
  /* ap-meta grid: 2 cols on mobile */
  .ap-meta {
    grid-template-columns: 1fr 1fr;
  }
  @keyframes slideUp {
    from{opacity:0;transform:translateY(14px)}
    to  {opacity:1;transform:translateY(0)}
  }
}
.sp-h { font-family:'Orbitron',monospace; font-size:8px; letter-spacing:2px; color:var(--dim); margin-bottom:8px; display:flex; align-items:center; gap:5px; }
.sp-h i { color:var(--cyan); opacity:.7; }
.sp-row { display:flex; gap:7px; margin-bottom:7px; }
.sp-col { flex:1; }
.sp-lbl { font-size:10px; color:var(--dim); font-family:'Orbitron',monospace; letter-spacing:1px; margin-bottom:3px; }
.sp-inp {
  width:100%; background:rgba(0,0,0,.5);
  border:1px solid rgba(0,212,255,.2); border-radius:6px;
  padding:5px 7px; color:#fff;
  font-family:'Orbitron',monospace; font-size:12px; outline:none; box-sizing:border-box;
  transition:border-color .2s;
}
.sp-inp:focus { border-color:var(--cyan); }
.sp-btn {
  width:100%; padding:7px; border-radius:7px; border:none;
  cursor:pointer; font-family:'Orbitron',monospace; font-size:9px;
  letter-spacing:1.5px; transition:all .2s; margin-top:4px;
}
.sp-btn.c { background:rgba(0,212,255,.09);  border:1px solid rgba(0,212,255,.28);  color:var(--cyan); }
.sp-btn.g { background:rgba(0,232,122,.07);  border:1px solid rgba(0,232,122,.26);  color:var(--green); }
.sp-btn:disabled { opacity:.35; cursor:not-allowed; }
.sp-btn.c:not(:disabled):hover { background:rgba(0,212,255,.2); }
.sp-btn.g:not(:disabled):hover { background:rgba(0,232,122,.16); }
.sp-sep { border:none; border-top:1px solid rgba(0,212,255,.09); margin:9px 0; }
.leg { display:flex; align-items:center; gap:7px; margin-bottom:4px; font-size:11px; color:#8aaccc; }
.leg-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.leg-line { width:18px; height:2px; flex-shrink:0; }
.leg-dash { width:18px; height:0; flex-shrink:0; border-top:2px dashed currentColor; opacity:.7; }
.vw-row { display:flex; gap:6px; }
.vw-btn {
  flex:1; padding:6px; text-align:center; border-radius:7px;
  cursor:pointer; font-size:9px; font-family:'Orbitron',monospace; letter-spacing:1px;
  background:rgba(0,0,0,.3); border:1px solid rgba(0,212,255,.1); color:var(--dim);
  transition:all .2s;
}
.vw-btn.on { background:rgba(0,212,255,.14); border-color:var(--cyan); color:var(--cyan); }
.st-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:4px; font-size:11px; }
.sk { color:var(--dim); }
.sv { font-family:'Orbitron',monospace; font-size:10px; }
.sv.c { color:var(--cyan); }
.sv.g { color:var(--green); }
.sv.r { color:var(--red); }
#jump-hint { font-size:9px; color:var(--green); font-family:'Orbitron',monospace; letter-spacing:1px; margin-top:4px; min-height:13px; text-align:center; transition:opacity .3s; }

/* ── Action panel ────────────────────────────────────────────────── */
#gm-action {
  position:absolute; bottom:calc(var(--ingameFooterH) + 12px); left:50%; transform:translateX(-50%);
  min-width:min(430px, calc(100vw - 24px)); max-width:min(590px, calc(100vw - 24px));
  width: max-content;
  background:var(--panel); backdrop-filter:blur(22px);
  border:1px solid var(--border); border-radius:13px;
  padding:15px 17px 13px; z-index:200; display:none;
  box-shadow:0 16px 50px rgba(0,0,0,.85);
  animation:slideUp .2s ease;
}
@keyframes slideUp {
  from{opacity:0;transform:translateX(-50%) translateY(14px)}
  to  {opacity:1;transform:translateX(-50%) translateY(0)}
}
.ap-x { position:absolute;top:8px;right:12px;background:none;border:none;color:var(--dim);font-size:17px;cursor:pointer; }
.ap-x:hover { color:var(--red); }
.ap-name { font-family:'Orbitron',monospace;font-size:13px;color:var(--cyan);letter-spacing:2px;margin-bottom:2px; }
.ap-coord { font-size:11px;color:var(--dim);font-family:'Orbitron',monospace;margin-bottom:10px; }
.ap-meta { display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:11px; }
.ap-box { background:rgba(0,0,0,.32);border:1px solid rgba(255,255,255,.05);border-radius:7px;padding:7px 9px;text-align:center; }
.ap-box-lbl { font-size:9px;color:var(--dim);font-family:'Orbitron',monospace;letter-spacing:1px; }
.ap-box-val { font-size:12px;margin-top:2px; }
.ap-btns { display:flex;flex-wrap:wrap;gap:7px;justify-content:center; }
.ap-btn {
  padding:7px 13px;border-radius:7px;border:none;cursor:pointer;
  font-family:'Orbitron',monospace;font-size:9px;letter-spacing:1px;
  display:inline-flex;align-items:center;gap:5px;
  transition:all .2s;text-decoration:none;line-height:1;
}
.ap-btn:hover { filter:brightness(1.45);transform:translateY(-1px); }
.ab-spy  { background:rgba(255,255,0,.09);  border:1px solid rgba(255,255,0,.28);  color:#ffee00; }
.ab-atk  { background:rgba(255,48,96,.1);   border:1px solid rgba(255,48,96,.35);  color:var(--red); }
.ab-flt  { background:rgba(0,212,255,.09);  border:1px solid rgba(0,212,255,.28);  color:var(--cyan); }
.ab-msg  { background:rgba(168,85,247,.09); border:1px solid rgba(168,85,247,.3);  color:var(--purple); }
.ab-card { background:rgba(255,215,0,.07);  border:1px solid rgba(255,215,0,.25);  color:var(--gold); }
.ab-rec  { background:rgba(255,153,0,.09);  border:1px solid rgba(255,153,0,.28);  color:#ff9900; }
.ap-own  { text-align:center;padding:7px;font-size:11px;color:var(--green);font-family:'Orbitron',monospace;letter-spacing:1px; }

/* ── Player card ─────────────────────────────────────────────────── */
#gm-card {
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:420px;max-width:calc(100vw - 24px);
  background:rgba(4,10,28,0.97);backdrop-filter:blur(28px);
  border:1px solid rgba(168,85,247,.38);border-radius:16px;
  overflow:hidden;z-index:300;display:none;
  box-shadow:0 24px 70px rgba(0,0,0,.95),0 0 60px rgba(168,85,247,.12),inset 0 1px 0 rgba(255,255,255,.06);
  animation:fadeScale .25s ease;
}
@keyframes fadeScale {
  from{opacity:0;transform:translate(-50%,-50%) scale(.88)}
  to  {opacity:1;transform:translate(-50%,-50%) scale(1)}
}
.pc-banner {
  height:72px;position:relative;overflow:hidden;
  background:linear-gradient(135deg,rgba(0,212,255,.18) 0%,rgba(168,85,247,.22) 50%,rgba(0,0,0,.4) 100%);
}
.pc-banner::after {
  content:'';position:absolute;inset:0;
  background:linear-gradient(180deg,transparent 30%,rgba(4,10,28,.9) 100%);
}
.pc-banner-grid {
  position:absolute;inset:0;opacity:.12;
  background-image:linear-gradient(rgba(0,212,255,.4) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,.4) 1px,transparent 1px);
  background-size:28px 28px;
}
.pc-av-wrap { position:absolute;left:18px;bottom:-20px;z-index:2; }
.pc-av {
  width:56px;height:56px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:22px;font-weight:700;color:#fff;font-family:'Orbitron',monospace;
  background:linear-gradient(135deg,var(--cyan),var(--purple));
  border:3px solid rgba(4,10,28,.9);box-shadow:0 0 20px rgba(168,85,247,.4);
}
.pc-x { position:absolute;top:10px;right:14px;background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.1);color:var(--dim);font-size:15px;cursor:pointer;width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;z-index:10;transition:all .2s; }
.pc-x:hover { color:var(--red);background:rgba(255,48,96,.18);border-color:rgba(255,48,96,.35); }
.pc-body-inner { padding:28px 18px 16px; }
.pc-hdr { display:flex;align-items:flex-end;gap:12px;margin-bottom:12px; }
.pc-hdr-info { flex:1; }
.pc-nm { font-family:'Orbitron',monospace;font-size:15px;color:#fff;font-weight:700; }
.pc-al { font-size:11px;color:var(--purple);margin-top:2px;letter-spacing:.5px; }
.pc-on { font-size:10px;color:var(--dim);margin-top:3px;display:flex;align-items:center;gap:5px; }
.dot { display:inline-block;width:7px;height:7px;border-radius:50%;flex-shrink:0; }
.dot-on  { background:var(--green);box-shadow:0 0 6px var(--green); }
.dot-off { background:var(--dim); }
.pc-divider { height:1px;background:rgba(255,255,255,.06);margin:10px 0; }
.pc-grid { display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px; }
.pc-st {
  background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.05);border-radius:8px;padding:8px 10px;
  transition:border-color .2s;
}
.pc-st:hover { border-color:rgba(0,212,255,.2); }
.pc-st-lbl { font-size:9px;color:var(--dim);font-family:'Orbitron',monospace;letter-spacing:1px;text-transform:uppercase; }
.pc-st-val { font-size:13px;color:#fff;margin-top:2px;font-family:'Orbitron',monospace; }
.pc-st-rnk { font-size:9px;color:var(--cyan);margin-top:1px; }
.pc-fights { display:flex;justify-content:space-around;background:rgba(0,0,0,.25);border:1px solid rgba(255,255,255,.04);border-radius:8px;padding:10px 8px;margin-bottom:10px; }
.pcf { text-align:center; }
.pcf-n { font-family:'Orbitron',monospace;font-size:15px;font-weight:700; }
.pcf-l { font-size:9px;color:var(--dim);margin-top:3px;letter-spacing:.8px; }
.pc-winbar-wrap { margin-bottom:10px; }
.pc-winbar-lbl { display:flex;justify-content:space-between;font-size:9px;color:var(--dim);font-family:'Orbitron',monospace;letter-spacing:1px;margin-bottom:4px; }
.pc-winbar-track { height:6px;background:rgba(255,255,255,.07);border-radius:4px;overflow:hidden;display:flex; }
.pc-winbar-w { height:100%;background:var(--green);transition:width .6s cubic-bezier(.4,0,.2,1); }
.pc-winbar-d { height:100%;background:rgba(168,200,232,.35); }
.pc-winbar-l { height:100%;background:var(--red); }
.pc-acts { display:flex;gap:7px;flex-wrap:wrap;justify-content:center; }

/* ── Player search results ──────────────────────────────────────── */
.gm-sr-item {
  display:flex;align-items:center;gap:8px;
  padding:7px 9px;border-radius:7px;cursor:pointer;
  border:1px solid transparent;transition:all .15s;
  font-size:11px;
}
.gm-sr-item:hover { background:rgba(0,212,255,.07);border-color:rgba(0,212,255,.15); }
.gm-sr-av {
  width:26px;height:26px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:10px;font-weight:700;color:#fff;font-family:'Orbitron',monospace;
  background:linear-gradient(135deg,var(--cyan),var(--purple));
}
.gm-sr-name { color:var(--text);font-family:'Orbitron',monospace;letter-spacing:.5px;flex:1; }
.gm-sr-coord { font-size:9px;color:var(--dim); }
.gm-sr-pts { font-size:9px;color:var(--cyan);font-family:'Orbitron',monospace; }
.gm-sr-none { text-align:center;padding:10px;font-size:10px;color:var(--dim);font-family:'Orbitron',monospace;letter-spacing:1px; }

/* ── Tooltip ─────────────────────────────────────────────────────── */
#gm-tip {
  position:fixed;
  background:rgba(2,5,16,.96);backdrop-filter:blur(10px);
  border:1px solid rgba(0,212,255,.2);border-radius:8px;
  padding:9px 12px;font-size:12px;color:var(--text);
  pointer-events:none;display:none;
  min-width:140px;z-index:600;
  box-shadow:0 6px 20px rgba(0,0,0,.7);
}
.tt-h { font-family:'Orbitron',monospace;font-size:10px;letter-spacing:1.5px;margin-bottom:4px; }
.tt-l { margin:2px 0;color:var(--dim); }
.tt-l span { color:var(--text); }

/* ── Loader ──────────────────────────────────────────────────────── */
#gm-load {
  position:absolute;inset:0;background:#020510;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  z-index:2000;transition:opacity .45s;
}
.ld-ring {
  width:52px;height:52px;
  border:2px solid rgba(0,212,255,.12);
  border-top:2px solid var(--cyan);
  border-radius:50%;animation:spin 1s linear infinite;margin-bottom:16px;
}
@keyframes spin{to{transform:rotate(360deg)}}
.ld-txt { font-family:'Orbitron',monospace;font-size:10px;letter-spacing:3px;color:var(--cyan); }

#gm-hint {
  position:absolute;bottom:12px;left:50%;transform:translateX(-50%);
  font-family:'Orbitron',monospace;font-size:8px;letter-spacing:1.5px;
  color:rgba(255,255,255,.22);pointer-events:none;white-space:nowrap;
  background:rgba(2,5,16,.55);backdrop-filter:blur(6px);
  padding:4px 14px;border-radius:20px;
  border:1px solid rgba(0,212,255,.07);
}
</style>

<!-- The map root: position:fixed so it sits OVER the game layout -->
<div id="gm-root">
  <!-- Loader -->
  <div id="gm-load">
    <div class="ld-ring"></div>
    <div class="ld-txt" id="ld-txt">SCANNING UNIVERSE…</div>
  </div>

  <!-- Canvas wrapper -->
  <div class="galaxy-wrapper">
    <canvas id="gm-canvas"></canvas>
  </div>

  <!-- HUD -->
  <div id="gm-hud">
