// ── Camera sync ────────────────────────────────────────────
// Zoom clamped to [100, 10000] per spec
const MIN_DIST = 100;
const MAX_DIST = 10000;
function syncCamera() {
  if (!camera) return;
  orb.r = Math.max(MIN_DIST, Math.min(MAX_DIST, orb.r));
  if (is3D) {
    camera.position.set(
      orb.tx + orb.r*Math.sin(orb.phi)*Math.sin(orb.theta),
      orb.ty + orb.r*Math.cos(orb.phi),
      orb.tz + orb.r*Math.sin(orb.phi)*Math.cos(orb.theta)
    );
    camera.lookAt(orb.tx, orb.ty, orb.tz);
  } else {
    camera.position.set(pan.x, orb.r*.75, pan.z);
    camera.lookAt(pan.x, 0, pan.z);
  }
}

// ── Footer height measurement (fixes overlap) ───────────────
function measureFooterHeight() {
  const measure = () => {
    // Try game footer selectors in order of specificity
    const footer = document.querySelector('.mobile-dock, .footer, footer, #footer, .game-footer, .ingame-footer')
      || document.querySelector('[class*="footer"]:not(#gm-root *)') || document.querySelector('[class*="dock"]:not(#gm-root *)');
    if (footer) {
      const style = window.getComputedStyle(footer);
      const isFixed = style.position === 'fixed' || style.position === 'sticky';
      if (isFixed) {
        const h = footer.getBoundingClientRect().height;
        document.getElementById('gm-root').style.setProperty('--ingameFooterH', h + 'px');
        return;
      }
    }
    // Fallback: on mobile, assume 70px dock height so FAB/panel never hide behind it
    if (window.innerWidth <= 768) {
      document.getElementById('gm-root').style.setProperty('--ingameFooterH', '70px');
    }
  };
  measure();
  // Re-measure on resize (mobile orientation change etc.)
  window.addEventListener('resize', measure, { passive: true });
}

// ── Mobile panel toggle (FAB) ───────────────────────────────
function initMobilePanel() {
  const fab   = document.getElementById('gm-panel-toggle');
  const panel = document.getElementById('gm-side');
  if (!fab || !panel) return;

  // Restore saved state
  try {
    if (localStorage.getItem('galaxyPanel') === 'open') {
      panel.classList.add('panel-open');
      fab.classList.add('active');
    }
  } catch(e) {}

  fab.addEventListener('click', e => {
    e.stopPropagation();
    const open = panel.classList.toggle('panel-open');
    fab.classList.toggle('active', open);
    try { localStorage.setItem('galaxyPanel', open ? 'open' : 'collapsed'); } catch(e2) {}
  });

  // Tap on canvas closes panel (mobile UX)
  canvas.addEventListener('touchstart', () => {
    if (window.innerWidth <= 768 && panel.classList.contains('panel-open')) {
      panel.classList.remove('panel-open');
      fab.classList.remove('active');
      try { localStorage.setItem('galaxyPanel', 'collapsed'); } catch(e) {}
    }
  }, { passive: true });
}

// ── Input events ───────────────────────────────────────────
function bindEvents() {
  canvas.addEventListener('mousedown', e=>{
    drag.down=true; drag.moved=0;
    drag.startX=e.clientX; drag.startY=e.clientY;
    drag.snapTheta=orb.theta; drag.snapPhi=orb.phi;
    drag.snapPanX=pan.x; drag.snapPanZ=pan.z;
    canvas.style.cursor='grabbing';
  });
  window.addEventListener('mouseup',()=>{drag.down=false;canvas.style.cursor='grab';});
  window.addEventListener('mousemove', e=>{
    if (drag.down) {
      const dx=e.clientX-drag.startX, dy=e.clientY-drag.startY;
      drag.moved=Math.max(drag.moved,Math.abs(dx)+Math.abs(dy));
      if (is3D) {
        orb.theta=drag.snapTheta-dx*.0055;
        orb.phi=Math.max(.12,Math.min(1.55,drag.snapPhi+dy*.0055));
      } else {
        pan.x=drag.snapPanX-dx*orb.r*.0016;
        pan.z=drag.snapPanZ-dy*orb.r*.0016;
      }
      syncCamera();
    } else { doHover(e.clientX,e.clientY); }
  });

  canvas.addEventListener('click', e=>{if(drag.moved<6)doClick(e.clientX,e.clientY);});

  canvas.addEventListener('wheel', e=>{
    e.preventDefault();
    orb.r = Math.max(MIN_DIST, Math.min(MAX_DIST, orb.r + e.deltaY * 1.2));
    syncCamera();
  },{passive:false});

  // Touch
  let tStart=null,tDist=0;
  canvas.addEventListener('touchstart',e=>{
    if(e.touches.length===1){
      tStart={x:e.touches[0].clientX,y:e.touches[0].clientY,
              theta:orb.theta,phi:orb.phi,px:pan.x,pz:pan.z};
    } else if(e.touches.length===2){
      tDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,
                       e.touches[0].clientY-e.touches[1].clientY);
    }
  },{passive:true});
  canvas.addEventListener('touchmove',e=>{
    e.preventDefault();
    if(e.touches.length===1&&tStart){
      const dx=e.touches[0].clientX-tStart.x, dy=e.touches[0].clientY-tStart.y;
      if(is3D){orb.theta=tStart.theta-dx*.007;orb.phi=Math.max(.12,Math.min(1.55,tStart.phi+dy*.007));}
      else{pan.x=tStart.px-dx*orb.r*.002;pan.z=tStart.pz-dy*orb.r*.002;}
      syncCamera();
    } else if(e.touches.length===2){
      const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,
                         e.touches[0].clientY-e.touches[1].clientY);
      orb.r = Math.max(MIN_DIST, Math.min(MAX_DIST, orb.r * (tDist / d)));
      tDist=d; syncCamera();
    }
  },{passive:false});

  window.addEventListener('resize',()=>{
    camera.aspect=innerWidth/innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(innerWidth,innerHeight);
  });
}

// ── Raycasting ─────────────────────────────────────────────
// Always use canvas-relative coords (NOT window) so NDC is correct
// regardless of where the canvas sits in the page layout.
const DEBUG_PICK = (new URLSearchParams(location.search)).get('debugPick') === '1';

function setMV(cx, cy) {
  const r = canvas.getBoundingClientRect();
  MV.x =  ((cx - r.left) / r.width)  * 2 - 1;
  MV.y = -((cy - r.top)  / r.height) * 2 + 1;
}

function hitPlanet(cx, cy) {
  if (!planetMeshes.length) return null;
  setMV(cx, cy);
  RC.setFromCamera(MV, camera);
  // Intersect ONLY the dedicated planetMeshes list
  const hits = RC.intersectObjects(planetMeshes, false);
  if (DEBUG_PICK) console.log('[pick] planet hits:', hits.length, hits.map(h => h.object.userData.key + ' d=' + h.distance.toFixed(0)));
  // Require: userData.type === 'planet'  AND  within distance gate
  for (const h of hits) {
    if (h.object.userData.type !== 'planet') continue;
    if (h.distance > MAX_PICK_DISTANCE) continue;
    return h.object.userData.planet;
  }
  return null;
}

function hitFleet(cx, cy) {
  const dots = fleetGroup.children.filter(c => c.userData.isFleetDot);
  if (!dots.length) return null;
  setMV(cx, cy);
  RC.setFromCamera(MV, camera);
  const hits = RC.intersectObjects(dots, false);
  return hits.length ? hits[0].object.userData.fleet : null;
}

function doHover(cx,cy){
  // Check fleet dots first (they're smaller targets)
  const fl=hitFleet(cx,cy);
  if(fl){
    canvas.style.cursor='pointer';
    tipEl.style.display='block';
    tipEl.style.left=(cx+16)+'px'; tipEl.style.top=(cy+10)+'px';
    const nowS = (Date.now()/1000) + serverTimeOffset;
    const remaining = Math.max(0, Math.round(fl.end_time - nowS));
    const mins=Math.floor(remaining/60), secs=remaining%60;
    const fcol = fl.is_hostile?'var(--red)':fl.is_own?'var(--cyan)':'var(--dim)';
    tipEl.innerHTML=`
      <div class="tt-h" style="color:${fcol}">${fl.mission_name||'FLEET'}</div>
      <div class="tt-l">Commander: <span>${fl.owner_name||'?'}</span></div>
      <div class="tt-l">From: <span>[${fl.start.g}:${fl.start.s}:${fl.start.p}]</span></div>
      <div class="tt-l">To: <span>[${fl.end.g}:${fl.end.s}:${fl.end.p}]</span></div>
      <div class="tt-l">ETA: <span>${mins}m ${secs}s</span></div>
    `;
    return;
  }
  const pl=hitPlanet(cx,cy);
  if(pl){
    canvas.style.cursor='pointer';
    tipEl.style.display='block';
    tipEl.style.left=(cx+16)+'px'; tipEl.style.top=(cy+10)+'px';
    if(pl.is_empty){
      /* Freier Slot */
      tipEl.innerHTML=`<div class="tt-h" style="color:#4a6a8a">FREIER SLOT</div><div class="tt-l">[${pl.galaxy}:${pl.system}:${pl.planet}]</div><div class="tt-l" style="color:var(--cyan)">Klicken zum Kolonisieren</div>`;
    } else {
      const c=pl.is_own?'var(--green)':pl.is_ally?'var(--purple)':'var(--cyan)';
      const name=(pl.name||'Unknown Planet').toUpperCase();
      tipEl.innerHTML=`
        <div class="tt-h" style="color:${c}">${name}</div>
        <div class="tt-l">[${pl.galaxy}:${pl.system}:${pl.planet}]</div>
        <div class="tt-l">Player: <span>${pl.username||'?'}</span></div>
        ${pl.ally_tag?`<div class="tt-l">Alliance: <span>[${pl.ally_tag}]</span></div>`:''}
        <div class="tt-l">Rank: <span>#${pl.total_rank||'?'}</span></div>
        ${pl.has_moon?'<div class="tt-l" style="color:#aaa"><i class="fas fa-moon fa-xs"></i> Moon</div>':''}
        ${pl.has_debris?'<div class="tt-l" style="color:#ff9900"><i class="fas fa-ring fa-xs"></i> Debris</div>':''}
      `;
    }
  } else {
    canvas.style.cursor='grab';
    tipEl.style.display='none';
  }
}

function doClick(cx, cy) {
  const pl = hitPlanet(cx, cy);
  if (pl) {
    selectPlanet(pl);
    showAction(pl);
    tipEl.style.display = 'none';
  } else {
    deselectPlanet();
    closeAction();
  }
}

// ── Planet selection + highlight ring ──────────────────────
function selectPlanet(pl) {
  selectedPlanet = pl;
  // Remove old ring
  if (selRing) { planetGroup.remove(selRing); selRing.geometry.dispose(); selRing.material.dispose(); selRing = null; }
  // Use live mesh position (planet is orbiting – posMap is updated by animate loop)
  const key = `${pl.galaxy}:${pl.system}:${pl.planet}`;
  const sprite = planetMeshes.find(s => s.userData.key === key);
  const pos = sprite ? sprite.position : posMap[key];
  if (!pos) return;
  const sz = sprite ? sprite.userData.baseScale * 0.62 : 9;
  const rg = new THREE.RingGeometry(sz, sz + 1.4, 32);
  const rm = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.55, side: THREE.DoubleSide, depthWrite: false });
  selRing = new THREE.Mesh(rg, rm);
  selRing.position.copy(pos);
  selRing.rotation.x = -Math.PI / 2;
  planetGroup.add(selRing);
  set('st-sel', key);
}

function deselectPlanet() {
  selectedPlanet = null;
  if (selRing) { planetGroup.remove(selRing); selRing.geometry.dispose(); selRing.material.dispose(); selRing = null; }
  set('st-sel', '–');
}

