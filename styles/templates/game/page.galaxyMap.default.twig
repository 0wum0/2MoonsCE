{% extends "layout.full.twig" %}

{% block title %}Galaxy Map{% endblock %}

{% block content %}
{% autoescape false %}
<script>
  window.SM = {
    userId:  {{ USER.id|default(0) }},
    allyId:  {{ USER.ally_id|default(0) }},
    galaxy:  {{ PLANET.galaxy|default(1) }},
    system:  {{ PLANET.system|default(1) }},
    planet:  {{ PLANET.planet|default(1) }},
    planetName: {{ USER.current_planet|default('Home Planet')|json_encode }},
    apiBase: 'game.php?page=galaxyMap&mode='
  };
</script>
{% endautoescape %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600&display=swap');

/* ── Escape the game layout container ─────────────────────────────── */
/* The map needs to cover the full viewport over the game UI */
#gm-root {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9000;
  background: #020510;
  font-family: 'Rajdhani', sans-serif;
  color: #c8e6ff;
  overflow: hidden;
}

#gm-canvas {
  position: absolute;
  inset: 0;
  width: 100% !important;
  height: 100% !important;
  display: block;
  cursor: grab;
}
#gm-canvas:active { cursor: grabbing; }

/* ── CSS Variables ───────────────────────────────────────────────── */
#gm-root {
  --cyan:   #00d4ff;
  --gold:   #ffd700;
  --red:    #e8304a;
  --green:  #00e87a;
  --purple: #a855f7;
  --dim:    #4a6a8a;
  --text:   #c8e6ff;
  --panel:  rgba(4,14,38,0.90);
  --border: rgba(0,200,255,0.18);
}

/* ── HUD top bar ─────────────────────────────────────────────────── */
#gm-hud {
  position: absolute; top: 0; left: 0; right: 0; height: 50px;
  background: linear-gradient(180deg,rgba(2,5,16,.97) 55%,transparent);
  display: flex; align-items: center; gap: 12px;
  padding: 0 16px; z-index: 100; pointer-events: none;
}
.hud-title {
  font-family: 'Orbitron', monospace;
  font-size: 12px; font-weight: 900;
  color: var(--cyan); letter-spacing: 4px;
  text-shadow: 0 0 20px var(--cyan);
}
.hud-sep { width: 1px; height: 18px; background: var(--border); }
.hud-pill {
  padding: 2px 10px; border-radius: 20px;
  font-family: 'Orbitron', monospace; font-size: 10px; letter-spacing: 1px;
}
.hud-pill.c { border:1px solid rgba(0,212,255,.3);  color:var(--cyan);   background:rgba(0,212,255,.07); }
.hud-pill.g { border:1px solid rgba(0,255,136,.3);  color:var(--green);  background:rgba(0,255,136,.07); }
.hud-pill.r { border:1px solid rgba(255,48,96,.35); color:var(--red);    background:rgba(255,48,96,.09); }

/* Close button to go back to game */
#gm-close {
  margin-left: auto;
  pointer-events: all;
  background: rgba(255,48,96,.1);
  border: 1px solid rgba(255,48,96,.3);
  color: var(--red);
  padding: 4px 12px; border-radius: 6px;
  font-family: 'Orbitron', monospace; font-size: 9px; letter-spacing: 1px;
  cursor: pointer; transition: all .2s;
}
#gm-close:hover { background: rgba(255,48,96,.25); }

/* ── Side panel ──────────────────────────────────────────────────── */
#gm-side {
  position: absolute; top: 58px; left: 12px;
  width: 236px;
  background: var(--panel); backdrop-filter: blur(18px);
  border: 1px solid var(--border); border-radius: 12px;
  padding: 13px 14px; z-index: 100;
  box-shadow: 0 8px 30px rgba(0,0,0,.75), inset 0 1px 0 rgba(255,255,255,.04);
}
.sp-h { font-family:'Orbitron',monospace; font-size:8px; letter-spacing:2px; color:var(--dim); margin-bottom:8px; display:flex; align-items:center; gap:5px; }
.sp-h i { color:var(--cyan); opacity:.7; }
.sp-row { display:flex; gap:7px; margin-bottom:7px; }
.sp-col { flex:1; }
.sp-lbl { font-size:10px; color:var(--dim); font-family:'Orbitron',monospace; letter-spacing:1px; margin-bottom:3px; }
.sp-inp {
  width:100%; background:rgba(0,0,0,.5);
  border:1px solid rgba(0,212,255,.2); border-radius:6px;
  padding:5px 7px; color:#fff;
  font-family:'Orbitron',monospace; font-size:12px; outline:none; box-sizing:border-box;
  transition:border-color .2s;
}
.sp-inp:focus { border-color:var(--cyan); }
.sp-btn {
  width:100%; padding:7px; border-radius:7px; border:none;
  cursor:pointer; font-family:'Orbitron',monospace; font-size:9px;
  letter-spacing:1.5px; transition:all .2s; margin-top:4px;
}
.sp-btn.c { background:rgba(0,212,255,.09);  border:1px solid rgba(0,212,255,.28);  color:var(--cyan); }
.sp-btn.g { background:rgba(0,232,122,.07);  border:1px solid rgba(0,232,122,.26);  color:var(--green); }
.sp-btn:disabled { opacity:.35; cursor:not-allowed; }
.sp-btn.c:not(:disabled):hover { background:rgba(0,212,255,.2); }
.sp-btn.g:not(:disabled):hover { background:rgba(0,232,122,.16); }
.sp-sep { border:none; border-top:1px solid rgba(0,212,255,.09); margin:9px 0; }
.leg { display:flex; align-items:center; gap:7px; margin-bottom:4px; font-size:11px; color:#8aaccc; }
.leg-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.leg-line { width:18px; height:2px; flex-shrink:0; }
.leg-dash { width:18px; height:0; flex-shrink:0; border-top:2px dashed currentColor; opacity:.7; }
.vw-row { display:flex; gap:6px; }
.vw-btn {
  flex:1; padding:6px; text-align:center; border-radius:7px;
  cursor:pointer; font-size:9px; font-family:'Orbitron',monospace; letter-spacing:1px;
  background:rgba(0,0,0,.3); border:1px solid rgba(0,212,255,.1); color:var(--dim);
  transition:all .2s;
}
.vw-btn.on { background:rgba(0,212,255,.14); border-color:var(--cyan); color:var(--cyan); }
.st-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:4px; font-size:11px; }
.sk { color:var(--dim); }
.sv { font-family:'Orbitron',monospace; font-size:10px; }
.sv.c { color:var(--cyan); }
.sv.g { color:var(--green); }
.sv.r { color:var(--red); }
#jump-hint { font-size:9px; color:var(--green); font-family:'Orbitron',monospace; letter-spacing:1px; margin-top:4px; min-height:13px; text-align:center; transition:opacity .3s; }

/* ── Action panel ────────────────────────────────────────────────── */
#gm-action {
  position:absolute; bottom:65px; left:50%; transform:translateX(-50%);
  min-width:430px; max-width:590px;
  background:var(--panel); backdrop-filter:blur(22px);
  border:1px solid var(--border); border-radius:13px;
  padding:15px 17px 13px; z-index:200; display:none;
  box-shadow:0 16px 50px rgba(0,0,0,.85);
  animation:slideUp .2s ease;
}
@keyframes slideUp {
  from{opacity:0;transform:translateX(-50%) translateY(14px)}
  to  {opacity:1;transform:translateX(-50%) translateY(0)}
}
.ap-x { position:absolute;top:8px;right:12px;background:none;border:none;color:var(--dim);font-size:17px;cursor:pointer; }
.ap-x:hover { color:var(--red); }
.ap-name { font-family:'Orbitron',monospace;font-size:13px;color:var(--cyan);letter-spacing:2px;margin-bottom:2px; }
.ap-coord { font-size:11px;color:var(--dim);font-family:'Orbitron',monospace;margin-bottom:10px; }
.ap-meta { display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:11px; }
.ap-box { background:rgba(0,0,0,.32);border:1px solid rgba(255,255,255,.05);border-radius:7px;padding:7px 9px;text-align:center; }
.ap-box-lbl { font-size:9px;color:var(--dim);font-family:'Orbitron',monospace;letter-spacing:1px; }
.ap-box-val { font-size:12px;margin-top:2px; }
.ap-btns { display:flex;flex-wrap:wrap;gap:7px;justify-content:center; }
.ap-btn {
  padding:7px 13px;border-radius:7px;border:none;cursor:pointer;
  font-family:'Orbitron',monospace;font-size:9px;letter-spacing:1px;
  display:inline-flex;align-items:center;gap:5px;
  transition:all .2s;text-decoration:none;line-height:1;
}
.ap-btn:hover { filter:brightness(1.45);transform:translateY(-1px); }
.ab-spy  { background:rgba(255,255,0,.09);  border:1px solid rgba(255,255,0,.28);  color:#ffee00; }
.ab-atk  { background:rgba(255,48,96,.1);   border:1px solid rgba(255,48,96,.35);  color:var(--red); }
.ab-flt  { background:rgba(0,212,255,.09);  border:1px solid rgba(0,212,255,.28);  color:var(--cyan); }
.ab-msg  { background:rgba(168,85,247,.09); border:1px solid rgba(168,85,247,.3);  color:var(--purple); }
.ab-card { background:rgba(255,215,0,.07);  border:1px solid rgba(255,215,0,.25);  color:var(--gold); }
.ab-rec  { background:rgba(255,153,0,.09);  border:1px solid rgba(255,153,0,.28);  color:#ff9900; }
.ap-own  { text-align:center;padding:7px;font-size:11px;color:var(--green);font-family:'Orbitron',monospace;letter-spacing:1px; }

/* ── Player card ─────────────────────────────────────────────────── */
#gm-card {
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:395px;background:var(--panel);backdrop-filter:blur(26px);
  border:1px solid rgba(168,85,247,.32);border-radius:14px;
  padding:20px;z-index:300;display:none;
  box-shadow:0 20px 60px rgba(0,0,0,.92),0 0 50px rgba(168,85,247,.1);
  animation:fadeScale .25s ease;
}
@keyframes fadeScale {
  from{opacity:0;transform:translate(-50%,-50%) scale(.88)}
  to  {opacity:1;transform:translate(-50%,-50%) scale(1)}
}
.pc-x { position:absolute;top:10px;right:14px;background:none;border:none;color:var(--dim);font-size:19px;cursor:pointer; }
.pc-x:hover { color:var(--red); }
.pc-hdr { display:flex;align-items:center;gap:12px;margin-bottom:14px; }
.pc-av {
  width:46px;height:46px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;font-weight:700;color:#fff;font-family:'Orbitron',monospace;
  background:linear-gradient(135deg,var(--cyan),var(--purple));
}
.pc-nm { font-family:'Orbitron',monospace;font-size:14px;color:#fff; }
.pc-al { font-size:12px;color:var(--purple);margin-top:2px; }
.pc-on { font-size:10px;color:var(--dim);margin-top:3px; }
.pc-on .dot { display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:4px; }
.dot-on  { background:var(--green);box-shadow:0 0 5px var(--green); }
.dot-off { background:var(--dim); }
.pc-grid { display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px; }
.pc-st { background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.05);border-radius:7px;padding:7px 9px; }
.pc-st-lbl { font-size:9px;color:var(--dim);font-family:'Orbitron',monospace;letter-spacing:1px; }
.pc-st-val { font-size:13px;color:#fff;margin-top:1px; }
.pc-st-rnk { font-size:9px;color:var(--dim); }
.pc-fights { display:flex;justify-content:space-around;margin-bottom:10px; }
.pcf { text-align:center; }
.pcf-n { font-family:'Orbitron',monospace;font-size:14px; }
.pcf-l { font-size:10px;color:var(--dim);margin-top:2px; }
.pc-acts { display:flex;gap:7px;flex-wrap:wrap;justify-content:center; }

/* ── Tooltip ─────────────────────────────────────────────────────── */
#gm-tip {
  position:fixed;
  background:rgba(2,5,16,.96);backdrop-filter:blur(10px);
  border:1px solid rgba(0,212,255,.2);border-radius:8px;
  padding:9px 12px;font-size:12px;color:var(--text);
  pointer-events:none;display:none;
  min-width:140px;z-index:600;
  box-shadow:0 6px 20px rgba(0,0,0,.7);
}
.tt-h { font-family:'Orbitron',monospace;font-size:10px;letter-spacing:1.5px;margin-bottom:4px; }
.tt-l { margin:2px 0;color:var(--dim); }
.tt-l span { color:var(--text); }

/* ── Loader ──────────────────────────────────────────────────────── */
#gm-load {
  position:absolute;inset:0;background:#020510;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  z-index:2000;transition:opacity .45s;
}
.ld-ring {
  width:52px;height:52px;
  border:2px solid rgba(0,212,255,.12);
  border-top:2px solid var(--cyan);
  border-radius:50%;animation:spin 1s linear infinite;margin-bottom:16px;
}
@keyframes spin{to{transform:rotate(360deg)}}
.ld-txt { font-family:'Orbitron',monospace;font-size:10px;letter-spacing:3px;color:var(--cyan); }

#gm-hint {
  position:absolute;bottom:12px;left:50%;transform:translateX(-50%);
  font-family:'Orbitron',monospace;font-size:8px;letter-spacing:1.5px;
  color:rgba(255,255,255,.22);pointer-events:none;white-space:nowrap;
  background:rgba(2,5,16,.55);backdrop-filter:blur(6px);
  padding:4px 14px;border-radius:20px;
  border:1px solid rgba(0,212,255,.07);
}
</style>

<!-- The map root: position:fixed so it sits OVER the game layout -->
<div id="gm-root">
  <!-- Loader -->
  <div id="gm-load">
    <div class="ld-ring"></div>
    <div class="ld-txt" id="ld-txt">SCANNING UNIVERSE…</div>
  </div>

  <!-- Canvas -->
  <canvas id="gm-canvas"></canvas>

  <!-- HUD -->
  <div id="gm-hud">
    <span class="hud-title"><i class="fas fa-meteor" style="margin-right:8px"></i>GALAXY MAP</span>
    <div class="hud-sep"></div>
    <span class="hud-pill c" id="h-planets">– PLANETS</span>
    <span class="hud-pill g" id="h-fleets">– FLEETS</span>
    <span class="hud-pill r" id="h-hostile">– HOSTILE</span>
    <button id="gm-close" onclick="window.history.back()"><i class="fas fa-times" style="margin-right:5px"></i>CLOSE MAP</button>
  </div>

  <!-- Side panel -->
  <div id="gm-side">
    <div style="margin-bottom:11px">
      <div class="sp-h"><i class="fas fa-sliders-h" style="margin-right:5px"></i>VIEW MODE</div>
      <div class="vw-row">
        <div class="vw-btn on" id="vb-3d" onclick="GM.setView('3d')">3D</div>
        <div class="vw-btn"   id="vb-2d" onclick="GM.setView('2d')">2D</div>
      </div>
    </div>
    <hr class="sp-sep">
    <div style="margin-bottom:11px">
      <div class="sp-h"><i class="fas fa-location-arrow" style="margin-right:5px"></i>NAVIGATION</div>
      <div class="sp-row">
        <div class="sp-col">
          <div class="sp-lbl">GALAXY</div>
          <input type="number" id="nav-g" class="sp-inp" value="{{ PLANET.galaxy|default(1) }}" min="1" max="9">
        </div>
        <div class="sp-col">
          <div class="sp-lbl">SYSTEM</div>
          <input type="number" id="nav-s" class="sp-inp" value="{{ PLANET.system|default(1) }}" min="1" max="499">
        </div>
      </div>
      <button class="sp-btn c" id="btn-jump" onclick="GM.navJump()"><i class="fas fa-arrow-right"></i>JUMP TO SYSTEM</button>
      <button class="sp-btn g" id="btn-home" onclick="GM.navHome()"><i class="fas fa-home"></i>MY HOME PLANET</button>
      <div id="jump-hint"></div>
    </div>
    <hr class="sp-sep">
    <div style="margin-bottom:11px">
      <div class="sp-h"><i class="fas fa-circle-info" style="margin-right:5px"></i>LEGEND</div>
      <div class="leg"><div class="leg-dot" style="background:#00e87a"></div>Your Planets</div>
      <div class="leg"><div class="leg-dot" style="background:#a855f7"></div>Alliance Members</div>
      <div class="leg"><div class="leg-dot" style="background:#00d4ff"></div>Other Players</div>
      <div class="leg"><div class="leg-dot" style="background:#aaa"></div>Moon</div>
      <div class="leg"><div class="leg-dot" style="background:#ff9900;border-radius:0"></div>Debris Field</div>
      <hr class="sp-sep" style="margin:5px 0">
      <div class="leg"><div class="leg-line" style="background:#00d4ff;opacity:.8"></div>Your Fleet</div>
      <div class="leg"><div class="leg-line" style="background:#a855f7;opacity:.55"></div>Alliance Fleet</div>
      <div class="leg"><div class="leg-dash" style="color:#6688aa"></div>Foreign Fleet</div>
      <div class="leg"><div class="leg-dash" style="color:#e8304a"></div>Hostile Fleet</div>
    </div>
    <hr class="sp-sep">
    <div style="margin-bottom:10px">
      <div class="sp-h"><i class="fas fa-chart-bar" style="margin-right:5px"></i>UNIVERSE STATS</div>
      <div class="st-row"><span class="sk">Planets</span><span class="sv c" id="st-p">–</span></div>
      <div class="st-row"><span class="sk">Active Fleets</span><span class="sv g" id="st-f">–</span></div>
      <div class="st-row"><span class="sk">Hostile</span><span class="sv r" id="st-h">–</span></div>
      <div class="st-row"><span class="sk">Alliances</span><span class="sv c" id="st-a">–</span></div>
      <div class="st-row"><span class="sk">Debris Fields</span><span class="sv" id="st-d" style="color:#ff9900">–</span></div>
      <div class="st-row"><span class="sk">Selected</span><span class="sv" id="st-sel" style="color:var(--dim)">–</span></div>
    </div>
    <button class="sp-btn c" onclick="GM.reloadFleets()" style="font-size:9px"><i class="fas fa-sync-alt" style="margin-right:5px"></i>REFRESH FLEETS</button>
    <div style="text-align:center;font-size:9px;color:var(--dim);margin-top:5px;font-family:'Orbitron',monospace" id="upd-time">Auto-refresh: 5s</div>
  </div>

  <!-- Action panel -->
  <div id="gm-action">
    <button class="ap-x" onclick="GM.closeAction()"><i class="fas fa-times"></i></button>
    <div class="ap-name" id="ap-name">–</div>
    <div class="ap-coord" id="ap-coord">–</div>
    <div class="ap-meta" id="ap-meta"></div>
    <div class="ap-btns" id="ap-btns"></div>
  </div>

  <!-- Player card -->
  <div id="gm-card">
    <button class="pc-x" onclick="GM.closeCard()"><i class="fas fa-times"></i></button>
    <div id="pc-body"></div>
  </div>

  <!-- Tooltip -->
  <div id="gm-tip"></div>

  <div id="gm-hint">SCROLL = ZOOM  •  DRAG = ROTATE / PAN  •  CLICK PLANET = ACTIONS</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
{% autoescape false %}
<script>
/* ============================================================
   SmartMoons Galaxy Map v3
   Planeten = THREE.Sprite mit Canvas-Kreis-Textur → immer rund
   ============================================================ */
const GM = (() => {
'use strict';

// ── State ──────────────────────────────────────────────────
let scene, camera, renderer;
let is3D  = true;
let frame = 0;

let orb = { theta: 0.4, phi: 1.05, r: 750, tx: 0, ty: 0, tz: 0 };
let pan = { x: 0, z: 0 };
let selectedPlanet = null;
let selRing = null; // THREE.Mesh highlight ring
let drag = { down:false, startX:0, startY:0, moved:0,
             snapTheta:0, snapPhi:0, snapPanX:0, snapPanZ:0 };

let starField    = null;
let planetGroup  = null;
let fleetGroup   = null;
let planetMeshes = [];   // sprite refs for raycasting
let posMap       = {};   // "g:s:p" → THREE.Vector3

let galaxyData       = null;
let fleetData        = null;
let serverTimeOffset = 0;
const fleetAnimState = {};

// ── DOM ────────────────────────────────────────────────────
const canvas   = document.getElementById('gm-canvas');
const loadEl   = document.getElementById('gm-load');
const ldTxt    = document.getElementById('ld-txt');
const actionEl = document.getElementById('gm-action');
const cardEl   = document.getElementById('gm-card');
const tipEl    = document.getElementById('gm-tip');

// ── Raycaster & dispose ─────────────────────────────────
const RC = new THREE.Raycaster();
const MV = new THREE.Vector2();
function disposeGroup(g) {
  while (g.children.length) {
    const o = g.children[0]; g.remove(o);
    if (o.geometry) o.geometry.dispose();
    if (o.material) { if (o.material.map) o.material.map.dispose(); o.material.dispose(); }
  }
}

// ── Sprite texture factory ─────────────────────────────────
// Off-screen canvas → perfekter Kreis → CanvasTexture
// THREE.Sprite dreht sich immer zur Kamera → immer rund!
const texCache = {};
function circleTex(hex) {
  if (texCache[hex]) return texCache[hex];
  const S = 128, c = document.createElement('canvas');
  c.width = c.height = S;
  const ctx = c.getContext('2d'), cx = S/2, r = S/2 - 2;

  // Glow halo
  const g1 = ctx.createRadialGradient(cx, cx, r*.15, cx, cx, r);
  g1.addColorStop(0,   hex + 'bb');
  g1.addColorStop(0.6, hex + '55');
  g1.addColorStop(1,   hex + '00');
  ctx.beginPath(); ctx.arc(cx, cx, r, 0, Math.PI*2);
  ctx.fillStyle = g1; ctx.fill();

  // Planet sphere gradient
  const g2 = ctx.createRadialGradient(cx-r*.2, cx-r*.2, 0, cx, cx, r*.5);
  g2.addColorStop(0,   '#ffffff');
  g2.addColorStop(0.2, hex);
  g2.addColorStop(1,   darken(hex));
  ctx.beginPath(); ctx.arc(cx, cx, r*.46, 0, Math.PI*2);
  ctx.fillStyle = g2; ctx.fill();

  texCache[hex] = new THREE.CanvasTexture(c);
  return texCache[hex];
}
function darken(hex) {
  hex = hex.replace('#','');
  const d = v => Math.max(0, Math.round(parseInt(v,16)*0.45)).toString(16).padStart(2,'0');
  return '#'+d(hex.slice(0,2))+d(hex.slice(2,4))+d(hex.slice(4,6));
}

// ── Init Three.js ──────────────────────────────────────────
function init() {
  scene = new THREE.Scene();
  scene.background = new THREE.Color(0x020510);
  scene.fog = new THREE.FogExp2(0x020510, 0.00022);

  camera = new THREE.PerspectiveCamera(58, innerWidth/innerHeight, 0.5, 12000);
  syncCamera();

  renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setSize(innerWidth, innerHeight);
  renderer.setPixelRatio(Math.min(devicePixelRatio, 2));

  scene.add(new THREE.AmbientLight(0x304060, 2));
  const dl = new THREE.DirectionalLight(0x5599ff, 0.6);
  dl.position.set(200, 400, 100); scene.add(dl);

  planetGroup = new THREE.Group(); scene.add(planetGroup);
  fleetGroup  = new THREE.Group(); scene.add(fleetGroup);

  buildStars();
  buildNebula();
  bindEvents();

  // Single rAF loop – start before fetch so canvas is live immediately
  animate();

  // Failsafe: always hide loader after 8 s regardless of fetch outcome
  const loaderTimeout = setTimeout(() => {
    if (loadEl.style.display !== 'none') {
      ldTxt.textContent = 'TIMEOUT – DEMO MODE';
      loadDemo();
      hideLoader(400);
    }
  }, 8000);

  Promise.all([fetchGalaxy(), fetchFleets()])
    .then(() => { clearTimeout(loaderTimeout); hideLoader(); })
    .catch(() => { clearTimeout(loaderTimeout); ldTxt.textContent = 'DEMO MODE'; loadDemo(); hideLoader(800); });

  // Fleet polling every 5 s – silent wrapper so poll errors don’t throw
  setInterval(() => fetchFleets().catch(e => console.warn('Fleet poll:', e)), 5000);
}

function hideLoader(delay=0) {
  setTimeout(() => {
    loadEl.style.opacity='0';
    setTimeout(()=>loadEl.style.display='none', 450);
  }, delay);
}

// ── Starfield ──────────────────────────────────────────────
function buildStars() {
  const N=8000, pos=new Float32Array(N*3), col=new Float32Array(N*3);
  for (let i=0;i<N;i++) {
    const rr=1000+Math.random()*4500, t=Math.random()*Math.PI*2, p=Math.acos(2*Math.random()-1);
    pos[i*3]=rr*Math.sin(p)*Math.cos(t); pos[i*3+1]=rr*Math.sin(p)*Math.sin(t)*.22; pos[i*3+2]=rr*Math.cos(p);
    const v=0.5+Math.random()*.5;
    col[i*3]=v*(0.7+Math.random()*.3); col[i*3+1]=v*(0.8+Math.random()*.2); col[i*3+2]=v;
  }
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  geo.setAttribute('color',new THREE.BufferAttribute(col,3));
  starField=new THREE.Points(geo,new THREE.PointsMaterial({
    size:1.3,vertexColors:true,sizeAttenuation:true,transparent:true,opacity:.88,depthWrite:false
  }));
  scene.add(starField);
}

function buildNebula() {
  const N=2500, pos=new Float32Array(N*3);
  for (let i=0;i<N;i++) {
    const t=(i/N)*Math.PI*9+Math.random()*.9, rr=(i/N)*500;
    const arm=Math.floor(Math.random()*3)*(Math.PI*2/3);
    pos[i*3]=Math.cos(t+arm)*rr+(Math.random()-.5)*22;
    pos[i*3+1]=(Math.random()-.5)*6;
    pos[i*3+2]=Math.sin(t+arm)*rr+(Math.random()-.5)*22;
  }
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  scene.add(new THREE.Points(geo,new THREE.PointsMaterial({
    color:0x1a2d99,size:2.8,sizeAttenuation:true,transparent:true,opacity:.18,depthWrite:false
  })));
}

// ── Koordinaten → 3D-Position (DETERMINISTIC – no Math.random) ──
function toWorld(g, s, p) {
  const gAngle = ((g - 1) / 9)   * Math.PI * 2;
  const gR = 480;
  const gx = Math.cos(gAngle) * gR, gz = Math.sin(gAngle) * gR;

  const sAngle = gAngle + ((s - 1) / 499) * Math.PI * 5.2;
  const sR = ((s - 1) / 499) * 390;
  const sx = gx + Math.cos(sAngle) * sR;
  const sz = gz + Math.sin(sAngle) * sR;

  const pAngle = ((p - 1) / 15) * Math.PI * 2;
  const pR = 3 + p * 2.5;
  // Deterministic Y offset – no random, based on coords only
  const py = Math.sin((g * 37 + s * 13 + p * 7) * 0.1) * 3;
  return new THREE.Vector3(sx + Math.cos(pAngle) * pR, py, sz + Math.sin(pAngle) * pR);
}

// ── Planeten als Sprites ───────────────────────────────────
function buildPlanets(planets) {
  // Remove selRing before disposeGroup to avoid double-dispose
  if (selRing) { planetGroup.remove(selRing); }
  disposeGroup(planetGroup);
  planetMeshes = [];
  posMap = {};

  planets.forEach(pl => {
    const key = `${pl.galaxy}:${pl.system}:${pl.planet}`;
    const pos = toWorld(pl.galaxy, pl.system, pl.planet);
    posMap[key] = pos.clone();

    let hex = '#00d4ff';
    if (pl.is_own)       hex = '#00ff88';
    else if (pl.is_ally) hex = '#a855f7';
    else if (pl.ally_color && pl.ally_color !== 'null') hex = pl.ally_color;

    const rankScale = pl.total_rank > 0
      ? Math.max(0.55, Math.min(2.2, 350/Math.max(pl.total_rank,1))) : 1.0;
    const sz = 11 * rankScale;

    // Sprite → immer zur Kamera gewandt → immer perfekt rund
    const sprite = new THREE.Sprite(new THREE.SpriteMaterial({
      map: circleTex(hex), transparent:true, depthWrite:false, sizeAttenuation:true
    }));
    sprite.position.copy(pos);
    sprite.scale.setScalar(sz);
    sprite.userData = { planet:pl, baseScale:sz, key };
    planetGroup.add(sprite);
    planetMeshes.push(sprite); // track for raycasting

    // Mond
    if (pl.has_moon) {
      const ms = new THREE.Sprite(new THREE.SpriteMaterial({
        map:circleTex('#aaaaaa'), transparent:true, depthWrite:false, sizeAttenuation:true
      }));
      ms.position.copy(pos).add(new THREE.Vector3(sz*.72, sz*.45, 0));
      ms.scale.setScalar(sz*.34);
      planetGroup.add(ms);
    }

    // Trümmerfeld
    if (pl.has_debris) {
      const tg = new THREE.TorusGeometry(sz*.7, 0.26, 6, 28);
      const mesh = new THREE.Mesh(tg, new THREE.MeshBasicMaterial({
        color:0xff9900, transparent:true, opacity:.5
      }));
      mesh.position.copy(pos); mesh.rotation.x = Math.PI/2;
      planetGroup.add(mesh);
    }
  });
}

// ── Flottenlinien (with smooth lerp between polls) ──────────────
function buildFleets(fleets) {
  const nowSec = (Date.now() / 1000) + serverTimeOffset;

  // Update animation state dict (keeps display progress for smooth lerp)
  const activeIds = new Set();
  fleets.forEach(f => {
    const start = f.start_time || 0;
    const end   = f.end_time   || (start + 1);
    const realPrg = Math.min(1, Math.max(0, (nowSec - start) / Math.max(1, end - start)));
    f.progress = realPrg;
    const id = f.id;
    activeIds.add(id);
    if (!fleetAnimState[id]) fleetAnimState[id] = { displayPrg: realPrg };
    fleetAnimState[id].targetPrg = realPrg;
    fleetAnimState[id].data      = f;
    fleetAnimState[id].sPos = posMap[`${f.start.g}:${f.start.s}:${f.start.p}`]
                              || toWorld(f.start.g, f.start.s, f.start.p);
    fleetAnimState[id].ePos = posMap[`${f.end.g}:${f.end.s}:${f.end.p}`]
                              || toWorld(f.end.g, f.end.s, f.end.p);
    fleetAnimState[id].col  = parseInt((f.color||'#00d4ff').replace('#',''), 16);
  });
  // Remove gone fleets
  for (const id in fleetAnimState) {
    if (!activeIds.has(parseInt(id))) delete fleetAnimState[id];
  }
  rebuildFleetMeshes();
}

function rebuildFleetMeshes() {
  disposeGroup(fleetGroup);
  for (const id in fleetAnimState) {
    const st  = fleetAnimState[id];
    const f   = st.data;
    const prg = st.displayPrg;
    const cur = st.sPos.clone().lerp(st.ePos, prg);

    // Determine line style by fleet ownership
    // own = solid cyan; ally = solid purple dim; hostile = dashed red; foreign = dashed gray
    const isOwn     = !!f.is_own;
    const isHostile = !!f.is_hostile;
    const isAlly    = !isOwn && !isHostile && !!f.is_ally;

    let trailCol, trailOpacity, remainOpacity, dotCol, useDash;
    if (isOwn) {
      trailCol = 0x00d4ff; trailOpacity = 0.75; remainOpacity = 0.12;
      dotCol = '#00d4ff'; useDash = false;
    } else if (isAlly) {
      trailCol = 0xa855f7; trailOpacity = 0.45; remainOpacity = 0.08;
      dotCol = '#a855f7'; useDash = false;
    } else if (isHostile) {
      trailCol = 0xe8304a; trailOpacity = 0.75; remainOpacity = 0.15;
      dotCol = '#e8304a'; useDash = true;
    } else { // foreign
      trailCol = 0x6688aa; trailOpacity = 0.35; remainOpacity = 0.06;
      dotCol = '#6688aa'; useDash = true;
    }

    // Trail line (start → current position)
    if (useDash) {
      const lg = new THREE.BufferGeometry().setFromPoints([st.sPos, cur]);
      const lm = new THREE.LineDashedMaterial({
        color: trailCol, transparent: true, opacity: trailOpacity,
        dashSize: 4, gapSize: 3, depthWrite: false
      });
      const ln = new THREE.Line(lg, lm);
      ln.computeLineDistances();
      ln.userData = {fleet: f};
      fleetGroup.add(ln);
    } else {
      const lg = new THREE.BufferGeometry().setFromPoints([st.sPos, cur]);
      const ln = new THREE.Line(lg, new THREE.LineBasicMaterial({
        color: trailCol, transparent: true, opacity: trailOpacity, depthWrite: false
      }));
      ln.userData = {fleet: f};
      fleetGroup.add(ln);
    }

    // Remaining path line (current → end, always dimmer)
    if (useDash) {
      const dg = new THREE.BufferGeometry().setFromPoints([cur, st.ePos]);
      const dm = new THREE.LineDashedMaterial({
        color: trailCol, transparent: true, opacity: remainOpacity,
        dashSize: 3, gapSize: 4, depthWrite: false
      });
      const dl = new THREE.Line(dg, dm);
      dl.computeLineDistances();
      fleetGroup.add(dl);
    } else {
      const dg = new THREE.BufferGeometry().setFromPoints([cur, st.ePos]);
      fleetGroup.add(new THREE.Line(dg, new THREE.LineBasicMaterial({
        color: trailCol, transparent: true, opacity: remainOpacity, depthWrite: false
      })));
    }

    // Fleet dot at current position
    const ds = new THREE.Sprite(new THREE.SpriteMaterial({
      map: circleTex(dotCol), transparent: true, depthWrite: false, sizeAttenuation: true
    }));
    ds.position.copy(cur);
    ds.scale.setScalar(isOwn ? 6 : isHostile ? 5 : 4);
    ds.userData = {fleet: f, isFleetDot: true};
    fleetGroup.add(ds);
  }
}

// ── Data fetching ──────────────────────────────────────────
async function fetchGalaxy() {
  const r = await fetch(window.SM.apiBase + 'galaxy');
  if (!r.ok) throw new Error('galaxy API ' + r.status);
  const text = await r.text();
  try {
    galaxyData = JSON.parse(text);
  } catch(e) {
    console.error('Galaxy JSON parse error:', text.slice(0, 200));
    throw new Error('Galaxy JSON invalid');
  }
  if (galaxyData.server_time) {
    serverTimeOffset = galaxyData.server_time - (Date.now() / 1000);
  }
  if (galaxyData.planets) { buildPlanets(galaxyData.planets); updateStats(); }
}

async function fetchFleets() {
  // NOTE: must NOT swallow error on initial call so Promise.all can reject
  const r = await fetch(window.SM.apiBase + 'fleets');
  if (!r.ok) throw new Error('fleets API ' + r.status);
  const text = await r.text();
  try {
    fleetData = JSON.parse(text);
  } catch(e) {
    console.warn('Fleet JSON parse error:', text.slice(0, 200));
    return; // non-fatal on poll failures
  }
  if (fleetData.server_time) {
    serverTimeOffset = fleetData.server_time - (Date.now() / 1000);
  }
  if (fleetData.fleets) { buildFleets(fleetData.fleets); updateStats(); }
  set('upd-time', 'Updated ' + new Date().toLocaleTimeString());
}

// ── Demo fallback ──────────────────────────────────────────
function loadDemo() {
  const cols=['#00d4ff','#a855f7','#ff6b35','#ffd700','#00ffcc','#ff3399'];
  const planets=[];
  for (let g=1;g<=4;g++) for (let s=1;s<=120;s++) {
    if (Math.random()>.55) continue; // keep more so array is never empty
    const n=Math.floor(Math.random()*4)+1;
    for (let k=0;k<n;k++) {
      const p=Math.floor(Math.random()*15)+1, ai=Math.floor(Math.random()*7);
      const uid=Math.floor(Math.random()*300)+1;
      planets.push({
        id:g*1e6+s*1e3+p+k, name:`Kepler-${g}${s}`, galaxy:g, system:s, planet:p,
        user_id:uid, username:`Cmdr${uid}`,
        ally_id:ai, ally_name:ai?`Empire${ai}`:'', ally_tag:ai?`E${ai}`:'',
        ally_color:ai?cols[ai%cols.length]:null,
        total_rank:Math.floor(Math.random()*500)+1, total_points:Math.floor(Math.random()*800000),
        is_own:g===window.SM.galaxy&&s===window.SM.system&&p===window.SM.planet,
        is_ally:ai>0&&ai===window.SM.allyId,
        has_moon:Math.random()>.72, has_debris:Math.random()>.88, online:Math.random()>.55
      });
    }
  }
  galaxyData={planets, current_user_id:window.SM.userId};
  buildPlanets(planets);

  const demoFleets=[];
  for (let i=0;i<30;i++) {
    const sp=planets[Math.floor(Math.random()*planets.length)];
    const ep=planets[Math.floor(Math.random()*planets.length)];
    if (!sp||!ep||sp.id===ep.id) continue;
    const m=[1,3,6,8][Math.floor(Math.random()*4)];
    const hostile=m===1&&sp.user_id!==window.SM.userId;
    demoFleets.push({
      id:i, mission:m, owner:sp.username, ally_tag:sp.ally_tag,
      is_own:sp.user_id===window.SM.userId, is_hostile:hostile,
      is_ally:!hostile && sp.user_id!==window.SM.userId && sp.ally_id>0 && sp.ally_id===window.SM.allyId,
      color:hostile?'#e8304a':m===6?'#ffee00':m===8?'#ff9900':'#00d4ff',
      start:{g:sp.galaxy,s:sp.system,p:sp.planet},
      end:{g:ep.galaxy,s:ep.system,p:ep.planet},
      progress:Math.random()
    });
  }
  fleetData={fleets:demoFleets};
  buildFleets(demoFleets);
  updateStats();
}

// ── Stats update ───────────────────────────────────────────
function updateStats() {
  const pl = galaxyData?.planets || [];
  const fl = Object.values(fleetAnimState).map(s => s.data).filter(Boolean);
  const hs = fl.filter(f => f.is_hostile);
  const al = new Set(pl.map(p => p.ally_id).filter(id => id > 0));
  set('st-p', pl.length);      set('h-planets', pl.length + ' PLANETS');
  set('st-f', fl.length);      set('h-fleets',  fl.length + ' FLEETS');
  set('st-h', hs.length);      set('h-hostile', hs.length + ' HOSTILE');
  set('st-a', al.size);        set('st-d', pl.filter(p => p.has_debris).length);
}
function set(id,v){const e=document.getElementById(id);if(e)e.textContent=v;}

// ── Camera sync ────────────────────────────────────────────
function syncCamera() {
  if (!camera) return;
  if (is3D) {
    camera.position.set(
      orb.tx + orb.r*Math.sin(orb.phi)*Math.sin(orb.theta),
      orb.ty + orb.r*Math.cos(orb.phi),
      orb.tz + orb.r*Math.sin(orb.phi)*Math.cos(orb.theta)
    );
    camera.lookAt(orb.tx, orb.ty, orb.tz);
  } else {
    camera.position.set(pan.x, orb.r*.75, pan.z);
    camera.lookAt(pan.x, 0, pan.z);
  }
}

// ── Input events ───────────────────────────────────────────
function bindEvents() {
  canvas.addEventListener('mousedown', e=>{
    drag.down=true; drag.moved=0;
    drag.startX=e.clientX; drag.startY=e.clientY;
    drag.snapTheta=orb.theta; drag.snapPhi=orb.phi;
    drag.snapPanX=pan.x; drag.snapPanZ=pan.z;
    canvas.style.cursor='grabbing';
  });
  window.addEventListener('mouseup',()=>{drag.down=false;canvas.style.cursor='grab';});
  window.addEventListener('mousemove', e=>{
    if (drag.down) {
      const dx=e.clientX-drag.startX, dy=e.clientY-drag.startY;
      drag.moved=Math.max(drag.moved,Math.abs(dx)+Math.abs(dy));
      if (is3D) {
        orb.theta=drag.snapTheta-dx*.0055;
        orb.phi=Math.max(.12,Math.min(1.55,drag.snapPhi+dy*.0055));
      } else {
        pan.x=drag.snapPanX-dx*orb.r*.0016;
        pan.z=drag.snapPanZ-dy*orb.r*.0016;
      }
      syncCamera();
    } else { doHover(e.clientX,e.clientY); }
  });

  canvas.addEventListener('click', e=>{if(drag.moved<6)doClick(e.clientX,e.clientY);});

  canvas.addEventListener('wheel', e=>{
    e.preventDefault();
    orb.r=Math.max(50,Math.min(3000,orb.r+e.deltaY*.55));
    syncCamera();
  },{passive:false});

  // Touch
  let tStart=null,tDist=0;
  canvas.addEventListener('touchstart',e=>{
    if(e.touches.length===1){
      tStart={x:e.touches[0].clientX,y:e.touches[0].clientY,
              theta:orb.theta,phi:orb.phi,px:pan.x,pz:pan.z};
    } else if(e.touches.length===2){
      tDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,
                       e.touches[0].clientY-e.touches[1].clientY);
    }
  },{passive:true});
  canvas.addEventListener('touchmove',e=>{
    e.preventDefault();
    if(e.touches.length===1&&tStart){
      const dx=e.touches[0].clientX-tStart.x, dy=e.touches[0].clientY-tStart.y;
      if(is3D){orb.theta=tStart.theta-dx*.007;orb.phi=Math.max(.12,Math.min(1.55,tStart.phi+dy*.007));}
      else{pan.x=tStart.px-dx*orb.r*.002;pan.z=tStart.pz-dy*orb.r*.002;}
      syncCamera();
    } else if(e.touches.length===2){
      const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,
                         e.touches[0].clientY-e.touches[1].clientY);
      orb.r=Math.max(50,Math.min(3000,orb.r*(tDist/d)));
      tDist=d; syncCamera();
    }
  },{passive:false});

  window.addEventListener('resize',()=>{
    camera.aspect=innerWidth/innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(innerWidth,innerHeight);
  });
}

// ── Raycasting ─────────────────────────────────────────────
function setMV(cx,cy){MV.x=(cx/innerWidth)*2-1;MV.y=-(cy/innerHeight)*2+1;}

function hitPlanet(cx,cy){
  if (!planetMeshes.length) return null;
  setMV(cx,cy); RC.setFromCamera(MV,camera);
  const hits=RC.intersectObjects(planetMeshes);
  return hits.length?hits[0].object.userData.planet:null;
}

function hitFleet(cx,cy){
  const dots = fleetGroup.children.filter(c=>c.userData.isFleetDot);
  if (!dots.length) return null;
  setMV(cx,cy); RC.setFromCamera(MV,camera);
  const hits = RC.intersectObjects(dots);
  return hits.length ? hits[0].object.userData.fleet : null;
}

function doHover(cx,cy){
  // Check fleet dots first (they're smaller targets)
  const fl=hitFleet(cx,cy);
  if(fl){
    canvas.style.cursor='pointer';
    tipEl.style.display='block';
    tipEl.style.left=(cx+16)+'px'; tipEl.style.top=(cy+10)+'px';
    const nowS = (Date.now()/1000) + serverTimeOffset;
    const remaining = Math.max(0, Math.round(fl.end_time - nowS));
    const mins=Math.floor(remaining/60), secs=remaining%60;
    const fcol = fl.is_hostile?'var(--red)':fl.is_own?'var(--cyan)':'var(--dim)';
    tipEl.innerHTML=`
      <div class="tt-h" style="color:${fcol}">${fl.mission_name||'FLEET'}</div>
      <div class="tt-l">Commander: <span>${fl.owner_name||'?'}</span></div>
      <div class="tt-l">From: <span>[${fl.start.g}:${fl.start.s}:${fl.start.p}]</span></div>
      <div class="tt-l">To: <span>[${fl.end.g}:${fl.end.s}:${fl.end.p}]</span></div>
      <div class="tt-l">ETA: <span>${mins}m ${secs}s</span></div>
    `;
    return;
  }
  const pl=hitPlanet(cx,cy);
  if(pl){
    canvas.style.cursor='pointer';
    tipEl.style.display='block';
    tipEl.style.left=(cx+16)+'px'; tipEl.style.top=(cy+10)+'px';
    const c=pl.is_own?'var(--green)':pl.is_ally?'var(--purple)':'var(--cyan)';
    const name=(pl.name||'Unknown Planet').toUpperCase();
    tipEl.innerHTML=`
      <div class="tt-h" style="color:${c}">${name}</div>
      <div class="tt-l">[${pl.galaxy}:${pl.system}:${pl.planet}]</div>
      <div class="tt-l">Player: <span>${pl.username||'?'}</span></div>
      ${pl.ally_tag?`<div class="tt-l">Alliance: <span>[${pl.ally_tag}]</span></div>`:''}
      <div class="tt-l">Rank: <span>#${pl.total_rank||'?'}</span></div>
      ${pl.has_moon?'<div class="tt-l" style="color:#aaa"><i class="fas fa-moon fa-xs"></i> Moon</div>':''}
      ${pl.has_debris?'<div class="tt-l" style="color:#ff9900"><i class="fas fa-ring fa-xs"></i> Debris</div>':''}
    `;
  } else {
    canvas.style.cursor='grab';
    tipEl.style.display='none';
  }
}

function doClick(cx, cy) {
  const pl = hitPlanet(cx, cy);
  if (pl) {
    selectPlanet(pl);
    showAction(pl);
    tipEl.style.display = 'none';
  } else {
    deselectPlanet();
    closeAction();
  }
}

// ── Planet selection + highlight ring ──────────────────────
function selectPlanet(pl) {
  selectedPlanet = pl;
  // Remove old ring
  if (selRing) { planetGroup.remove(selRing); selRing.geometry.dispose(); selRing.material.dispose(); selRing = null; }
  const pos = posMap[`${pl.galaxy}:${pl.system}:${pl.planet}`];
  if (!pos) return;
  const sprite = planetMeshes.find(s => s.userData.key === `${pl.galaxy}:${pl.system}:${pl.planet}`);
  const sz = sprite ? sprite.userData.baseScale * 0.62 : 9;
  const rg = new THREE.RingGeometry(sz, sz + 1.4, 32);
  const rm = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.55, side: THREE.DoubleSide, depthWrite: false });
  selRing = new THREE.Mesh(rg, rm);
  selRing.position.copy(pos);
  selRing.rotation.x = -Math.PI / 2;
  planetGroup.add(selRing);
  set('st-sel', `${pl.galaxy}:${pl.system}:${pl.planet}`);
}

function deselectPlanet() {
  selectedPlanet = null;
  if (selRing) { planetGroup.remove(selRing); selRing.geometry.dispose(); selRing.material.dispose(); selRing = null; }
  set('st-sel', '–');
}

// ── Action panel ───────────────────────────────────────────
function showAction(pl) {
  const nameCol = pl.is_own ? 'var(--green)' : pl.is_ally ? 'var(--purple)' : 'var(--cyan)';
  set('ap-name', (pl.name||'Unknown').toUpperCase());
  set('ap-coord', `[${pl.galaxy}:${pl.system}:${pl.planet}]`);
  document.getElementById('ap-name').style.color = nameCol;
  document.getElementById('ap-meta').innerHTML = `
    <div class="ap-box"><div class="ap-box-lbl">PLAYER</div><div class="ap-box-val" style="color:${nameCol}">${pl.username||'?'}</div></div>
    <div class="ap-box"><div class="ap-box-lbl">RANK</div><div class="ap-box-val" style="color:var(--gold)">#${pl.total_rank||'?'}</div></div>
    <div class="ap-box"><div class="ap-box-lbl">ALLIANCE</div><div class="ap-box-val">${pl.ally_tag?'['+pl.ally_tag+']':'–'}</div></div>
  `;
  const btn = document.getElementById('ap-btns');
  if (pl.is_own) {
    btn.innerHTML = `<div class="ap-own"><i class="fas fa-check" style="margin-right:6px"></i>YOUR PLANET</div>`;
  } else {
    const {galaxy:g, system:s, planet:p, user_id:uid} = pl;
    const base = `game.php?page=fleetTable&galaxy=${g}&system=${s}&planet=${p}&planettype=1`;
    btn.innerHTML = `
      <a class="ap-btn ab-spy"  href="${base}&target_mission=6"><i class="fas fa-satellite"></i> SPY</a>
      <a class="ap-btn ab-atk"  href="${base}&target_mission=1"><i class="fas fa-crosshairs"></i> ATTACK</a>
      <a class="ap-btn ab-flt"  href="${base}"><i class="fas fa-rocket"></i> FLEET</a>
      <a class="ap-btn ab-msg"  href="game.php?page=messages&mode=write&player_id=${uid}"><i class="fas fa-envelope"></i> MESSAGE</a>
      <a class="ap-btn ab-card" href="javascript:GM.showCard(${uid})"><i class="fas fa-id-card"></i> PLAYERCARD</a>
      ${pl.has_debris ? `<a class="ap-btn ab-rec" href="${base}&target_mission=8"><i class="fas fa-recycle"></i> RECYCLE</a>` : ''}
    `;
  }
  actionEl.style.display = 'block';
  // Fly to planet – do NOT call flyTo here since selectPlanet caller already triggers it
  const key = `${pl.galaxy}:${pl.system}:${pl.planet}`;
  if (posMap[key]) flyTo(posMap[key], 110);
}
function closeAction() { actionEl.style.display = 'none'; }

// ── Player card ────────────────────────────────────────────
async function showCard(userId){
  cardEl.style.display='block';
  document.getElementById('pc-body').innerHTML=
    '<div style="text-align:center;padding:30px;color:var(--dim);font-family:\'Orbitron\',monospace;font-size:10px;letter-spacing:2px">LOADING…</div>';
  try{
    const r=await fetch(`${window.SM.apiBase}card&player_id=${userId}`);
    const d=await r.json();
    if(d.error) throw new Error(d.error);
    renderCard(d);
  }catch{
    renderCard({
      id:userId,username:'Commander'+userId,planet_name:'HomePlanet',
      galaxy:1,system:1,planet:1,ally_id:0,ally_name:'',ally_tag:'',
      total_rank:Math.floor(Math.random()*300)+1,total_points:'123.456',
      fleet_rank:50,fleet_points:'50.000',tech_rank:80,tech_points:'30.000',
      build_rank:60,build_points:'40.000',defs_rank:90,defs_points:'3.000',
      wons:25,loos:10,draws:5,win_pct:71.4,online:true,
      is_self:userId===window.SM.userId
    });
  }
}

function renderCard(d){
  const isSelf=d.is_self||d.id===window.SM.userId;
  const onTxt=d.online
    ?'<span class="dot dot-on"></span>Online now'
    :'<span class="dot dot-off"></span>Offline';
  document.getElementById('pc-body').innerHTML=`
    <div class="pc-hdr">
      <div class="pc-av">${(d.username||'?')[0].toUpperCase()}</div>
      <div>
        <div class="pc-nm">${d.username}</div>
        <div class="pc-al">${d.ally_tag?`[${d.ally_tag}] ${d.ally_name}`:'No Alliance'}</div>
        <div class="pc-on">${onTxt}</div>
      </div>
    </div>
    <div class="pc-grid">
      <div class="pc-st"><div class="pc-st-lbl">TOTAL POINTS</div><div class="pc-st-val">${d.total_points}</div><div class="pc-st-rnk">Rank #${d.total_rank}</div></div>
      <div class="pc-st"><div class="pc-st-lbl">FLEET POINTS</div><div class="pc-st-val">${d.fleet_points}</div><div class="pc-st-rnk">Rank #${d.fleet_rank}</div></div>
      <div class="pc-st"><div class="pc-st-lbl">TECH POINTS</div><div class="pc-st-val">${d.tech_points}</div><div class="pc-st-rnk">Rank #${d.tech_rank}</div></div>
      <div class="pc-st"><div class="pc-st-lbl">BUILD POINTS</div><div class="pc-st-val">${d.build_points}</div><div class="pc-st-rnk">Rank #${d.build_rank}</div></div>
    </div>
    <div class="pc-fights">
      <div class="pcf"><div class="pcf-n" style="color:var(--green)">${d.wons}</div><div class="pcf-l">WINS</div></div>
      <div class="pcf"><div class="pcf-n" style="color:var(--red)">${d.loos}</div><div class="pcf-l">LOSSES</div></div>
      <div class="pcf"><div class="pcf-n" style="color:var(--dim)">${d.draws}</div><div class="pcf-l">DRAWS</div></div>
      <div class="pcf"><div class="pcf-n" style="color:var(--gold)">${d.win_pct}%</div><div class="pcf-l">WIN RATE</div></div>
    </div>
    ${!isSelf?`<div class="pc-acts">
      <a class="ap-btn ab-spy" href="game.php?page=fleetTable&galaxy=${d.galaxy}&system=${d.system}&planet=${d.planet}&planettype=1&target_mission=6"><i class="fas fa-satellite"></i> SPY</a>
      <a class="ap-btn ab-atk" href="game.php?page=fleetTable&galaxy=${d.galaxy}&system=${d.system}&planet=${d.planet}&planettype=1&target_mission=1"><i class="fas fa-crosshairs"></i> ATTACK</a>
      <a class="ap-btn ab-msg" href="game.php?page=messages&mode=write&player_id=${d.id}"><i class="fas fa-envelope"></i> MESSAGE</a>
    </div>`:'<div class="ap-own"><i class="fas fa-user" style="margin-right:6px"></i>YOUR PROFILE</div>'}
  `;
}
function closeCard(){cardEl.style.display='none';}

// ── Fly-to ─────────────────────────────────────────────────
function flyTo(target, dist) {
  const sp = camera.position.clone();
  // Approach from slightly elevated angle behind target
  const ep = new THREE.Vector3(target.x + dist * 0.35, dist * 0.55, target.z + dist);
  let t = 0;
  const go = () => {
    t++;
    const a = Math.min(1, t / 52);
    const e = 1 - Math.pow(1 - a, 3); // ease-out cubic
    camera.position.lerpVectors(sp, ep, e);
    camera.lookAt(target.x, target.y, target.z);
    if (a < 1) {
      requestAnimationFrame(go);
    } else {
      // Update orb so subsequent drag/zoom stays orbiting target, not origin
      orb.tx = target.x; orb.ty = target.y; orb.tz = target.z;
      orb.r  = dist;
      // Recalculate theta/phi from final camera position relative to target
      const dx = ep.x - target.x, dy = ep.y - target.y, dz = ep.z - target.z;
      orb.phi   = Math.acos(Math.max(-1, Math.min(1, dy / dist)));
      orb.theta = Math.atan2(dx, dz);
      syncCamera();
    }
  };
  requestAnimationFrame(go);
}

// ── Public controls ────────────────────────────────────────
function setView(mode){
  is3D = mode === '3d';
  document.getElementById('vb-3d').classList.toggle('on',  is3D);
  document.getElementById('vb-2d').classList.toggle('on', !is3D);
  if (!is3D) { orb.r=650; orb.phi=0.02; orb.tx=0; orb.ty=0; orb.tz=0; pan.x=pan.z=0; }
  else       { orb.r=750; orb.phi=1.05; orb.tx=0; orb.ty=0; orb.tz=0; }
  syncCamera();
  if (galaxyData?.planets) {
    buildPlanets(galaxyData.planets);
    if (fleetData?.fleets) buildFleets(fleetData.fleets);
    // Re-select previously selected planet to restore ring
    if (selectedPlanet) selectPlanet(selectedPlanet);
  }
}
function navJump() {
  const gEl = document.getElementById('nav-g');
  const sEl = document.getElementById('nav-s');
  let g = parseInt(gEl.value) || 1;
  let s = parseInt(sEl.value) || 1;
  // Clamp to valid universe bounds
  g = Math.max(1, Math.min(9, g));   gEl.value = g;
  s = Math.max(1, Math.min(499, s)); sEl.value = s;

  // Check if any planet exists in this system
  const planets = galaxyData?.planets || [];
  const inSys = planets.filter(p => p.galaxy === g && p.system === s);

  const hint = document.getElementById('jump-hint');
  if (inSys.length === 0 && planets.length > 0) {
    hint.textContent = 'No planets in this system';
    hint.style.color = 'var(--dim)';
    setTimeout(() => { hint.textContent = ''; }, 2500);
  } else {
    hint.textContent = 'JUMPING…';
    hint.style.color = 'var(--cyan)';
    setTimeout(() => { hint.textContent = ''; }, 1800);
  }
  flyTo(toWorld(g, s, 8), 180);
}

function navHome() {
  const g = window.SM.galaxy, s = window.SM.system, p = window.SM.planet;
  const hint = document.getElementById('jump-hint');
  hint.textContent = 'HOME';
  hint.style.color = 'var(--green)';
  setTimeout(() => { hint.textContent = ''; }, 1800);
  flyTo(toWorld(g, s, p), 110);
  // Highlight home planet if loaded
  if (galaxyData?.planets) {
    const hp = galaxyData.planets.find(pl => pl.is_own &&
      pl.galaxy === g && pl.system === s && pl.planet === p);
    if (hp) selectPlanet(hp);
  }
}
function reloadFleets(){ fetchFleets(); }

// ── Render loop ────────────────────────────────────────────
let needFleetRebuild = false;
function animate(){
  requestAnimationFrame(animate); frame++;
  if(starField) starField.rotation.y += 0.000012;

  // Planet pulse
  const pulse = Math.sin(frame * 0.022) * 0.05 + 1.0;
  planetMeshes.forEach(sp => {
    if (sp.userData.baseScale) sp.scale.setScalar(sp.userData.baseScale * pulse);
  });

  // Smooth-lerp fleet positions between polls
  needFleetRebuild = false;
  const nowSec = (Date.now() / 1000) + serverTimeOffset;
  for (const id in fleetAnimState) {
    const st = fleetAnimState[id];
    if (st.targetPrg === undefined) continue;
    const realPrg = Math.min(1, Math.max(0,
      (nowSec - (st.data.start_time||0)) / Math.max(1, (st.data.end_time||1) - (st.data.start_time||0))
    ));
    st.targetPrg = realPrg;
    if (Math.abs(st.displayPrg - realPrg) > 0.0001) {
      st.displayPrg += (realPrg - st.displayPrg) * 0.04; // smooth lerp
      needFleetRebuild = true;
    }
  }
  if (needFleetRebuild) rebuildFleetMeshes();

  // Hostile blink on dashed lines only (LineDashedMaterial type check)
  fleetGroup.children.forEach(obj => {
    if (obj.isLine && obj.userData?.fleet?.is_hostile && obj.material?.isLineDashedMaterial) {
      obj.material.opacity = 0.3 + Math.abs(Math.sin(frame * 0.06)) * 0.45;
    }
  });

  // Selection ring pulse
  if (selRing) {
    selRing.material.opacity = 0.35 + Math.abs(Math.sin(frame * 0.04)) * 0.35;
  }

  renderer.render(scene, camera);
}

// Boot
init();
return{setView,navJump,navHome,reloadFleets,closeAction,closeCard,showCard,selectPlanet,deselectPlanet};
})();
</script>
