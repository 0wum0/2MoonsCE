// ── Fly-to ─────────────────────────────────────────────────
function flyTo(target, dist) {
  const sp = camera.position.clone();
  // Approach from slightly elevated angle behind target
  const ep = new THREE.Vector3(target.x + dist * 0.35, dist * 0.55, target.z + dist);
  let t = 0;
  const go = () => {
    t++;
    const a = Math.min(1, t / 52);
    const e = 1 - Math.pow(1 - a, 3); // ease-out cubic
    camera.position.lerpVectors(sp, ep, e);
    camera.lookAt(target.x, target.y, target.z);
    if (a < 1) {
      requestAnimationFrame(go);
    } else {
      // Update orb so subsequent drag/zoom stays orbiting target, not origin
      orb.tx = target.x; orb.ty = target.y; orb.tz = target.z;
      orb.r  = dist;
      // Recalculate theta/phi from final camera position relative to target
      const dx = ep.x - target.x, dy = ep.y - target.y, dz = ep.z - target.z;
      orb.phi   = Math.acos(Math.max(-1, Math.min(1, dy / dist)));
      orb.theta = Math.atan2(dx, dz);
      syncCamera();
    }
  };
  requestAnimationFrame(go);
}

// ── Public controls ────────────────────────────────────────
function setView(mode){
  is3D = mode === '3d';
  try { localStorage.setItem('galaxy_view', mode); } catch(e) {}
  document.getElementById('vb-3d').classList.toggle('on',  is3D);
  document.getElementById('vb-2d').classList.toggle('on', !is3D);
  if (!is3D) {
    // 2D = straight top-down, phi near zero, higher r so full map is visible
    orb.r=4000; orb.phi=0.01; orb.theta=0;
    orb.tx=0; orb.ty=0; orb.tz=0;
    pan.x=0; pan.z=0;
  } else {
    orb.r=3000; orb.phi=1.05; orb.theta=0.4;
    orb.tx=0; orb.ty=0; orb.tz=0;
  }
  syncCamera();
  // No rebuild needed – orbit meshes stay live; just re-select ring if needed
  if (selectedPlanet) selectPlanet(selectedPlanet);
}
function navJump() {
  const gEl = document.getElementById('nav-g');
  const sEl = document.getElementById('nav-s');
  let g = parseInt(gEl.value) || 1;
  let s = parseInt(sEl.value) || 1;
  // Clamp to valid universe bounds
  g = Math.max(1, Math.min(9, g));   gEl.value = g;
  s = Math.max(1, Math.min(499, s)); sEl.value = s;

  // Check if any planet exists in this system
  const planets = galaxyData?.planets || [];
  const inSys = planets.filter(p => p.galaxy === g && p.system === s);

  const hint = document.getElementById('jump-hint');
  if (inSys.length === 0 && planets.length > 0) {
    hint.textContent = 'No planets in this system';
    hint.style.color = 'var(--dim)';
    setTimeout(() => { hint.textContent = ''; }, 2500);
  } else {
    hint.textContent = 'JUMPING…';
    hint.style.color = 'var(--cyan)';
    setTimeout(() => { hint.textContent = ''; }, 1800);
  }
  // Fly to system sun center (stored as g:s:0 in posMap)
  const sunCenter = posMap[`${g}:${s}:0`] || toWorld(g, s, 0, 0, 1);
  flyTo(sunCenter, 400);
}

function navHome() {
  const g = window.SM.galaxy, s = window.SM.system, p = window.SM.planet;
  const hint = document.getElementById('jump-hint');
  hint.textContent = 'HOME';
  hint.style.color = 'var(--green)';
  setTimeout(() => { hint.textContent = ''; }, 1800);
  const homeCenter = posMap[`${g}:${s}:0`] || toWorld(g, s, 0, 0, 1);
  flyTo(homeCenter, 400);
  // Highlight home planet if loaded
  if (galaxyData?.planets) {
    const hp = galaxyData.planets.find(pl => pl.is_own &&
      pl.galaxy === g && pl.system === s && pl.planet === p);
    if (hp) selectPlanet(hp);
  }
}
function reloadFleets(){
  const btn = document.getElementById('gm-reload-fleets');
  const icon = btn?.querySelector('i');
  if (icon) icon.classList.add('fa-spin');
  fetchFleets()
    .catch(e => console.warn('Manual fleet reload:', e))
    .finally(() => {
      if (icon) icon.classList.remove('fa-spin');
      updateFleetBadge();
    });
}

// ── Player Search ──────────────────────────────────────────
(function(){
  const inp  = document.getElementById('gm-search-inp');
  const res  = document.getElementById('gm-search-results');
  const clr  = document.getElementById('gm-search-clear');
  if(!inp||!res) return;

  let debounceT=null;
  let lastQuery='';

  function clearSearch(){
    inp.value='';
    res.innerHTML='';
    clr.style.display='none';
    lastQuery='';
  }
  if(clr) clr.addEventListener('click',clearSearch);

  function renderSearchResults(players){
    if(!players||!players.length){
      res.innerHTML='<div class="gm-sr-none">KEINE TREFFER</div>';
      return;
    }
    res.innerHTML=players.slice(0,8).map(p=>{
      const letter=(p.username||'?')[0].toUpperCase();
      const coord=p.galaxy&&p.system?`${p.galaxy}:${p.system}:${p.planet||1}`:'';
      return `<div class="gm-sr-item" data-uid="${p.id}" data-g="${p.galaxy||1}" data-s="${p.system||1}" data-p="${p.planet||1}">
        <div class="gm-sr-av">${letter}</div>
        <span class="gm-sr-name">${p.username}</span>
        ${coord?`<span class="gm-sr-coord">${coord}</span>`:''}
        ${p.total_points?`<span class="gm-sr-pts">${p.total_points}</span>`:''}
      </div>`;
    }).join('');
    res.querySelectorAll('.gm-sr-item').forEach(el=>{
      el.addEventListener('click',function(){
        const uid=parseInt(el.dataset.uid);
        const g=parseInt(el.dataset.g)||1;
        const s=parseInt(el.dataset.s)||1;
        const sunKey=`${g}:${s}:0`;
        const sunPos=posMap[sunKey]||toWorld(g,s,0,0,1);
        flyTo(sunPos,400);
        document.getElementById('nav-g').value=g;
        document.getElementById('nav-s').value=s;
        setTimeout(()=>GM.showCard(uid),600);
        clearSearch();
      });
    });
  }

  function searchLocally(q){
    if(!galaxyData||!galaxyData.planets) return null;
    const ql=q.toLowerCase();
    const seen={};
    const hits=[];
    galaxyData.planets.forEach(p=>{
      if(!p.owner_name||seen[p.owner_id]) return;
      if(p.owner_name.toLowerCase().indexOf(ql)>=0){
        seen[p.owner_id]=true;
        hits.push({id:p.owner_id,username:p.owner_name,galaxy:p.galaxy,system:p.system,planet:p.planet,total_points:''});
      }
    });
    return hits;
  }

  inp.addEventListener('input',function(){
    const q=inp.value.trim();
    clr.style.display=q?'flex':'none';
    if(q===lastQuery) return;
    lastQuery=q;
    clearTimeout(debounceT);
    if(q.length<2){ res.innerHTML=''; return; }
    debounceT=setTimeout(function(){
      const local=searchLocally(q);
      if(local&&local.length){ renderSearchResults(local); return; }
      res.innerHTML='<div class="gm-sr-none"><i class="fas fa-spinner fa-spin"></i> SEARCHING…</div>';
      fetch(`game.php?page=galaxyMap&mode=search&q=${encodeURIComponent(q)}`)
        .then(r=>r.json())
        .then(d=>renderSearchResults(d.players||d))
        .catch(()=>{ const l2=searchLocally(q); renderSearchResults(l2||[]); });
    },320);
  });

  inp.addEventListener('keydown',function(e){
    if(e.key==='Escape'){ clearSearch(); inp.blur(); }
  });
})();

// ── Render loop ───────────────────────────────────────────────
let needFleetRebuild = false;
let fleetRebuildCooldown = -1; // start at -1 so first frame always rebuilds if fleets exist
let lastTime = 0;
function animate(now = 0){
  requestAnimationFrame(animate); frame++;
  const dt = Math.min((now - lastTime) / 1000, 0.05); // seconds, capped at 50ms
  lastTime = now;

  if(starField) starField.rotation.y += 0.000012;

  // ── Orbit animation: update each planet's XZ position ──
  // No new meshes created; only position is mutated
  orbitData.forEach(od => {
    od.angle += od.speed * (dt > 0 ? dt * 60 : 1); // dt*60 normalises to ~60fps
    const nx = od.sunX + Math.cos(od.angle) * od.radius;
    const nz = od.sunZ + Math.sin(od.angle) * od.radius;
    od.mesh.position.set(nx, od.heightOff, nz);
    // Keep posMap in sync so fleet fallback lookups stay accurate
    if (od.key) posMap[od.key] = od.mesh.position.clone();
  });

  // Planet pulse – scale only, no new meshes
  const pulse = Math.sin(frame * 0.022) * 0.05 + 1.0;
  planetMeshes.forEach(sp => {
    if (sp.userData.baseScale) sp.scale.setScalar(sp.userData.baseScale * pulse);
  });

  // Sun + corona pulse – each star type has its own amplitude, speed & phase offset
  const tSec = now * 0.001; // time in seconds
  sunGroup.children.forEach(obj => {
    if (!obj.isSprite) return;
    if (obj.userData.isSun) {
      const base   = obj.userData.baseSunScale || 28;
      const amp    = obj.userData.pulseAmp    || 0.05;
      const speed  = obj.userData.pulseSpeed  || 1.0;
      const offset = obj.userData.pulseOffset || 0;
      const sp = 1.0 + Math.sin(tSec * speed + offset) * amp;
      obj.scale.setScalar(base * sp);
    } else if (obj.userData.isCorona) {
      const base   = obj.userData.baseCoronaScale || 60;
      const amp    = obj.userData.pulseAmp    || 0.07;
      const speed  = obj.userData.pulseSpeed  || 0.6;
      const offset = obj.userData.pulseOffset || 0;
      // Corona rotates slowly + pulses
      obj.material.rotation = (obj.material.rotation || 0) + 0.0003 * speed;
      const sp = 1.0 + Math.sin(tSec * speed + offset) * amp;
      obj.scale.setScalar(base * sp);
    }
  });

  // Move selection ring with selected planet
  if (selRing && selectedPlanet) {
    const key = `${selectedPlanet.galaxy}:${selectedPlanet.system}:${selectedPlanet.planet}`;
    const livePos = posMap[key];
    if (livePos) selRing.position.copy(livePos);
  }

  // Smooth-lerp fleet progress between polls
  needFleetRebuild = false;
  const nowSec = (Date.now() / 1000) + serverTimeOffset;
  for (const id in fleetAnimState) {
    const st = fleetAnimState[id];
    if (st.targetPrg === undefined || !st.curve) continue;
    const realPrg = Math.min(1, Math.max(0,
      (nowSec - (st.data.start_time||0)) / Math.max(1, (st.data.end_time||1) - (st.data.start_time||0))
    ));
    st.targetPrg = realPrg;
    if (Math.abs(st.displayPrg - realPrg) > 0.0005) {
      st.displayPrg += (realPrg - st.displayPrg) * 0.04;
      needFleetRebuild = true;
    }
  }
  // Throttle fleet rebuilds to max once per 3 frames for performance
  fleetRebuildCooldown--;
  if (needFleetRebuild && fleetRebuildCooldown <= 0) {
    rebuildFleetMeshes();
    fleetRebuildCooldown = 3;
  }

  // Hostile blink + "arriving soon" pulse – only mutates material/scale, no geometry changes
  const nowSecAnim = (Date.now() / 1000) + serverTimeOffset;
  fleetGroup.children.forEach(obj => {
    const f = obj.userData?.fleet;
    if (!f) return;
    if (obj.isLine && f.is_hostile && obj.material?.isLineDashedMaterial) {
      obj.material.opacity = 0.18 + Math.abs(Math.sin(frame * 0.05)) * 0.42;
    }
    if (obj.isSprite && obj.userData.isFleetDot) {
      const eta = Math.max(0, (f.end_time || 0) - nowSecAnim);
      if (eta > 0 && eta <= 30) {
        // Arriving soon: fast blink + scale pulse
        const blink = 0.55 + Math.abs(Math.sin(frame * 0.18)) * 0.45;
        const scalePulse = 1.0 + Math.abs(Math.sin(frame * 0.14)) * 0.5;
        obj.material.opacity = blink;
        const base = obj.userData._baseDotScale || obj.scale.x;
        if (!obj.userData._baseDotScale) obj.userData._baseDotScale = obj.scale.x;
        obj.scale.setScalar(base * scalePulse);
      } else if (eta <= 0) {
        // Past ETA: full opacity, no pulse
        obj.material.opacity = 1.0;
      }
    }
  });

  // Selection ring pulse
  if (selRing) {
    selRing.material.opacity = 0.35 + Math.abs(Math.sin(frame * 0.04)) * 0.35;
  }

  renderer.render(scene, camera);
}

// Boot – restore saved view preference; force 2D on mobile
(function() {
  const isMobile = window.innerWidth <= 768;
  if (isMobile) {
    // Mobile: always 2D, ignore saved preference
    is3D = false;
    const b3 = document.getElementById('vb-3d');
    const b2 = document.getElementById('vb-2d');
    if (b3) { b3.classList.remove('on'); b3.style.display = 'none'; }
    if (b2) b2.classList.add('on');
    try { localStorage.setItem('galaxy_view', '2d'); } catch(e) {}
  } else {
    try {
      const saved = localStorage.getItem('galaxy_view');
      if (saved === '2d') {
        is3D = false;
        const b3 = document.getElementById('vb-3d');
        const b2 = document.getElementById('vb-2d');
        if (b3) b3.classList.remove('on');
        if (b2) b2.classList.add('on');
      }
    } catch(e) {}
  }
})();
init();
return{setView,navJump,navHome,reloadFleets,closeAction,closeCard,showCard,selectPlanet,deselectPlanet};
})();
</script>
