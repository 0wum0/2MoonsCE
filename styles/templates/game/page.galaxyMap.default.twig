<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
{% autoescape false %}
<script>
/* ============================================================
   2MoonsCE Galaxy Map v3
   Planeten = THREE.Sprite mit Canvas-Kreis-Textur → immer rund
   ============================================================ */
const GM = (() => {
'use strict';

// ── State ──────────────────────────────────────────────────
let scene, camera, renderer;
let is3D  = true;
let frame = 0;

let orb = { theta: 0.4, phi: 1.05, r: 3000, tx: 0, ty: 0, tz: 0 };
let pan = { x: 0, z: 0 };
let selectedPlanet = null;
let selRing = null; // THREE.Mesh highlight ring
let drag = { down:false, startX:0, startY:0, moved:0,
             snapTheta:0, snapPhi:0, snapPanX:0, snapPanZ:0 };

let starField    = null;
let planetGroup  = null;
let sunGroup     = null;  // suns + orbit rings
let fleetGroup   = null;
let planetMeshes = [];   // sprite refs for raycasting
let posMap       = {};   // "g:s:p" → THREE.Vector3
let orbitData    = [];   // {mesh, sunPos, radius, speed, angle, heightOff} for animate loop

let galaxyData       = null;
let fleetData        = null;
let serverTimeOffset = 0;
const fleetAnimState = {};

// ── DOM ────────────────────────────────────────────────────
const canvas   = document.getElementById('gm-canvas');
const loadEl   = document.getElementById('gm-load');
const ldTxt    = document.getElementById('ld-txt');
const actionEl = document.getElementById('gm-action');
const cardEl   = document.getElementById('gm-card');
const tipEl    = document.getElementById('gm-tip');

// ── Raycaster & dispose ─────────────────────────────────
const RC = new THREE.Raycaster();
const MV = new THREE.Vector2();
function disposeGroup(g) {
  while (g.children.length) {
    const o = g.children[0]; g.remove(o);
    if (o.geometry) o.geometry.dispose();
    if (o.material) {
      if (Array.isArray(o.material)) {
        o.material.forEach(m => { if (m.map) m.map.dispose(); m.dispose(); });
      } else {
        if (o.material.map) o.material.map.dispose();
        o.material.dispose();
      }
    }
    // PointLight and other non-mesh objects: no geometry/material, just removed above
  }
}

// ── Realistic planet texture system ───────────────────────
// 10 planet types rendered entirely on canvas – no external images.
// Each type has a deterministic seeded renderer producing sphere-like
// appearance with terrain noise, atmosphere glow, and optional ring.

// Simple seeded pseudo-random (mulberry32)
function mkRng(seed) {
  let s = seed >>> 0;
  return () => { s += 0x6D2B79F5; let t=s; t=(t^t>>>15)*((t|1)+0x94D049BB); t^=t+((t^t>>>7)*(t|0x9E3779B9)); return ((t^t>>>14)>>>0)/4294967295; };
}

// ── Planet type catalogue ──────────────────────────────────
const PLANET_TYPES = [
  // 0 – Terrestrial (Earth-like): blue ocean, green continents, white clouds
  { id:'terr', draw(ctx,S,rng){ drawTerrestrial(ctx,S,rng); } },
  // 1 – Desert / Mars: ochre, red-brown dunes
  { id:'desert', draw(ctx,S,rng){ drawDesert(ctx,S,rng); } },
  // 2 – Ice world: white-blue glaciers, cracks
  { id:'ice', draw(ctx,S,rng){ drawIce(ctx,S,rng); } },
  // 3 – Lava: dark rock, glowing fissures, red-orange
  { id:'lava', draw(ctx,S,rng){ drawLava(ctx,S,rng); } },
  // 4 – Gas giant (Jupiter-like): brown/tan horizontal bands
  { id:'gas', draw(ctx,S,rng){ drawGasGiant(ctx,S,rng); } },
  // 5 – Rocky / Moon: grey craters, no atmosphere
  { id:'rock', draw(ctx,S,rng){ drawRocky(ctx,S,rng); } },
  // 6 – Ocean world: deep blue, no land, glinting
  { id:'ocean', draw(ctx,S,rng){ drawOcean(ctx,S,rng); } },
  // 7 – Jungle: dark green, dense, with mist bands
  { id:'jungle', draw(ctx,S,rng){ drawJungle(ctx,S,rng); } },
  // 8 – Gas giant with rings (Saturn-like)
  { id:'saturn', draw(ctx,S,rng){ drawSaturn(ctx,S,rng); } },
  // 9 – Toxic / Venus: yellow-green thick clouds
  { id:'toxic', draw(ctx,S,rng){ drawToxic(ctx,S,rng); } },
];

// Assign type deterministically from galaxy+system+slot
function planetType(g, s, slot) {
  const n = ((g * 499 + s) * 17 + slot) * 2246822519 >>> 0;
  return PLANET_TYPES[n % PLANET_TYPES.length];
}

// ── Shared helpers ─────────────────────────────────────────
function clipCircle(ctx, cx, r) {
  ctx.save(); ctx.beginPath(); ctx.arc(cx, cx, r, 0, Math.PI*2); ctx.clip();
}
function sphereShading(ctx, cx, r) {
  // Terminator shadow (right side dark)
  const sh = ctx.createRadialGradient(cx+r*.35, cx-r*.35, r*.1, cx, cx, r);
  sh.addColorStop(0, 'rgba(255,255,255,0.18)');
  sh.addColorStop(0.55, 'rgba(0,0,0,0)');
  sh.addColorStop(1, 'rgba(0,0,0,0.72)');
  ctx.beginPath(); ctx.arc(cx, cx, r, 0, Math.PI*2);
  ctx.fillStyle = sh; ctx.fill();
}
function atmosphereGlow(ctx, cx, r, col) {
  ctx.restore(); // outside clip
  const ag = ctx.createRadialGradient(cx, cx, r*.92, cx, cx, r*1.18);
  ag.addColorStop(0, col);
  ag.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.beginPath(); ctx.arc(cx, cx, r*1.18, 0, Math.PI*2);
  ctx.fillStyle = ag; ctx.fill();
}
// Noise-like band/patch via small arcs
function noisePatch(ctx, rng, cx, r, col, count, minSz, maxSz) {
  ctx.fillStyle = col;
  for (let i = 0; i < count; i++) {
    const px = cx + (rng()-.5)*r*1.6, py = cx + (rng()-.5)*r*1.6;
    const sz = minSz + rng()*(maxSz-minSz);
    ctx.beginPath(); ctx.ellipse(px, py, sz, sz*(.4+rng()*.6), rng()*Math.PI, 0, Math.PI*2);
    ctx.fill();
  }
}

// ── Planet renderers ───────────────────────────────────────
function drawTerrestrial(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  // Ocean base
  const base = ctx.createLinearGradient(0,0,S,S);
  base.addColorStop(0,'#1a4a8a'); base.addColorStop(1,'#0d2d5e');
  ctx.fillRect(0,0,S,S);
  ctx.fillStyle = base; ctx.fillRect(0,0,S,S);
  // Continents
  ctx.globalAlpha = 0.85;
  noisePatch(ctx,rng,cx,r,'#4a7a3a',7,r*.1,r*.3);
  noisePatch(ctx,rng,cx,r,'#5a8a48',5,r*.05,r*.18);
  noisePatch(ctx,rng,cx,r,'#c8a86a',3,r*.04,r*.12); // desert patches
  ctx.globalAlpha = 1;
  // Ice caps
  const iceCap1 = ctx.createRadialGradient(cx,cx-r*.82,0,cx,cx-r*.78,r*.28);
  iceCap1.addColorStop(0,'rgba(240,248,255,0.95)'); iceCap1.addColorStop(1,'rgba(220,235,255,0)');
  ctx.fillStyle=iceCap1; ctx.fillRect(0,0,S,S);
  // Cloud bands
  ctx.globalAlpha = 0.55;
  noisePatch(ctx,rng,cx,r,'rgba(255,255,255,0.7)',10,r*.08,r*.22);
  ctx.globalAlpha = 1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(80,140,255,0.45)');
}

function drawDesert(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  const base = ctx.createLinearGradient(0,0,S,S);
  base.addColorStop(0,'#c87a30'); base.addColorStop(0.5,'#a85a1a'); base.addColorStop(1,'#7a3a0a');
  ctx.fillStyle = base; ctx.fillRect(0,0,S,S);
  // Dune patterns
  ctx.globalAlpha = 0.5;
  for (let i = 0; i < 8; i++) {
    const y = cx + (rng()-.5)*r*1.4;
    ctx.strokeStyle = `rgba(${180+Math.floor(rng()*40)},${100+Math.floor(rng()*30)},${30+Math.floor(rng()*20)},0.6)`;
    ctx.lineWidth = 1.5+rng()*3;
    ctx.beginPath(); ctx.moveTo(0,y); ctx.bezierCurveTo(S*.3,y+(rng()-.5)*12,S*.7,y+(rng()-.5)*12,S,y+(rng()-.5)*8); ctx.stroke();
  }
  ctx.globalAlpha = 0.4;
  noisePatch(ctx,rng,cx,r,'#8a4a18',4,r*.06,r*.15);
  ctx.globalAlpha = 1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(200,120,60,0.35)');
}

function drawIce(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  const base = ctx.createRadialGradient(cx-r*.2,cx-r*.2,0,cx,cx,r);
  base.addColorStop(0,'#e8f4ff'); base.addColorStop(0.5,'#b8d8f0'); base.addColorStop(1,'#7aaad4');
  ctx.fillStyle = base; ctx.fillRect(0,0,S,S);
  // Cracks / fault lines
  ctx.globalAlpha = 0.55;
  for (let i = 0; i < 12; i++) {
    ctx.strokeStyle = `rgba(100,160,220,${0.3+rng()*.4})`;
    ctx.lineWidth = 0.5+rng()*1.5;
    const sx=cx+(rng()-.5)*r*1.8, sy=cx+(rng()-.5)*r*1.8;
    ctx.beginPath(); ctx.moveTo(sx,sy);
    for(let j=0;j<4;j++) ctx.lineTo(sx+(rng()-.5)*r*.8,sy+(rng()-.5)*r*.8);
    ctx.stroke();
  }
  ctx.globalAlpha = 0.3;
  noisePatch(ctx,rng,cx,r,'rgba(160,200,240,0.6)',6,r*.05,r*.14);
  ctx.globalAlpha = 1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(160,220,255,0.5)');
}

function drawLava(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  // Dark rock base
  const base = ctx.createRadialGradient(cx,cx,0,cx,cx,r);
  base.addColorStop(0,'#3a1a08'); base.addColorStop(1,'#1a0a04');
  ctx.fillStyle = base; ctx.fillRect(0,0,S,S);
  // Glowing lava fissures
  ctx.globalAlpha = 0.9;
  for(let i=0;i<14;i++){
    const sx=cx+(rng()-.5)*r*1.6, sy=cx+(rng()-.5)*r*1.6;
    const lava=ctx.createLinearGradient(sx,sy,sx+rng()*r*.6,sy+rng()*r*.6);
    lava.addColorStop(0,'rgba(255,60,0,0.9)');
    lava.addColorStop(0.5,'rgba(255,140,0,0.7)');
    lava.addColorStop(1,'rgba(180,20,0,0)');
    ctx.strokeStyle=lava; ctx.lineWidth=1+rng()*3;
    ctx.beginPath();ctx.moveTo(sx,sy);
    for(let j=0;j<3;j++) ctx.lineTo(sx+(rng()-.5)*r*.5,sy+(rng()-.5)*r*.5);
    ctx.stroke();
  }
  // Lava pools
  ctx.globalAlpha=0.7;
  noisePatch(ctx,rng,cx,r,'rgba(255,80,0,0.6)',5,r*.04,r*.12);
  noisePatch(ctx,rng,cx,r,'rgba(255,160,0,0.4)',4,r*.02,r*.07);
  ctx.globalAlpha=1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(255,60,0,0.4)');
}

function drawGasGiant(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  // Base tan/brown
  ctx.fillStyle='#c8904a'; ctx.fillRect(0,0,S,S);
  // Horizontal bands
  const bands=[
    ['#e8a850',0.08],['#a86830',0.12],['#d4904a',0.07],['#8a5025',0.10],
    ['#e0a048',0.09],['#b87838',0.13],['#cc8840',0.08],['#9a6030',0.11],
    ['#d89848',0.07],['#a07028',0.10],
  ];
  let y=0;
  bands.forEach(([col,frac])=>{
    const bh = S*frac + rng()*S*0.04;
    ctx.fillStyle=col; ctx.fillRect(0,y,S,bh+2); y+=bh;
  });
  // Turbulence swirls
  ctx.globalAlpha=0.35;
  for(let i=0;i<6;i++){
    const py=cx+(rng()-.5)*r*1.2;
    ctx.fillStyle=`rgba(${200+Math.floor(rng()*40)},${130+Math.floor(rng()*30)},${60+Math.floor(rng()*20)},0.5)`;
    ctx.beginPath();ctx.ellipse(cx+(rng()-.5)*r*.6,py,r*(.2+rng()*.25),r*(.05+rng()*.06),0,0,Math.PI*2);ctx.fill();
  }
  ctx.globalAlpha=1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(220,160,80,0.3)');
}

function drawRocky(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  // Grey base
  const base=ctx.createRadialGradient(cx-r*.15,cx-r*.15,0,cx,cx,r);
  base.addColorStop(0,'#c0b8b0'); base.addColorStop(1,'#585450');
  ctx.fillStyle=base; ctx.fillRect(0,0,S,S);
  // Craters
  for(let i=0;i<12;i++){
    const px=cx+(rng()-.5)*r*1.4, py=cx+(rng()-.5)*r*1.4;
    const cr=r*(.04+rng()*.12);
    // Rim highlight
    ctx.strokeStyle=`rgba(200,195,190,${0.4+rng()*.3})`; ctx.lineWidth=0.8;
    ctx.beginPath(); ctx.arc(px,py,cr,0,Math.PI*2); ctx.stroke();
    // Interior shadow
    const ci=ctx.createRadialGradient(px+cr*.2,py+cr*.2,0,px,py,cr);
    ci.addColorStop(0,'rgba(50,45,40,0.7)'); ci.addColorStop(1,'rgba(50,45,40,0)');
    ctx.fillStyle=ci; ctx.beginPath(); ctx.arc(px,py,cr,0,Math.PI*2); ctx.fill();
  }
  sphereShading(ctx,cx,r);
  ctx.restore(); // no atmosphere for dead rocks
}

function drawOcean(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  const base=ctx.createRadialGradient(cx-r*.2,cx-r*.1,0,cx,cx,r);
  base.addColorStop(0,'#1a6aaa'); base.addColorStop(0.5,'#0a3d7a'); base.addColorStop(1,'#051a44');
  ctx.fillStyle=base; ctx.fillRect(0,0,S,S);
  // Glint lines (wave reflections)
  ctx.globalAlpha=0.25;
  for(let i=0;i<16;i++){
    const py=cx+(rng()-.5)*r*1.6;
    ctx.strokeStyle='rgba(160,210,255,0.6)'; ctx.lineWidth=0.6+rng();
    ctx.beginPath(); ctx.moveTo(cx+(rng()-.5)*r*1.2,py);
    ctx.lineTo(cx+(rng()-.5)*r*.8,py+(rng()-.5)*4); ctx.stroke();
  }
  ctx.globalAlpha=0.2;
  noisePatch(ctx,rng,cx,r,'rgba(100,180,255,0.5)',8,r*.04,r*.12);
  ctx.globalAlpha=1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(40,120,220,0.55)');
}

function drawJungle(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  const base=ctx.createLinearGradient(0,0,S,S);
  base.addColorStop(0,'#1a3a12'); base.addColorStop(1,'#0d2008');
  ctx.fillStyle=base; ctx.fillRect(0,0,S,S);
  // Dense foliage patches
  ctx.globalAlpha=0.8;
  noisePatch(ctx,rng,cx,r,'#2a5a18',12,r*.06,r*.22);
  noisePatch(ctx,rng,cx,r,'#386828',8,r*.04,r*.14);
  noisePatch(ctx,rng,cx,r,'#4a7a30',6,r*.03,r*.10);
  // River/water patches
  ctx.globalAlpha=0.4;
  noisePatch(ctx,rng,cx,r,'#1a4468',3,r*.02,r*.08);
  // Mist/cloud bands
  ctx.globalAlpha=0.3;
  noisePatch(ctx,rng,cx,r,'rgba(200,220,200,0.5)',8,r*.06,r*.18);
  ctx.globalAlpha=1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(60,160,60,0.4)');
}

function drawSaturn(ctx, S, rng) {
  // Draw rings FIRST (behind planet), then planet on top
  const cx = S/2, r = S/2 - 2;
  // Ring system (elliptical, angled)
  const ringColors=['rgba(200,170,120,0.55)','rgba(180,145,95,0.45)','rgba(220,190,140,0.5)','rgba(160,130,80,0.4)'];
  for(let ri=0;ri<4;ri++){
    const ro=(r*1.18)+(ri*r*.15), ri2=ro-r*.12;
    const rg=ctx.createRadialGradient(cx,cx,ri2,cx,cx,ro);
    rg.addColorStop(0,'rgba(0,0,0,0)'); rg.addColorStop(0.5,ringColors[ri]); rg.addColorStop(1,'rgba(0,0,0,0)');
    ctx.save();
    ctx.translate(cx,cx); ctx.scale(1,0.32); ctx.translate(-cx,-cx);
    ctx.beginPath(); ctx.arc(cx,cx,ro,0,Math.PI*2);
    ctx.fillStyle=rg; ctx.fill();
    ctx.restore();
  }
  // Now planet (gas giant style but more golden)
  clipCircle(ctx,cx,r);
  ctx.fillStyle='#d4aa60'; ctx.fillRect(0,0,S,S);
  const bands2=[['#e8c070',0.09],['#b88840',0.13],['#dab060',0.08],['#c09848',0.11],['#e0b858',0.10],['#a87830',0.12]];
  let y2=0;
  bands2.forEach(([col,frac])=>{ const bh=S*frac+rng()*S*.04; ctx.fillStyle=col; ctx.fillRect(0,y2,S,bh+2); y2+=bh; });
  ctx.globalAlpha=0.3;
  for(let i=0;i<4;i++){
    const py=cx+(rng()-.5)*r*.8;
    ctx.fillStyle='rgba(240,200,120,0.4)';
    ctx.beginPath();ctx.ellipse(cx+(rng()-.5)*r*.4,py,r*(.15+rng()*.2),r*.04,0,0,Math.PI*2);ctx.fill();
  }
  ctx.globalAlpha=1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(220,180,100,0.3)');
}

function drawToxic(ctx, S, rng) {
  const cx = S/2, r = S/2 - 2;
  clipCircle(ctx, cx, r);
  const base=ctx.createRadialGradient(cx,cx,0,cx,cx,r);
  base.addColorStop(0,'#c8d840'); base.addColorStop(0.5,'#a0b020'); base.addColorStop(1,'#606008');
  ctx.fillStyle=base; ctx.fillRect(0,0,S,S);
  // Thick cloud swirls
  ctx.globalAlpha=0.6;
  for(let i=0;i<10;i++){
    const py=cx+(rng()-.5)*r*1.3;
    ctx.fillStyle=`rgba(${180+Math.floor(rng()*40)},${195+Math.floor(rng()*30)},${30+Math.floor(rng()*40)},0.5)`;
    ctx.beginPath();ctx.ellipse(cx+(rng()-.5)*r*.8,py,r*(.2+rng()*.3),r*(.06+rng()*.08),rng()*.5,0,Math.PI*2);ctx.fill();
  }
  ctx.globalAlpha=0.25;
  noisePatch(ctx,rng,cx,r,'rgba(255,255,120,0.4)',6,r*.04,r*.12);
  ctx.globalAlpha=1;
  sphereShading(ctx,cx,r);
  atmosphereGlow(ctx,cx,r,'rgba(180,220,0,0.5)');
}

// ── Texture cache: key = planetType.id + seed ─────────────
const texCache = {};
const planetTexCache = {};

// Main entry: returns a CanvasTexture for a given planet slot
// colorHex = ownership tint overlay (own=green, ally=purple, etc.)
function planetTex(g, s, slot, colorHex) {
  const ptype = planetType(g, s, slot);
  const seed  = (g * 499 * 15 + s * 15 + slot) * 1234567;
  const key   = ptype.id + '_' + (seed >>> 0);
  if (planetTexCache[key]) return { tex: planetTexCache[key], ptype };

  const S = 192;
  const c = document.createElement('canvas');
  c.width = c.height = S;
  const ctx = c.getContext('2d');
  const rng = mkRng(seed);

  ptype.draw(ctx, S, rng);

  // Ownership tint overlay (subtle, only if colorHex provided and not neutral)
  if (colorHex && colorHex !== '#00d4ff') {
    ctx.save();
    ctx.globalAlpha = 0.22;
    ctx.globalCompositeOperation = 'source-atop';
    ctx.fillStyle = colorHex;
    ctx.beginPath(); ctx.arc(S/2, S/2, S/2-2, 0, Math.PI*2); ctx.fill();
    ctx.restore();
  }

  planetTexCache[key] = new THREE.CanvasTexture(c);
  return { tex: planetTexCache[key], ptype };
}

// Legacy fallback: simple colour circle (used for moons, debris, empty slots)
function circleTex(hex) {
  if (texCache[hex]) return texCache[hex];
  const S = 96, c = document.createElement('canvas');
  c.width = c.height = S;
  const ctx = c.getContext('2d'), cx = S/2, r = S/2 - 2;
  const g1 = ctx.createRadialGradient(cx, cx, r*.15, cx, cx, r);
  g1.addColorStop(0, hex + 'bb'); g1.addColorStop(0.6, hex + '44'); g1.addColorStop(1, hex + '00');
  ctx.beginPath(); ctx.arc(cx,cx,r,0,Math.PI*2); ctx.fillStyle=g1; ctx.fill();
  const g2 = ctx.createRadialGradient(cx-r*.2,cx-r*.2,0,cx,cx,r*.5);
  g2.addColorStop(0,'#ffffff'); g2.addColorStop(0.2,hex); g2.addColorStop(1,darken(hex));
  ctx.beginPath(); ctx.arc(cx,cx,r*.46,0,Math.PI*2); ctx.fillStyle=g2; ctx.fill();
  texCache[hex] = new THREE.CanvasTexture(c);
  return texCache[hex];
}
function darken(hex) {
  hex = hex.replace('#','');
  const d = v => Math.max(0, Math.round(parseInt(v,16)*0.45)).toString(16).padStart(2,'0');
  return '#'+d(hex.slice(0,2))+d(hex.slice(2,4))+d(hex.slice(4,6));
}

// ── Init Three.js ──────────────────────────────────────────
function init() {
  scene = new THREE.Scene();
  scene.background = new THREE.Color(0x020510);
  scene.fog = new THREE.FogExp2(0x020510, 0.00010);

  camera = new THREE.PerspectiveCamera(58, innerWidth/innerHeight, 0.5, 60000);
  // Initial camera position per spec
  camera.position.set(0, 2000, 3000);
  camera.lookAt(0, 0, 0);

  renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setSize(innerWidth, innerHeight);
  renderer.setPixelRatio(Math.min(devicePixelRatio, 2));

  scene.add(new THREE.AmbientLight(0x304060, 2));
  const dl = new THREE.DirectionalLight(0x5599ff, 0.6);
  dl.position.set(200, 400, 100); scene.add(dl);

  planetGroup = new THREE.Group(); scene.add(planetGroup);
  sunGroup    = new THREE.Group(); scene.add(sunGroup);
  fleetGroup  = new THREE.Group(); scene.add(fleetGroup);

  buildStars();
  buildNebula();
  bindEvents();
  initMobilePanel();
  measureFooterHeight();

  // Apply correct initial camera for whichever view mode was set by the boot IIFE
  if (!is3D) {
    orb.r = 4000; orb.phi = 0.01; orb.theta = 0;
    pan.x = 0; pan.z = 0;
  }
  syncCamera();

  // Single rAF loop – start before fetch so canvas is live immediately
  animate();

  // Failsafe: always hide loader after 8 s regardless of fetch outcome
  const loaderTimeout = setTimeout(() => {
    if (loadEl.style.display !== 'none') {
      ldTxt.textContent = 'TIMEOUT – DEMO MODE';
      loadDemo();
      hideLoader(400);
    }
  }, 8000);

  // Galaxy fetch is authoritative – failure → demo mode
  // Fleet fetch is independent – failure just means no fleet lines shown
  fetchGalaxy()
    .then(() => { clearTimeout(loaderTimeout); hideLoader(); })
    .catch(() => { clearTimeout(loaderTimeout); ldTxt.textContent = 'DEMO MODE'; loadDemo(); hideLoader(800); });
  fetchFleets().catch(e => console.warn('Initial fleet fetch failed:', e));

  // ── Adaptive fleet polling engine ──────────────────────────────
  // Interval adapts based on fleet proximity:
  //   2 s  – any fleet arriving within 60 s
  //   5 s  – fleets active but none imminent
  //  15 s  – no fleets at all / tab hidden
  let fleetPollTimer = null;
  let fleetPollPaused = false;

  function getAdaptiveInterval() {
    const nowSec = (Date.now() / 1000) + serverTimeOffset;
    const states = Object.values(fleetAnimState);
    // 3 s when no fleets known – catches newly dispatched fleets quickly
    if (!states.length) return 3000;
    const minEta = Math.min(...states.map(st => Math.max(0, (st.data?.end_time || 0) - nowSec)));
    if (minEta <= 60) return 2000;
    return 4000;
  }

  function schedulePoll() {
    clearTimeout(fleetPollTimer);
    if (fleetPollPaused) return;
    const interval = getAdaptiveInterval();
    const secs = (interval / 1000).toFixed(0);
    set('upd-time', `Auto-refresh: ${secs}s`);
    fleetPollTimer = setTimeout(() => {
      fetchFleets()
        .catch(e => console.warn('Fleet poll:', e))
        .finally(() => schedulePoll());
    }, interval);
  }

  // Pause when tab hidden, resume immediately on focus
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      fleetPollPaused = true;
      clearTimeout(fleetPollTimer);
    } else {
      fleetPollPaused = false;
      // Immediate re-fetch on tab focus then re-schedule
      fetchFleets().catch(e => console.warn('Fleet resume poll:', e)).finally(() => schedulePoll());
    }
  });

  // Also re-fetch on window focus (user switches browser tab / app back to map)
  window.addEventListener('focus', () => {
    if (!fleetPollPaused) {
      clearTimeout(fleetPollTimer);
      fetchFleets().catch(e => console.warn('Fleet focus poll:', e)).finally(() => schedulePoll());
    }
  });

  schedulePoll();
}

function hideLoader(delay=0) {
  setTimeout(() => {
    loadEl.style.opacity='0';
    setTimeout(()=>loadEl.style.display='none', 450);
  }, delay);
}

// ── Starfield ──────────────────────────────────────────────
function buildStars() {
  const N=8000, pos=new Float32Array(N*3), col=new Float32Array(N*3);
  for (let i=0;i<N;i++) {
    const rr=1000+Math.random()*4500, t=Math.random()*Math.PI*2, p=Math.acos(2*Math.random()-1);
    pos[i*3]=rr*Math.sin(p)*Math.cos(t); pos[i*3+1]=rr*Math.sin(p)*Math.sin(t)*.22; pos[i*3+2]=rr*Math.cos(p);
    const v=0.5+Math.random()*.5;
    col[i*3]=v*(0.7+Math.random()*.3); col[i*3+1]=v*(0.8+Math.random()*.2); col[i*3+2]=v;
  }
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  geo.setAttribute('color',new THREE.BufferAttribute(col,3));
  starField=new THREE.Points(geo,new THREE.PointsMaterial({
    size:1.3,vertexColors:true,sizeAttenuation:true,transparent:true,opacity:.88,depthWrite:false
  }));
  scene.add(starField);
}

function buildNebula() {
  const N=2500, pos=new Float32Array(N*3);
  for (let i=0;i<N;i++) {
    const t=(i/N)*Math.PI*9+Math.random()*.9, rr=(i/N)*500;
    const arm=Math.floor(Math.random()*3)*(Math.PI*2/3);
    pos[i*3]=Math.cos(t+arm)*rr+(Math.random()-.5)*22;
    pos[i*3+1]=(Math.random()-.5)*6;
    pos[i*3+2]=Math.sin(t+arm)*rr+(Math.random()-.5)*22;
  }
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  scene.add(new THREE.Points(geo,new THREE.PointsMaterial({
    color:0x1a2d99,size:2.8,sizeAttenuation:true,transparent:true,opacity:.18,depthWrite:false
  })));
}

// ── Spiral-Galaxy coordinate system ───────────────────────
// [1:1] = centre (0,0).  Each (galaxy, system) pair maps to
// a unique position on a Fermat (golden-angle) spiral so that
// systems never pile up, are evenly spaced, and [1:1] is at
// the origin.  Positions are FULLY DETERMINISTIC.
//
// galaxyIndex = g-1  (0-based)
// systemIndex  = s-1  (0-based within galaxy)
// globalIndex  = galaxyIndex * SYSTEMS_PER_GALAXY + systemIndex
//   → index 0 ([1:1]) maps to r=0  (the very centre)
//
// Fermat spiral:  r = RADIAL_STEP * sqrt(n),  θ = n * GOLDEN_ANGLE
// RADIAL_STEP chosen so adjacent rings have ~320 units of space.
const SYSTEMS_PER_GALAXY = 499;
const RADIAL_STEP        = 320;   // units between spiral rings
const GOLDEN_ANGLE       = Math.PI * (3 - Math.sqrt(5)); // ≈ 137.5°

function systemCenter(g, s) {
  const n = (g - 1) * SYSTEMS_PER_GALAXY + (s - 1); // 0-based
  if (n === 0) return { x: 0, z: 0 };               // [1:1] = centre
  const r     = RADIAL_STEP * Math.sqrt(n);
  const theta = n * GOLDEN_ANGLE;
  return { x: Math.cos(theta) * r, z: Math.sin(theta) * r };
}

// Fallback helper (used by fleet position lookup when posMap misses)
function toWorld(g, s, p, _pi, _tot) {
  const c = systemCenter(g, s);
  const slot  = Math.max(1, p || 1);
  const r     = 40 + slot * 18;
  const angle = (slot / 10) * Math.PI * 2;
  return new THREE.Vector3(c.x + Math.cos(angle) * r, 0, c.z + Math.sin(angle) * r);
}

// ── Star type definitions ─────────────────────────────────
// 5 spectral classes, each with unique colour, size scale,
// corona radius, pulse speed and point-light intensity.
const STAR_TYPES = [
  // Blue-white dwarf (class B)
  { id:'B', core:'#c8e8ff', mid:'#99ccff', halo:'#4488ff',
    spriteScale: 18, coreR: 3.2,  coronaScale: 1.6,
    lightInt: 0.8,  pulseAmp: 0.03, pulseSpeed: 1.8 },
  // White main sequence (class A)
  { id:'A', core:'#ffffff', mid:'#eef5ff', halo:'#aaccff',
    spriteScale: 22, coreR: 4.2,  coronaScale: 1.5,
    lightInt: 1.0,  pulseAmp: 0.04, pulseSpeed: 1.4 },
  // Yellow main sequence (class G – Sun-like)
  { id:'G', core:'#fffde0', mid:'#ffdd88', halo:'#ffaa33',
    spriteScale: 28, coreR: 5.0,  coronaScale: 1.8,
    lightInt: 1.2,  pulseAmp: 0.05, pulseSpeed: 1.1 },
  // Orange giant (class K)
  { id:'K', core:'#fff0cc', mid:'#ffaa44', halo:'#ff6600',
    spriteScale: 36, coreR: 6.5,  coronaScale: 2.1,
    lightInt: 1.5,  pulseAmp: 0.07, pulseSpeed: 0.8 },
  // Red supergiant (class M)
  { id:'M', core:'#ffe8cc', mid:'#ff6644', halo:'#cc2200',
    spriteScale: 48, coreR: 8.5,  coronaScale: 2.6,
    lightInt: 1.8,  pulseAmp: 0.10, pulseSpeed: 0.55 },
];
// Weighted distribution: G most common, M rarest
const STAR_TYPE_WEIGHTS = [1, 2, 5, 3, 1]; // B A G K M
const _starWeightSum = STAR_TYPE_WEIGHTS.reduce((a,b)=>a+b,0);

function starType(g, s) {
  // Deterministic pseudo-random pick weighted by rarity
  const n = ((g - 1) * SYSTEMS_PER_GALAXY + (s - 1)) * 2654435761 >>> 0;
  let pick = (n % _starWeightSum);
  for (let i = 0; i < STAR_TYPES.length; i++) {
    pick -= STAR_TYPE_WEIGHTS[i];
    if (pick < 0) return STAR_TYPES[i];
  }
  return STAR_TYPES[2]; // fallback G
}

// ── Sun glow texture – per star type ──────────────────────
const sunTexCache = {};
function sunTex(st) {
  if (sunTexCache[st.id]) return sunTexCache[st.id];
  const S = 512, c = document.createElement('canvas');
  c.width = c.height = S;
  const ctx = c.getContext('2d'), cx = S / 2, r = S / 2 - 1;

  // 1. Wide diffuse halo
  const g1 = ctx.createRadialGradient(cx, cx, 0, cx, cx, r);
  g1.addColorStop(0,    '#ffffff');
  g1.addColorStop(0.06, st.core);
  g1.addColorStop(0.20, st.mid + 'dd');
  g1.addColorStop(0.50, st.halo + '66');
  g1.addColorStop(0.80, st.halo + '22');
  g1.addColorStop(1,    st.halo + '00');
  ctx.beginPath(); ctx.arc(cx, cx, r, 0, Math.PI * 2);
  ctx.fillStyle = g1; ctx.fill();

  // 2. Mid corona ring
  const g2 = ctx.createRadialGradient(cx, cx, r * 0.10, cx, cx, r * 0.38);
  g2.addColorStop(0,   st.mid + 'aa');
  g2.addColorStop(0.5, st.mid + '33');
  g2.addColorStop(1,   st.mid + '00');
  ctx.beginPath(); ctx.arc(cx, cx, r * 0.38, 0, Math.PI * 2);
  ctx.fillStyle = g2; ctx.fill();

  // 3. Bright core highlight (off-center for 3D feel)
  const g3 = ctx.createRadialGradient(cx - r*.08, cx - r*.08, 0, cx, cx, r * .14);
  g3.addColorStop(0, '#ffffff');
  g3.addColorStop(0.6, st.core + 'bb');
  g3.addColorStop(1,   st.core + '00');
  ctx.beginPath(); ctx.arc(cx, cx, r * .16, 0, Math.PI * 2);
  ctx.fillStyle = g3; ctx.fill();

  sunTexCache[st.id] = new THREE.CanvasTexture(c);
  return sunTexCache[st.id];
}

// Corona / spike texture for large stars (K, M)
const coronaTexCache = {};
function coronaTex(st) {
  if (coronaTexCache[st.id]) return coronaTexCache[st.id];
  const S = 256, c = document.createElement('canvas');
  c.width = c.height = S;
  const ctx = c.getContext('2d'), cx = S / 2;
  // 4 diagonal spike lines
  const spikes = 6;
  for (let i = 0; i < spikes; i++) {
    const a = (i / spikes) * Math.PI;
    const len = cx * 0.92;
    const grd = ctx.createLinearGradient(
      cx + Math.cos(a) * len, cx + Math.sin(a) * len,
      cx - Math.cos(a) * len, cx - Math.sin(a) * len
    );
    grd.addColorStop(0,    st.halo + '00');
    grd.addColorStop(0.45, st.mid  + '55');
    grd.addColorStop(0.5,  '#ffffff88');
    grd.addColorStop(0.55, st.mid  + '55');
    grd.addColorStop(1,    st.halo + '00');
    ctx.save();
    ctx.strokeStyle = grd;
    ctx.lineWidth = 1.5;
    ctx.globalAlpha = 0.55;
    ctx.beginPath();
    ctx.moveTo(cx + Math.cos(a) * len, cx + Math.sin(a) * len);
    ctx.lineTo(cx - Math.cos(a) * len, cx - Math.sin(a) * len);
    ctx.stroke();
    ctx.restore();
  }
  coronaTexCache[st.id] = new THREE.CanvasTexture(c);
  return coronaTexCache[st.id];
}

// Compatibility shim: old callers used sunColor(g,s) → hex string
function sunColor(g, s) { return starType(g, s).mid; }

// ── Solar system builder ───────────────────────────────────
// Each system: spiral-positioned sun + 10 orbital slots (real or empty).
// Only the nearest MAX_LIGHTS systems get a PointLight (performance).
const MAX_LIGHTS = 12;      // max active PointLights in scene
const MAX_PICK_DISTANCE = 4000; // raycaster distance gate

function buildPlanets(planets) {
  if (selRing) { planetGroup.remove(selRing); }
  disposeGroup(planetGroup);
  disposeGroup(sunGroup);
  planetMeshes = [];
  posMap = {};
  orbitData = [];

  // ── 1. Group real planets by system (max 10) ─────────────
  const sysMap = {};
  planets.forEach(pl => {
    const sk = `${pl.galaxy}:${pl.system}`;
    if (!sysMap[sk]) {
      const c = systemCenter(pl.galaxy, pl.system);
      sysMap[sk] = { g: pl.galaxy, s: pl.system, sunX: c.x, sunZ: c.z, planets: [] };
    }
    if (sysMap[sk].planets.length < 10) sysMap[sk].planets.push(pl);
  });

  // ── 2. Sort systems by distance to camera for light budget ─
  const camPos = camera ? camera.position : new THREE.Vector3(0, 2000, 3000);
  const sysList = Object.values(sysMap);
  sysList.sort((a, b) => {
    const da = Math.hypot(a.sunX - camPos.x, a.sunZ - camPos.z);
    const db = Math.hypot(b.sunX - camPos.x, b.sunZ - camPos.z);
    return da - db;
  });

  // ── 3. Build each system ─────────────────────────────────
  sysList.forEach((sys, sysIdx) => {
    const { sunX, sunZ, g, s } = sys;
    const sunPos = new THREE.Vector3(sunX, 0, sunZ);
    // ── Star type for this system ──────────────────────────
    const st = starType(g, s);
    const colNum = parseInt(st.mid.replace('#',''), 16);
    const coreNum = parseInt(st.core.replace('#',''), 16);

    // 1. Wide glow sprite
    const sunSprite = new THREE.Sprite(new THREE.SpriteMaterial({
      map: sunTex(st), transparent: true, depthWrite: false,
      sizeAttenuation: true, blending: THREE.AdditiveBlending
    }));
    sunSprite.position.copy(sunPos);
    sunSprite.scale.setScalar(st.spriteScale);
    sunSprite.userData = { isSun: true, baseSunScale: st.spriteScale,
      pulseAmp: st.pulseAmp, pulseSpeed: st.pulseSpeed,
      pulseOffset: (g * 7.3 + s * 3.1) % (Math.PI * 2),
      galaxy: g, system: s };
    sunGroup.add(sunSprite);

    // 2. Corona / spike overlay (K and M only – large stars)
    if (st.id === 'K' || st.id === 'M') {
      const coronaSprite = new THREE.Sprite(new THREE.SpriteMaterial({
        map: coronaTex(st), transparent: true, depthWrite: false,
        sizeAttenuation: true, blending: THREE.AdditiveBlending
      }));
      coronaSprite.position.copy(sunPos);
      const cs = st.spriteScale * st.coronaScale;
      coronaSprite.scale.setScalar(cs);
      coronaSprite.userData = { isCorona: true, baseCoronaScale: cs,
        pulseAmp: st.pulseAmp * 1.4, pulseSpeed: st.pulseSpeed * 0.7,
        pulseOffset: (g * 5.1 + s * 2.7) % (Math.PI * 2) };
      sunGroup.add(coronaSprite);
    }

    // 3. Emissive core sphere
    const coreMesh = new THREE.Mesh(
      new THREE.SphereGeometry(st.coreR, 12, 12),
      new THREE.MeshStandardMaterial({
        color: coreNum, emissive: coreNum, emissiveIntensity: 2.8,
        transparent: true, opacity: 0.97
      })
    );
    coreMesh.position.copy(sunPos);
    coreMesh.userData = { isSunCore: true };
    sunGroup.add(coreMesh);

    // 4. PointLight only for nearest MAX_LIGHTS systems (perf)
    if (sysIdx < MAX_LIGHTS) {
      const ptLight = new THREE.PointLight(colNum, st.lightInt, 300 + st.spriteScale * 5);
      ptLight.position.copy(sunPos);
      sunGroup.add(ptLight);
    }

    posMap[`${g}:${s}:0`] = sunPos.clone();

    // ── Per-slot: orbit ring + planet (real or empty) ──────
    // Build a lookup from slot → real planet data
    const slotToPlanet = {};
    sys.planets.forEach(pl => {
      const slot = Math.max(1, Math.min(10, pl.planet || 1));
      slotToPlanet[slot] = pl;
    });

    for (let slot = 1; slot <= 10; slot++) {
      const orbitRadius = 40 + slot * 22;  // 62..260 – slightly more spread
      const orbitSpeed  = 0.00025 + (1 / (slot + 1)) * 0.00045;
      // Deterministic initial angle: differs per system so planets aren't lined up
      const initAngle   = (slot / 10) * Math.PI * 2 + (g * 1.7 + s * 0.91);
      const heightOff   = (slot % 2 === 0 ? 1 : -1) * (slot * 0.6);

      // Orbit ring (static line, no picking)
      // On mobile 2D we use a brighter colour so rings are clearly visible
      const ringOpacity  = (window.innerWidth <= 768) ? 0.55 : 0.22;
      const ringColorHex = (window.innerWidth <= 768) ? 0x1e5a8a : 0x1a3a55;
      const ringPts = [];
      for (let i = 0; i <= 64; i++) {
        const a = (i / 64) * Math.PI * 2;
        ringPts.push(new THREE.Vector3(
          sunX + Math.cos(a) * orbitRadius, heightOff,
          sunZ + Math.sin(a) * orbitRadius
        ));
      }
      const ringLine = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(ringPts),
        new THREE.LineBasicMaterial({ color: ringColorHex, transparent: true, opacity: ringOpacity, depthWrite: false })
      );
      ringLine.userData = { isOrbitRing: true }; // excluded from raycaster
      sunGroup.add(ringLine);

      const initX = sunX + Math.cos(initAngle) * orbitRadius;
      const initZ = sunZ + Math.sin(initAngle) * orbitRadius;
      const key   = `${g}:${s}:${slot}`;

      const pl = slotToPlanet[slot]; // real planet or undefined

      if (pl) {
        // ── Real planet ──
        let hex = '#00d4ff';
        if (pl.is_own)  hex = '#00ff88';
        else if (pl.is_ally) hex = '#a855f7';
        else if (pl.ally_color && pl.ally_color !== 'null') hex = pl.ally_color;

        const rankScale = pl.total_rank > 0
          ? Math.max(0.6, Math.min(2.0, 300 / Math.max(pl.total_rank, 1))) : 0.9;
        const sz = 4.5 * rankScale;

        // Use realistic planet texture
        const { tex: plTex } = planetTex(g, s, slot, hex);
        const sprite = new THREE.Sprite(new THREE.SpriteMaterial({
          map: plTex, transparent: true, depthWrite: false, sizeAttenuation: true
        }));
        sprite.position.set(initX, heightOff, initZ);
        sprite.scale.setScalar(sz);
        sprite.userData = { type: 'planet', planet: pl, baseScale: sz, key };
        planetGroup.add(sprite);
        planetMeshes.push(sprite);
        posMap[key] = sprite.position.clone();
        orbitData.push({ mesh: sprite, sunX, sunZ, radius: orbitRadius, speed: orbitSpeed, angle: initAngle, heightOff, key });

        // Moon (decorative, not pickable)
        if (pl.has_moon) {
          const ms = new THREE.Sprite(new THREE.SpriteMaterial({
            map: circleTex('#aaaaaa'), transparent: true, depthWrite: false, sizeAttenuation: true
          }));
          ms.position.set(initX + sz * 0.72, heightOff + sz * 0.45, initZ);
          ms.scale.setScalar(sz * 0.34);
          ms.userData = { isMoon: true, parentKey: key };
          planetGroup.add(ms);
          orbitData.push({ mesh: ms, sunX, sunZ, radius: orbitRadius + sz * 0.72, speed: orbitSpeed * 0.85, angle: initAngle + 0.5, heightOff: heightOff + sz * 0.45, key: null });
        }

        // Debris ring (decorative, not pickable)
        if (pl.has_debris) {
          const db = new THREE.Mesh(
            new THREE.TorusGeometry(sz * 0.7, 0.24, 6, 28),
            new THREE.MeshBasicMaterial({ color: 0xff9900, transparent: true, opacity: 0.48 })
          );
          db.position.set(initX, heightOff, initZ);
          db.rotation.x = Math.PI / 2;
          db.userData = { isDebris: true };
          planetGroup.add(db);
          orbitData.push({ mesh: db, sunX, sunZ, radius: orbitRadius, speed: orbitSpeed, angle: initAngle, heightOff, key: null });
        }

      } else {
        // ── Empty slot (colonisable) ──
        const emptyPl = {
          galaxy: g, system: s, planet: slot,
          name: 'Freier Slot', username: null, user_id: null,
          ally_id: 0, ally_tag: '', total_rank: 0, total_points: 0,
          is_own: false, is_ally: false, has_moon: false, has_debris: false, is_empty: true
        };
        // Empty slot: large enough to see at default camera distance (orb.r=3000-4000)
        // sizeAttenuation=true means scale must be much larger than user planets at close zoom
        const emptyColor   = '#40c8ff'; // bright cyan-blue – distinct from dark bg
        const emptyOpacity = 0.90;
        const emptyScale   = (window.innerWidth <= 768) ? 6.0 : 8.0;
        const emptySprite = new THREE.Sprite(new THREE.SpriteMaterial({
          map: circleTex(emptyColor), transparent: true, opacity: emptyOpacity,
          depthWrite: false, sizeAttenuation: true
        }));
        emptySprite.position.set(initX, heightOff, initZ);
        emptySprite.scale.setScalar(emptyScale);
        emptySprite.userData = { type: 'planet', planet: emptyPl, baseScale: emptyScale, key };
        planetGroup.add(emptySprite);
        // Outer glow ring so empty slots are visible even when camera is far out
        const emptyGlow = new THREE.Sprite(new THREE.SpriteMaterial({
          map: circleTex(emptyColor), transparent: true, opacity: 0.22,
          depthWrite: false, sizeAttenuation: true
        }));
        emptyGlow.position.set(initX, heightOff, initZ);
        emptyGlow.scale.setScalar(emptyScale * 2.2);
        emptyGlow.userData = { isGlow: true };
        planetGroup.add(emptyGlow);
        orbitData.push({ mesh: emptyGlow, sunX, sunZ, radius: orbitRadius, speed: orbitSpeed * 0.6, angle: initAngle, heightOff, key: null });
        planetMeshes.push(emptySprite);
        posMap[key] = emptySprite.position.clone();
        orbitData.push({ mesh: emptySprite, sunX, sunZ, radius: orbitRadius, speed: orbitSpeed * 0.6, angle: initAngle, heightOff, key });
      }
    }
  });
}

// ── Flottenlinien (CatmullRomCurve3, animated dot via rAF) ─────
function buildFleets(fleets) {
  const nowSec = (Date.now() / 1000) + serverTimeOffset;

  // Seed posMap sun entries for any system referenced by fleets but not yet rendered
  fleets.forEach(f => {
    const coords = [f.start, f.end];
    coords.forEach(c => {
      if (!c) return;
      const sunKey = `${c.g}:${c.s}:0`;
      if (!posMap[sunKey]) {
        const sc = systemCenter(c.g, c.s);
        posMap[sunKey] = new THREE.Vector3(sc.x, 0, sc.z);
      }
    });
  });

  const activeIds = new Set();
  fleets.forEach(f => {
    const start = f.start_time || 0;
    const end   = f.end_time   || (start + 1);
    const realPrg = Math.min(1, Math.max(0, (nowSec - start) / Math.max(1, end - start)));
    f.progress = realPrg;
    const id = f.id;
    activeIds.add(id);
    if (!fleetAnimState[id]) fleetAnimState[id] = { displayPrg: realPrg };
    fleetAnimState[id].targetPrg = realPrg;
    fleetAnimState[id].data      = f;

    // Resolve world positions – posMap[g:s:p] → posMap[g:s:0] (sun) → toWorld() fallback
    const spKey = `${f.start.g}:${f.start.s}:${f.start.p}`;
    const epKey = `${f.end.g}:${f.end.s}:${f.end.p}`;
    const spFallback = posMap[`${f.start.g}:${f.start.s}:0`] || toWorld(f.start.g, f.start.s, f.start.p, 0, 1);
    const epFallback = posMap[`${f.end.g}:${f.end.s}:0`]   || toWorld(f.end.g,   f.end.s,   f.end.p,   0, 1);
    fleetAnimState[id].sPos = (posMap[spKey] || spFallback).clone();
    fleetAnimState[id].ePos = (posMap[epKey] || epFallback).clone();

    // Build CatmullRomCurve3 with a mid-point arc for visual interest
    const s3 = fleetAnimState[id].sPos;
    const e3 = fleetAnimState[id].ePos;
    const mid = s3.clone().lerp(e3, 0.5);
    mid.y += s3.distanceTo(e3) * 0.12; // slight arc
    fleetAnimState[id].curve = new THREE.CatmullRomCurve3([s3, mid, e3]);
  });

  // Remove gone fleets
  for (const id in fleetAnimState) {
    if (!activeIds.has(parseInt(id))) delete fleetAnimState[id];
  }
  rebuildFleetMeshes();
}

function rebuildFleetMeshes() {
  disposeGroup(fleetGroup);
  for (const id in fleetAnimState) {
    const st  = fleetAnimState[id];
    const f   = st.data;
    if (!st.curve) continue;

    const prg = Math.min(1, Math.max(0, st.displayPrg));

    // Ownership flags
    const isOwn         = !!f.is_own;
    const isHostile     = !!f.is_hostile;
    const isTargetingMe = !!f.is_targeting_me;
    const isAlly        = !isOwn && !isHostile && !!f.is_ally;
    const isNeutral     = !!f.is_neutral; // non-combat, non-own, non-ally

    // Color scheme:
    // own          = solid cyan (#00d4ff)
    // ally         = dashed purple (#a855f7)
    // targeting_me = bright red dashed (combat fleet heading for ME)
    // hostile      = red dashed (any other combat fleet)
    // neutral      = white dashed (transport, espionage, colony etc.)
    // On mobile the camera is at r=4000, so dots need to be much larger
    const dotMult = (window.innerWidth <= 768) ? 14 : 4;
    let lineCol, lineOpacity, useDash, dotCol, dotSize;
    if (isOwn) {
      lineCol = 0x00d4ff; lineOpacity = 0.95; useDash = false;
      dotCol = '#00d4ff'; dotSize = 22; // cyan – high contrast vs dark bg
    } else if (isAlly) {
      lineCol = 0xa855f7; lineOpacity = 0.80; useDash = true;
      dotCol = '#a855f7'; dotSize = 18;
    } else if (isTargetingMe) {
      lineCol = 0xff0033; lineOpacity = 0.98; useDash = true;
      dotCol = '#ff0033'; dotSize = 22; // largest – danger!
    } else if (isHostile) {
      lineCol = 0xff3355; lineOpacity = 0.85; useDash = true;
      dotCol = '#ff3355'; dotSize = 18;
    } else { // neutral – white dashed
      lineCol = 0xddeeff; lineOpacity = 0.65; useDash = true;
      dotCol = '#ddeeff'; dotSize = 14;
    }

    // Full path line (start → end, ghost/dim background)
    const pathPoints = st.curve.getPoints(64);
    const pathGeo = new THREE.BufferGeometry().setFromPoints(pathPoints);
    let pathLine;
    if (useDash) {
      const pm = new THREE.LineDashedMaterial({
        color: lineCol, transparent: true, opacity: lineOpacity * 0.55,
        dashSize: 18, gapSize: 10, depthWrite: false, linewidth: 1
      });
      pathLine = new THREE.Line(pathGeo, pm);
      pathLine.computeLineDistances();
    } else {
      pathLine = new THREE.Line(pathGeo, new THREE.LineBasicMaterial({
        color: lineCol, transparent: true, opacity: lineOpacity * 0.45, depthWrite: false
      }));
    }
    pathLine.userData = { fleet: f };
    fleetGroup.add(pathLine);

    // Trail line (start → current dot position — brighter/solid)
    const trailCount = Math.max(2, Math.round(Math.max(0.01, prg) * 64));
    const trailPoints = st.curve.getPoints(trailCount);
    const trailGeo = new THREE.BufferGeometry().setFromPoints(trailPoints);
    let trailLine;
    if (useDash) {
      const tm = new THREE.LineDashedMaterial({
        color: lineCol, transparent: true, opacity: lineOpacity,
        dashSize: 14, gapSize: 6, depthWrite: false, linewidth: 1
      });
      trailLine = new THREE.Line(trailGeo, tm);
      trailLine.computeLineDistances();
    } else {
      trailLine = new THREE.Line(trailGeo, new THREE.LineBasicMaterial({
        color: lineCol, transparent: true, opacity: lineOpacity, depthWrite: false
      }));
    }
    trailLine.userData = { fleet: f, isTrail: true };
    fleetGroup.add(trailLine);

    // Fleet dot at current position — large enough to be visible at galaxy scale
    const curPos = st.curve.getPoint(Math.max(0, Math.min(1, prg)));
    const ds = new THREE.Sprite(new THREE.SpriteMaterial({
      map: circleTex(dotCol), transparent: true, depthWrite: false,
      sizeAttenuation: true, blending: THREE.AdditiveBlending
    }));
    ds.position.set(curPos.x, curPos.y + 4, curPos.z); // slight Y lift so it's above orbit plane
    ds.scale.setScalar(dotSize * dotMult); // scale up: orbit radii are 60-260 units, dot must be visible
    ds.userData = { fleet: f, isFleetDot: true };
    fleetGroup.add(ds);
  }
}

// ── Data fetching ──────────────────────────────────────────
async function fetchGalaxy() {
  const r = await fetch(window.SM.apiBase + 'galaxy');
  if (!r.ok) throw new Error('galaxy API ' + r.status);
  const text = await r.text();
  try {
    galaxyData = JSON.parse(text);
  } catch(e) {
    console.error('Galaxy JSON parse error:', text.slice(0, 200));
    throw new Error('Galaxy JSON invalid');
  }
  if (galaxyData.server_time) {
    serverTimeOffset = galaxyData.server_time - (Date.now() / 1000);
  }
  if (galaxyData.planets) {
    buildPlanets(galaxyData.planets);
    // posMap is now populated – always re-fetch fleets immediately so
    // newly dispatched fleets that arrived during galaxy load are shown
    fetchFleets().catch(e => console.warn('Post-galaxy fleet fetch:', e));
    updateStats();
  }
}

async function fetchFleets() {
  // NOTE: must NOT swallow error on initial call so Promise.all can reject
  const r = await fetch(window.SM.apiBase + 'fleets');
  if (!r.ok) throw new Error('fleets API ' + r.status);
  const text = await r.text();
  try {
    fleetData = JSON.parse(text);
  } catch(e) {
    console.warn('Fleet JSON parse error:', text.slice(0, 200));
    return; // non-fatal on poll failures
  }
  if (fleetData.server_time) {
    serverTimeOffset = fleetData.server_time - (Date.now() / 1000);
  }
  if (fleetData.fleets) {
    // Arrival detection: compare against previously known fleet IDs
    const prevIds = new Set(Object.keys(fleetAnimState).map(Number));
    const newIds  = new Set(fleetData.fleets.map(f => f.id));
    prevIds.forEach(id => {
      if (!newIds.has(id)) {
        const st = fleetAnimState[id];
        if (st && st.data) fleetArrivalToast(st.data);
      }
    });
    buildFleets(fleetData.fleets);
    updateStats();
    updateFleetBadge();
  }
  set('upd-time', 'Updated ' + new Date().toLocaleTimeString());
}

function fleetArrivalToast(f) {
  const isOwn         = !!f.is_own;
  const isHostile     = !!f.is_hostile;
  const isTargetingMe = !!f.is_targeting_me;
  if (!isOwn && !isHostile) return; // only notify for own / combat fleets
  let col, icon, label;
  if (isTargetingMe) {
    col = '#ff0033'; icon = '🚨';
    label = `UNDER ATTACK! [${f.end?.g}:${f.end?.s}:${f.end?.p}]`;
  } else if (isHostile) {
    col = '#ff3355'; icon = '⚠';
    label = `COMBAT FLEET ARRIVED [${f.end?.g}:${f.end?.s}:${f.end?.p}]`;
  } else {
    col = '#00e87a'; icon = '✓';
    label = `${f.mission_name || 'FLEET'} ARRIVED [${f.end?.g}:${f.end?.s}:${f.end?.p}]`;
  }
  showFleetToast(icon + ' ' + label, col);
}

function showFleetToast(msg, color) {
  let container = document.getElementById('gm-fleet-toasts');
  if (!container) {
    container = document.createElement('div');
    container.id = 'gm-fleet-toasts';
    container.style.cssText = 'position:fixed;top:64px;right:16px;z-index:9800;display:flex;flex-direction:column;gap:6px;pointer-events:none;';
    document.body.appendChild(container);
  }
  const t = document.createElement('div');
  t.style.cssText = `
    background:rgba(4,10,28,0.97);border:1px solid ${color};border-radius:8px;
    padding:8px 14px;font-family:'Orbitron',monospace;font-size:10px;letter-spacing:1.5px;
    color:${color};box-shadow:0 4px 20px rgba(0,0,0,0.7);
    opacity:0;transform:translateX(24px);
    transition:opacity .25s ease,transform .25s ease;
    pointer-events:none;white-space:nowrap;
  `;
  t.textContent = msg;
  container.appendChild(t);
  requestAnimationFrame(() => {
    t.style.opacity = '1';
    t.style.transform = 'translateX(0)';
  });
  setTimeout(() => {
    t.style.opacity = '0';
    t.style.transform = 'translateX(24px)';
    setTimeout(() => t.remove(), 300);
  }, 5000);
}

function updateFleetBadge() {
  const states = Object.values(fleetAnimState);
  const hostileCount = states.filter(st => st.data?.is_hostile).length;
  const totalCount   = states.length;
  let badge = document.getElementById('gm-fleet-badge');
  if (!badge) {
    const btn = document.getElementById('gm-reload-fleets');
    if (!btn) return;
    badge = document.createElement('span');
    badge.id = 'gm-fleet-badge';
    badge.style.cssText = 'position:absolute;top:-4px;right:-4px;min-width:16px;height:16px;border-radius:8px;font-size:9px;font-family:\'Orbitron\',monospace;display:flex;align-items:center;justify-content:center;padding:0 3px;pointer-events:none;';
    btn.style.position = 'relative';
    btn.appendChild(badge);
  }
  if (hostileCount > 0) {
    badge.textContent = hostileCount;
    badge.style.background = '#ff3355';
    badge.style.color = '#fff';
    badge.style.display = 'flex';
  } else if (totalCount > 0) {
    badge.textContent = totalCount;
    badge.style.background = 'rgba(0,212,255,0.7)';
    badge.style.color = '#000';
    badge.style.display = 'flex';
  } else {
    badge.style.display = 'none';
  }
}

// ── Demo fallback ──────────────────────────────────────────
function loadDemo() {
  const cols=['#00d4ff','#a855f7','#ff6b35','#ffd700','#00ffcc','#ff3399'];
  const planets=[];
  for (let g=1;g<=4;g++) for (let s=1;s<=120;s++) {
    if (Math.random()>.55) continue; // keep more so array is never empty
    const n=Math.floor(Math.random()*4)+1;
    for (let k=0;k<n;k++) {
      const p=Math.floor(Math.random()*15)+1, ai=Math.floor(Math.random()*7);
      const uid=Math.floor(Math.random()*300)+1;
      planets.push({
        id:g*1e6+s*1e3+p+k, name:`Kepler-${g}${s}`, galaxy:g, system:s, planet:p,
        user_id:uid, username:`Cmdr${uid}`,
        ally_id:ai, ally_name:ai?`Empire${ai}`:'', ally_tag:ai?`E${ai}`:'',
        ally_color:ai?cols[ai%cols.length]:null,
        total_rank:Math.floor(Math.random()*500)+1, total_points:Math.floor(Math.random()*800000),
        is_own:g===window.SM.galaxy&&s===window.SM.system&&p===window.SM.planet,
        is_ally:ai>0&&ai===window.SM.allyId,
        has_moon:Math.random()>.72, has_debris:Math.random()>.88, online:Math.random()>.55
      });
    }
  }
  galaxyData={planets, current_user_id:window.SM.userId};
  buildPlanets(planets);

  const MISSION_NAMES_JS = {1:'ATTACK',2:'ACS_ATTACK',3:'TRANSPORT',4:'DEPLOY',5:'HOLD',6:'ESPIONAGE',7:'COLONY',8:'RECYCLE',9:'DESTROY',11:'EXPEDITION'};
  const nowDemo = Date.now()/1000;
  const demoFleets=[];
  for (let i=0;i<30;i++) {
    const sp=planets[Math.floor(Math.random()*planets.length)];
    const ep=planets[Math.floor(Math.random()*planets.length)];
    if (!sp||!ep||sp.id===ep.id) continue;
    const m=[1,3,6,8][Math.floor(Math.random()*4)];
    const hostile=m===1&&sp.user_id!==window.SM.userId;
    const travelDur = 120 + Math.random()*600; // 2-12 minutes
    const elapsed   = Math.random() * travelDur;
    const st = nowDemo - elapsed;
    const et = st + travelDur;
    demoFleets.push({
      id:i+1, mission:m, mission_name:MISSION_NAMES_JS[m]||'TRANSPORT',
      owner_name:sp.username||'Commander', ally_tag:sp.ally_tag,
      is_own:sp.user_id===window.SM.userId, is_hostile:hostile,
      is_ally:!hostile && sp.user_id!==window.SM.userId && sp.ally_id>0 && sp.ally_id===window.SM.allyId,
      color:hostile?'#e8304a':m===6?'#ffee00':m===8?'#ff9900':'#00d4ff',
      start:{g:sp.galaxy,s:sp.system,p:sp.planet},
      end:{g:ep.galaxy,s:ep.system,p:ep.planet},
      start_time:st, end_time:et,
      progress: elapsed/travelDur
    });
  }
  fleetData={fleets:demoFleets};
  buildFleets(demoFleets);
  updateStats();
}

// ── Stats update ───────────────────────────────────────────
function updateStats() {
  const pl = galaxyData?.planets || [];
  const fl = Object.values(fleetAnimState).map(s => s.data).filter(Boolean);
  const hs = fl.filter(f => f.is_hostile);
  const al = new Set(pl.map(p => p.ally_id).filter(id => id > 0));
  set('st-p', pl.length);      set('h-planets', pl.length + ' PLANETS');
  set('st-f', fl.length);      set('h-fleets',  fl.length + ' FLEETS');
  set('st-h', hs.length);      set('h-hostile', hs.length + ' HOSTILE');
  set('st-a', al.size);        set('st-d', pl.filter(p => p.has_debris).length);
}
function set(id,v){const e=document.getElementById(id);if(e)e.textContent=v;}

// ── Camera sync ────────────────────────────────────────────
// Zoom clamped to [100, 10000] per spec
const MIN_DIST = 100;
const MAX_DIST = 10000;
function syncCamera() {
  if (!camera) return;
  orb.r = Math.max(MIN_DIST, Math.min(MAX_DIST, orb.r));
  if (is3D) {
    camera.position.set(
      orb.tx + orb.r*Math.sin(orb.phi)*Math.sin(orb.theta),
      orb.ty + orb.r*Math.cos(orb.phi),
      orb.tz + orb.r*Math.sin(orb.phi)*Math.cos(orb.theta)
    );
    camera.lookAt(orb.tx, orb.ty, orb.tz);
  } else {
    camera.position.set(pan.x, orb.r*.75, pan.z);
    camera.lookAt(pan.x, 0, pan.z);
  }
}

// ── Footer height measurement (fixes overlap) ───────────────
function measureFooterHeight() {
  const measure = () => {
    const root = document.getElementById('gm-root');
    if (!root) return;

    // Priority 1: mobile-dock (bottom nav bar on mobile)
    const dock = document.querySelector('nav.mobile-dock, .mobile-dock');
    if (dock) {
      const style = window.getComputedStyle(dock);
      // Visible if display != none
      if (style.display !== 'none') {
        const h = dock.getBoundingClientRect().height || dock.offsetHeight || 62;
        // Add safe-area-inset-bottom for iPhone notch
        const safeArea = parseInt(getComputedStyle(document.documentElement)
          .getPropertyValue('--sab') || '0') || 0;
        root.style.setProperty('--ingameFooterH', (h + safeArea) + 'px');
        return;
      }
    }

    // Priority 2: game footer
    const footer = document.querySelector('.game-footer, footer.game-footer');
    if (footer) {
      const style = window.getComputedStyle(footer);
      const isFixed = style.position === 'fixed' || style.position === 'sticky';
      if (isFixed) {
        root.style.setProperty('--ingameFooterH', footer.getBoundingClientRect().height + 'px');
        return;
      }
    }

    // Fallback: on mobile assume 62px dock
    if (window.innerWidth <= 768) {
      root.style.setProperty('--ingameFooterH', '62px');
    } else {
      root.style.setProperty('--ingameFooterH', '0px');
    }
  };
  measure();
  window.addEventListener('resize', measure, { passive: true });
  // Re-measure after fonts/layout settle
  setTimeout(measure, 300);
}

// ── Mobile panel toggle (FAB) ───────────────────────────────
function initMobilePanel() {
  const innerFab = document.getElementById('gm-panel-toggle');
  const outerFab = document.getElementById('gm-fab-outer');
  const panel    = document.getElementById('gm-side');
  if (!panel) return;

  function togglePanel(e) {
    if (e) e.stopPropagation();
    const open = panel.classList.toggle('panel-open');
    if (innerFab) innerFab.classList.toggle('active', open);
    if (outerFab) outerFab.classList.toggle('active', open);
    try { localStorage.setItem('galaxyPanel', open ? 'open' : 'collapsed'); } catch(e2) {}
  }

  function closePanel() {
    panel.classList.remove('panel-open');
    if (innerFab) innerFab.classList.remove('active');
    if (outerFab) outerFab.classList.remove('active');
    try { localStorage.setItem('galaxyPanel', 'collapsed'); } catch(e) {}
  }

  // Restore saved state
  try {
    if (localStorage.getItem('galaxyPanel') === 'open') {
      panel.classList.add('panel-open');
      if (innerFab) innerFab.classList.add('active');
      if (outerFab) outerFab.classList.add('active');
    }
  } catch(e) {}

  if (innerFab) innerFab.addEventListener('click', togglePanel);
  if (outerFab) outerFab.addEventListener('click', togglePanel);

  // Tap on canvas closes panel (mobile UX)
  canvas.addEventListener('touchstart', () => {
    if (window.innerWidth <= 768 && panel.classList.contains('panel-open')) closePanel();
  }, { passive: true });
}

// ── Input events ───────────────────────────────────────────
function bindEvents() {
  canvas.addEventListener('mousedown', e=>{
    drag.down=true; drag.moved=0;
    drag.startX=e.clientX; drag.startY=e.clientY;
    drag.snapTheta=orb.theta; drag.snapPhi=orb.phi;
    drag.snapPanX=pan.x; drag.snapPanZ=pan.z;
    canvas.style.cursor='grabbing';
  });
  window.addEventListener('mouseup',()=>{drag.down=false;canvas.style.cursor='grab';});
  window.addEventListener('mousemove', e=>{
    if (drag.down) {
      const dx=e.clientX-drag.startX, dy=e.clientY-drag.startY;
      drag.moved=Math.max(drag.moved,Math.abs(dx)+Math.abs(dy));
      if (is3D) {
        orb.theta=drag.snapTheta-dx*.0055;
        orb.phi=Math.max(.12,Math.min(1.55,drag.snapPhi+dy*.0055));
      } else {
        pan.x=drag.snapPanX-dx*orb.r*.0016;
        pan.z=drag.snapPanZ-dy*orb.r*.0016;
      }
      syncCamera();
    } else { doHover(e.clientX,e.clientY); }
  });

  canvas.addEventListener('click', e=>{if(drag.moved<6)doClick(e.clientX,e.clientY);});

  canvas.addEventListener('wheel', e=>{
    e.preventDefault();
    orb.r = Math.max(MIN_DIST, Math.min(MAX_DIST, orb.r + e.deltaY * 1.2));
    syncCamera();
  },{passive:false});

  // Touch
  let tStart=null,tDist=0;
  canvas.addEventListener('touchstart',e=>{
    if(e.touches.length===1){
      tStart={x:e.touches[0].clientX,y:e.touches[0].clientY,
              theta:orb.theta,phi:orb.phi,px:pan.x,pz:pan.z};
    } else if(e.touches.length===2){
      tDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,
                       e.touches[0].clientY-e.touches[1].clientY);
    }
  },{passive:true});
  canvas.addEventListener('touchmove',e=>{
    e.preventDefault();
    if(e.touches.length===1&&tStart){
      const dx=e.touches[0].clientX-tStart.x, dy=e.touches[0].clientY-tStart.y;
      if(is3D){orb.theta=tStart.theta-dx*.007;orb.phi=Math.max(.12,Math.min(1.55,tStart.phi+dy*.007));}
      else{pan.x=tStart.px-dx*orb.r*.002;pan.z=tStart.pz-dy*orb.r*.002;}
      syncCamera();
    } else if(e.touches.length===2){
      const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,
                         e.touches[0].clientY-e.touches[1].clientY);
      orb.r = Math.max(MIN_DIST, Math.min(MAX_DIST, orb.r * (tDist / d)));
      tDist=d; syncCamera();
    }
  },{passive:false});

  window.addEventListener('resize',()=>{
    camera.aspect=innerWidth/innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(innerWidth,innerHeight);
  });
}

// ── Raycasting ─────────────────────────────────────────────
// Always use canvas-relative coords (NOT window) so NDC is correct
// regardless of where the canvas sits in the page layout.
const DEBUG_PICK = (new URLSearchParams(location.search)).get('debugPick') === '1';

function setMV(cx, cy) {
  const r = canvas.getBoundingClientRect();
  MV.x =  ((cx - r.left) / r.width)  * 2 - 1;
  MV.y = -((cy - r.top)  / r.height) * 2 + 1;
}

function hitPlanet(cx, cy) {
  if (!planetMeshes.length) return null;
  setMV(cx, cy);
  RC.setFromCamera(MV, camera);
  // Intersect ONLY the dedicated planetMeshes list
  const hits = RC.intersectObjects(planetMeshes, false);
  if (DEBUG_PICK) console.log('[pick] planet hits:', hits.length, hits.map(h => h.object.userData.key + ' d=' + h.distance.toFixed(0)));
  // Require: userData.type === 'planet'  AND  within distance gate
  for (const h of hits) {
    if (h.object.userData.type !== 'planet') continue;
    if (h.distance > MAX_PICK_DISTANCE) continue;
    return h.object.userData.planet;
  }
  return null;
}

function hitFleet(cx, cy) {
  const dots = fleetGroup.children.filter(c => c.userData.isFleetDot);
  if (!dots.length) return null;
  setMV(cx, cy);
  RC.setFromCamera(MV, camera);
  const hits = RC.intersectObjects(dots, false);
  return hits.length ? hits[0].object.userData.fleet : null;
}

function doHover(cx,cy){
  // Check fleet dots first (they're smaller targets)
  const fl=hitFleet(cx,cy);
  if(fl){
    canvas.style.cursor='pointer';
    tipEl.style.display='block';
    tipEl.style.left=(cx+16)+'px'; tipEl.style.top=(cy+10)+'px';
    const nowS = (Date.now()/1000) + serverTimeOffset;
    const remaining = Math.max(0, Math.round(fl.end_time - nowS));
    const mins=Math.floor(remaining/60), secs=remaining%60;
    const fcol = fl.is_hostile?'var(--red)':fl.is_own?'var(--cyan)':'var(--dim)';
    tipEl.innerHTML=`
      <div class="tt-h" style="color:${fcol}">${fl.mission_name||'FLEET'}</div>
      <div class="tt-l">Commander: <span>${fl.owner_name||'?'}</span></div>
      <div class="tt-l">From: <span>[${fl.start.g}:${fl.start.s}:${fl.start.p}]</span></div>
      <div class="tt-l">To: <span>[${fl.end.g}:${fl.end.s}:${fl.end.p}]</span></div>
      <div class="tt-l">ETA: <span>${mins}m ${secs}s</span></div>
    `;
    return;
  }
  const pl=hitPlanet(cx,cy);
  if(pl){
    canvas.style.cursor='pointer';
    tipEl.style.display='block';
    tipEl.style.left=(cx+16)+'px'; tipEl.style.top=(cy+10)+'px';
    if(pl.is_empty){
      /* Freier Slot */
      tipEl.innerHTML=`<div class="tt-h" style="color:#4a6a8a">FREIER SLOT</div><div class="tt-l">[${pl.galaxy}:${pl.system}:${pl.planet}]</div><div class="tt-l" style="color:var(--cyan)">Klicken zum Kolonisieren</div>`;
    } else {
      const c=pl.is_own?'var(--green)':pl.is_ally?'var(--purple)':'var(--cyan)';
      const name=(pl.name||'Unknown Planet').toUpperCase();
      tipEl.innerHTML=`
        <div class="tt-h" style="color:${c}">${name}</div>
        <div class="tt-l">[${pl.galaxy}:${pl.system}:${pl.planet}]</div>
        <div class="tt-l">Player: <span>${pl.username||'?'}</span></div>
        ${pl.ally_tag?`<div class="tt-l">Alliance: <span>[${pl.ally_tag}]</span></div>`:''}
        <div class="tt-l">Rank: <span>#${pl.total_rank||'?'}</span></div>
        ${pl.has_moon?'<div class="tt-l" style="color:#aaa"><i class="fas fa-moon fa-xs"></i> Moon</div>':''}
        ${pl.has_debris?'<div class="tt-l" style="color:#ff9900"><i class="fas fa-ring fa-xs"></i> Debris</div>':''}
      `;
    }
  } else {
    canvas.style.cursor='grab';
    tipEl.style.display='none';
  }
}

function doClick(cx, cy) {
  const pl = hitPlanet(cx, cy);
  if (pl) {
    selectPlanet(pl);
    showAction(pl);
    tipEl.style.display = 'none';
  } else {
    deselectPlanet();
    closeAction();
  }
}

// ── Planet selection + highlight ring ──────────────────────
function selectPlanet(pl) {
  selectedPlanet = pl;
  // Remove old ring
  if (selRing) { planetGroup.remove(selRing); selRing.geometry.dispose(); selRing.material.dispose(); selRing = null; }
  // Use live mesh position (planet is orbiting – posMap is updated by animate loop)
  const key = `${pl.galaxy}:${pl.system}:${pl.planet}`;
  const sprite = planetMeshes.find(s => s.userData.key === key);
  const pos = sprite ? sprite.position : posMap[key];
  if (!pos) return;
  const sz = sprite ? sprite.userData.baseScale * 0.62 : 9;
  const rg = new THREE.RingGeometry(sz, sz + 1.4, 32);
  const rm = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.55, side: THREE.DoubleSide, depthWrite: false });
  selRing = new THREE.Mesh(rg, rm);
  selRing.position.copy(pos);
  selRing.rotation.x = -Math.PI / 2;
  planetGroup.add(selRing);
  set('st-sel', key);
}

function deselectPlanet() {
  selectedPlanet = null;
  if (selRing) { planetGroup.remove(selRing); selRing.geometry.dispose(); selRing.material.dispose(); selRing = null; }
  set('st-sel', '–');
}

