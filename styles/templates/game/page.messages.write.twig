{% extends "layout.popup.twig" %}

{% block title %}{{ LNG.write_message }}{% endblock %}
{% block content %}
<div class="mcc-compose">

    <div class="mcc-compose-head">
        <div class="mcc-compose-head-icon">
            <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                <path d="M17.414 2.586a2 2 0 00-2.828 0L7 10.172V13h2.828l7.586-7.586a2 2 0 000-2.828z"/>
                <path fill-rule="evenodd" d="M2 6a2 2 0 012-2h4a1 1 0 010 2H4v10h10v-4a1 1 0 112 0v4a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" clip-rule="evenodd"/>
            </svg>
        </div>
        <div>
            <div class="mcc-compose-head-title">{{ LNG.mg_send_new }}</div>
            <div class="mcc-compose-head-sub">Neue Nachricht verfassen</div>
        </div>
    </div>

    <form name="message" id="mcc-compose-form">
        <input type="hidden" name="id" value="{{ id }}">

        <div class="mcc-compose-body">

            <div class="mcc-field">
                <label class="mcc-flabel">{{ LNG.mg_send_to }}</label>
                {% if allowFreeRecipient %}
                <input type="text" name="to" id="to" class="mcc-finput" value="{{ OwnerRecord.username|default('') }}" placeholder="Spielername eingeben…">
                {% else %}
                <input type="text" name="to" id="to" class="mcc-finput" readonly
                    value="{{ OwnerRecord.username }} [{{ OwnerRecord.galaxy }}:{{ OwnerRecord.system }}:{{ OwnerRecord.planet }}]">
                {% endif %}
            </div>

            <div class="mcc-field">
                <label class="mcc-flabel">{{ LNG.mg_subject }}</label>
                <input type="text" name="subject" id="subject" class="mcc-finput" maxlength="40"
                    value="{% if subject %}{{ subject }}{% else %}{{ LNG.mg_no_subject }}{% endif %}">
            </div>

            <div class="mcc-field">
                <label class="mcc-flabel">{{ LNG.mg_message }}</label>
                <div class="mcc-bb-bar">
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('b')"><b>B</b></button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('i')"><i>I</i></button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('u')"><u>U</u></button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('s')"><s>S</s></button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('url')">🔗</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('img')">🖼</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('quote')">❝ Zitat</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('code')">⌨ Code</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBBHr()">— HR</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBBList()">≡ Liste</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBBOList()">1. Liste</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBBTable()">⊞ Tabelle</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('color=red')">🎨</button>
                    <button type="button" class="mcc-bb-btn" onclick="msgBB('size=16')">Aa</button>
                </div>
                <textarea name="text" id="text" class="mcc-finput mcc-ftextarea"
                    oninput="mccUpdateCounter(this)">{{ message|default('') }}</textarea>
                <div class="mcc-char-row"><span class="mcc-char-count" id="mcc-counter">0 / 5.000</span></div>
            </div>

        </div>

        <div class="mcc-compose-footer">
            <button type="button" id="mcc-send-btn" class="mcc-send-btn" onclick="mccSend()">
                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                    <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/>
                </svg>
                {{ LNG.mg_send }}
            </button>
            <span class="mcc-send-status" id="mcc-send-status"></span>
        </div>
    </form>

</div>

{% autoescape false %}
<script>
function msgBB(tag) {
    const area = document.getElementById('text');
    if (!area) return;
    const s = area.selectionStart, e = area.selectionEnd;
    const sel = area.value.substring(s, e);
    let open = tag, close = tag;
    if (tag.indexOf('=') !== -1) close = tag.split('=')[0];
    if (tag === 'url') { open = 'url=https://'; close = 'url'; }
    const ins = '[' + open + ']' + sel + '[/' + close + ']';
    area.value = area.value.substring(0, s) + ins + area.value.substring(e);
    area.selectionStart = area.selectionEnd = s + ins.length;
    area.focus(); mccUpdateCounter(area);
}
function msgBBHr() {
    const area = document.getElementById('text');
    const p = area.selectionStart;
    area.value = area.value.substring(0, p) + '[hr]\n' + area.value.substring(p);
    area.selectionStart = area.selectionEnd = p + 5;
    area.focus(); mccUpdateCounter(area);
}
function msgBBList() {
    const area = document.getElementById('text'), p = area.selectionStart;
    const t = '[list]\n[*]Eintrag 1\n[*]Eintrag 2\n[/list]\n';
    area.value = area.value.substring(0, p) + t + area.value.substring(p);
    area.selectionStart = area.selectionEnd = p + t.length;
    area.focus(); mccUpdateCounter(area);
}
function msgBBOList() {
    const area = document.getElementById('text'), p = area.selectionStart;
    const t = '[list=1]\n[*]Eintrag 1\n[*]Eintrag 2\n[/list]\n';
    area.value = area.value.substring(0, p) + t + area.value.substring(p);
    area.selectionStart = area.selectionEnd = p + t.length;
    area.focus(); mccUpdateCounter(area);
}
function msgBBTable() {
    const area = document.getElementById('text'), p = area.selectionStart;
    const t = '[table]\n[tr][th]Spalte 1[/th][th]Spalte 2[/th][/tr]\n[tr][td]Zelle 1[/td][td]Zelle 2[/td][/tr]\n[/table]\n';
    area.value = area.value.substring(0, p) + t + area.value.substring(p);
    area.selectionStart = area.selectionEnd = p + t.length;
    area.focus(); mccUpdateCounter(area);
}
function mccUpdateCounter(area) {
    const len = area.value.length;
    const el = document.getElementById('mcc-counter');
    if (!el) return;
    el.textContent = len.toLocaleString('de-DE') + ' / 5.000';
    el.className = 'mcc-char-counter' + (len > 5000 ? ' over' : len > 4000 ? ' warn' : '');
}
function mccSend() {
    const text = document.getElementById('text');
    if (!text || text.value.trim().length === 0) {
        document.getElementById('mcc-send-status').textContent = '{{ LNG.mg_empty_text }}';
        return;
    }
    const btn = document.getElementById('mcc-send-btn');
    const status = document.getElementById('mcc-send-status');
    btn.disabled = true;
    status.textContent = 'Wird gesendet…';
    const form = document.getElementById('mcc-compose-form');
    fetch('game.php?page=messages&mode=send&ajax=1', {
        method: 'POST',
        body: new URLSearchParams(new FormData(form))
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        status.textContent = d;
        status.style.color = '#22c55e';
        if (window.parent && typeof window.parent.Message !== 'undefined') {
            window.parent.Message.getMessages(window.parent.Message.MessID || 100, 1);
        }
        setTimeout(function() {
            try {
                if (window.parent && window.parent.ModalManager) window.parent.ModalManager.close();
                else if (window.parent && window.parent.$.fancybox) window.parent.$.fancybox.close();
            } catch(e) {}
        }, 900);
    })
    .catch(function() {
        status.textContent = '{{ LNG.mg_error }}';
        status.style.color = '#ef4444';
        btn.disabled = false;
    });
}
document.addEventListener('DOMContentLoaded', function() {
    const t = document.getElementById('text');
    if (t) mccUpdateCounter(t);
});
</script>
{% endautoescape %}
{% endblock %}
