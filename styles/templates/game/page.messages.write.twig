{% extends "layout.popup.twig" %}

{% block title %}{{ LNG.write_message }}{% endblock %}
{% block content %}
<div class="galactic-write-wrap">
    <div class="popup-galactic-head">
        <i class="far fa-edit"></i> {{ LNG.mg_send_new }}
    </div>

    <form name="message" id="message-form-galactic">
        <input type="hidden" name="id" value="{{ id }}">

        <div class="g-form-group">
            <label class="g-label-cyan">{{ LNG.mg_send_to }}</label>
            {% if allowFreeRecipient %}
            <input type="text" name="to" id="to" class="g-input-field" value="{{ OwnerRecord.username|default('') }}" placeholder="Empfänger eingeben...">
            {% else %}
            <input type="text" name="to" id="to" class="g-input-field g-input-readonly" value="{{ OwnerRecord.username }} [{{ OwnerRecord.galaxy }}:{{ OwnerRecord.system }}:{{ OwnerRecord.planet }}]" readonly>
            {% endif %}
        </div>

        <div class="g-form-group">
            <label class="g-label-cyan">{{ LNG.mg_subject }}</label>
            <input type="text" name="subject" id="subject" class="g-input-field" maxlength="40" value="{% if subject %}{{ subject }}{% else %}{{ LNG.mg_no_subject }}{% endif %}">
        </div>

        <div class="g-form-group">
            <label class="g-label-cyan">
                {{ LNG.mg_message }}
                <span class="char-counter">(<span id="cntChars">0</span> / 5.000)</span>
            </label>

            <div class="bb-toolbar-galactic">
                <button type="button" class="bb-btn-galactic" onclick="msgBB('b')"><b>B</b></button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('i')"><i>I</i></button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('u')"><u>U</u></button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('s')"><s>S</s></button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('url')">🔗 Link</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('img')">🖼 Bild</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('quote')">❝ Zitat</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('code')">⌨ Code</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBBHr()">— HR</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBBList()">≡ Liste</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBBOList()">1. Liste</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBBTable()">⊞ Tabelle</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('color=red')">🎨 Farbe</button>
                <button type="button" class="bb-btn-galactic" onclick="msgBB('size=16')">Aa Größe</button>
            </div>

            <textarea name="text" id="text" class="g-input-field g-textarea-field" onkeyup="document.getElementById('cntChars').textContent=this.value.length;">{{ message|default('') }}</textarea>
        </div>

        <input id="submit-btn" type="button" onClick="check();" class="btn-galactic-send" value="{{ LNG.mg_send }}">
    </form>
</div>

{% autoescape false %}
<script type="text/javascript">
function msgBB(tag) {
    const area = document.getElementById('text');
    if (!area) return;
    const start = area.selectionStart;
    const end   = area.selectionEnd;
    const sel   = area.value.substring(start, end);
    let open = tag, close = tag;
    if (tag.indexOf('=') !== -1) { close = tag.split('=')[0]; }
    if (tag === 'url') { open = 'url=https://'; close = 'url'; }
    const insert = '[' + open + ']' + sel + '[/' + close + ']';
    area.value = area.value.substring(0, start) + insert + area.value.substring(end);
    area.selectionStart = area.selectionEnd = start + insert.length;
    area.focus();
}
function msgBBHr() {
    const area = document.getElementById('text');
    const pos = area.selectionStart;
    area.value = area.value.substring(0, pos) + '[hr]\n' + area.value.substring(pos);
    area.selectionStart = area.selectionEnd = pos + 5;
    area.focus();
}
function msgBBList() {
    const area = document.getElementById('text');
    const pos = area.selectionStart;
    const tpl = '[list]\n[*]Eintrag 1\n[*]Eintrag 2\n[/list]\n';
    area.value = area.value.substring(0, pos) + tpl + area.value.substring(pos);
    area.selectionStart = area.selectionEnd = pos + tpl.length;
    area.focus();
}
function msgBBOList() {
    const area = document.getElementById('text');
    const pos = area.selectionStart;
    const tpl = '[list=1]\n[*]Eintrag 1\n[*]Eintrag 2\n[/list]\n';
    area.value = area.value.substring(0, pos) + tpl + area.value.substring(pos);
    area.selectionStart = area.selectionEnd = pos + tpl.length;
    area.focus();
}
function msgBBTable() {
    const area = document.getElementById('text');
    const pos = area.selectionStart;
    const tpl = '[table]\n[tr][th]Spalte 1[/th][th]Spalte 2[/th][/tr]\n[tr][td]Zelle 1[/td][td]Zelle 2[/td][/tr]\n[/table]\n';
    area.value = area.value.substring(0, pos) + tpl + area.value.substring(pos);
    area.selectionStart = area.selectionEnd = pos + tpl.length;
    area.focus();
}
function check(){
    if(document.getElementById('text').value.trim().length === 0) {
        alert('{{ LNG.mg_empty_text }}');
        return false;
    }
    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.value = 'Wird übertragen...';
    const form = document.getElementById('message-form-galactic');
    const data = new FormData(form);
    fetch('game.php?page=messages&mode=send&ajax=1', { method: 'POST', body: new URLSearchParams(data) })
    .then(r => r.json())
    .then(function(d) {
        alert(d);
        if (window.parent && typeof window.parent.Message !== 'undefined') {
            window.parent.Message.getMessages(window.parent.Message.MessID || 100, 1);
        }
        if (parent.$.fancybox) parent.$.fancybox.close();
    })
    .fail(function() {
        alert('{{ LNG.mg_error }}');
        btn.disabled = false;
        btn.value = '{{ LNG.mg_send }}';
    });
}
document.addEventListener('DOMContentLoaded', function() {
    const t = document.getElementById('text');
    if (t) document.getElementById('cntChars').textContent = t.value.length;
});
</script>
{% endautoescape %}
{% endblock %}
