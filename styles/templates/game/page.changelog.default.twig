{% extends "layout.full.twig" %}

{% block title %}{{ LNG.menu_changelog }}{% endblock %}

{% block content %}
<div class="aerospace-container">

    <div class="content-box header-panel">
        <h2 class="page-title"><i class="fas fa-history"></i> {{ LNG.menu_changelog }}</h2>
    </div>

    <div class="content-box content-panel">
        <div class="changelog-wrapper markdown-body">
            {{ ChangelogList|raw }}
        </div>
    </div>

</div>
<style>
.changelog-wrapper.markdown-body { padding: 8px 4px; }
.changelog-wrapper h1 { font-size: 1.4rem; color: var(--cyan, #00d4ff); border-bottom: 1px solid rgba(0,212,255,0.2); padding-bottom: 8px; margin-bottom: 16px; }
.changelog-wrapper h2 { font-size: 1.15rem; color: #e0e6f0; margin-top: 28px; margin-bottom: 10px; }
.changelog-wrapper h3 { font-size: 1rem; color: rgba(0,212,255,0.85); margin-top: 20px; margin-bottom: 8px; }
.changelog-wrapper p  { color: rgba(255,255,255,0.78); line-height: 1.65; margin-bottom: 10px; }
.changelog-wrapper ul, .changelog-wrapper ol { padding-left: 22px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 10px; }
.changelog-wrapper li { margin-bottom: 4px; }
.changelog-wrapper strong { color: #fff; }
.changelog-wrapper code { background: rgba(0,212,255,0.08); border: 1px solid rgba(0,212,255,0.18); border-radius: 4px; padding: 1px 5px; font-size: 0.88em; color: #00d4ff; }
.changelog-wrapper hr { border: none; border-top: 1px solid rgba(255,255,255,0.08); margin: 20px 0; }
</style>
{% endblock %}
