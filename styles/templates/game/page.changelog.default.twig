{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_changelog }}{% endblock %}

{% block content %}
<div class="aerospace-container">
    
    <div class="content-box header-panel">
        <h2 class="page-title"><i class="fas fa-history"></i> {{ LNG.lm_changelog }}</h2>
    </div>

    <div class="content-box content-panel">
        <div class="changelog-wrapper">
            <table class="glass-table full-width">
                {{ ChangelogList|raw }}
            </table>
        </div>
    </div>

</div>
{% endblock %}
