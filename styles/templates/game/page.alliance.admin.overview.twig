{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_alliance }}{% endblock %}
{% block content %}

<div class="aerospace-container">
    
    <div class="glass-panel header-panel">
        <h2 class="page-title"><i class="fas fa-users-cog"></i> {{ LNG.al_manage_alliance }}</h2>
        
        <div class="admin-nav-buttons">
            <a href="game.php?page=alliance&amp;mode=admin&amp;action=permissions" class="btn-action-glow small">
                <i class="fas fa-user-lock"></i> {{ LNG.al_manage_ranks }}
            </a>
            <a href="game.php?page=alliance&amp;mode=admin&amp;action=members" class="btn-action-glow small">
                <i class="fas fa-users"></i> {{ LNG.al_manage_members }}
            </a>
            {% if rights.DIPLOMATIC %}
            <a href="game.php?page=alliance&amp;mode=admin&amp;action=diplomacy" class="btn-action-glow small">
                <i class="fas fa-handshake"></i> {{ LNG.al_manage_diplo }}
            </a>
            {% endif %}
        </div>
    </div>

    <form action="game.php?page=alliance&mode=admin" method="post">
    <input type="hidden" name="textMode" value="{{ textMode }}">
    <input type="hidden" name="send" value="1">

    <div class="admin-grid">
        
        <div class="admin-col-left">
            
            <div class="glass-panel setting-panel">
                <div class="panel-header"><i class="fas fa-cogs"></i> {{ LNG.al_manage_options }}</div>
                
                <div class="form-group">
                    <label>{{ LNG.al_tag }}</label>
                    <input type="text" name="ally_tag" value="{{ ally_tag }}" class="glass-input" maxlength="8" required>
                </div>
                
                <div class="form-group">
                    <label>{{ LNG.al_name }}</label>
                    <input type="text" name="ally_name" value="{{ ally_name }}" class="glass-input" maxlength="30" required>
                </div>
                
                <div class="form-group">
                    <label>{{ LNG.al_manage_founder_rank }}</label>
                    <input type="text" name="owner_range" value="{{ ally_owner_range }}" class="glass-input">
                </div>
                
                <div class="form-group">
                    <label>{{ LNG.al_web_site }}</label>
                    <input type="text" name="web" value="{{ ally_web }}" class="glass-input">
                </div>
                
                <div class="form-group">
                    <label>{{ LNG.al_manage_image }}</label>
                    <input type="text" name="image" value="{{ ally_image }}" class="glass-input">
                </div>

                <div class="form-group">
                    <label>{{ LNG.al_set_max_members }} ({{ ally_members }})</label>
                    <input type="number" min="1" name="ally_max_members" value="{{ ally_max_members }}" class="glass-input">
                </div>

                <div class="form-group">
                    <label>{{ LNG.al_manage_request_min_points }}</label>
                    <input type="number" min="0" name="request_min_points" value="{{ ally_request_min_points }}" class="glass-input">
                </div>

                <div class="form-group">
                     <label>{{ LNG.al_view_events }}</label>
                     <select name="events[]" multiple class="glass-select multi-select">
                        {% for id, mission in available_events %}
                            {% set selected = '' %}
                            {% for selected_events in ally_events %}
                                {% if selected_events == id %}
                                    {% set selected = 'selected' %}
                                {% endif %}
                            {% endfor %}
                            <option value="{{ id }}" {{ selected }}>{{ mission }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            {% if AllianceOwner %}
            <div class="glass-panel danger-panel">
                <div class="panel-header text-danger"><i class="fas fa-exclamation-circle"></i> Danger Zone</div>
                <div class="danger-actions">
                    <button type="submit" formaction="game.php?page=alliance&amp;mode=admin&amp;action=close" onclick="return confirm('{{ LNG.al_close_ally }}');" class="btn-icon-danger">
                        <i class="fas fa-trash-alt"></i> {{ LNG.al_disolve_alliance }}
                    </button>
                    
                    <button type="submit" formaction="game.php?page=alliance&amp;mode=admin&amp;action=transfer" class="btn-icon-danger">
                        <i class="fas fa-exchange-alt"></i> {{ LNG.al_transfer_alliance }}
                    </button>
                </div>
            </div>
            {% endif %}

        </div>

        <div class="admin-col-right">
            <div class="glass-panel text-panel">
                <div class="panel-header">
                    <i class="fas fa-pen-nib"></i> {{ LNG.al_texts }}
                    <div class="text-tabs">
                        <a href="game.php?page=alliance&amp;mode=admin&amp;textMode=external" class="tab-link {% if textMode == 'external' %}active{% endif %}">{{ LNG.al_outside_text }}</a>
                        <a href="game.php?page=alliance&amp;mode=admin&amp;textMode=internal" class="tab-link {% if textMode == 'internal' %}active{% endif %}">{{ LNG.al_inside_text }}</a>
                        <a href="game.php?page=alliance&amp;mode=admin&amp;textMode=apply" class="tab-link {% if textMode == 'apply' %}active{% endif %}">{{ LNG.al_request_text }}</a>
                    </div>
                </div>
                
                <div class="bbcode-editor-wrap">
                    <div data-bbcode-toolbar="ally-text"></div>
                    <textarea name="text" id="ally-text" class="glass-textarea" rows="14" style="min-height:220px;">{{ text }}</textarea>
                </div>

                <div class="action-bar">
                    <button type="reset" class="btn-ghost">{{ LNG.al_circular_reset }}</button>
                    <button type="submit" class="btn-action-glow">{{ LNG.al_save }}</button>
                </div>
            </div>
        </div>

    </div>
    </form>
</div>
{% endblock %}
{% block script %}
<script src="scripts/game/bbcodeToolbar.js"></script>
{% endblock %}
