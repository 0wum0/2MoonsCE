<div id="leftmenu" class="sidebar">

    <!-- ── DESKTOP COLLAPSE TOGGLE ── -->
    <button class="sidebar-collapse-btn" id="sidebar-collapse-btn"
            aria-label="Sidebar einklappen" title="Sidebar einklappen / ausklappen">
        <i class="fas fa-chevron-left" id="sidebar-collapse-icon"></i>
    </button>

    <div class="sidebar-nav">

        <!-- ── ÜBERSICHT ── -->
        <div class="nav-section">
            <div class="nav-section-label">{{ LNG.lm_overview }}</div>
            <a href="game.php?page=overview" class="nav-link{% if GET.page|default('overview') == 'overview' %} active{% endif %}">
                <i class="fas fa-home"></i><span class="nav-link-text">{{ LNG.lm_overview }}</span>
            </a>
        </div>

        <!-- ── IMPERIUM ── -->
        <div class="nav-section">
            <div class="nav-section-label">{{ LNG.lm_empire }}</div>

            {% if isModuleAvailable(constant('MODULE_BUILDING')) %}
            <a href="game.php?page=buildings" class="nav-link{% if GET.page|default('') == 'buildings' %} active{% endif %}">
                <i class="fas fa-city"></i><span class="nav-link-text">{{ LNG.lm_buildings }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_RESEARCH')) %}
            <a href="game.php?page=research" class="nav-link{% if GET.page|default('') == 'research' %} active{% endif %}">
                <i class="fas fa-flask"></i><span class="nav-link-text">{{ LNG.lm_research }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_SHIPYARD_FLEET')) %}
            <a href="game.php?page=shipyard&mode=fleet" class="nav-link{% if GET.page|default('') == 'shipyard' and GET.mode|default('') == 'fleet' %} active{% endif %}">
                <i class="fas fa-rocket"></i><span class="nav-link-text">{{ LNG.lm_shipshard }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_SHIPYARD_DEFENSIVE')) %}
            <a href="game.php?page=shipyard&mode=defense" class="nav-link{% if GET.page|default('') == 'shipyard' and GET.mode|default('') == 'defense' %} active{% endif %}">
                <i class="fas fa-shield-alt"></i><span class="nav-link-text">{{ LNG.lm_defenses }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_RESSOURCE_LIST')) %}
            <a href="game.php?page=resources" class="nav-link{% if GET.page|default('') == 'resources' %} active{% endif %}">
                <i class="fas fa-industry"></i><span class="nav-link-text">{{ LNG.lm_resources }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_OFFICIER')) or isModuleAvailable(constant('MODULE_DMEXTRAS')) %}
            <a href="game.php?page=officier" class="nav-link{% if GET.page|default('') == 'officier' %} active{% endif %}">
                <i class="fas fa-user-tie"></i><span class="nav-link-text">{{ LNG.lm_officiers }}</span>
            </a>
            {% endif %}
        </div>

        <!-- ── FLOTTE & KARTE ── -->
        <div class="nav-section">
            <div class="nav-section-label">{{ LNG.lm_navigation }}</div>

            {% if isModuleAvailable(constant('MODULE_FLEET_TABLE')) %}
            <a href="game.php?page=fleetTable" class="nav-link{% if GET.page|default('') == 'fleetTable' %} active{% endif %}">
                <i class="fas fa-space-shuttle"></i><span class="nav-link-text">{{ LNG.lm_fleet }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_GALAXY')) %}
            <a href="game.php?page=galaxy" class="nav-link{% if GET.page|default('') == 'galaxy' %} active{% endif %}">
                <i class="fas fa-globe"></i><span class="nav-link-text">{{ LNG.lm_galaxy }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_FLEET_TRADER')) %}
            <a href="game.php?page=fleetDealer" class="nav-link{% if GET.page|default('') == 'fleetDealer' %} active{% endif %}">
                <i class="fas fa-recycle"></i><span class="nav-link-text">{{ LNG.lm_fleettrader }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_TRADER')) %}
            <a href="game.php?page=trader" class="nav-link{% if GET.page|default('') == 'trader' %} active{% endif %}">
                <i class="fas fa-exchange-alt"></i><span class="nav-link-text">{{ LNG.lm_trader }}</span>
            </a>
            {% endif %}
        </div>

        <!-- ── GEMEINSCHAFT ── -->
        <div class="nav-section">
            <div class="nav-section-label">{{ LNG.lm_community|default('Community') }}</div>

            {% if isModuleAvailable(constant('MODULE_MESSAGES')) %}
            <a href="game.php?page=messages" class="nav-link{% if GET.page|default('') == 'messages' %} active{% endif %}">
                <i class="fas fa-envelope"></i><span class="nav-link-text">{{ LNG.lm_messages }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_ALLIANCE')) %}
            <a href="game.php?page=alliance" class="nav-link{% if GET.page|default('') == 'alliance' %} active{% endif %}">
                <i class="fas fa-users"></i><span class="nav-link-text">{{ LNG.lm_alliance }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_SUPPORT')) %}
            <a href="game.php?page=ticket" class="nav-link{% if GET.page|default('') == 'ticket' %} active{% endif %}">
                <i class="fas fa-life-ring"></i><span class="nav-link-text">{{ LNG.lm_support }}</span>
            </a>
            {% endif %}
        </div>

        <!-- ── TOOLS ── -->
        <div class="nav-section">
            <div class="nav-section-label">{{ LNG.lm_tools|default('Tools') }}</div>

            {% if isModuleAvailable(constant('MODULE_STATISTICS')) %}
            <a href="game.php?page=statistics" class="nav-link{% if GET.page|default('') == 'statistics' %} active{% endif %}">
                <i class="fas fa-chart-line"></i><span class="nav-link-text">{{ LNG.lm_statistics }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_BATTLEHALL')) %}
            <a href="game.php?page=battleHall" class="nav-link{% if GET.page|default('') == 'battleHall' %} active{% endif %}">
                <i class="fas fa-trophy"></i><span class="nav-link-text">{{ LNG.lm_topkb }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_RECORDS')) %}
            <a href="game.php?page=records" class="nav-link{% if GET.page|default('') == 'records' %} active{% endif %}">
                <i class="fas fa-medal"></i><span class="nav-link-text">{{ LNG.lm_records }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_SIMULATOR')) %}
            <a href="game.php?page=battleSimulator" class="nav-link{% if GET.page|default('') == 'battleSimulator' %} active{% endif %}">
                <i class="fas fa-chess-knight"></i><span class="nav-link-text">{{ LNG.lm_battlesim }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_SEARCH')) %}
            <a href="game.php?page=search" class="nav-link{% if GET.page|default('') == 'search' %} active{% endif %}">
                <i class="fas fa-search"></i><span class="nav-link-text">{{ LNG.lm_search }}</span>
            </a>
            {% endif %}

            {% if isModuleAvailable(constant('MODULE_TECHTREE')) %}
            <a href="game.php?page=techtree" class="nav-link{% if GET.page|default('') == 'techtree' %} active{% endif %}">
                <i class="fas fa-sitemap"></i><span class="nav-link-text">{{ LNG.lm_technology }}</span>
            </a>
            {% endif %}
        </div>

    </div>

    <!-- ── SIDEBAR FOOTER ── -->
    <div class="sidebar-footer">
        <a href="game.php?page=settings" class="nav-link" title="{{ LNG.lm_settings|default('Einstellungen') }}">
            <i class="fas fa-cog"></i><span class="nav-link-text">{{ LNG.lm_settings|default('Einstellungen') }}</span>
        </a>
        {% if authlevel > 0 %}
        <a href="./admin.php" class="nav-link" title="{{ LNG.lm_administration|default('Admin') }}" style="color:var(--sm-orange);">
            <i class="fas fa-user-shield"></i><span class="nav-link-text">{{ LNG.lm_administration|default('Admin') }}</span>
        </a>
        {% endif %}
        <a href="game.php?page=logout" class="nav-link danger" title="{{ LNG.lm_logout|default('Logout') }}" style="color:var(--sm-red);">
            <i class="fas fa-power-off"></i><span class="nav-link-text">{{ LNG.lm_logout|default('Logout') }}</span>
        </a>
    </div>
	{{ hook('sidebar_end') }}
</div>
