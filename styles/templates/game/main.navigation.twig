<div id="leftmenu" class="sidebar">

    <!-- ── DESKTOP COLLAPSE TOGGLE ── -->
    <button class="sidebar-collapse-btn" id="sidebar-collapse-btn"
            aria-label="Sidebar einklappen" title="Sidebar einklappen / ausklappen"
            onclick="(function(){
                var s=document.getElementById('leftmenu');
                var ic=document.getElementById('sidebar-collapse-icon');
                var collapsed=s.classList.toggle('sidebar-icon-only');
                ic.className=collapsed?'fas fa-chevron-right':'fas fa-chevron-left';
                localStorage.setItem('sm_sidebar_collapsed',collapsed?'1':'0');
            })();">
        <i class="fas fa-chevron-left" id="sidebar-collapse-icon"></i>
    </button>
    <script>(function(){
        var v=localStorage.getItem('sm_sidebar_collapsed');
        if(v==='1'){
            var s=document.getElementById('leftmenu');
            var ic=document.getElementById('sidebar-collapse-icon');
            if(s){s.classList.add('sidebar-icon-only');}
            if(ic){ic.className='fas fa-chevron-right';}
        }
    })();</script>

    <div class="sidebar-nav">
{{ hook('ingame.sidebar.top') }}
        <!-- ── ÜBERSICHT ── -->
        <div class="nav-section">
            <div class="nav-section-label">{{ LNG.lm_overview }}</div>
            <a href="game.php?page=overview" class="nav-link{% if GET.page|default('overview') == 'overview' %} active{% endif %}">
                <i class="fas fa-home"></i><span class="nav-link-text">{{ LNG.lm_overview }}</span>
            </a>
        </div>

