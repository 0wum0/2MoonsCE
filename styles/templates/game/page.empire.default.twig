{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_empire }}{% endblock %}

{% block content %}
<div class="aerospace-container">
    
    <div class="content-box title-panel">
        <h2 class="page-title"><i class="fas fa-sitemap"></i> {{ LNG.lv_imperium_title }}</h2>
    </div>

    <div class="content-box empire-panel">
        <div class="empire-scroll-wrapper">
            <table class="empire-table">
                
                <thead>
                    <tr>
                        <th class="sticky-col sticky-corner">
                            <div class="corner-box">
                                <span class="corner-icon"><i class="fas fa-globe"></i></span>
                            </div>
                        </th>
                        <th class="sum-col">
                            <div class="sum-header">
                                <span class="sum-symbol">&Sigma;</span>
                                <span class="sum-label">{{ LNG.lv_total }}</span>
                            </div>
                        </th>
                        {% for planetID, image in planetList.image %}
                        <th class="planet-col">
                            <a href="game.php?page=overview&amp;cp={{ planetID }}" class="planet-link">
                                <img src="{{ dpath }}planeten/small/s_{{ image }}.jpg" alt="" class="planet-thumb">
                                <div class="planet-overlay"></div>
                            </a>
                        </th>
                        {% endfor %}
                    </tr>
                    
                    <tr class="info-row">
                        <td class="sticky-col label-cell">{{ LNG.lv_name }}</td>
                        <td class="sum-cell">-</td>
                        {% for name in planetList.name %}
                        <td class="data-cell planet-name">{{ name }}</td>
                        {% endfor %}
                    </tr>

                    <tr class="info-row">
                        <td class="sticky-col label-cell">{{ LNG.lv_coords }}</td>
                        <td class="sum-cell">-</td>
                        {% for coords in planetList.coords %}
                        <td class="data-cell">
                            <a href="game.php?page=galaxy&amp;galaxy={{ coords.galaxy }}&amp;system={{ coords.system }}" class="coord-link">
                                [{{ coords.galaxy }}:{{ coords.system }}:{{ coords.planet }}]
                            </a>
                        </td>
                        {% endfor %}
                    </tr>

                    <tr class="info-row">
                        <td class="sticky-col label-cell">{{ LNG.lv_fields }}</td>
                        <td class="sum-cell">-</td>
                        {% for field in planetList.field %}
                        <td class="data-cell field-data">{{ field.current }} / {{ field.max }}</td>
                        {% endfor %}
                    </tr>
                </thead>

                <tbody>
                    <tr class="section-header">
                        <td class="sticky-col sectiontitle" colspan="2">{{ LNG.lv_resources }}</td>
                        <td colspan="{{ planetList.image|length }}" class="section-spacer"></td>
                    </tr>
                    {% for elementID, resourceArray in planetList.resource %}
                    <tr class="data-row">
                        <td class="sticky-col row-header">
                            <div class="tech-label">
                                <img src="{{ dpath }}images/{{ elementID }}.gif" class="mini-icon">
                                {{ LNG.tech[elementID] }}
                            </div>
                        </td>
                        <td class="sum-cell text-highlight">{{ array_sum(resourceArray)|number_format(0, '.', ',') }}</td>
                        {% for planetID, resource in resourceArray %}
                        <td class="data-cell">{{ resource|number_format(0, '.', ',') }}</td>
                        {% endfor %}
                    </tr>
                    {% endfor %}

                    <tr class="section-header">
                        <td class="sticky-col sectiontitle" colspan="2">{{ LNG.lv_buildings }}</td>
                        <td colspan="{{ planetList.image|length }}" class="section-spacer"></td>
                    </tr>
                    {% for elementID, buildArray in planetList.build %}
                    <tr class="data-row">
                        <td class="sticky-col row-header">
                            <div class="tech-label">
                                <img src="{{ dpath }}gebaeude/{{ elementID }}.gif" class="mini-icon-rect" onerror="this.style.display='none'">
                                {{ LNG.tech[elementID] }}
                            </div>
                        </td>
                        <td class="sum-cell text-highlight">{{ array_sum(buildArray)|number_format(0, '.', ',') }}</td>
                        {% for planetID, build in buildArray %}
                        <td class="data-cell {% if build == 0 %}muted-val{% else %}active-val{% endif %}">
                            {{ build|number_format(0, '.', ',') }}
                        </td>
                        {% endfor %}
                    </tr>
                    {% endfor %}

                    <tr class="section-header">
                        <td class="sticky-col sectiontitle" colspan="2">{{ LNG.lv_technology }}</td>
                        <td colspan="{{ planetList.image|length }}" class="section-spacer"></td>
                    </tr>
                    {% for elementID, tech in planetList.tech %}
                    <tr class="data-row">
                        <td class="sticky-col row-header">
                            <div class="tech-label">
                                <img src="{{ dpath }}gebaeude/{{ elementID }}.gif" class="mini-icon-rect" onerror="this.style.display='none'">
                                {{ LNG.tech[elementID] }}
                            </div>
                        </td>
                        <td class="sum-cell text-highlight">{{ tech|number_format(0, '.', ',') }}</td>
                        {% for name in planetList.name %}
                        <td class="data-cell tech-global">{{ tech|number_format(0, '.', ',') }}</td>
                        {% endfor %}
                    </tr>
                    {% endfor %}

                    <tr class="section-header">
                        <td class="sticky-col sectiontitle" colspan="2">{{ LNG.lv_ships }}</td>
                        <td colspan="{{ planetList.image|length }}" class="section-spacer"></td>
                    </tr>
                    {% for elementID, fleetArray in planetList.fleet %}
                    {% if array_sum(fleetArray) > 0 %}
                    <tr class="data-row">
                        <td class="sticky-col row-header">
                            <div class="tech-label">
                                <img src="{{ dpath }}gebaeude/{{ elementID }}.gif" class="mini-icon-rect" onerror="this.style.display='none'">
                                {{ LNG.tech[elementID] }}
                            </div>
                        </td>
                        <td class="sum-cell text-highlight">{{ array_sum(fleetArray)|number_format(0, '.', ',') }}</td>
                        {% for planetID, fleet in fleetArray %}
                        <td class="data-cell {% if fleet == 0 %}muted-val{% endif %}">
                            {{ fleet|number_format(0, '.', ',') }}
                        </td>
                        {% endfor %}
                    </tr>
                    {% endif %}
                    {% endfor %}

                    <tr class="section-header">
                        <td class="sticky-col sectiontitle" colspan="2">{{ LNG.lv_defenses }}</td>
                        <td colspan="{{ planetList.image|length }}" class="section-spacer"></td>
                    </tr>
                    {% for elementID, defenseArray in planetList.defense %}
                    {% if array_sum(defenseArray) > 0 %}
                    <tr class="data-row">
                        <td class="sticky-col row-header">
                            <div class="tech-label">
                                <img src="{{ dpath }}gebaeude/{{ elementID }}.gif" class="mini-icon-rect" onerror="this.style.display='none'">
                                {{ LNG.tech[elementID] }}
                            </div>
                        </td>
                        <td class="sum-cell text-highlight">{{ array_sum(defenseArray)|number_format(0, '.', ',') }}</td>
                        {% for planetID, defense in defenseArray %}
                        <td class="data-cell {% if defense == 0 %}muted-val{% endif %}">
                            {{ defense|number_format(0, '.', ',') }}
                        </td>
                        {% endfor %}
                    </tr>
                    {% endif %}
                    {% endfor %}

                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
