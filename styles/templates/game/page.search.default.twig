{% extends "layout.full.twig" %}

{% block title %}{{ LNG.lm_search }}{% endblock %}
{% block content %}

<div class="content_page">
    <div class="aerospace-wrapper search-wrapper-centered">
        
        <div class="search-box-large">
            <h1 class="search-title"><i class="fas fa-search"></i> {{ LNG.sh_search_in_the_universe }}</h1>
            
            <div class="search-input-container">
                <div class="input-group">
                    <select name="type" id="type" class="search-select">
                        <option value="playername">{{ LNG.sh_player_name }}</option>
                        <option value="planetname">{{ LNG.sh_planet_name }}</option>
                        <option value="tag">{{ LNG.sh_tag }}</option>
                        <option value="allyname">{{ LNG.sh_ally_name }}</option>
                    </select>
                    <input type="text" name="searchtext" id="searchtext" class="search-field" placeholder="Suchbegriff...">
                </div>
                
                <button type="button" id="search-btn" class="btn-search-large">
                    {{ LNG.sh_search }}
                </button>
            </div>
            
            <span id="loading" class="loading-indicator" style="display:none;">
                <i class="fas fa-spinner fa-spin"></i> {{ LNG.sh_loading }}
            </span>
        </div>

        <div id="result_search" class="search-results-container"></div>

    </div>
</div>

<script type="text/javascript">
    // Simple JS connector for the button
    $(document).ready(function(){
        $('#search-btn').click(function(){
            // Trigger 2Moons search logic manually if needed, or assume existing JS handles #type and #searchtext
            // Usually 2Moons binds to the inputs. We just ensure the ID matches.
             var type = $('#type').val();
             var text = $('#searchtext').val();
             if(text) {
                 $('#loading').show();
                 $.post('game.php?page=search&mode=search&ajax=1', {type: type, searchtext: text}, function(data){
                     $('#loading').hide();
                     $('#result_search').html(data);
                 });
             }
        });
        
        // Enter key support
        $('#searchtext').keypress(function(e){
            if(e.which == 13){
                $('#search-btn').click();
            }
        });
    });
</script>
{% endblock %}
