{% extends "layout.full.twig" %}

{% block title %}{{ LNG.ti_read }}{% endblock %}
{% block content %}
<div class="tc-root">

    {% set firstMsg = answerList|first %}

    <div class="tc-topbar">
        <div class="tc-topbar-left">
            <div class="tc-topbar-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/></svg>
            </div>
            <div>
                <div class="tc-topbar-title">{{ firstMsg.subject|default('Ticket')|e }}</div>
                <div class="tc-topbar-sub">// TICKET #{{ ticketID }} &middot; {{ categoryList[firstMsg.categoryID]|default('?')|e }}</div>
            </div>
        </div>
        <div class="tc-topbar-right">
            {% if status == 0 %}
            <span class="tc-badge open">
                <svg viewBox="0 0 16 16" fill="currentColor"><circle cx="8" cy="8" r="4"/></svg>
                {{ LNG.ti_status_open }}
            </span>
            {% elseif status == 1 %}
            <span class="tc-badge answered">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M10.97 4.97a.75.75 0 011.07 1.05l-3.99 4.99a.75.75 0 01-1.08.02L4.324 8.384a.75.75 0 111.06-1.06l2.094 2.093 3.473-4.425-.047-.048z"/></svg>
                {{ LNG.ti_status_answer }}
            </span>
            {% else %}
            <span class="tc-badge closed">
                <svg viewBox="0 0 16 16" fill="currentColor"><path d="M4.646 4.646a.5.5 0 01.708 0L8 7.293l2.646-2.647a.5.5 0 01.708.708L8.707 8l2.647 2.646a.5.5 0 01-.708.708L8 8.707l-2.646 2.647a.5.5 0 01-.708-.708L7.293 8 4.646 5.354a.5.5 0 010-.708z"/></svg>
                {{ LNG.ti_status_closed }}
            </span>
            {% endif %}
            <a href="game.php?page=ticket" class="tc-btn-back">
                <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11"><path d="M15 8a.5.5 0 00-.5-.5H2.707l3.147-3.146a.5.5 0 10-.708-.708l-4 4a.5.5 0 000 .708l4 4a.5.5 0 00.708-.708L2.707 8.5H14.5A.5.5 0 0015 8z"/></svg>
                Zurück
            </a>
        </div>
    </div>

    <div class="tc-thread-body">

        {% for answerRow in answerList %}
        {% set isSupport = answerRow.ownerID != answerList|first.ownerID %}
        {% set initial = answerRow.ownerName|slice(0,1)|upper %}
        <div class="tc-msg {% if isSupport %}is-support{% endif %}">
            <div class="tc-msg-avatar">{{ initial }}</div>
            <div class="tc-msg-bubble">
                <div class="tc-msg-head">
                    <span class="tc-msg-author">{{ answerRow.ownerName|e }}</span>
                    {% if isSupport %}
                    <span class="tc-msg-role">Support</span>
                    {% else %}
                    <span class="tc-msg-role" style="color:var(--tc-accent);background:rgba(0,212,255,0.08);border-color:rgba(0,212,255,0.2)">User</span>
                    {% endif %}
                    <span class="tc-msg-time">{{ answerRow.time }}</span>
                </div>
                <div class="tc-msg-text">{{ answerRow.message|raw }}</div>
            </div>
        </div>
        {% endfor %}

        {% if status < 2 %}
        <div class="tc-reply-section">
            <div class="tc-reply-title">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 01-.923 1.785A5.969 5.969 0 006 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337z"/></svg>
                {{ LNG.ti_answer }}
            </div>
            <form action="game.php?page=ticket&mode=send" method="post">
                <input type="hidden" name="id" value="{{ ticketID }}">
                <div class="tc-field" style="margin-bottom:10px;">
                    <div class="tc-bb-bar">
                        <button type="button" class="tc-bb-btn" onclick="tkBB('b')"><b>B</b></button>
                        <button type="button" class="tc-bb-btn" onclick="tkBB('i')"><i>I</i></button>
                        <button type="button" class="tc-bb-btn" onclick="tkBB('u')"><u>U</u></button>
                        <button type="button" class="tc-bb-btn" onclick="tkBB('s')"><s>S</s></button>
                        <div class="tc-bb-sep"></div>
                        <button type="button" class="tc-bb-btn" onclick="tkBB('url')">Link</button>
                        <button type="button" class="tc-bb-btn" onclick="tkBB('quote')">Zitat</button>
                        <button type="button" class="tc-bb-btn" onclick="tkBB('code')">Code</button>
                    </div>
                    <textarea class="tc-finput tc-ftextarea" id="message" name="message" required
                              placeholder="{{ LNG.ti_answer }}..." style="min-height:120px;"></textarea>
                </div>
                <button type="submit" class="tc-btn-send">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13"><path d="M15.964.686a.5.5 0 00-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 00-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 00.886-.083l6-15Zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 00-.154-.154l-.338-.215 7.494-7.494 1.178-.471-.47 1.178z"/></svg>
                    {{ LNG.ti_submit }}
                </button>
            </form>
        </div>
        {% else %}
        <div class="tc-closed-notice">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
            Dieses Ticket ist geschlossen. Keine weiteren Antworten möglich.
        </div>
        {% endif %}

    </div>

</div>

<script>
function tkBB(tag) {
    var area = document.getElementById('message');
    if (!area) return;
    var start = area.selectionStart, end = area.selectionEnd;
    var sel = area.value.substring(start, end);
    var open = tag, close = tag;
    if (tag.indexOf('=') !== -1) { close = tag.split('=')[0]; }
    if (tag === 'url') { open = 'url=https://'; close = 'url'; }
    var insert = '[' + open + ']' + sel + '[/' + close + ']';
    area.value = area.value.substring(0, start) + insert + area.value.substring(end);
    area.selectionStart = area.selectionEnd = start + insert.length;
    area.focus();
}
</script>
{% endblock %}
