{% extends "layout.full.twig" %}

{% block title %}{{ LNG.ti_create_head }} - {{ LNG.lm_support }}{% endblock %}
{% block content %}

<div class="content_page">
    <div class="aerospace-wrapper" style="max-width: 800px; margin: 0 auto;">
        
        <div class="glass-panel form-card">
            <div class="form-header">
                <h2>{{ LNG.ti_create_head }}</h2>
                <p>{{ LNG.ti_create_info }}</p>
            </div>

            <form action="game.php?page=ticket&mode=send" method="post" id="form">
                <input type="hidden" name="id" value="0">
                
                <div class="form-group">
                    <label for="category">{{ LNG.ti_category }}</label>
                    <select id="category" name="category" class="glass-input">
                        {% for key, value in categoryList %}
                            <option value="{{ key }}">{{ value }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label for="subject">{{ LNG.ti_subject }}</label>
                    <input class="glass-input validate[required]" type="text" id="subject" name="subject" maxlength="255">
                </div>

                <div class="form-group">
                    <label for="message">{{ LNG.ti_message }}</label>
                    <textarea class="glass-textarea validate[required]" id="message" name="message" rows="10"></textarea>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">{{ LNG.ti_submit }}</button>
                </div>
            </form>
        </div>

    </div>
</div>
{% endblock %}
{% block script %}
<script>
$(document).ready(function() {
    $("#form").validationEngine('attach');
});
</script>
{% endblock %}
