{% extends "layout.full.twig" %}

{% block title %}{{ LNG.ti_create_head }}{% endblock %}
{% block content %}
<style>
    .support-full { width: 100% !important; max-width: 100% !important; box-sizing: border-box; }
    .glass-textarea { 
        width: 100% !important; 
        min-height: 250px !important; 
        background: rgba(0,0,0,0.5) !important; 
        color: #fff !important; 
        border: 1px solid rgba(56, 189, 248, 0.3) !important;
        padding: 15px; 
        resize: vertical; 
        font-family: inherit;
    }
    .bb-toolbar { display: flex; gap: 8px; margin-bottom: 10px; background: rgba(255,255,255,0.05); padding: 10px; border-radius: 8px; flex-wrap: wrap; }
    .bb-btn { padding: 6px 12px; background: #38bdf8; color: #000; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; font-size: 13px; }
</style>

<div class="content_page support-full">
    <div class="glass-panel support-full">
        <h2 style="color: #fff; margin-top: 0;">🚀 {{ LNG.ti_create_head }}</h2>
        
        <form action="game.php?page=ticket&mode=send" method="post">
            <input type="hidden" name="id" value="0">
            
            <div style="margin-bottom: 15px;">
                <label style="display:block; color: #38bdf8; font-weight: bold;">{{ LNG.ti_category }}</label>
                <select name="category" style="width: 100%; padding: 10px; background: #000; color: #fff; border: 1px solid #333;">
                    {% for key, value in categoryList %}<option value="{{ key }}">{{ value }}</option>{% endfor %}
                </select>
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display:block; color: #38bdf8; font-weight: bold;">{{ LNG.ti_subject }}</label>
                <input type="text" name="subject" style="width: 100%; padding: 10px; background: #000; color: #fff; border: 1px solid #333;" required>
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display:block; color: #38bdf8; font-weight: bold; margin-bottom: 5px;">{{ LNG.ti_message }}</label>
                <div class="bb-toolbar">
                    <button type="button" class="bb-btn" onclick="addBB('b')">B</button>
                    <button type="button" class="bb-btn" onclick="addBB('i')">I</button>
                    <button type="button" class="bb-btn" onclick="addBB('u')">U</button>
                    <button type="button" class="bb-btn" onclick="addBB('quote')">Zitat</button>
                    <button type="button" class="bb-btn" onclick="addBB('url')">Link</button>
                </div>
                <textarea class="glass-textarea" id="message" name="message" required></textarea>
            </div>

            <button type="submit" style="padding: 10px 25px; background: #38bdf8; color: #000; border: none; border-radius: 5px; font-weight: bold; cursor: pointer;">{{ LNG.ti_submit }}</button>
        </form>
    </div>
</div>

<script>
function addBB(tag) {
    const area = document.getElementById('message');
    const start = area.selectionStart;
    const end = area.selectionEnd;
    const text = area.value;
    const sel = text.substring(start, end);
    let res = "";
    if(tag === 'url') res = "[url=https://]" + (sel || "Link") + "[/url]";
    else res = "[" + tag + "]" + sel + "[/" + tag + "]";
    area.value = text.substring(0, start) + res + text.substring(end);
    area.focus();
}
</script>
{% endblock %}