{% extends "layout.full.twig" %}

{% block title %}{{ LNG.ti_create_head }}{% endblock %}
{% block content %}
<div class="tc-root">

    <div class="tc-topbar">
        <div class="tc-topbar-left">
            <div class="tc-topbar-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
            </div>
            <div>
                <div class="tc-topbar-title">{{ LNG.ti_create_head }}</div>
                <div class="tc-topbar-sub">// NEW_TICKET &middot; SUPPORT_CENTER</div>
            </div>
        </div>
        <div class="tc-topbar-right">
            <a href="game.php?page=ticket" class="tc-btn-back">
                <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11"><path d="M15 8a.5.5 0 00-.5-.5H2.707l3.147-3.146a.5.5 0 10-.708-.708l-4 4a.5.5 0 000 .708l4 4a.5.5 0 00.708-.708L2.707 8.5H14.5A.5.5 0 0015 8z"/></svg>
                Zurück
            </a>
        </div>
    </div>

    <div class="tc-form-body">
        <form action="game.php?page=ticket&mode=send" method="post" id="tc-create-form">
            <input type="hidden" name="id" value="0">
            <input type="hidden" name="category" id="tc-category-input" value="1">

            <div class="tc-field">
                <div class="tc-flabel">{{ LNG.ti_category }}</div>
                <div class="tc-cat-row">
                    {% for key, value in categoryList %}
                    <div class="tc-cat-option {% if key == 1 %}selected{% endif %}" data-cat="{{ key }}" onclick="tcSelectCat(this)">
                        {% if key == 1 %}
                        <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M8 16A8 8 0 108 0a8 8 0 000 16zm.93-9.412l-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 110-2 1 1 0 010 2z"/></svg>
                        {% elseif key == 2 %}
                        <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M7.938 2.016A.13.13 0 018.002 2a.13.13 0 01.063.016.146.146 0 01.054.057l6.857 11.667c.036.06.035.124.002.183a.163.163 0 01-.054.06.116.116 0 01-.066.017H1.146a.115.115 0 01-.066-.017.163.163 0 01-.054-.06.176.176 0 01.002-.183L7.884 2.073a.147.147 0 01.054-.057zm1.044-.45a1.13 1.13 0 00-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 01-1.1 0L7.1 5.995A.905.905 0 018 5zm.002 6a1 1 0 110 2 1 1 0 010-2z"/></svg>
                        {% elseif key == 3 %}
                        <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M8 4.754a3.246 3.246 0 100 6.492 3.246 3.246 0 000-6.492zM5.754 8a2.246 2.246 0 114.492 0 2.246 2.246 0 01-4.492 0z"/><path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 01-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 01-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 01.52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 011.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 011.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 01.52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 01-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 01-1.255-.52l-.094-.319z"/></svg>
                        {% else %}
                        <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M14 1a1 1 0 011 1v8a1 1 0 01-1 1H4.414A2 2 0 003 11.586l-2 2V2a1 1 0 011-1h12zM2 0a2 2 0 00-2 2v12.793a.5.5 0 00.854.353l2.853-2.853A1 1 0 014.414 12H14a2 2 0 002-2V2a2 2 0 00-2-2H2z"/></svg>
                        {% endif %}
                        {{ value|e }}
                    </div>
                    {% endfor %}
                </div>
            </div>

            <div class="tc-field">
                <label class="tc-flabel" for="tc-subject">{{ LNG.ti_subject }}</label>
                <input type="text" id="tc-subject" name="subject" class="tc-finput" placeholder="Kurze Beschreibung des Problems..." required maxlength="100">
            </div>

            <div class="tc-field">
                <div class="tc-flabel">{{ LNG.ti_message }}</div>
                <div class="tc-bb-bar">
                    <button type="button" class="tc-bb-btn" onclick="tkBB('b')"><b>B</b></button>
                    <button type="button" class="tc-bb-btn" onclick="tkBB('i')"><i>I</i></button>
                    <button type="button" class="tc-bb-btn" onclick="tkBB('u')"><u>U</u></button>
                    <button type="button" class="tc-bb-btn" onclick="tkBB('s')"><s>S</s></button>
                    <div class="tc-bb-sep"></div>
                    <button type="button" class="tc-bb-btn" onclick="tkBB('url')">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11"><path d="M4.715 6.542L3.343 7.914a3 3 0 104.243 4.243l1.828-1.829A3 3 0 008.586 5.5L8 6.086a1.002 1.002 0 00-.154.199 2 2 0 01.861 3.337L6.88 11.45a2 2 0 11-2.83-2.83l.793-.792a4.018 4.018 0 01-.128-1.287z"/><path d="M6.586 4.672A3 3 0 007.414 9.5l.775-.776a2 2 0 01-.896-3.346L9.12 3.55a2 2 0 112.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 10-4.243-4.243L6.586 4.672z"/></svg>
                        Link
                    </button>
                    <button type="button" class="tc-bb-btn" onclick="tkBB('quote')">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11"><path d="M12 12a1 1 0 000-2H4a1 1 0 000 2h8zM10.5 6a1 1 0 000-2h-5a1 1 0 000 2h5z"/></svg>
                        Zitat
                    </button>
                    <button type="button" class="tc-bb-btn" onclick="tkBB('code')">
                        <svg viewBox="0 0 16 16" fill="currentColor" width="11" height="11"><path d="M5.854 4.854a.5.5 0 10-.708-.708l-3.5 3.5a.5.5 0 000 .708l3.5 3.5a.5.5 0 00.708-.708L2.707 8l3.147-3.146zm4.292 0a.5.5 0 01.708-.708l3.5 3.5a.5.5 0 010 .708l-3.5 3.5a.5.5 0 01-.708-.708L13.293 8l-3.147-3.146z"/></svg>
                        Code
                    </button>
                    <div class="tc-bb-sep"></div>
                    <button type="button" class="tc-bb-btn" onclick="tkBBList()">Liste</button>
                </div>
                <textarea class="tc-finput tc-ftextarea" id="message" name="message" required
                          placeholder="Beschreibe dein Problem so detailliert wie möglich..."
                          oninput="document.getElementById('tc-charcount').textContent=this.value.length"></textarea>
                <div class="tc-char-row">
                    <span class="tc-char-count"><span id="tc-charcount">0</span> Zeichen</span>
                </div>
            </div>

            <div class="tc-form-footer">
                <button type="submit" class="tc-btn-send">
                    <svg viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M15.964.686a.5.5 0 00-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 00-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 00.886-.083l6-15Zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 00-.154-.154l-.338-.215 7.494-7.494 1.178-.471-.47 1.178z"/></svg>
                    {{ LNG.ti_submit }}
                </button>
                <a href="game.php?page=ticket" class="tc-btn-back">Abbrechen</a>
            </div>
        </form>
    </div>

</div>

<script>
function tcSelectCat(el) {
    document.querySelectorAll('.tc-cat-option').forEach(function(o){ o.classList.remove('selected'); });
    el.classList.add('selected');
    document.getElementById('tc-category-input').value = el.getAttribute('data-cat');
}
function tkBB(tag) {
    var area = document.getElementById('message');
    if (!area) return;
    var start = area.selectionStart, end = area.selectionEnd;
    var sel = area.value.substring(start, end);
    var open = tag, close = tag;
    if (tag.indexOf('=') !== -1) { close = tag.split('=')[0]; }
    if (tag === 'url') { open = 'url=https://'; close = 'url'; }
    var insert = '[' + open + ']' + sel + '[/' + close + ']';
    area.value = area.value.substring(0, start) + insert + area.value.substring(end);
    area.selectionStart = area.selectionEnd = start + insert.length;
    area.focus();
}
function tkBBList() {
    var area = document.getElementById('message');
    var pos = area.selectionStart;
    var tpl = '[list]\n[*]Eintrag 1\n[*]Eintrag 2\n[/list]\n';
    area.value = area.value.substring(0, pos) + tpl + area.value.substring(pos);
    area.selectionStart = area.selectionEnd = pos + tpl.length;
    area.focus();
}
</script>
{% endblock %}
