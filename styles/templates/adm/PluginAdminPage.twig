.pm-stat-lbl { font-size: 0.75rem; color: #64748b; margin-top: 2px; }

/* Toolbar */
.pm-toolbar {
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
    margin-bottom: 20px;
}
.pm-search {
    flex: 1; min-width: 200px;
    background: var(--adm-card-bg, #131929);
    border: 1px solid var(--adm-border, #1e2d4a);
    border-radius: 8px; padding: 9px 14px 9px 36px;
    color: #e2e8f0; font-size: 0.875rem; outline: none;
    transition: border-color .2s;
}
.pm-search:focus { border-color: #38bdf8; }
.pm-search-wrap { position: relative; flex: 1; min-width: 200px; }
.pm-search-wrap i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #475569; font-size: 13px; pointer-events: none; }
.pm-filter-btn {
    padding: 9px 16px; border-radius: 8px; cursor: pointer; font-size: 0.8rem;
    background: var(--adm-card-bg, #131929);
    border: 1px solid var(--adm-border, #1e2d4a);
    color: #94a3b8; transition: all .2s; white-space: nowrap;
}
.pm-filter-btn.active, .pm-filter-btn:hover {
    background: rgba(56,189,248,0.1); border-color: #38bdf8; color: #7dd3fc;
}

/* Cards grid */
.pm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px; margin-bottom: 30px;
}
.pm-card {
    background: var(--adm-card-bg, #131929);
    border: 1px solid var(--adm-border, #1e2d4a);
    border-radius: 12px; padding: 0;
    display: flex; flex-direction: column;
    transition: border-color .2s, box-shadow .2s;
    overflow: hidden;
}
.pm-card:hover {
    border-color: rgba(56,189,248,0.35);
    box-shadow: 0 4px 24px rgba(0,0,0,0.45), 0 0 0 1px rgba(56,189,248,0.1);
}
.pm-card.is-active { border-color: rgba(34,197,94,0.3); }
.pm-card.is-active:hover { border-color: rgba(34,197,94,0.55); box-shadow: 0 4px 24px rgba(0,0,0,0.45), 0 0 0 1px rgba(34,197,94,0.15); }

/* Card header strip */
.pm-card-header {
    height: 5px;
    background: linear-gradient(90deg, #1e2d4a, #1e3a5a);
}
.pm-card.is-active .pm-card-header {
    background: linear-gradient(90deg, #065f46, #0d9488);
}
.pm-card.is-discover .pm-card-header {
    background: linear-gradient(90deg, #78350f, #d97706);
}

/* Card body */
.pm-card-body { padding: 16px 18px; flex: 1; display: flex; flex-direction: column; gap: 10px; }

.pm-card-top { display: flex; align-items: flex-start; gap: 12px; }
.pm-card-avatar {
    width: 44px; height: 44px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 700; color: #fff;
    background: linear-gradient(135deg, #1e3a5f, #0f2440);
    border: 1px solid rgba(56,189,248,0.2);
    letter-spacing: 0;
}
.pm-card.is-active .pm-card-avatar { background: linear-gradient(135deg, #064e3b, #0d9488); border-color: rgba(34,197,94,0.25); }
.pm-card.is-discover .pm-card-avatar { background: linear-gradient(135deg, #7c2d12, #d97706); border-color: rgba(245,158,11,0.25); }

.pm-card-title-wrap { flex: 1; min-width: 0; }
.pm-card-name { font-size: 0.95rem; font-weight: 700; color: #e2e8f0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.pm-card-id   { font-size: 0.72rem; font-family: monospace; color: #7dd3fc; margin-top: 2px; opacity: .8; }

/* Toggle switch */
.pm-toggle { position: relative; width: 40px; height: 22px; flex-shrink: 0; }
.pm-toggle input { opacity: 0; width: 0; height: 0; position: absolute; }
.pm-toggle-slider {
    position: absolute; inset: 0; background: #1e2d4a; border-radius: 22px;
    cursor: pointer; transition: background .25s;
    border: 1px solid rgba(255,255,255,0.08);
}
.pm-toggle-slider::before {
    content: ''; position: absolute;
    width: 16px; height: 16px; border-radius: 50%;
    background: #475569; top: 2px; left: 2px;
    transition: transform .25s, background .25s;
}
.pm-toggle input:checked + .pm-toggle-slider { background: rgba(34,197,94,0.25); border-color: rgba(34,197,94,0.4); }
.pm-toggle input:checked + .pm-toggle-slider::before { transform: translateX(18px); background: #22c55e; }

/* Meta tags */
.pm-card-meta { display: flex; gap: 6px; flex-wrap: wrap; }
.pm-badge {
    font-size: 0.7rem; padding: 2px 8px; border-radius: 20px;
    border: 1px solid transparent; white-space: nowrap;
}
.pm-badge-version { background: rgba(56,189,248,0.1); border-color: rgba(56,189,248,0.2); color: #7dd3fc; }
.pm-badge-type    { background: rgba(167,139,250,0.1); border-color: rgba(167,139,250,0.2); color: #a78bfa; }
.pm-badge-active  { background: rgba(34,197,94,0.1);  border-color: rgba(34,197,94,0.25);  color: #86efac; }
.pm-badge-inactive{ background: rgba(100,116,139,0.12); border-color: rgba(100,116,139,0.2); color: #64748b; }
.pm-badge-discover{ background: rgba(245,158,11,0.12); border-color: rgba(245,158,11,0.25);  color: #fbbf24; }

.pm-card-desc { font-size: 0.82rem; color: #64748b; line-height: 1.5; flex: 1; }

/* Card footer */
.pm-card-footer {
    padding: 11px 18px;
    border-top: 1px solid rgba(255,255,255,0.04);
    display: flex; gap: 8px; flex-wrap: wrap; align-items: center;
    background: rgba(0,0,0,0.15);
}
.pm-btn {
    padding: 5px 13px; border-radius: 6px; font-size: 0.78rem; font-weight: 500;
    cursor: pointer; border: 1px solid transparent; text-decoration: none;
    display: inline-flex; align-items: center; gap: 5px;
    transition: all .18s; white-space: nowrap;
}
.pm-btn-danger { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.3); color: #fca5a5; }
.pm-btn-danger:hover { background: rgba(239,68,68,0.22); }
.pm-btn-primary { background: rgba(56,189,248,0.12); border-color: rgba(56,189,248,0.35); color: #7dd3fc; }
.pm-btn-primary:hover { background: rgba(56,189,248,0.24); }
.pm-btn-success { background: rgba(34,197,94,0.12); border-color: rgba(34,197,94,0.3); color: #86efac; }
.pm-btn-success:hover { background: rgba(34,197,94,0.22); }

/* Empty state */
.pm-empty {
    grid-column: 1/-1;
    text-align: center; padding: 40px 20px;
    color: #475569; font-size: 0.9rem;
}
.pm-empty i { font-size: 2.5rem; margin-bottom: 12px; display: block; opacity: .4; }

/* Section title */
.pm-section-title {
    font-size: 0.78rem; font-weight: 600; letter-spacing: 1.2px;
    text-transform: uppercase; color: #475569;
    margin: 0 0 14px; display: flex; align-items: center; gap: 8px;
}
.pm-section-title::after {
    content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.04);
}

/* Drag-and-drop upload zone */
.pm-upload-zone {
    border: 2px dashed rgba(56,189,248,0.25);
    border-radius: 12px; padding: 32px 24px;
    text-align: center; cursor: pointer;
    transition: all .2s; background: rgba(56,189,248,0.03);
    position: relative;
}
.pm-upload-zone:hover, .pm-upload-zone.drag-over {
    border-color: #38bdf8; background: rgba(56,189,248,0.07);
}
.pm-upload-zone input[type=file] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
}
.pm-upload-icon { font-size: 2rem; color: #38bdf8; margin-bottom: 8px; opacity: .7; }
.pm-upload-title { color: #e2e8f0; font-size: 0.95rem; font-weight: 600; margin-bottom: 4px; }
.pm-upload-sub   { color: #64748b; font-size: 0.8rem; }
.pm-upload-file-name { margin-top: 10px; font-size: 0.82rem; color: #7dd3fc; display: none; }

/* Hook debug */
.pm-hook-box {
    background: var(--adm-card-bg, #131929);
    border: 1px solid var(--adm-border, #1e2d4a);
    border-radius: 12px; padding: 20px 24px; margin-bottom: 24px;
}
.pm-hook-toggle {
    display: flex; align-items: center; justify-content: space-between;
    cursor: pointer; user-select: none;
}
.pm-hook-toggle h2 { color: var(--adm-neon-blue,#38bdf8); font-size: 1rem; margin: 0; display: flex; align-items: center; gap: 10px; }
.pm-hook-body { display: none; margin-top: 16px; }
.pm-hook-body.open { display: block; }
.pm-hook-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media(max-width:600px){ .pm-hook-grid { grid-template-columns: 1fr; } }
.pm-hook-col-title { font-size: 0.75rem; color: #64748b; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
.pm-hook-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
.pm-hook-table tr { border-bottom: 1px solid #0f1a2e; }
.pm-hook-table td { padding: 5px 8px; }
</style>

<script>
function pfaqToggle() {
    var body = document.getElementById('pfaqBody');
    var btn  = document.getElementById('pfaqBtn');
    if (!body || !btn) return;
    var isOpen = body.classList.toggle('open');
    btn.textContent = isOpen ? '\u25B2 Zuklappen' : '\u25BC Aufklappen';
}
function pfaqCopy(btn) {
    var pre = btn.parentElement.querySelector('pre');
    if (!pre) return;
    var text = pre.textContent || pre.innerText;
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
            btn.textContent = 'Kopiert!';
            btn.classList.add('copied');
            setTimeout(function() { btn.textContent = 'Kopieren'; btn.classList.remove('copied'); }, 1800);
        });
    } else {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); btn.textContent = 'Kopiert!'; btn.classList.add('copied'); setTimeout(function() { btn.textContent = 'Kopieren'; btn.classList.remove('copied'); }, 1800); } catch(e) {}
        document.body.removeChild(ta);
    }
}
</script>

<!-- ── Stats Bar ──────────────────────────────────────────── -->
{% set activeCount    = installedPlugins|filter(p => p.is_active)|length %}
{% set inactiveCount  = installedPlugins|filter(p => not p.is_active)|length %}
{% set discoverCount  = uninstalledPlugins|length %}
<div class="pm-stats-bar">
    <div class="pm-stat">
        <div class="pm-stat-icon" style="background:rgba(56,189,248,0.12);color:#38bdf8;">&#128230;</div>
        <div><div class="pm-stat-val">{{ installedPlugins|length }}</div><div class="pm-stat-lbl">Installiert</div></div>
    </div>
    <div class="pm-stat">
        <div class="pm-stat-icon" style="background:rgba(34,197,94,0.12);color:#22c55e;">&#9989;</div>
        <div><div class="pm-stat-val">{{ activeCount }}</div><div class="pm-stat-lbl">Aktiv</div></div>
    </div>
    <div class="pm-stat">
        <div class="pm-stat-icon" style="background:rgba(100,116,139,0.12);color:#64748b;">&#9744;</div>
        <div><div class="pm-stat-val">{{ inactiveCount }}</div><div class="pm-stat-lbl">Inaktiv</div></div>
    </div>
    <div class="pm-stat">
        <div class="pm-stat-icon" style="background:rgba(245,158,11,0.12);color:#f59e0b;">&#128193;</div>
        <div><div class="pm-stat-val">{{ discoverCount }}</div><div class="pm-stat-lbl">Verfügbar</div></div>
    </div>
    {% if hookDebug is defined %}
