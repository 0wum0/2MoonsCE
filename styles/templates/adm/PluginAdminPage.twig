<!-- ── Hook Debug ─────────────────────────────────────────── -->
{% if hookDebug is defined %}
<div class="pm-hook-box">
    <div class="pm-hook-toggle" onclick="this.nextElementSibling.classList.toggle('open')">
        <h2>
            <i class="fas fa-link" style="color:#a78bfa;font-size:0.9rem"></i>
            Registrierte Hooks
            <span style="background:rgba(56,189,248,0.12);border:1px solid rgba(56,189,248,0.3);color:#7dd3fc;border-radius:20px;padding:1px 10px;font-size:0.75rem;font-weight:400;">
                {{ hookDebug.actions|length }} Actions &bull; {{ hookDebug.filters|length }} Filters
            </span>
        </h2>
        <span style="color:#475569;font-size:0.75rem;">&#9660; Aufklappen</span>
    </div>
    <div class="pm-hook-body">
        <div class="pm-hook-grid">
            <div>
                <div class="pm-hook-col-title">Actions ({{ hookDebug.actions|length }})</div>
                {% if hookDebug.actions is empty %}
                <div style="color:#475569;font-size:0.85rem;">Keine Actions registriert.</div>
                {% else %}
                <table class="pm-hook-table">
                    {% for hook in hookDebug.actions %}
                    <tr>
                        <td style="font-family:monospace;color:#7dd3fc;">{{ hook.name }}</td>
                        <td style="color:#94a3b8;text-align:right;white-space:nowrap;">
                            <span style="background:rgba(56,189,248,0.1);border-radius:4px;padding:1px 8px;">{{ hook.count }} Listener</span>
                        </td>
                    </tr>
                    {% endfor %}
                </table>
                {% endif %}
            </div>
            <div>
                <div class="pm-hook-col-title">Filters ({{ hookDebug.filters|length }})</div>
                {% if hookDebug.filters is empty %}
                <div style="color:#475569;font-size:0.85rem;">Keine Filter registriert.</div>
                {% else %}
                <table class="pm-hook-table">
                    {% for hook in hookDebug.filters %}
                    <tr>
                        <td style="font-family:monospace;color:#a78bfa;">{{ hook.name }}</td>
                        <td style="color:#94a3b8;text-align:right;white-space:nowrap;">
                            <span style="background:rgba(167,139,250,0.1);border-radius:4px;padding:1px 8px;">{{ hook.count }} Listener</span>
                        </td>
                    </tr>
                    {% endfor %}
                </table>
                {% endif %}
            </div>
        </div>
        <p style="color:#475569;font-size:0.75rem;margin:12px 0 0;">&#8505; Nur Hooks die zum Zeitpunkt des Seitenaufrufs registriert sind (aktive Plugins).</p>
    </div>
</div>
{% endif %}

<script>
(function() {
    var currentFilter = 'all';

    // Search + filter
    window.pmFilter = function() {
        var q = document.getElementById('pm-search').value.toLowerCase().trim();
        document.querySelectorAll('.pm-card').forEach(function(card) {
            var name  = (card.dataset.name  || '').toLowerCase();
            var id    = (card.dataset.id    || '').toLowerCase();
            var state = card.dataset.state || '';
            var matchSearch = !q || name.indexOf(q) !== -1 || id.indexOf(q) !== -1;
            var matchFilter = currentFilter === 'all'
                || (currentFilter === 'active'   && state === 'active')
                || (currentFilter === 'inactive' && state === 'inactive')
                || (currentFilter === 'discover' && state === 'discover');
            card.style.display = (matchSearch && matchFilter) ? '' : 'none';
        });
    };

    window.pmSetFilter = function(f, btn) {
        currentFilter = f;
        document.querySelectorAll('.pm-filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        pmFilter();
    };

    // Drag-and-drop upload zone
    var zone  = document.getElementById('pm-drop-zone');
    var input = document.getElementById('pm-zip-input');
    var fname = document.getElementById('pm-file-name');

    if (zone && input) {
        input.addEventListener('change', function() {
            if (input.files.length) {
                fname.textContent = '📎 ' + input.files[0].name;
                fname.style.display = 'block';
            }
        });
        zone.addEventListener('dragover', function(e) {
            e.preventDefault();
            zone.classList.add('drag-over');
        });
        zone.addEventListener('dragleave', function() {
            zone.classList.remove('drag-over');
        });
        zone.addEventListener('drop', function(e) {
            e.preventDefault();
            zone.classList.remove('drag-over');
            var files = e.dataTransfer.files;
            if (files.length) {
                // Build a new FileList-compatible object via DataTransfer
                var dt = new DataTransfer();
                dt.items.add(files[0]);
                input.files = dt.files;
                fname.textContent = '📎 ' + files[0].name;
                fname.style.display = 'block';
            }
        });
    }
})();
</script>

