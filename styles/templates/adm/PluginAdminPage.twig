</div>

<!-- ── Toolbar: Search + Filter ──────────────────────────── -->
<div class="pm-toolbar">
    <div class="pm-search-wrap">
        <i class="fas fa-search"></i>
        <input type="text" id="pm-search" class="pm-search" placeholder="Plugin suchen…" oninput="pmFilter()">
    </div>
    <button class="pm-filter-btn active" id="pm-f-all"      onclick="pmSetFilter('all',      this)">Alle</button>
    <button class="pm-filter-btn"        id="pm-f-active"   onclick="pmSetFilter('active',   this)">Aktiv</button>
    <button class="pm-filter-btn"        id="pm-f-inactive" onclick="pmSetFilter('inactive', this)">Inaktiv</button>
    <button class="pm-filter-btn"        id="pm-f-discover" onclick="pmSetFilter('discover', this)">Neu verfügbar</button>
</div>

<!-- ── Installed Plugins ──────────────────────────────────── -->
<div id="pm-section-installed">
    <div class="pm-section-title"><i class="fas fa-puzzle-piece" style="color:#38bdf8"></i> Installierte Plugins</div>
    <div class="pm-grid" id="pm-installed-grid">
        {% if installedPlugins is empty %}
        <div class="pm-empty">
            <i class="fas fa-box-open"></i>
            Keine Plugins installiert. Lade ein ZIP hoch oder installiere ein gefundenes Plugin.
        </div>
        {% else %}
        {% for plugin in installedPlugins %}
        {% set initial = plugin.name|slice(0,1)|upper %}
        <div class="pm-card {% if plugin.is_active %}is-active{% endif %}"
             data-id="{{ plugin.id }}"
             data-name="{{ plugin.name|lower }}"
             data-state="{{ plugin.is_active ? 'active' : 'inactive' }}">
            <div class="pm-card-header"></div>
            <div class="pm-card-body">
                <div class="pm-card-top">
                    <div class="pm-card-avatar">{{ initial }}</div>
                    <div class="pm-card-title-wrap">
                        <div class="pm-card-name">{{ plugin.name }}</div>
                        <div class="pm-card-id">{{ plugin.id }}</div>
                    </div>
                    <!-- Toggle switch → links to activate/deactivate -->
                    <a href="admin.php?page=pluginAdmin&amp;action={{ plugin.is_active ? 'deactivate' : 'activate' }}&amp;pluginId={{ plugin.id }}"
                       title="{{ plugin.is_active ? 'Deaktivieren' : 'Aktivieren' }}"
                       style="text-decoration:none;">
                        <label class="pm-toggle" onclick="event.preventDefault();window.location.href=this.parentElement.href;">
                            <input type="checkbox" {% if plugin.is_active %}checked{% endif %} readonly>
                            <span class="pm-toggle-slider"></span>
                        </label>
                    </a>
                </div>
                <div class="pm-card-meta">
                    <span class="pm-badge pm-badge-version">v{{ plugin.version }}</span>
                    <span class="pm-badge pm-badge-type">{{ plugin.type }}</span>
                    {% if plugin.is_active %}
                    <span class="pm-badge pm-badge-active">&#9679; Aktiv</span>
                    {% else %}
                    <span class="pm-badge pm-badge-inactive">&#9675; Inaktiv</span>
                    {% endif %}
                </div>
            </div>
            <div class="pm-card-footer">
                {% if plugin.is_active %}
                <a href="admin.php?page=pluginAdmin&amp;action=deactivate&amp;pluginId={{ plugin.id }}"
                   class="pm-btn" style="background:rgba(245,158,11,0.1);border-color:rgba(245,158,11,0.3);color:#fbbf24;">
                    <i class="fas fa-pause"></i> Deaktivieren
                </a>
                {% else %}
                <a href="admin.php?page=pluginAdmin&amp;action=activate&amp;pluginId={{ plugin.id }}"
                   class="pm-btn pm-btn-success">
                    <i class="fas fa-play"></i> Aktivieren
                </a>
                {% endif %}
                <a href="admin.php?page=pluginAdmin&amp;action=uninstall&amp;pluginId={{ plugin.id }}"
                   class="pm-btn pm-btn-danger"
                   onclick="return confirm('Plugin \'{{ plugin.name }}\' wirklich deinstallieren?\nDieser Vorgang kann nicht rückgängig gemacht werden.');">
                    <i class="fas fa-trash-alt"></i> Deinstallieren
                </a>
            </div>
        </div>
        {% endfor %}
        {% endif %}
    </div>
</div>

<!-- ── Discovered (not installed) Plugins ────────────────── -->
{% if uninstalledPlugins is not empty %}
<div id="pm-section-discover">
    <div class="pm-section-title" style="color:#f59e0b;"><i class="fas fa-folder-open" style="color:#f59e0b"></i> Gefunden – nicht installiert</div>
