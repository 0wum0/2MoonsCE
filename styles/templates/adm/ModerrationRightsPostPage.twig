{% include "overall_header.twig" %}
<div class="legacy-content">
<form action="?page=rights&amp;mode=rights&amp;sid={{ sid }}" method="post">
<input name="action" type="hidden" value="send">
<input name="id_1" type="hidden" value="{{ id }}">
<table>
<tr>
	<th colspan="2">{{ ad_authlevel_title }}</th>
</tr>
<tr>
	<td>
		{{ User }}
	</td>
	<td>
		<a href="javascript:;" onclick="$('.yes').attr('checked', 'checked');">{{ yesorno.1 }}</a> <a href="javascript:;" onclick="$('.no').attr('checked', 'checked');">{{ yesorno.0 }}</a>
	</td>
</tr>
{% for File in Files %}
<tr>
	<td>
		{{ File }}
	</td>
	<td>
		{{ yesorno.1 }} <input class="yes" name="rights[{{ File }}]" type="radio"{% if attribute(Rights, File) == 1 %} checked="checked"{% endif %} value="1"> {{ yesorno.0 }} <input class="no" name="rights[{{ File }}]" type="radio"{% if attribute(Rights, File) is not defined or attribute(Rights, File) == 0 %} checked="checked"{% endif %} value="0">
	</td>
</tr>
{% endfor %}
<tr><td colspan="3"><input type="submit" value="{{ button_submit }}"></td></tr>
</table>
</form>
</div>
{% include "overall_footer.twig" %}