{% include "overall_header.twig" %}
<div class="legacy-content">
<form action="" method="GET">
<div style="margin-bottom:12px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
    <label style="display:flex;align-items:center;gap:6px;">
        <input type="checkbox" {{ minimize }} name="minimize"> {{ se_contrac }}
    </label>
    <input type="submit" value="{{ se_contrac }}" class="button">
</div>
<div id="seeker"{{ diisplaay }}>
<div class="table-responsive">
<table>
	<tr>
		<th colspan="8">{{ se_search_title }}</th>
	</tr>
	<tr>
		<td>{{ se_intro }}</td>
		<td>{{ se_type_typee }}</td>
		<td>{{ se_search_in }}</td>
		<td>{{ se_filter_title }}</td>
		<td>{{ se_limit }}</td>
		<td>{{ se_asc_desc }}</td>
		{% if OrderBYParse %}
		<td>{{ se_search_order }}</td>
		{% endif %}
		<td></td>
	</tr>
	<tr>
		<td>
			<input type="text" name="key_user" value="{{ search }}">
		</td>
		<td>
			<select name="search">
				{% for key, value in Selector.list %}
				<option value="{{ key }}"{% if key == SearchFile %} selected{% endif %}>{{ value }}</option>
				{% endfor %}
			</select>
		</td>
		<td>
			<select name="search_in">
				{% for key, value in Selector.search %}
				<option value="{{ key }}"{% if key == SearchFor %} selected{% endif %}>{{ value }}</option>
				{% endfor %}
			</select>
		</td>
		<td>
			<select name="fuki">
				{% for key, value in Selector.filter %}
				<option value="{{ key }}"{% if key == SearchMethod %} selected{% endif %}>{{ value }}</option>
				{% endfor %}
			</select>
		</td>
		<td>
			<select name="limit">
				{% for key, value in Selector.limit %}
				<option value="{{ key }}"{% if key == limit %} selected{% endif %}>{{ value }}</option>
				{% endfor %}
			</select>
		</td>
		<td>
			<select name="key_order">
				{% for key, value in Selector.order %}
				<option value="{{ key }}"{% if key == Order %} selected{% endif %}>{{ value }}</option>
				{% endfor %}
			</select>
		</td>
		{% if OrderBYParse %}
		<td>
			<select name="key_acc">
				{% for key, value in OrderBYParse %}
				<option value="{{ key }}"{% if key == OrderBY %} selected{% endif %}>{{ value }}</option>
				{% endfor %}
			</select>
		</td>
		{% endif %}
		<td>
			<input type="submit" value="{{ se_search }}">
		</td>
	</tr>
	{% if error is defined and error %}
	<tr>
		<td colspan="8"><span style="color:var(--red)">{{ error }}</span></td>
	</tr>
	{% endif %}
</table>
</div>
</div>
{{ PAGES|raw }}
{{ LIST|raw }}
{{ PAGES|raw }}
</form>
</div>