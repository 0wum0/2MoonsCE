{% include "overall_header.twig" %}

<div class="container-fluid p-4">
    
    <div class="row mb-4">
        <div class="col-12">
            <div class="dash-header">
                <h1><i class="fas fa-server"></i> Server Informationen</h1>
                <p class="text-muted">Technische Details und Umgebungsvariablen</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-12 col-lg-6">
            <div class="card h-100 neon-card">
                <div class="card-header">
                    <h5 class="m-0"><i class="fab fa-php"></i> System Umgebung</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush neon-list">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>PHP Version</span>
                            <span class="badge bg-primary">{{ vPHP }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>PHP API</span>
                            <span class="text-muted">{{ vAPI }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>Memory Limit</span>
                            <span class="badge bg-warning text-dark">{{ memory }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>SafeMode</span>
                            <span class="badge {% if safemode == 'Ja' %}bg-danger{% else %}bg-success{% endif %}">{{ safemode }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>JSON Verfügbar</span>
                            <span class="badge {% if json == 'Ja' %}bg-success{% else %}bg-danger{% endif %}">{{ json }}</span>
                        </li>
                         <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>BCMath Verfügbar</span>
                            <span class="badge {% if bcmath == 'Ja' %}bg-success{% else %}bg-danger{% endif %}">{{ bcmath }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>cURL Verfügbar</span>
                            <span class="badge {% if curl == 'Ja' %}bg-success{% else %}bg-danger{% endif %}">{{ curl }}</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card h-100 neon-card">
                <div class="card-header">
                    <h5 class="m-0"><i class="fas fa-database"></i> Datenbank & Spiel</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush neon-list">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>MySQL Client</span>
                            <span class="text-end text-accent">{{ vMySQLc }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>MySQL Server</span>
                            <span class="text-end text-accent">{{ vMySQLs }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>DB Version</span>
                            <span class="badge bg-info">{{ dbVersion }}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>Game Version</span>
                            <span class="badge bg-purple">2Moons {{ vGame }}</span>
                        </li>
                         <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>Information</span>
                            <span class="text-end text-muted" style="font-size: 0.85rem;">{{ info }}</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card neon-card">
                <div class="card-header">
                    <h5 class="m-0"><i class="fas fa-map-signs"></i> Pfade & Einstellungen</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Game Adresse</label>
                            <div class="input-group">
                                <input type="text" class="form-control glass-input" value="http://{{ root }}/" readonly>
                            </div>
                        </div>
                         <div class="col-md-6">
                            <label class="text-muted small">Game Pfad</label>
                            <div class="input-group">
                                <input type="text" class="form-control glass-input" value="http://{{ gameroot }}/index.php" readonly>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label class="text-muted small">Timezone (PHP/CONF/USER)</label>
                            <input type="text" class="form-control glass-input" value="{{ php_tz }} / {{ conf_tz }} / {{ user_tz }}" readonly>
                        </div>
                         <div class="col-md-12">
                            <label class="text-muted small">User Agent</label>
                            <div class="p-2 glass-input rounded" style="font-size: 0.8rem; word-break: break-all;">
                                {{ browser }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card neon-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="m-0"><i class="fas fa-bug"></i> Bug Report Template</h5>
                    <button class="btn btn-sm btn-primary" onclick="copyToClipboard()">Kopieren</button>
                </div>
                <div class="card-body p-0">
<textarea id="rawLog" class="form-control glass-input" style="height: 200px; font-family: monospace; border:none; border-radius: 0 0 12px 12px;" readonly>```-- Server Info --
Server Infos: {{ info }}
PHP-Version: {{ vPHP }} ({{ vAPI }})
JSON Verfügbar: {{ json }}
BCMath Verfügbar: {{ bcmath }}
cURL Verfügbar: {{ curl }}
SafeMode: {{ safemode }}
MemoryLimit: {{ memory }}
MySQL-Client-Version: {{ vMySQLc }}
MySQL-Server-Version: {{ vMySQLs }}
ErrorLog: {{ errorlog }} ({{ errorloglines }}, {{ log_errors }})
Timezone(PHP/CONF/USER): {{ php_tz }} / {{ conf_tz }} / {{ user_tz }}
Suhosin: {{ suhosin }}
DB Version: {{ dbVersion }}

-- Game --
Game Version: 2Moons {{ vGame }}
Game Addresse: http://{{ root }}/
Game Pfad: http://{{ gameroot }}/index.php

Browser: {{ browser }}
```</textarea>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
function copyToClipboard() {
  var copyText = document.getElementById("rawLog");
  copyText.select();
  copyText.setSelectionRange(0, 99999); 
  navigator.clipboard.writeText(copyText.value);
  alert("In die Zwischenablage kopiert!");
}
</script>

{% include "overall_footer.twig" %}
