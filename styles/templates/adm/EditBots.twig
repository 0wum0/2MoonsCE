                    <td style="padding: 8px;">{{ planet.id }}</td>
                    <td style="padding: 8px; color: var(--adm-accent);">{{ planet.name }}</td>
                    <td style="padding: 8px;">{{ planet.id_owner }}</td>
                    <td style="padding: 8px;">{{ planet.1|default(0) }} / {{ planet.2|default(0) }} / {{ planet.3|default(0) }}</td>
                    <td style="padding: 8px;">{{ planet.4|default(0) }}</td>
                    <td style="padding: 8px;">{{ planet.12|default(0) }}</td>
                    <td style="padding: 8px;">{{ planet.22|default(0) }} / {{ planet.23|default(0) }} / {{ planet.24|default(0) }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if mode == 'show_create_bot' or mode == 'create_bot' %}
<div style="display: flex; justify-content: center; margin-top: 40px;">
    <div class="report-card" style="width: 100%; max-width: 500px; padding: 30px;">
        <div style="text-align: center; margin-bottom: 30px;">
            <div style="font-size: 40px; margin-bottom: 10px;">&#129302;</div>
            <h2 style="color: var(--adm-text); margin: 0;">Bot Generator</h2>
            <p style="color: var(--adm-text-muted);">Erstellt zufällige Bots basierend auf den Strategien</p>
        </div>

        <form method="post" action="admin.php?page=EditBots&mode=create_bot">
