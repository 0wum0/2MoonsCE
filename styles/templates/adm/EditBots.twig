                </div>
            </div>

            <div style="grid-column: 1 / -1; background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--adm-border);">
                <h4 style="color: var(--adm-warning); margin-top: 0; margin-bottom: 15px;">Fleet Timing (Seconds)</h4>

                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:15px;">
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Min Fleet Time (Space)</label>
                        <input type="number" name="min_fleet_seconds_in_space" value="{{ type.min_fleet_seconds_in_space }}" class="glass-input">
                    </div>
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Max Fleet Time (Space)</label>
                        <input type="number" name="max_fleet_seconds_in_space" value="{{ type.max_fleet_seconds_in_space }}" class="glass-input">
                    </div>
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Min Fleet Time (Planet)</label>
                        <input type="number" name="min_fleet_seconds_on_planet" value="{{ type.min_fleet_seconds_on_planet }}" class="glass-input">
                    </div>
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Max Fleet Time (Planet)</label>
                        <input type="number" name="max_fleet_seconds_on_planet" value="{{ type.max_fleet_seconds_on_planet }}" class="glass-input">
                    </div>
                </div>
            </div>

            <div style="grid-column: 1 / -1; background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--adm-border);">
                <h4 style="color: var(--adm-danger); margin-top: 0; margin-bottom: 15px;">PVP Raid Rules</h4>

                <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 15px;">
                    <label class="chk">
                        <input type="checkbox" name="raid_inactive_only" {% if type.raid_inactive_only %}checked{% endif %}>
                        Inactive only (7d)
                    </label>
                    <label class="chk">
                        <input type="checkbox" name="raid_allow_same_ally" {% if type.raid_allow_same_ally %}checked{% endif %}>
                        Allow same alliance
                    </label>
                </div>

                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:15px;">
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Min Metal on target</label>
                        <input type="number" name="raid_min_cargo_metal" value="{{ type.raid_min_cargo_metal|default(20000) }}" class="glass-input">
                    </div>
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Min Crystal on target</label>
                        <input type="number" name="raid_min_cargo_crystal" value="{{ type.raid_min_cargo_crystal|default(10000) }}" class="glass-input">
                    </div>
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Min Gain (M+C)</label>
                        <input type="number" name="raid_min_gain" value="{{ type.raid_min_gain|default(50000) }}" class="glass-input">
                    </div>
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Max Flight Seconds</label>
                        <input type="number" name="raid_max_flight_seconds" value="{{ type.raid_max_flight_seconds|default(14400) }}" class="glass-input">
                    </div>
                    <div>
                        <label style="font-size:12px;color:var(--adm-text-muted);">Max Rank Diff (points)</label>
                        <input type="number" name="raid_max_rank_diff" value="{{ type.raid_max_rank_diff|default(250) }}" class="glass-input">
                    </div>
                </div>
            </div>

            <div style="grid-column: 1 / -1; background: rgba(255,255,255,0.02); padding: 15px; border-radius: 8px; border: 1px solid var(--adm-border);">
                <h4 style="color: var(--adm-accent); margin-top: 0; margin-bottom: 10px;">Fleet Preset (serialized)</h4>
                <p style="color:var(--adm-text-muted); margin-top:0; font-size:12px;">
                    Beispiel: <code>a:3:{i:202;i:50;i:210;i:10;i:209;i:10;}</code> (ShipID =&gt; Amount)
                </p>
                <textarea name="ships_array" class="glass-input" rows="3" style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;">{{ type.ships_array|default('') }}</textarea>
            </div>

        </div>

        <div style="margin-top: 20px; text-align: right;">
            <button type="submit" class="btn-save">Save Configuration</button>
        </div>
    </form>
    {% endfor %}
</div>
{% endif %}

{% if mode == 'show_edit_bot_users' %}
<div class="report-card">
    <div class="report-card-title">Aktive Bot Accounts</div>
    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 1px solid var(--adm-border); color: var(--adm-text-muted); text-align: left;">
                    <th style="padding: 12px;">ID</th>
                    <th style="padding: 12px;">Username</th>
                    <th style="padding: 12px;">Strategy</th>
                    <th style="padding: 12px;">Alliance</th>
                    <th style="padding: 12px;">Location</th>
                    <th style="padding: 12px;">Last Activity</th>
                    <th style="padding: 12px;">Action</th>
                </tr>
            </thead>
            <tbody>
                {% for bot in data.activeBots %}
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
                    <td style="padding: 12px;">{{ bot.id }}</td>
                    <td style="padding: 12px; color: var(--adm-accent);">{{ bot.username }}</td>
                    <td style="padding: 12px;">{{ bot.bot_type_name }}</td>
                    <td style="padding: 12px;">{{ bot.ally_name|default('-') }}</td>
                    <td style="padding: 12px;">[{{ bot.galaxy }}:{{ bot.system }}:{{ bot.planet }}]</td>
                    <td style="padding: 12px;">{{ bot.onlinetime|date('d.m.Y H:i') }}</td>
                    <td style="padding: 12px;">
                        <form method="post" action="admin.php?page=EditBots&mode=delete_bot" onsubmit="return confirm('Account #{{ bot.id }} wirklich löschen?');" style="margin:0;">
                            <input type="hidden" name="bot_id" value="{{ bot.id }}">
                            <button type="submit" style="background: var(--adm-danger); border: none; padding: 6px 12px; border-radius: 4px; color: white; cursor: pointer; font-size: 11px;">
                                LÖSCHEN
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{% if mode == 'show_edit_bot_planets' %}
<div class="report-card">
    <div class="report-card-title">Bot Planet Settings (Massenbearbeitung)</div>

    <div style="background: rgba(56, 189, 248, 0.05); border: 1px solid var(--adm-border); padding: 15px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
        <span style="font-weight: bold; color: var(--adm-text);"><span style="color:var(--adm-warning)">⚠</span> Mass Action:</span>
