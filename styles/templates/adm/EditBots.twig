<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// Aktivitäts-Heatmap
const heatmapCtx = document.getElementById('activityHeatmap');
if (heatmapCtx) {
    new Chart(heatmapCtx, {
        type: 'bar',
        data: {
            labels: [
                '00:00', '01:00', '02:00', '03:00', '04:00', '05:00',
                '06:00', '07:00', '08:00', '09:00', '10:00', '11:00',
                '12:00', '13:00', '14:00', '15:00', '16:00', '17:00',
                '18:00', '19:00', '20:00', '21:00', '22:00', '23:00'
            ],
            datasets: [{
                label: 'Bot-Aktionen',
                data: {{ data.analytics.hourly_activity|json_encode|raw }},
                backgroundColor: function(context) {
                    const value = context.parsed.y;
                    const max = Math.max(...context.dataset.data);
                    const intensity = value / max;
                    return `rgba(56, 189, 248, ${0.3 + intensity * 0.7})`;
                },
                borderColor: 'rgba(56, 189, 248, 1)',
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(255,255,255,0.05)' },
                    ticks: { color: 'rgba(255,255,255,0.6)' }
                },
                x: {
                    grid: { display: false },
                    ticks: { color: 'rgba(255,255,255,0.6)' }
                }
            },
            plugins: {
                legend: { display: false }
            }
        }
    });
}

// Ressourcen-Flow Chart
const resourcesCtx = document.getElementById('resourcesChart');
if (resourcesCtx) {
    new Chart(resourcesCtx, {
        type: 'line',
        data: {
            labels: {{ data.analytics.time_labels|json_encode|raw }},
            datasets: [
                {
                    label: 'Metall',
                    data: {{ data.analytics.metal_flow|json_encode|raw }},
                    borderColor: 'rgb(156, 163, 175)',
                    backgroundColor: 'rgba(156, 163, 175, 0.1)',
                    tension: 0.4
                },
                {
                    label: 'Kristall',
                    data: {{ data.analytics.crystal_flow|json_encode|raw }},
                    borderColor: 'rgb(96, 165, 250)',
                    backgroundColor: 'rgba(96, 165, 250, 0.1)',
                    tension: 0.4
                },
                {
                    label: 'Deuterium',
                    data: {{ data.analytics.deut_flow|json_encode|raw }},
                    borderColor: 'rgb(34, 197, 94)',
                    backgroundColor: 'rgba(34, 197, 94, 0.1)',
                    tension: 0.4
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(255,255,255,0.05)' },
                    ticks: { 
                        color: 'rgba(255,255,255,0.6)',
                        callback: function(value) {
                            return value >= 1000000 ? (value/1000000).toFixed(1) + 'M' : 
                                   value >= 1000 ? (value/1000).toFixed(0) + 'k' : value;
                        }
                    }
                },
                x: {
                    grid: { display: false },
                    ticks: { color: 'rgba(255,255,255,0.6)' }
                }
            },
            plugins: {
                legend: {
                    labels: { color: 'rgba(255,255,255,0.8)' }
                }
            }
        }
    });
}
</script>
{% endif %}
