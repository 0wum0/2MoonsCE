{% include 'overall_header.twig' %}

<div class="dash-header">
    <h1><span style="color: var(--adm-accent);">&#129302;</span> Bot Manager</h1>
    <p>Verwaltung der KI-Spieler, Ressourcen-Kontingente und Strategien (PVE + PVP)</p>
</div>

<div class="period-tabs" style="margin-bottom: 25px;">
    <a href="admin.php?page=EditBots" class="period-tab {% if mode == 'default' %}active{% endif %}">Kontingente</a>
    <a href="admin.php?page=EditBots&mode=show_all_bots" class="period-tab {% if mode == 'show_all_bots' %}active{% endif %}">Schiffsliste</a>
    <a href="admin.php?page=EditBots&mode=show_edit_bot_types" class="period-tab {% if mode == 'show_edit_bot_types' %}active{% endif %}">Strategien / Typen</a>
    <a href="admin.php?page=EditBots&mode=bot_settings" class="period-tab {% if mode == 'bot_settings' %}active{% endif %}">⚙️ Bot-Einstellungen</a>
    <a href="admin.php?page=EditBots&mode=ai_behavior" class="period-tab {% if mode == 'ai_behavior' %}active{% endif %}">🤖 KI-Verhalten</a>
    <a href="admin.php?page=EditBots&mode=live_monitor" class="period-tab {% if mode == 'live_monitor' %}active{% endif %}">📊 Live-Monitor</a>
    <a href="admin.php?page=EditBots&mode=analytics" class="period-tab {% if mode == 'analytics' %}active{% endif %}">📈 Analytics</a>
    <a href="admin.php?page=EditBots&mode=personalities" class="period-tab {% if mode == 'personalities' %}active{% endif %}">🎭 Persönlichkeiten</a>
    <a href="admin.php?page=EditBots&mode=dev_tools" class="period-tab {% if mode == 'dev_tools' %}active{% endif %}">🛠️ Dev-Tools</a>
    <a href="admin.php?page=EditBots&mode=show_edit_bot_users" class="period-tab {% if mode == 'show_edit_bot_users' %}active{% endif %}">Bot-Accounts</a>
    <a href="admin.php?page=EditBots&mode=show_edit_bot_planets" class="period-tab {% if mode == 'show_edit_bot_planets' %}active{% endif %}">Bot-Planeten</a>
    <a href="admin.php?page=EditBots&mode=show_create_bot" class="period-tab {% if mode == 'show_create_bot' or mode == 'create_bot' %}active{% endif %}">Generator</a>
</div>

{% if message %}
<div class="report-card" style="margin-bottom: 20px; border-left: 4px solid {% if message.class == 'success' %}var(--adm-success){% else %}var(--adm-danger){% endif %}; padding: 15px;">
    <span style="color: var(--adm-text); font-weight: 500;">{{ message.text }}</span>
</div>
{% endif %}

{# ==================== BOT SETTINGS TAB ==================== #}
{% if mode == 'bot_settings' %}
<div class="report-card">
    <div class="report-card-title">⚙️ Globale Bot-Einstellungen</div>

    <form method="post" action="admin.php?page=EditBots&mode=bot_settings">
        <input type="hidden" name="save_bot_settings" value="1">

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(400px,1fr));gap:20px;">

            <div class="config-section">
                <h4><span style="color: var(--adm-accent);">⚡</span> Parallelität & Performance</h4>

                <div class="form-group">
                    <label>Anzahl paralleler Bots pro Cronjob-Lauf</label>
                    <input type="number" name="bots_per_tick" value="{{ data.bot_config.bots_per_tick|default(10) }}" min="1" max="50" class="glass-input">
                    <small>Wie viele Bots sollen <b>gleichzeitig</b> aktiv sein? (1-50)<br>
                    <b>Standard: 10</b> | Mehr = alle Bots kommen schneller dran</small>
                </div>

                <div class="form-group">
                    <label>Min. Bots online (Nachts)</label>
                    <input type="number" name="min_bots_online" value="{{ data.bot_config.min_bots_online|default(15) }}" min="5" max="100" class="glass-input">
                    <small>Mindestens X Bots erscheinen online (00:00-06:00)</small>
                </div>

                <div class="form-group">
                    <label>Max. Bots online (Prime-Time)</label>
                    <input type="number" name="max_bots_online" value="{{ data.bot_config.max_bots_online|default(150) }}" min="20" max="300" class="glass-input">
                    <small>Maximal X Bots erscheinen online (18:00-00:00)</small>
                </div>

                <div class="form-group">
                    <label>Max. Aktionen pro Bot-Tick</label>
                    <input type="number" name="max_actions_per_tick" value="{{ data.bot_config.max_actions_per_tick|default(3) }}" min="1" max="10" class="glass-input">
                    <small>Wie viele Aktionen darf ein Bot pro Tick machen?</small>
                </div>
            </div>

            <div class="config-section">
                <h4><span style="color: var(--adm-neon-green);">🕐</span> Timing & Delays</h4>

                <div class="form-group">
                    <label>Min. Delay zwischen Bot-Ticks (Sekunden)</label>
                    <input type="number" name="min_tick_delay" value="{{ data.bot_config.min_tick_delay|default(1800) }}" min="300" max="7200" class="glass-input">
                    <small>Mindestens X Sekunden zwischen zwei Aktionen desselben Bots<br>
                    <b>Standard: 1800s (30 Min)</b></small>
                </div>

                <div class="form-group">
                    <label>Max. Delay zwischen Bot-Ticks (Sekunden)</label>
                    <input type="number" name="max_tick_delay" value="{{ data.bot_config.max_tick_delay|default(7200) }}" min="1800" max="14400" class="glass-input">
                    <small>Maximal X Sekunden zwischen zwei Aktionen desselben Bots<br>
                    <b>Standard: 7200s (2 Std)</b></small>
                </div>

                <div class="form-group">
                    <label>Crash-Delay (Sekunden)</label>
                    <input type="number" name="crash_delay" value="{{ data.bot_config.crash_delay|default(1800) }}" min="300" max="3600" class="glass-input">
                    <small>Bei Bot-Crash: Nächster Versuch erst nach X Sekunden<br>
                    <b>Standard: 1800s (30 Min)</b></small>
                </div>
            </div>

            <div class="config-section">
                <h4><span style="color: var(--adm-warning);">🎯</span> Aktivitätsmodus</h4>

                <div class="checkbox-group">
                    <label class="chk">
                        <input type="checkbox" name="random_timing" {% if data.bot_config.random_timing %}checked{% endif %}>
                        Zufällige Timing-Variation (+/- 20%)
                    </label>
                    <small style="margin-left: 30px; color: var(--adm-text-muted); font-size: 11px;">
                        Bots ticken nicht exakt nach Schema → wirkt menschlicher
                    </small>
                </div>

                <div class="checkbox-group" style="margin-top: 15px;">
                    <label class="chk">
                        <input type="checkbox" name="spread_bots" {% if data.bot_config.spread_bots|default(true) %}checked{% endif %}>
                        Bots zeitlich verteilen (Spread)
                    </label>
                    <small style="margin-left: 30px; color: var(--adm-text-muted); font-size: 11px;">
                        Nicht alle Bots auf einmal starten → reduziert Last-Spitzen
                    </small>
                </div>
            </div>

        </div>

        <div style="margin-top: 20px; text-align: right;">
            <button type="submit" class="btn-save">💾 Einstellungen Speichern</button>
        </div>
    </form>
</div>
{% endif %}

{# ==================== AI BEHAVIOR TAB ==================== #}
{% if mode == 'ai_behavior' %}
<div class="report-card">
    <div class="report-card-title">🤖 Bot KI-Verhalten Konfiguration</div>
    
    <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px;">
        {% for type in data.botTypes %}
        <button type="button"
                onclick="$('.ai-config-form').hide(); $('#ai_{{ type.id }}').fadeIn();"
                class="type-select-btn">
            {{ type.name }}
        </button>
        {% endfor %}
    </div>

    {% for type in data.botTypes %}
    <form method="post" action="admin.php?page=EditBots&mode=ai_behavior" id="ai_{{ type.id }}" class="ai-config-form" style="display: {% if loop.first %}block{% else %}none{% endif %};">
        <input type="hidden" name="save_ai_behavior" value="1">
        <input type="hidden" name="type_id" value="{{ type.id }}">

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(350px,1fr));gap:20px;">

            {# ECONOMY PRIORITY #}
            <div class="config-section">
                <h4><span style="color: var(--adm-neon-green);">💰</span> Wirtschafts-Priorität</h4>
                
                <div class="form-group">
                    <label>Bau-Strategie</label>
                    <select name="build_strategy" class="glass-input">
                        <option value="balanced" {% if type.build_strategy == 'balanced' %}selected{% endif %}>Ausgewogen (Mine→Kraftwerk→Speicher)</option>
                        <option value="metal_rush" {% if type.build_strategy == 'metal_rush' %}selected{% endif %}>Metall-Rush (Metallmine Priorität)</option>
                        <option value="crystal_rush" {% if type.build_strategy == 'crystal_rush' %}selected{% endif %}>Kristall-Rush (Kristallmine Priorität)</option>
                        <option value="energy_first" {% if type.build_strategy == 'energy_first' %}selected{% endif %}>Energie Zuerst (Solar/Fusion)</option>
                        <option value="infrastructure" {% if type.build_strategy == 'infrastructure' %}selected{% endif %}>Infrastruktur (Labor/Werft)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Forschungs-Strategie</label>
                    <select name="research_strategy" class="glass-input">
                        <option value="economy" {% if type.research_strategy == 'economy' %}selected{% endif %}>Wirtschaft (Energie/Plasma/Astro)</option>
                        <option value="military" {% if type.research_strategy == 'military' %}selected{% endif %}>Militär (Waffen/Schilde/Panzerung)</option>
                        <option value="drive" {% if type.research_strategy == 'drive' %}selected{% endif %}>Antriebstech (Geschwindigkeit)</option>
                        <option value="balanced" {% if type.research_strategy == 'balanced' %}selected{% endif %}>Ausgewogener Mix</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Werft-Fokus</label>
                    <select name="shipyard_focus" class="glass-input">
                        <option value="cargo" {% if type.shipyard_focus == 'cargo' %}selected{% endif %}>Transporter (Transport)</option>
                        <option value="recycler" {% if type.shipyard_focus == 'recycler' %}selected{% endif %}>Recycler (Trümmerfeld)</option>
                        <option value="fighter" {% if type.shipyard_focus == 'fighter' %}selected{% endif %}>Jäger (Kampf)</option>
                        <option value="mixed_fleet" {% if type.shipyard_focus == 'mixed_fleet' %}selected{% endif %}>Gemischte Flotte</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Min. Ressourcen vor Upgrade</label>
                    <input type="number" name="min_resources_for_upgrade" value="{{ type.min_resources_for_upgrade|default(5000) }}" class="glass-input">
                    <small>Wartet bis genug Ressourcen vorhanden sind</small>
                </div>
            </div>

            {# FLEET BEHAVIOR #}
            <div class="config-section">
                <h4><span style="color: var(--adm-accent);">🚀</span> Flotten-Verhalten</h4>

                <div class="form-group">
                    <label>Expeditions-Frequenz</label>
                    <select name="expedition_frequency" class="glass-input">
                        <option value="never" {% if type.expedition_frequency == 'never' %}selected{% endif %}>Niemals</option>
                        <option value="when_idle" {% if type.expedition_frequency == 'when_idle' %}selected{% endif %}>Wenn untätig (Standard)</option>
                        <option value="aggressive" {% if type.expedition_frequency == 'aggressive' %}selected{% endif %}>Aggressiv (Alle Slots)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Auto-Recycling eigener TF</label>
                    <select name="auto_recycle" class="glass-input">
                        <option value="always" {% if type.auto_recycle == 'always' %}selected{% endif %}>Immer (Sofort)</option>
                        <option value="when_worth" {% if type.auto_recycle == 'when_worth' %}selected{% endif %}>Wenn lohnenswert (>10k)</option>
                        <option value="never" {% if type.auto_recycle == 'never' %}selected{% endif %}>Niemals</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Flottengröße pro Mission</label>
                    <input type="number" name="fleet_percentage" value="{{ type.fleet_percentage|default(50) }}" min="10" max="100" class="glass-input">
                    <small>% der Flotte pro Mission (10-100%)</small>
                </div>

                <div class="form-group">
                    <label>Bevorzugte Missions-Distanz</label>
                    <input type="number" name="max_mission_distance" value="{{ type.max_mission_distance|default(100) }}" class="glass-input">
                    <small>Max. Systeme Entfernung</small>
                </div>
            </div>

            {# ADVANCED AI #}
            <div class="config-section">
                <h4><span style="color: var(--adm-neon-purple);">⚙️</span> Erweiterte KI</h4>

                <div class="form-group">
                    <label>Entscheidungsgeschwindigkeit</label>
                    <select name="decision_speed" class="glass-input">
                        <option value="slow" {% if type.decision_speed == 'slow' %}selected{% endif %}>Langsam (Konservativ)</option>
                        <option value="normal" {% if type.decision_speed == 'normal' %}selected{% endif %}>Normal</option>
                        <option value="fast" {% if type.decision_speed == 'fast' %}selected{% endif %}>Schnell (Aggressiv)</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Risiko-Toleranz</label>
                    <input type="range" name="risk_tolerance" min="0" max="100" value="{{ type.risk_tolerance|default(30) }}" class="range-slider" oninput="this.nextElementSibling.textContent = this.value + '%'">
                    <output>{{ type.risk_tolerance|default(30) }}%</output>
                    <small>Wie aggressiv bei Raids/Expos</small>
                </div>

                <div class="form-group">
                    <label>Ressourcen-Priorität</label>
                    <div style="display:flex;gap:10px;">
                        <input type="number" name="priority_metal" value="{{ type.priority_metal|default(1.0) }}" step="0.1" class="glass-input" placeholder="Metall">
                        <input type="number" name="priority_crystal" value="{{ type.priority_crystal|default(0.7) }}" step="0.1" class="glass-input" placeholder="Kristall">
                        <input type="number" name="priority_deut" value="{{ type.priority_deut|default(0.5) }}" step="0.1" class="glass-input" placeholder="Deut">
                    </div>
                    <small>Gewichtung beim Ressourcen-Management</small>
                </div>

                <div class="checkbox-group">
                    <label class="chk">
                        <input type="checkbox" name="auto_research" {% if type.auto_research %}checked{% endif %}>
                        Auto-Forschung (Automatische Tech-Warteschlange)
                    </label>
                    <label class="chk">
                        <input type="checkbox" name="smart_fleet_save" {% if type.smart_fleet_save %}checked{% endif %}>
                        Smart Fleet Save (Bei Gefahr zurückrufen)
                    </label>
                    <label class="chk">
                        <input type="checkbox" name="opportunistic_raids" {% if type.opportunistic_raids %}checked{% endif %}>
                        Opportunistische Raids (Schwache Ziele nutzen)
                    </label>
                </div>
            </div>

        </div>

        <div style="margin-top: 20px; text-align: right;">
            <button type="submit" class="btn-save">💾 KI-Konfiguration Speichern</button>
        </div>
    </form>
    {% endfor %}
</div>
{% endif %}

{# ==================== LIVE MONITOR TAB ==================== #}
{% if mode == 'live_monitor' %}
<div class="report-card">
    <div class="report-card-title">📊 Live Bot-Monitor <span id="live-status" style="color: var(--adm-success); margin-left: 10px;">●</span></div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 20px;">
        <div class="stat-box">
            <div class="stat-label">Aktive Bots</div>
            <div class="stat-value" id="stat-active">{{ data.stats.active_bots|default(0) }}</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Bau-Warteschlange</div>
            <div class="stat-value" id="stat-building">{{ data.stats.building_queue|default(0) }}</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Forschungs-Warteschlange</div>
            <div class="stat-value" id="stat-research">{{ data.stats.research_queue|default(0) }}</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Flotten im Weltall</div>
            <div class="stat-value" id="stat-fleets">{{ data.stats.fleets_flying|default(0) }}</div>
        </div>
    </div>

    <div id="live-activity-feed" style="background: rgba(0,0,0,0.2); border-radius: 8px; padding: 15px; max-height: 500px; overflow-y: auto; font-family: 'Courier New', monospace; font-size: 12px;">
        <div style="color: var(--adm-text-muted);">Warte auf Bot-Aktivität...</div>
    </div>
</div>

<script>
let lastLogTimestamp = 0;

function fetchLiveData() {
    fetch('admin.php?page=EditBots&mode=live_monitor&ajax=1&last=' + lastLogTimestamp)
        .then(r => r.json())
        .then(data => {
            // Update stats
            if(data.stats) {
                document.getElementById('stat-active').textContent = data.stats.active_bots || 0;
                document.getElementById('stat-building').textContent = data.stats.building_queue || 0;
                document.getElementById('stat-research').textContent = data.stats.research_queue || 0;
                document.getElementById('stat-fleets').textContent = data.stats.fleets_flying || 0;
            }

            // Update activity feed
            if(data.logs && data.logs.length > 0) {
                const feed = document.getElementById('live-activity-feed');
                data.logs.forEach(log => {
                    const line = document.createElement('div');
                    line.style.marginBottom = '5px';
                    line.style.color = log.type === 'error' ? 'var(--adm-danger)' : 
                                      log.type === 'success' ? 'var(--adm-success)' : 
                                      'var(--adm-text)';
                    line.textContent = `[${log.time}] ${log.message}`;
                    feed.insertBefore(line, feed.firstChild);
                });
                lastLogTimestamp = data.last_timestamp;
            }

            document.getElementById('live-status').style.color = 'var(--adm-success)';
        })
        .catch(err => {
            document.getElementById('live-status').style.color = 'var(--adm-danger)';
        });
}

// Poll every 5 seconds
setInterval(fetchLiveData, 5000);
fetchLiveData();
</script>
{% endif %}

{# ==================== ANALYTICS TAB ==================== #}
{% if mode == 'analytics' %}
<div class="report-card">
    <div class="report-card-title">📈 Bot Analytics & Performance</div>

    {# KPI Cards #}
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px;">
        <div class="kpi-card">
            <div class="kpi-icon">⚡</div>
            <div class="kpi-value">{{ data.analytics.total_actions|number_format }}</div>
            <div class="kpi-label">Gesamt-Aktionen (24h)</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">💰</div>
            <div class="kpi-value">{{ data.analytics.resources_per_hour|number_format }}</div>
            <div class="kpi-label">Ressourcen/Stunde</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">🎯</div>
            <div class="kpi-value">{{ data.analytics.success_rate }}%</div>
            <div class="kpi-label">Erfolgsquote</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon">🚀</div>
            <div class="kpi-value">{{ data.analytics.fleets_active|number_format }}</div>
            <div class="kpi-label">Aktive Flotten</div>
        </div>
    </div>

    {# Aktivitäts-Heatmap #}
    <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 20px; margin-bottom: 20px;">
        <h3 style="color: var(--adm-accent); margin-top: 0;">🔥 Aktivitäts-Heatmap (24 Stunden)</h3>
        <div style="position: relative; height: 200px;">
            <canvas id="activityHeatmap"></canvas>
        </div>
    </div>

    {# Ressourcen-Flow Chart #}
    <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 20px; margin-bottom: 20px;">
        <h3 style="color: var(--adm-neon-green); margin-top: 0;">💎 Ressourcen-Flow (Letzte 24h)</h3>
        <div style="position: relative; height: 300px;">
            <canvas id="resourcesChart"></canvas>
        </div>
    </div>

    {# Erfolgsquoten #}
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 20px;">
        
        <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 20px;">
            <h4 style="color: var(--adm-accent); margin-top: 0;">🎯 Raid Erfolgsquote</h4>
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="progress-circle" data-percent="{{ data.analytics.raid_success_rate }}">
                    <span>{{ data.analytics.raid_success_rate }}%</span>
                </div>
                <div>
                    <div style="color: var(--adm-text-muted); font-size: 12px;">Erfolgreich: {{ data.analytics.raids_success }}</div>
                    <div style="color: var(--adm-text-muted); font-size: 12px;">Gesamt: {{ data.analytics.raids_total }}</div>
                </div>
            </div>
        </div>

        <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 20px;">
            <h4 style="color: var(--adm-neon-purple); margin-top: 0;">🌌 Expeditions Erfolgsquote</h4>
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="progress-circle" data-percent="{{ data.analytics.expo_success_rate }}">
                    <span>{{ data.analytics.expo_success_rate }}%</span>
                </div>
                <div>
                    <div style="color: var(--adm-text-muted); font-size: 12px;">Erfolgreich: {{ data.analytics.expos_success }}</div>
                    <div style="color: var(--adm-text-muted); font-size: 12px;">Gesamt: {{ data.analytics.expos_total }}</div>
                </div>
            </div>
        </div>

    </div>

    {# Top 10 Bots #}
    <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 20px;">
        <h3 style="color: var(--adm-warning); margin-top: 0;">🏆 Top 10 Aktivste Bots (24h)</h3>
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 1px solid var(--adm-border); color: var(--adm-text-muted);">
                    <th style="padding: 10px; text-align: left;">Rang</th>
                    <th style="padding: 10px; text-align: left;">Bot Name</th>
                    <th style="padding: 10px; text-align: right;">Aktionen</th>
                    <th style="padding: 10px; text-align: right;">Ress gewonnen</th>
                    <th style="padding: 10px; text-align: right;">Flotten</th>
                </tr>
            </thead>
            <tbody>
                {% for bot in data.analytics.top_bots %}
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.03);">
