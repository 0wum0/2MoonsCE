            <input type="number" name="elementid" placeholder="Element ID" class="glass-input" style="width: 120px;">
            <input type="number" name="elemval" placeholder="Level/Amount" class="glass-input" style="width: 120px;">
            <button type="submit" class="btn-save">Auf ALLE Planeten anwenden</button>
        </form>
    </div>

    <div style="overflow-x: auto; max-height: 600px;">
        <table style="width: 100%; border-collapse: collapse; font-size: 12px;">
            <thead>
