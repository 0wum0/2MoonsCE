<script>
function updateContingent(botType, userId, value, type) {
    var xhr = new XMLHttpRequest();
    xhr.open("POST", "admin.php?page=EditBots", true);
    xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
    xhr.send("bot_type=" + botType + "&userid=" + userId + "&" + type + "=" + value);
}
</script>

