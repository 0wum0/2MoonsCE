{% include "ins_header.twig" %}

<h2>{{ LNG.upgrade_intro_welcome }}</h2>

{% if updates %}
	<div class="ins-info"><i class="fas fa-info-circle"></i>{{ LNG.upgrade_available|format(sql_revision, file_revision)|raw }}</div>
	<form action="?mode=doupgrade" method="POST">
		{% for file, content in updates %}
			<div class="ins-file-label" style="margin-top:16px"><i class="fas fa-file-code"></i> {{ file }}</div>
			<div class="ins-sql-preview">{{ content|raw }}</div>
		{% endfor %}
		<div style="margin-top:20px">
			<input type="submit" value="{{ LNG.continue }}">
		</div>
	</form>
{% else %}
	<div class="ins-alert-success"><i class="fas fa-check-circle"></i> {{ LNG.upgrade_notavailable|format(sql_revision)|raw }}</div>
	<a href="index.php"><button><i class="fas fa-arrow-left"></i> {{ LNG.upgrade_back }}</button></a>
{% endif %}

{% include "ins_footer.twig" %}
