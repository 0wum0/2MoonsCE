{% include "ins_header.twig" %}

<div class="ins-info" style="margin-bottom:18px"><i class="fas fa-user-shield"></i> {{ LNG.step4_desc|raw }}</div>

<form action="index.php?mode=install&step=8" method="post" style="display:flex;flex-direction:column;gap:14px">
	<input type="hidden" name="post" value="1">

	<div class="ins-form-group">
		<label class="ins-form-label">{{ LNG.step4_admin_name }}</label>
		<input type="text" name="username" value="{{ name }}" placeholder="admin" required>
		<div style="font-size:11px;color:var(--dim);margin-top:4px">{{ LNG.step4_admin_name_desc }}</div>
	</div>

	<div class="ins-form-group">
		<label class="ins-form-label">{{ LNG.step4_admin_pass }}</label>
		<input type="password" name="password" value="{{ password }}" placeholder="secure_password" required>
		<div style="font-size:11px;color:var(--dim);margin-top:4px">{{ LNG.step4_admin_pass_desc }}</div>
	</div>

	<div class="ins-form-group">
		<label class="ins-form-label">{{ LNG.step4_admin_mail }}</label>
		<input type="email" name="email" value="{{ mail }}" placeholder="admin@example.com" required>
	</div>

	<div style="margin-top:8px">
		<button type="submit" name="next"><i class="fas fa-user-plus"></i> {{ LNG.continue }}</button>
	</div>
</form>
{% include "ins_footer.twig" %}