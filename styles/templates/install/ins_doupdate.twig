	<div class="ins-info"><i class="fas fa-info-circle"></i> {{ LNG.upgrade_nothingtodo|format(revision)|raw }}</div>
{% endif %}

<div style="margin-top:20px">
	<a href="../index.php"><button><i class="fas fa-home"></i> {{ LNG.upgrade_back }}</button></a>
</div>

