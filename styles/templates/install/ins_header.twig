<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
	<meta http-equiv="Pragma" content="no-cache">
	<title>{{ title }}</title>
	<meta name="generator" content="2MoonsCE">
	{% if goto %}
	<meta http-equiv="refresh" content="{{ gotoinsec }};URL={{ goto }}">
	{% endif %}
	<link rel="stylesheet" href="/styles/resource/css/install/2moonsce.install.css?v=1.0.2">
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
	<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
	<script type="text/javascript" src="/scripts/base/jquery.js"></script>
	{% block script %}{% endblock %}
	{% if execscript is defined and execscript %}
	<script type="text/javascript">$(function(){ {{ execscript|raw }} });</script>
	{% endif %}
	<link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
<canvas id="ins-bg-canvas"></canvas>

<div class="ins-page">

	<!-- Top bar -->
	<div class="ins-topbar">
		<div class="ins-logo">
			<i class="fas fa-globe"></i> 2MoonsCE
		</div>
		<div class="ins-lang">
			<select onchange="document.location='?lang='+this.value;">
				{% for key, value in Selector %}
				<option value="{{ key }}"{% if key == lang %} selected{% endif %}>{{ value }}</option>
				{% endfor %}
			</select>
		</div>
	</div>

	<!-- Main card -->
	<div class="ins-card">

		<!-- Card header -->
		<div class="ins-card-header">
			<div class="ins-card-header-icon"><i class="fas fa-satellite"></i></div>
			<div>
				<div class="ins-card-title">{{ header }}</div>
				<div class="ins-card-subtitle">2MoonsCE &bull; Setup &amp; Update Tool</div>
			</div>
		</div>

		<!-- Step indicator (install mode only) -->
		{% if GET.mode is not defined or GET.mode == 'install' %}
		{% set cur_step = GET.step|default(0)|number_format(0) %}
		<div class="ins-steps">
			{% set step_labels = ['Lizenz','System','Datenbank','Verbindung','Tabellen','Daten','Admin','Fertig'] %}
			{% for i in 1..8 %}
			{% if not loop.first %}<div class="ins-step-connector{% if i <= cur_step + 1 %} done{% endif %}"></div>{% endif %}
			<div class="ins-step{% if i == cur_step %} active{% elseif i < cur_step %} done{% endif %}">
				<div class="ins-step-dot">
					{% if i < cur_step %}<i class="fas fa-check" style="font-size:9px"></i>{% else %}{{ i }}{% endif %}
				</div>
				<div class="ins-step-label">{{ step_labels[i-1] }}</div>
			</div>
			{% endfor %}
		</div>
		{% endif %}

		<!-- Body -->
		<div class="ins-card-body">