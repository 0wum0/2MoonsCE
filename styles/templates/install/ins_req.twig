{% include "ins_header.twig" %}

<div class="ins-info" style="margin-bottom:18px"><i class="fas fa-info-circle"></i> {{ LNG.req_desc|raw }}</div>

<div style="display:flex;flex-direction:column;gap:10px">
	<div class="ins-req-row"><span>{{ LNG.req_php_need }}</span><span>{{ PHP|raw }}</span></div>
	<div class="ins-req-row"><span>{{ LNG.reg_global_need }}</span><span>{{ global|raw }}</span></div>
	<div class="ins-req-row"><span>{{ LNG.reg_pdo_active }}</span><span>{{ pdo|raw }}</span></div>
	<div class="ins-req-row"><span>{{ LNG.reg_gd_need }}</span><span>{{ gdlib|raw }}</span></div>
	<div class="ins-req-row"><span>{{ LNG.reg_json_need }}</span><span>{{ json|raw }}</span></div>
	<div class="ins-req-row"><span>{{ LNG.reg_iniset_need }}</span><span>{{ iniset|raw }}</span></div>
	{{ dir|raw }}
	{{ config|raw }}
</div>

<div style="margin-top:20px">{{ done|raw }}</div>
{% if ftp == 0 %}
<div class="ins-divider"></div>
<h2>{{ LNG.req_ftp_head }}</h2>
<div class="ins-info"><i class="fas fa-info-circle"></i> {{ LNG.req_ftp_desc|raw }}</div>
<form name="ftp" id="ftp" action="" onsubmit="return false;" style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:16px">
	<div class="ins-form-group">
		<label class="ins-form-label">{{ LNG.req_ftp_host }}</label>
		<input type="text" name="host" placeholder="ftp.example.com">
	</div>
	<div class="ins-form-group">
		<label class="ins-form-label">{{ LNG.req_ftp_username }}</label>
		<input type="text" name="user" placeholder="username">
	</div>
	<div class="ins-form-group">
		<label class="ins-form-label">{{ LNG.req_ftp_password }}</label>
		<input type="password" name="pass" placeholder="password">
	</div>
	<div class="ins-form-group">
		<label class="ins-form-label">{{ LNG.req_ftp_dir }}</label>
		<input type="text" name="path" placeholder="/path/to/2moonsce">
	</div>
	<div style="grid-column:span 2;text-align:center">
		<button type="button" onclick="submitftp();"><i class="fas fa-wrench"></i> {{ LNG.req_ftp_send }}</button>
	</div>
</form>
{% endif %}
{% include "ins_footer.twig" %}