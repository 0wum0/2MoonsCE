// ── Camera fly-to ─────────────────────────────────────────────────
function flyToPosition(targetPos, distance) {
  const targetR = distance || 120;
  const startPos = camera.position.clone();
  const endPos = new THREE.Vector3(
    targetPos.x + targetR * 0.5,
    targetPos.y + targetR * 0.5,
    targetPos.z + targetR
  );

  let t = 0;
  const duration = 60; // frames
  const step = () => {
    t++;
    const alpha = Math.min(1, t / duration);
    const ease = 1 - Math.pow(1 - alpha, 3); // ease-out cubic
    camera.position.lerpVectors(startPos, endPos, ease);
    camera.lookAt(targetPos.x, targetPos.y, targetPos.z);
    if (alpha < 1) requestAnimationFrame(step);
  };
  requestAnimationFrame(step);
}

// ── View toggle ───────────────────────────────────────────────────
window.setView = function(mode) {
  is3D = (mode === '3d');
  document.getElementById('toggle-3d').classList.toggle('active', is3D);
  document.getElementById('toggle-2d').classList.toggle('active', !is3D);
  document.getElementById('stat-cam').textContent = is3D ? '3D' : '2D';

  if (!is3D) {
    camera.position.set(0, 900, 0);
    camera.lookAt(0, 0, 0);
    spherical.phi = 0.02;
  } else {
    camera.position.set(0, 300, 700);
    camera.lookAt(0, 0, 0);
    spherical.phi = 1.0;
  }

  if (galaxyData) {
    _posCache = buildPlanets(galaxyData.planets);
    if (fleetData) buildFleets(fleetData.fleets, _posCache);
  }
};

// ── Nav jump ──────────────────────────────────────────────────────
window.navJump = function() {
  const g = parseInt(document.getElementById('nav-galaxy').value) || 1;
  const s = parseInt(document.getElementById('nav-system').value) || 1;
  const pos = is3D ? planetToWorld(g, s, 8) : planetToWorld2D(g, s, 8);
  flyToPosition(pos, 200);
};

window.navHome = function() {
  const g = window.SM_CURRENT_GALAXY;
  const s = window.SM_CURRENT_SYSTEM;
  const p = window.SM_CURRENT_PLANET;
  const pos = is3D ? planetToWorld(g, s, p) : planetToWorld2D(g, s, p);
  flyToPosition(pos, 120);
};

window.closeActionPanel = function() {
  document.getElementById('action-panel').style.display = 'none';
  selectedPlanet = null;
};

// ── Animate ───────────────────────────────────────────────────────
let frameCount = 0;
function animate() {
  requestAnimationFrame(animate);
  frameCount++;

  // Update camera from spherical
  if (is3D && !isDragging) {
    // Allow passive rotation / just update on drag
  }
  if (is3D) {
    camera.position.x = spherical.r * Math.sin(spherical.phi) * Math.sin(spherical.theta);
    camera.position.y = spherical.r * Math.cos(spherical.phi);
    camera.position.z = spherical.r * Math.sin(spherical.phi) * Math.cos(spherical.theta);
    camera.lookAt(0, 0, 0);
  }

  // Slowly rotate galaxy background
  if (galaxySpiral) {
    galaxySpiral.rotation.y += 0.00008;
  }
  if (starField) {
    starField.rotation.y += 0.00002;
  }

  // Pulse planet glows
  const pulse = Math.sin(frameCount * 0.03) * 0.05 + 0.6;
  planetMeshes.forEach(pm => {
    if (pm.mesh.material) {
      pm.mesh.material.emissiveIntensity = pulse;
    }
  });

  // Animate fleet lines (opacity flicker for hostile)
  fleetLines.forEach(obj => {
    if (obj.userData.fleet && obj.userData.fleet.is_hostile) {
      if (obj.material) {
        obj.material.opacity = 0.4 + Math.sin(frameCount * 0.1) * 0.3;
      }
    }
  });

  renderer.render(scene, camera);
}

// ── Resize ────────────────────────────────────────────────────────
function onResize() {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
}

// ── Boot ──────────────────────────────────────────────────────────
init();

// Expose for external calls
window.galaxyMapRefresh = loadFleets;
window.galaxyMapNavTo   = (g, s, p) => {
  const pos = is3D ? planetToWorld(g, s, p) : planetToWorld2D(g, s, p);
  flyToPosition(pos, 150);
};

})(); // end IIFE
</script>
